<%- include('../partials/head', { title: 'Control remoto — ' + topicTitle }) %>

<style>
  .ctrl-wrap {
    display: flex;
    flex-direction: column;
    min-height: calc(100dvh - var(--header-offset, 100px));
    padding: 16px 16px calc(16px + env(safe-area-inset-bottom));
    gap: 14px;
  }
  .ctrl-head {
    text-align: center;
  }
  .ctrl-head strong { display: block; font-size: 16px; }
  .ctrl-head span { color: var(--muted); font-size: 13px; }
  .ctrl-progress {
    text-align: center;
    font-weight: 900;
    font-size: 22px;
    font-variant-numeric: tabular-nums;
  }
  .ctrl-buttons {
    flex: 1;
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    min-height: 0;
  }
  .ctrl-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: none;
    border-radius: var(--radius-lg);
    font-weight: 900;
    font-size: 22px;
    color: #fff;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    transition: transform .08s ease, opacity .15s ease;
  }
  .ctrl-btn:active { transform: scale(.97); }
  .ctrl-btn[disabled] { opacity: .35; }
  .ctrl-btn .ctrl-icon { font-size: 40px; line-height: 1; }
  .ctrl-btn.prev { background: var(--ink); }
  .ctrl-btn.next { background: var(--brand); }
  .ctrl-toast {
    position: fixed;
    left: 50%;
    bottom: calc(24px + env(safe-area-inset-bottom));
    transform: translateX(-50%) translateY(20px);
    background: var(--ink);
    color: #fff;
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    font-size: 13px;
    opacity: 0;
    transition: opacity .2s ease, transform .2s ease;
    pointer-events: none;
  }
  .ctrl-toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>

<div
  class="ctrl-wrap"
  data-ctrl-code="<%= code %>"
  data-ctrl-index="<%= slideIndex %>"
  data-ctrl-total="<%= slideCount %>"
>
  <div class="ctrl-head">
    <strong><%= courseTitle %></strong>
    <span><%= topicTitle %></span>
  </div>
  <div class="ctrl-progress" data-ctrl="progress"><%= slideIndex + 1 %> / <%= slideCount %></div>
  <div class="ctrl-buttons">
    <button class="ctrl-btn prev" type="button" data-ctrl="prev">
      <span class="ctrl-icon">←</span>
      Atrás
    </button>
    <button class="ctrl-btn next" type="button" data-ctrl="next">
      <span class="ctrl-icon">→</span>
      Siguiente
    </button>
  </div>
</div>
<div class="ctrl-toast" data-ctrl="toast"></div>

<script src="/static/js/presentation-control.js"></script>
