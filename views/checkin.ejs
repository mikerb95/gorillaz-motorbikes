<%- include('partials/head', { title: 'Check-in de taller — Gorillaz Motorbikes' }) %>

<style>
  .checkin-wrap {
    max-width: 520px;
    margin: 60px auto 80px;
    padding: 0 16px;
  }
  .checkin-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .checkin-header h1 {
    font-size: 26px;
    font-weight: 900;
    margin: 0 0 8px;
  }
  .checkin-header p {
    color: #6b7280;
    margin: 0;
    font-size: 15px;
  }
  .checkin-card {
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 16px;
    padding: 28px 24px;
    display: grid;
    gap: 16px;
  }
  .checkin-field label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .4px;
    color: #374151;
    margin-bottom: 6px;
  }
  .checkin-field input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    outline: none;
    box-sizing: border-box;
    transition: border-color .15s;
  }
  .checkin-field input:focus {
    border-color: #111;
  }
  .checkin-field.plate input {
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  .checkin-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .checkin-phone {
    display: flex;
    gap: 8px;
  }
  .checkin-phone input:first-child {
    width: 72px;
    text-align: center;
    flex: none;
  }
  .checkin-btn {
    width: 100%;
    margin-top: 4px;
  }
  .checkin-error {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    border-radius: 10px;
    padding: 12px 16px;
    color: #991b1b;
    font-size: 14px;
    font-weight: 600;
  }
  .checkin-success {
    background: #fff;
    border: 1.5px solid #bbf7d0;
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    display: grid;
    gap: 10px;
  }
  .checkin-success .icon {
    font-size: 40px;
  }
  .checkin-success h2 {
    margin: 0;
    font-size: 20px;
    font-weight: 900;
  }
  .checkin-success p {
    margin: 0;
    color: #6b7280;
    font-size: 14px;
  }

  .brand-suggest {
    position: relative;
  }
  .brand-suggest-list {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    margin: 0;
    padding: 6px;
    list-style: none;
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,.12);
    z-index: 20;
    max-height: 220px;
    overflow-y: auto;
  }
  .brand-suggest-list li {
    padding: 9px 10px;
    border-radius: 7px;
    font-size: 14px;
    cursor: pointer;
  }
  .brand-suggest-list li:hover {
    background: #f3f4f6;
  }

  @media (max-width: 540px) {
    .checkin-wrap { margin-top: 36px; }
    .checkin-card { padding: 20px 16px; }
    .checkin-row { grid-template-columns: 1fr; }
  }
</style>

<main>
  <div class="checkin-wrap">
    <div class="checkin-header">
      <h1>Check-in de taller</h1>
      <p>Regístrate al llegar para que un mecánico continúe con tu servicio más rápido.</p>
    </div>

    <% if (ok) { %>
      <div class="checkin-success">
        <div class="icon">✅</div>
        <h2>¡Listo, quedaste registrado!</h2>
        <p>Un mecánico tomará tus datos en unos minutos. Puedes esperar en el taller.</p>
      </div>
    <% } else { %>

      <% if (error) { %>
        <div class="checkin-error"><%= error %></div>
        <br>
      <% } %>

      <form class="checkin-card" method="post" action="/checkin">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="checkin-field">
          <label for="clientName">Nombre completo</label>
          <input id="clientName" name="clientName" type="text" required maxlength="120"
            placeholder="Juan Pérez" value="<%= values.clientName || '' %>" />
        </div>

        <div class="checkin-field">
          <label for="clientPhone">Número de WhatsApp</label>
          <div class="checkin-phone">
            <input name="clientPhoneCountry" type="text" maxlength="4" value="<%= values.clientPhoneCountry || '+57' %>" />
            <input id="clientPhone" name="clientPhone" type="text" required inputmode="numeric"
              placeholder="3001234567" value="<%= values.clientPhone || '' %>" />
          </div>
        </div>

        <div class="checkin-field plate">
          <label for="plate">Placa de la moto</label>
          <input id="plate" name="plate" type="text" required maxlength="10"
            placeholder="ABC123" oninput="this.value=this.value.toUpperCase()"
            value="<%= values.plate || '' %>" />
        </div>

        <div class="checkin-row">
          <div class="checkin-field">
            <label for="brand">Marca</label>
            <input id="brand" name="brand" type="text" required maxlength="60"
              placeholder="Yamaha" value="<%= values.brand || '' %>" data-brand-suggest />
          </div>
          <div class="checkin-field">
            <label for="reference">Referencia</label>
            <input id="reference" name="reference" type="text" required maxlength="60"
              placeholder="MT-03" value="<%= values.reference || '' %>" data-model-suggest />
          </div>
        </div>

        <button class="btn btn-primary checkin-btn" type="submit">Registrar ingreso →</button>
      </form>

    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
