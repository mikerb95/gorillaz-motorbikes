<%- include('partials/head', { title: 'Tienda' }) %>

<main class="container shop-layout">
  <aside class="shop-sidebar">
    <form class="shop-filters" method="get" action="/tienda">
      <div class="filter-group">
        <label for="q">Buscar</label>
        <div class="shop-search-wrap">
          <input id="q" name="q" placeholder="Producto, marca o categoría" value="<%= q %>" />
          <button type="submit" class="shop-search-btn" aria-label="Buscar">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </div>
      </div>

      <div class="filter-group">
        <div class="filter-title">Categorías</div>
        <ul class="filter-list">
          <li><a class="<%= !selectedCat ? 'is-active' : '' %>" href="/tienda<%= baseQuery ? ('?' + baseQuery) : '' %>">
            <span>Todas</span>
            <small class="muted"><%= allProductsCount %></small>
          </a></li>
          <% categories.forEach(c => { %>
            <li>
              <a class="<%= selectedCat === c.slug ? 'is-active' : '' %>" href="/tienda?<%= baseQuery %><%= baseQuery ? '&' : '' %>cat=<%= c.slug %>">
                <span><%= c.name %></span>
                <small class="muted"><%= c.count %></small>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>

      <% if (brands && brands.length > 1) { %>
        <div class="filter-group">
          <div class="filter-title">Marca</div>
          <ul class="filter-list">
            <li><a class="<%= !selectedBrand ? 'is-active' : '' %>" href="/tienda?<%= baseQuery ? baseQuery : '' %><%= selectedCat ? ('&cat=' + selectedCat) : '' %>">Todas</a></li>
            <% brands.forEach(b => { %>
              <li><a class="<%= selectedBrand === b ? 'is-active' : '' %>" href="/tienda?<%= baseQuery ? (baseQuery + '&') : '' %><%= selectedCat ? ('cat=' + selectedCat + '&') : '' %>brand=<%= encodeURIComponent(b) %>"><%= b %></a></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="filter-group">
        <div class="filter-title">Precio</div>
        <div class="price-slider" data-price-slider data-min-default="<%= priceStats.min %>" data-max-default="<%= priceStats.max %>">
          <div class="price-values">
            <span>Desde: $<span data-price-min-text><%= (min || priceStats.min).toLocaleString('es-CO') %></span></span>
            <span>Hasta: $<span data-price-max-text><%= (max || priceStats.max).toLocaleString('es-CO') %></span></span>
          </div>
          <div class="slider-rows">
            <input type="range" min="<%= priceStats.min %>" max="<%= priceStats.max %>" step="1" value="<%= min || priceStats.min %>" data-price-min>
            <input type="range" min="<%= priceStats.min %>" max="<%= priceStats.max %>" step="1" value="<%= max || priceStats.max %>" data-price-max>
          </div>
          <input type="hidden" name="min" value="<%= min %>">
          <input type="hidden" name="max" value="<%= max %>">
        </div>
      </div>

      <div class="filter-group">
        <label for="sort">Ordenar</label>
        <select id="sort" name="sort">
          <option value="">Relevancia</option>
          <option value="price-asc" <%= sort==='price-asc' ? 'selected' : '' %>>Precio: menor a mayor</option>
          <option value="price-desc" <%= sort==='price-desc' ? 'selected' : '' %>>Precio: mayor a menor</option>
        </select>
      </div>

      <div class="filter-actions">
        <button class="btn btn-primary" type="submit">Aplicar</button>
        <a class="btn btn-ghost" href="/tienda">Limpiar</a>
      </div>
    </form>
  </aside>

  <section class="shop-content">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/tienda">Tienda</a>
      <% if (selectedCat) { %>
        <span class="breadcrumb-sep">›</span>
        <span><%= (categories.find(c => c.slug === selectedCat) || {}).name %></span>
      <% } %>
    </nav>

    <div class="shop-header">
      <h1 class="section-title">Tienda</h1>
      <% if (selectedCat) { %>
        <div class="muted">Categoría: <strong><%= (categories.find(c => c.slug === selectedCat) || {}).name %></strong></div>
      <% } %>
      <span class="muted"><%= allProductsCount %> producto(s)</span>
    </div>

    <% if (products.length === 0) { %>
      <div class="shop-empty">
        <p>No hay resultados para tu búsqueda.</p>
        <a class="btn btn-ghost" href="/tienda">Ver todos los productos</a>
      </div>
    <% } else { %>
      <div class="grid products-grid">
        <% products.forEach(p => { %>
          <article class="card product-card">
            <a href="/tienda/<%= p.id %>" class="product-card-link">
              <div class="card-media" aria-hidden="true" style="background-image:url('<%= p.image %>');background-size:cover;background-position:center">
                <% if (p.discount > 0) { %>
                  <span class="product-discount-chip">-<%= p.discount %>%</span>
                <% } %>
                <% if (typeof p.stock === 'number' && p.stock === 0) { %>
                  <span class="product-soldout-chip">Agotado</span>
                <% } %>
              </div>
              <div class="card-body">
                <% if (p.brand) { %><span class="product-brand"><%= p.brand %></span><% } %>
                <h3 class="card-title"><%= p.name %></h3>
                <% if (p.description) { %>
                  <p class="card-text"><%= p.description.substring(0, 80) %><%= p.description.length > 80 ? '...' : '' %></p>
                <% } %>
                <div class="price-row">
                  <div>
                    <% if (p.discount > 0) { %>
                      <span class="price">$<%= Math.round(p.price * (1 - p.discount / 100)).toLocaleString('es-CO') %></span>
                      <span class="price-old">$<%= p.price.toLocaleString('es-CO') %></span>
                    <% } else { %>
                      <span class="price">$<%= (p.price).toLocaleString('es-CO') %></span>
                    <% } %>
                  </div>
                </div>
              </div>
            </a>
            <div class="product-card-actions">
              <a href="/tienda/<%= p.id %>" class="btn btn-ghost btn-sm">Ver producto</a>
              <button type="button" class="btn btn-primary btn-sm btn-add-cart"
                data-id="<%= p.id %>"
                <%= (typeof p.stock === 'number' && p.stock === 0) ? 'disabled' : '' %>>
                Añadir
              </button>
            </div>
          </article>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <nav class="shop-pagination">
          <% if (page > 1) { %>
            <a href="/tienda?<%= baseQuery %><%= baseQuery ? '&' : '' %><%= selectedCat ? ('cat=' + selectedCat + '&') : '' %>page=<%= page - 1 %>" class="btn btn-ghost btn-sm">← Anterior</a>
          <% } %>
          <div class="shop-pagination-pages">
            <% for (let i = 1; i <= totalPages; i++) { %>
              <a href="/tienda?<%= baseQuery %><%= baseQuery ? '&' : '' %><%= selectedCat ? ('cat=' + selectedCat + '&') : '' %>page=<%= i %>"
                class="shop-pagination-page <%= i === page ? 'is-active' : '' %>"><%= i %></a>
            <% } %>
          </div>
          <% if (page < totalPages) { %>
            <a href="/tienda?<%= baseQuery %><%= baseQuery ? '&' : '' %><%= selectedCat ? ('cat=' + selectedCat + '&') : '' %>page=<%= page + 1 %>" class="btn btn-ghost btn-sm">Siguiente →</a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </section>
</main>

<%- include('partials/footer') %>
