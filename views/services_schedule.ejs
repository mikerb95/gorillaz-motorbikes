<%- include('partials/head', { title: 'Agendar servicio — Gorillaz Motorbikes' }) %>

<!-- Banner horizontal de horarios -->
<div class="schedule-hours-banner">
  <div class="container schedule-hours-inner">
    <span class="schedule-hours-title">
      <svg viewBox="0 0 24 24" width="16" height="16" style="vertical-align:middle;margin-right:5px" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 6v6l4 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      Horario del taller
    </span>
    <span class="schedule-hours-item"><strong>Lun &mdash; Vie:</strong> 9:00 am &ndash; 6:00 pm</span>
    <span class="schedule-hours-sep" aria-hidden="true">&middot;</span>
    <span class="schedule-hours-item"><strong>Sábados:</strong> 10:00 am &ndash; 4:00 pm</span>
    <span class="schedule-hours-sep" aria-hidden="true">&middot;</span>
    <span class="schedule-hours-item schedule-hours-closed"><strong>Domingos:</strong> Cerrado</span>
  </div>
</div>

<main class="container schedule-full">
  <h1 class="section-title" style="margin-top:28px">Agendar servicio</h1>
  <p class="section-subtitle">Selecciona la fecha deseada y completa tus datos. Nuestro equipo confirmará la cita y recibirás un correo de confirmación.</p>

  <% if (bookingMessage) { %>
    <div class="alert" style="border:1px solid #d1fae5;background:#ecfdf5;color:#065f46;border-radius:12px;padding:12px;margin:12px 0"><%= bookingMessage %></div>
  <% } %>

  <!-- Leyenda de demanda del calendario -->
  <div class="demand-legend">
    <span class="demand-dot demand-low"></span><span>Disponibilidad alta</span>
    <span class="demand-dot demand-medium"></span><span>Alta demanda</span>
    <span class="demand-dot demand-high"></span><span>Muy ocupado</span>
  </div>

  <form class="card schedule-form" method="post" action="/servicios/agendar">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="grid three">
      <div>
        <label for="name">Nombre completo</label>
        <input id="name" name="name" placeholder="Tu nombre" required />
      </div>
      <div>
        <label for="email">Correo electrónico</label>
        <input id="email" name="email" type="email" placeholder="para confirmar tu cita" required />
      </div>
      <div>
        <label for="phone">Teléfono</label>
        <input id="phone" name="phone" placeholder="Tu número de contacto" required />
      </div>
    </div>
    <div class="grid two" style="margin-top:16px">
      <div>
        <label for="service">Servicio</label>
        <select id="service" name="service" required>
          <% services.forEach(s => { %>
            <option value="<%= s %>"><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label>Fecha de la cita</label>
        <input id="date" name="date" type="hidden" required />
        <div id="calendar"
          data-calendar
          data-demand='<%- JSON.stringify(typeof demandMap !== "undefined" ? demandMap : {}) %>'
          aria-label="Calendario para seleccionar fecha"></div>
        <div class="muted" id="selectedDateText" style="margin-top:6px">Selecciona una fecha disponible</div>
      </div>
    </div>
    <button class="btn btn-primary" type="submit" style="margin-top:20px">Solicitar cita</button>
  </form>
</main>

<!-- Modal: Aviso de tiempos de servicio (se abre automáticamente al entrar a la página) -->
<div class="modal" id="modal-servicio" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="modal-servicio-title">
  <div class="modal-backdrop" data-modal-close></div>
  <div class="modal-dialog">
    <div class="modal-header">
      <h3 id="modal-servicio-title" class="modal-title">Aviso importante sobre tiempos</h3>
      <button class="modal-close" type="button" aria-label="Cerrar" data-modal-close>&times;</button>
    </div>
    <div class="modal-body">
      <p>
        El tiempo de trabajo para cada motocicleta dependerá de sus condiciones particulares. Durante el proceso
        pueden surgir novedades que alarguen o acorten el tiempo estimado del servicio. Agradecemos tu comprensión.
      </p>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-primary" data-modal-close>Entendido</button>
    </div>
  </div>
</div>

<script>
  // Auto-open modal only on first visit per session
  (function () {
    <% if (!bookingMessage) { %>
    const seen = sessionStorage.getItem('notice-servicio');
    if (!seen) {
      const modal = document.getElementById('modal-servicio');
      if (modal) {
        modal.setAttribute('aria-hidden', 'false');
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        sessionStorage.setItem('notice-servicio', '1');
      }
    }
    <% } %>
  })();
</script>

<%- include('partials/footer') %>
