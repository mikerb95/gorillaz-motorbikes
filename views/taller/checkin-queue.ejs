<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Check-ins — Taller Gorillaz</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: Montserrat, system-ui, sans-serif; background: #f3f4f6; color: #111; }
    .tl-top {
      background: #0f1115; color: #fff; padding: 14px 18px; display: flex; align-items: center; gap: 12px;
      position: sticky; top: 0; z-index: 10;
    }
    .tl-back { color: #fff; text-decoration: none; font-weight: 800; font-size: 14px; }
    .tl-top .label { font-weight: 900; font-size: 15px; }
    .tl-wrap { max-width: 680px; margin: 0 auto; padding: 18px 16px 40px; }
    .tl-h { font-size: 14px; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: .5px; margin: 8px 4px 14px; }
    .search { display: flex; gap: 8px; margin-bottom: 18px; }
    .search input { flex: 1; padding: 13px 12px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 16px; font-family: inherit; font-weight: 700; outline: none; text-transform: uppercase; }
    .search input:focus { border-color: #F25C05; }
    .search button { padding: 0 18px; border: none; border-radius: 12px; background: #F25C05; color: #fff; font-weight: 800; font-size: 14px; cursor: pointer; font-family: inherit; }
    .tl-checkin {
      display: block; text-decoration: none; color: inherit; background: #fff; border-radius: 14px;
      padding: 16px 18px; margin-bottom: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.08); border: 1px solid #eef0f2;
    }
    .tl-checkin:active { transform: scale(.995); }
    .tl-checkin-top { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 6px; }
    .tl-plate { font-weight: 900; font-size: 16px; letter-spacing: .5px; }
    .tl-name { font-size: 14px; color: #374151; font-weight: 700; }
    .tl-moto { font-size: 13px; color: #6b7280; margin-top: 2px; }
    .tl-meta { font-size: 12px; color: #9ca3af; margin-top: 4px; }
    .tl-empty { text-align: center; color: #9ca3af; font-size: 14px; padding: 50px 20px; }
  </style>
</head>
<body>
  <div class="tl-top">
    <a class="tl-back" href="/taller">←</a>
    <span class="label">Check-ins pendientes</span>
  </div>

  <div class="tl-wrap">
    <form class="search" method="get" action="/taller/checkin">
      <input type="text" name="placa" placeholder="Buscar por placa" value="<%= placa %>" />
      <button type="submit">Buscar</button>
    </form>

    <div class="tl-h">En espera (<%= checkins.length %>)</div>

    <% if (!checkins.length) { %>
      <div class="tl-empty">
        <% if (placa) { %>No hay check-ins pendientes para esa placa.<% } else { %>No hay clientes esperando por ahora.<% } %>
      </div>
    <% } %>

    <% checkins.forEach(c => { %>
      <a class="tl-checkin" href="/taller/checkin/<%= c.id %>/orden">
        <div class="tl-checkin-top">
          <span class="tl-plate"><%= c.plate %></span>
        </div>
        <div class="tl-name"><%= c.clientName %></div>
        <div class="tl-moto"><%= [c.brand, c.reference].filter(Boolean).join(' ') || 'Sin datos de moto' %></div>
        <div class="tl-meta">WhatsApp <%= c.clientPhoneCountry %> <%= c.clientPhone %></div>
      </a>
    <% }) %>
  </div>
</body>
</html>
