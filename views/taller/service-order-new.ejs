<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nueva orden — Taller Gorillaz</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: Montserrat, system-ui, sans-serif; background: #f3f4f6; color: #111; }
    .tl-top { background: #0f1115; color: #fff; padding: 14px 18px; display: flex; align-items: center; gap: 12px; position: sticky; top: 0; z-index: 10; }
    .tl-back { color: #fff; text-decoration: none; font-weight: 800; font-size: 14px; }
    .tl-top .label { font-weight: 900; font-size: 15px; }
    .tl-wrap { max-width: 680px; margin: 0 auto; padding: 18px 16px 60px; }
    .card { background: #fff; border-radius: 14px; padding: 18px; margin-bottom: 14px; box-shadow: 0 1px 3px rgba(0,0,0,.08); border: 1px solid #eef0f2; }
    .card h2 { font-size: 12px; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: .5px; margin: 0 0 12px; }
    .row { display: grid; grid-template-columns: repeat(auto-fill,minmax(140px,1fr)); gap: 14px; }
    .k { font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: .4px; margin-bottom: 3px; }
    .v { font-weight: 800; font-size: 14px; }
    .error-banner { background: #fef2f2; border: 1px solid #fca5a5; color: #991b1b; border-radius: 12px; padding: 14px; font-size: 13px; font-weight: 700; margin-bottom: 14px; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 11px; color: #9ca3af; text-transform: uppercase; letter-spacing: .4px; padding: 0 4px 8px; }
    td { padding: 6px 4px; }
    input[type=text], input[type=number], textarea {
      width: 100%; padding: 10px; border: 1.5px solid #e5e7eb; border-radius: 9px; font-size: 14px;
      font-family: inherit; outline: none; box-sizing: border-box;
    }
    input:focus, textarea:focus { border-color: #F25C05; }
    .it-sub { font-weight: 800; color: #F25C05; white-space: nowrap; padding-left: 8px; }
    .it-del { background: none; border: none; color: #dc2626; font-size: 18px; cursor: pointer; padding: 4px 8px; }
    .addrow { background: none; border: 1.5px dashed #e5e7eb; border-radius: 10px; padding: 10px; width: 100%; font-weight: 700; font-size: 13px; color: #374151; cursor: pointer; font-family: inherit; margin-top: 8px; }
    .total-row { display: flex; justify-content: space-between; align-items: center; padding-top: 12px; margin-top: 8px; border-top: 2px solid #111; font-weight: 900; font-size: 17px; }
    .total-row span:last-child { color: #F25C05; }
    .save { width: 100%; margin-top: 14px; padding: 15px; font-size: 16px; font-weight: 800; background: #F25C05; color: #fff; border: none; border-radius: 12px; cursor: pointer; }
  </style>
</head>
<body>
  <div class="tl-top">
    <a class="tl-back" href="/taller/checkin">←</a>
    <span class="label">Nueva orden de servicio</span>
  </div>

  <div class="tl-wrap">
    <% if (error) { %>
      <div class="error-banner"><%= error %></div>
    <% } %>

    <div class="card">
      <h2>Cliente (desde check-in)</h2>
      <div class="row">
        <div><div class="k">Placa</div><div class="v"><%= checkin.plate %></div></div>
        <div><div class="k">Moto</div><div class="v"><%= [checkin.brand, checkin.reference].filter(Boolean).join(' ') || '—' %></div></div>
        <div><div class="k">Cliente</div><div class="v"><%= checkin.clientName %></div></div>
        <div><div class="k">WhatsApp</div><div class="v"><%= checkin.clientPhoneCountry %> <%= checkin.clientPhone %></div></div>
      </div>
    </div>

    <form method="post" action="/taller/checkin/<%= checkin.id %>/orden" id="soForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="items" id="itemsField" />

      <div class="card">
        <h2>Productos y servicios</h2>
        <table id="itemsTable">
          <thead>
            <tr><th>Ítem</th><th style="width:56px;text-align:center">Cant.</th><th style="width:90px;text-align:right">Precio</th><th></th></tr>
          </thead>
          <tbody id="itemsBody"></tbody>
        </table>
        <button type="button" class="addrow" id="addRow">+ Agregar ítem</button>
        <div class="total-row"><span>Total</span><span id="grandTotal">$0</span></div>
      </div>

      <button class="save" type="submit">Crear orden de servicio →</button>
    </form>
  </div>

  <script>
  (function () {
    const body       = document.getElementById('itemsBody');
    const addBtn     = document.getElementById('addRow');
    const grandTotal = document.getElementById('grandTotal');
    const form       = document.getElementById('soForm');
    const itemsField = document.getElementById('itemsField');

    const fmt = n => '$' + (Number(n) || 0).toLocaleString('es-CO');

    function recalc() {
      let total = 0;
      body.querySelectorAll('tr').forEach(tr => {
        const price = Number(tr.querySelector('.it-price').value) || 0;
        const qty   = Number(tr.querySelector('.it-qty').value)   || 0;
        const sub   = price * qty;
        tr.querySelector('.it-sub').textContent = fmt(sub);
        total += sub;
      });
      grandTotal.textContent = fmt(total);
    }

    function addRow() {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td><input class="it-name" type="text" placeholder="Nombre del ítem"></td>
        <td><input class="it-qty" type="number" min="1" value="1" style="text-align:center"></td>
        <td><input class="it-price" type="number" min="0" step="1" placeholder="0" style="text-align:right"></td>
        <td class="it-sub">$0</td>
        <td><button type="button" class="it-del">✕</button></td>`;
      body.appendChild(tr);
      tr.querySelector('.it-del').addEventListener('click', () => { tr.remove(); recalc(); });
      tr.querySelectorAll('.it-price, .it-qty').forEach(el => el.addEventListener('input', recalc));
      recalc();
    }

    addBtn.addEventListener('click', addRow);
    addRow();

    form.addEventListener('submit', e => {
      const items = [];
      body.querySelectorAll('tr').forEach(tr => {
        const name  = tr.querySelector('.it-name').value.trim();
        const price = Math.round(Number(tr.querySelector('.it-price').value));
        const qty   = Math.round(Number(tr.querySelector('.it-qty').value));
        if (name && price >= 1 && qty >= 1) items.push({ name, type: 'custom', price, qty });
      });
      if (items.length === 0) {
        e.preventDefault();
        alert('Agrega al menos un ítem válido (nombre, cantidad y precio).');
        return;
      }
      itemsField.value = JSON.stringify(items);
    });
  })();
  </script>
</body>
</html>
