<%- include('partials/head', { title: product.name + ' — Tienda' }) %>

<main class="container pdp">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/">Inicio</a>
            <span class="breadcrumb-sep">›</span>
            <a href="/tienda">Tienda</a>
            <% if (category) { %>
                <span class="breadcrumb-sep">›</span>
                <a href="/tienda?cat=<%= category.slug %>">
                    <%= category.name %>
                </a>
                <% } %>
                    <span class="breadcrumb-sep">›</span>
                    <span>
                        <%= product.name %>
                    </span>
        </nav>

        <div class="pdp-layout">
            <!-- Gallery Column -->
            <div class="pdp-gallery">
                <div class="pdp-main-image" id="pdpMainImage">
                    <img src="<%= (product.gallery && product.gallery[0]) || product.image %>" alt="<%= product.name %>"
                        id="pdpMainImg" />
                    <% if (product.discount> 0) { %>
                        <span class="pdp-discount-badge">-<%= product.discount %>%</span>
                        <% } %>
                            <% if (typeof product.stock==='number' && product.stock===0) { %>
                                <span class="pdp-soldout-badge">Agotado</span>
                                <% } %>
                </div>
                <% if (product.gallery && product.gallery.length> 1) { %>
                    <div class="pdp-thumbs">
                        <% product.gallery.forEach((img, i)=> { %>
                            <button type="button" class="pdp-thumb <%= i === 0 ? 'is-active' : '' %>"
                                onclick="switchImage(this, '<%= img %>')">
                                <img src="<%= img %>" alt="Imagen <%= i + 1 %>" />
                            </button>
                            <% }) %>
                    </div>
                    <% } %>
            </div>

            <!-- Info Column -->
            <div class="pdp-info">
                <% if (product.brand) { %>
                    <span class="pdp-brand">
                        <%= product.brand %>
                    </span>
                    <% } %>
                        <h1 class="pdp-title">
                            <%= product.name %>
                        </h1>
                        <% if (product.sku) { %>
                            <span class="muted" style="font-size:.85rem">SKU: <%= product.sku %></span>
                            <% } %>

                                <!-- Price -->
                                <div class="pdp-price-block">
                                    <% if (product.discount> 0) { %>
                                        <span class="pdp-price">$<%= Math.round(product.price * (1 - product.discount /
                                                100)).toLocaleString('es-CO') %></span>
                                        <span class="pdp-price-original">$<%= product.price.toLocaleString('es-CO') %>
                                                </span>
                                        <span class="pdp-discount-tag">
                                            <%= product.discount %>% OFF
                                        </span>
                                        <% } else { %>
                                            <span class="pdp-price">$<%= product.price.toLocaleString('es-CO') %></span>
                                            <% } %>
                                </div>

                                <!-- Stock -->
                                <div class="pdp-stock">
                                    <% if (typeof product.stock==='number' && product.stock===0) { %>
                                        <span class="chip chip-danger">Agotado</span>
                                        <% } else if (typeof product.stock==='number' && product.stock <=5) { %>
                                            <span class="chip chip-warning">Últimas <%= product.stock %> unidades</span>
                                            <% } else if (typeof product.stock==='number' ) { %>
                                                <span class="chip chip-success">En stock</span>
                                                <% } %>
                                </div>

                                <!-- Add to Cart -->
                                <div class="pdp-actions">
                                    <div class="pdp-qty">
                                        <button type="button" class="pdp-qty-btn" onclick="changeQty(-1)">−</button>
                                        <input type="number" id="pdpQty" value="1" min="1"
                                            max="<%= typeof product.stock === 'number' ? product.stock : 99 %>" />
                                        <button type="button" class="pdp-qty-btn" onclick="changeQty(1)">+</button>
                                    </div>
                                    <button type="button" class="btn btn-primary pdp-add-btn" id="pdpAddCart" <%=(typeof
                                        product.stock==='number' && product.stock===0) ? 'disabled' : '' %>
                                        data-id="<%= product.id %>">
                                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M3 4h2l2.5 12h9l2-8H7.2" />
                                                <circle cx="9" cy="20" r="1.5" />
                                                <circle cx="17" cy="20" r="1.5" />
                                            </svg>
                                            Agregar al carrito
                                    </button>
                                </div>

                                <!-- Description -->
                                <% if (product.description) { %>
                                    <div class="pdp-description">
                                        <h3>Descripción</h3>
                                        <p>
                                            <%= product.description %>
                                        </p>
                                    </div>
                                    <% } %>

                                        <!-- Tags -->
                                        <% if (product.tags && product.tags.length> 0) { %>
                                            <div class="pdp-tags">
                                                <% product.tags.forEach(tag=> { %>
                                                    <a href="/tienda?q=<%= encodeURIComponent(tag) %>" class="chip">
                                                        <%= tag %>
                                                    </a>
                                                    <% }) %>
                                            </div>
                                            <% } %>

                                                <!-- Share -->
                                                <div class="pdp-share">
                                                    <span class="muted">Compartir:</span>
                                                    <a href="https://wa.me/?text=<%= encodeURIComponent(product.name + ' — $' + product.price.toLocaleString('es-CO') + ' en Gorillaz Motorbikes') %>"
                                                        target="_blank" rel="noopener" class="pdp-share-btn"
                                                        title="WhatsApp">
                                                        <svg viewBox="0 0 24 24" width="18" height="18"
                                                            fill="currentColor">
                                                            <path
                                                                d="M17.47 14.38c-.3-.15-1.73-.85-2-.94-.27-.1-.47-.15-.67.15-.2.3-.77.94-.94 1.14-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.47-.89-.79-1.48-1.77-1.65-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.6-.92-2.2-.24-.58-.48-.5-.67-.5H8.1c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.5s1.07 2.9 1.22 3.1c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.5 1.69.64.71.23 1.35.2 1.86.12.57-.09 1.73-.71 1.98-1.4.24-.69.24-1.28.17-1.4-.07-.12-.27-.2-.57-.35z" />
                                                        </svg>
                                                    </a>
                                                </div>
            </div>
        </div>

        <!-- Related Products -->
        <% if (related && related.length> 0) { %>
            <section class="pdp-related">
                <h2 class="section-title">Productos relacionados</h2>
                <div class="grid products-grid">
                    <% related.forEach(p=> { %>
                        <article class="card product-card">
                            <a href="/tienda/<%= p.id %>" class="product-card-link">
                                <div class="card-media" aria-hidden="true"
                                    style="background-image:url('<%= p.image %>');background-size:cover;background-position:center">
                                    <% if (p.discount> 0) { %>
                                        <span class="product-discount-chip">-<%= p.discount %>%</span>
                                        <% } %>
                                            <% if (typeof p.stock==='number' && p.stock===0) { %>
                                                <span class="product-soldout-chip">Agotado</span>
                                                <% } %>
                                </div>
                                <div class="card-body">
                                    <% if (p.brand) { %><span class="product-brand">
                                            <%= p.brand %>
                                        </span>
                                        <% } %>
                                            <h3 class="card-title">
                                                <%= p.name %>
                                            </h3>
                                            <div class="price-row">
                                                <% if (p.discount> 0) { %>
                                                    <span class="price">$<%= Math.round(p.price * (1 - p.discount /
                                                            100)).toLocaleString('es-CO') %></span>
                                                    <span class="price-old">$<%= p.price.toLocaleString('es-CO') %>
                                                            </span>
                                                    <% } else { %>
                                                        <span class="price">$<%= p.price.toLocaleString('es-CO') %>
                                                                </span>
                                                        <% } %>
                                            </div>
                                </div>
                            </a>
                        </article>
                        <% }) %>
                </div>
            </section>
            <% } %>
    </main>

    <script>
        function switchImage(thumb, src) {
            document.getElementById('pdpMainImg').src = src;
            document.querySelectorAll('.pdp-thumb').forEach(t => t.classList.remove('is-active'));
            thumb.classList.add('is-active');
        }
        function changeQty(delta) {
            const input = document.getElementById('pdpQty');
            const max = parseInt(input.max) || 99;
            const val = Math.max(1, Math.min(max, parseInt(input.value || '1') + delta));
            input.value = val;
        }
        // AJAX Add to cart
        document.getElementById('pdpAddCart')?.addEventListener('click', async function () {
            const id = this.dataset.id;
            const qty = document.getElementById('pdpQty').value;
            const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
                    body: JSON.stringify({ id, qty: parseInt(qty), _csrf: csrf })
                });
                const data = await res.json();
                if (data.ok) {
                    // Update cart badge
                    document.querySelectorAll('.cart-badge').forEach(b => b.textContent = data.cartCount);
                    // Show toast
                    showToast(data.message || 'Añadido al carrito');
                } else {
                    showToast(data.message || 'Error', true);
                }
            } catch (e) {
                showToast('Error de conexión', true);
            }
        });

        function showToast(msg, isError) {
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast';
                document.body.appendChild(toast);
            }
            toast.textContent = msg;
            toast.className = 'toast ' + (isError ? 'toast-error' : 'toast-success') + ' toast-show';
            clearTimeout(toast._timer);
            toast._timer = setTimeout(() => { toast.classList.remove('toast-show'); }, 3000);
        }
    </script>

    <%- include('partials/footer') %>