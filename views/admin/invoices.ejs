<%- include('../partials/admin-head', { title: 'Facturas' }) %>

<%
const STATUS = { pendiente:{label:'Pendiente',cls:'badge-warning'}, pagada:{label:'Pagada',cls:'badge-success'}, anulada:{label:'Anulada',cls:'badge-danger'}, proforma:{label:'Proforma',cls:'badge-warning'} };
// `stats` (agregados en SQL) y `status`/`page`/`pages`/`total` llegan del servidor.
const s = typeof stats !== 'undefined' ? stats : { pendientes: 0, pagadas: 0, totalPagado: 0 };
const activeStatus = typeof status !== 'undefined' ? status : '';
%>

<div class="crm-page-header">

</div>

<div class="crm-kpi-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:12px">
  <a class="crm-kpi-card" href="<%= activeStatus === 'pendiente' ? '/admin/facturas' : '?status=pendiente' %>" style="text-decoration:none;color:inherit;<%= activeStatus==='pendiente' ? 'outline:2px solid var(--brand);outline-offset:-2px' : '' %>"><div class="crm-kpi-value"><%= s.pendientes %></div><div class="crm-kpi-label">Pendientes de pago</div></a>
  <a class="crm-kpi-card" href="<%= activeStatus === 'pagada' ? '/admin/facturas' : '?status=pagada' %>" style="text-decoration:none;color:inherit;<%= activeStatus==='pagada' ? 'outline:2px solid var(--brand);outline-offset:-2px' : '' %>"><div class="crm-kpi-value"><%= s.pagadas %></div><div class="crm-kpi-label">Pagadas</div></a>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value" style="font-size:1.1rem">$<%= s.totalPagado.toLocaleString('es-CO') %></div><div class="crm-kpi-label">Total recaudado</div></div>
</div>

<% if (activeStatus) { %>
  <div style="margin-bottom:16px;font-size:.85rem;color:#6b7280">
    Filtrando por <strong><%= (STATUS[activeStatus]||{label:activeStatus}).label %></strong>
    · <a href="/admin/facturas" style="color:var(--brand);font-weight:700">Ver todas</a>
  </div>
<% } %>

<div class="crm-card">
  <% if (total === 0) { %>
    <p class="muted" style="padding:32px;text-align:center"><%= activeStatus ? 'No hay facturas con este estado.' : 'No hay facturas aún.' %></p>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr><th>N° Factura</th><th>Fecha</th><th>Orden</th><th>Subtotal</th><th>IVA</th><th>Total</th><th>Método</th><th>Estado</th><th></th></tr>
      </thead>
      <tbody>
        <% invoices.forEach(inv => {
          const st = STATUS[inv.status] || {label:inv.status, cls:'badge-warning'};
        %>
        <tr>
          <td><span class="badge badge-success" style="font-weight:900;font-size:.8rem"><%= inv.label %></span></td>
          <td class="muted" style="font-size:.82rem;white-space:nowrap"><%= fechaCO(inv.createdAt, {day:'2-digit',month:'short',year:'numeric'}) %></td>
          <td class="muted" style="font-size:.82rem"><a href="/admin/ordenes-servicio/<%= inv.serviceOrderId %>" style="color:var(--brand)">Ver orden</a></td>
          <td>$<%= inv.subtotal.toLocaleString('es-CO') %></td>
          <td class="muted" style="font-size:.85rem">$<%= inv.tax.toLocaleString('es-CO') %></td>
          <td><strong>$<%= inv.total.toLocaleString('es-CO') %></strong></td>
          <td style="font-size:.85rem;text-transform:capitalize"><%= inv.paymentMethod %></td>
          <td><span class="badge <%= st.cls %>"><%= st.label %></span></td>
          <td><a class="btn btn-ghost btn-sm" href="/admin/facturas/<%= inv.id %>">Ver</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pager', { page, pages, params: { status: activeStatus } }) %>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
