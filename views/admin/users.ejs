<%- include('../partials/admin-head', { title: 'Usuarios' }) %>

<div class="crm-page-header">
  <span class="badge badge-info"><%= users.length %> registrados</span>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="crm-card" style="border:1px solid #fca5a5;background:#fef2f2;color:#b91c1c;padding:10px 14px;margin-bottom:14px;font-size:.85rem;font-weight:600">
    <%= error %>
  </div>
<% } %>

<!-- Filters -->
<div class="crm-filter-bar" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;align-items:flex-end">
  <div style="flex:1;min-width:180px">
    <label class="crm-filter-label">Buscar</label>
    <input class="crm-search-input" style="width:100%;box-sizing:border-box" type="text" id="userSearch" placeholder="Nombre, email, ciudad o placa…" />
  </div>
  <div style="min-width:130px">
    <label class="crm-filter-label">Rol</label>
    <select class="crm-select" id="filterRol">
      <option value="">Todos</option>
      <option value="admin">Admin</option>
      <option value="user">Usuario</option>
    </select>
  </div>
  <div style="min-width:150px">
    <label class="crm-filter-label">Ciudad</label>
    <select class="crm-select" id="filterCiudad">
      <option value="">Todas</option>
    </select>
  </div>
  <div style="min-width:130px">
    <label class="crm-filter-label">Registro desde</label>
    <input class="crm-input" type="date" id="filterDesde" />
  </div>
  <div style="min-width:130px">
    <label class="crm-filter-label">Registro hasta</label>
    <input class="crm-input" type="date" id="filterHasta" />
  </div>
  <div style="padding-bottom:1px">
    <button class="btn btn-ghost btn-sm" id="clearFilters" type="button">Limpiar</button>
  </div>
</div>

<!-- Desktop table -->
<div class="crm-card crm-users-desktop-table" style="padding:0;overflow:hidden">
  <div class="crm-table-wrap">
    <table class="crm-table" id="usersTable">
      <thead>
        <tr>
          <th style="width:44px"></th>
          <th>Nombre</th>
          <th>Email</th>
          <th>Rol</th>
          <th>Membresía</th>
          <th>Ciudad</th>
          <th>Placas</th>
          <th>Teléfono</th>
          <th>Registro</th>
          <th style="width:110px">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <% const plates = (u.vehicles || []).map(v => v.plate).filter(Boolean); %>
          <% const fechaISO = u.createdAt ? new Date(u.createdAt).toISOString().slice(0,10) : ''; %>
          <tr
            data-search="<%= (u.name + ' ' + u.email + ' ' + (u.city || '') + ' ' + plates.join(' ')).toLowerCase() %>"
            data-rol="<%= u.role || 'user' %>"
            data-ciudad="<%= (u.city || '').toLowerCase().trim() %>"
            data-fecha="<%= fechaISO %>">
            <td>
              <div class="crm-user-circle"><%= u.name.charAt(0).toUpperCase() %></div>
            </td>
            <td>
              <strong><%= u.name %></strong>
              <% if (u.nickname) { %><br><span style="font-size:.75rem;color:#71717a">@<%= u.nickname %></span><% } %>
            </td>
            <td style="font-size:.8rem;color:#52525b"><%= u.email %></td>
            <td>
              <% if (u.role === 'admin') { %>
                <span class="badge badge-orange">Admin</span>
              <% } else { %>
                <span class="badge badge-muted">Usuario</span>
              <% } %>
            </td>
            <td>
              <% const lvlD = u.membership && u.membership.level; %>
              <% if (lvlD) { %><span class="badge badge-info"><%= lvlD %></span><% } else { %><span class="badge badge-muted">—</span><% } %>
            </td>
            <td style="font-size:.8rem;color:#52525b"><%= u.city || '—' %></td>
            <td>
              <% if (plates.length) { %>
                <div style="display:flex;flex-wrap:wrap;gap:4px">
                  <% plates.forEach(p => { %>
                    <span class="badge badge-muted" style="font-size:.7rem;letter-spacing:.5px;font-weight:700"><%= p %></span>
                  <% }) %>
                </div>
              <% } else { %>
                <span style="color:#a1a1aa;font-size:.8rem">—</span>
              <% } %>
            </td>
            <td style="font-size:.8rem;color:#52525b"><%= u.phone || '—' %></td>
            <td style="font-size:.75rem;color:#71717a">
              <% if (u.createdAt) { %><%= new Date(u.createdAt).toLocaleDateString('es-CO') %><% } else { %>—<% } %>
            </td>
            <td>
              <div class="crm-table-actions">
                <button class="btn btn-sm btn-ghost" type="button"
                  onclick="toggleEdit('<%= u.id %>')" title="Editar">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <form method="post" action="/admin/usuarios/eliminar" data-confirm="¿Eliminar a <%= u.name %>? Esta acción no se puede deshacer.">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="id" value="<%= u.id %>" />
                  <button class="btn btn-sm btn-danger" type="submit" title="Eliminar">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <!-- Inline edit row -->
          <tr>
            <td colspan="10" style="padding:0;border:none">
              <div class="crm-inline-edit" id="edit-<%= u.id %>">
                <form method="post" action="/admin/usuarios/actualizar">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="id" value="<%= u.id %>" />
                  <div style="margin-bottom:12px">
                    <%- include('../partials/profile-fields', { u: u, admin: true }) %>
                  </div>
                  <div class="crm-form-actions">
                    <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
                    <button class="btn btn-ghost btn-sm" type="button" onclick="toggleEdit('<%= u.id %>')">Cancelar</button>
                  </div>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Mobile card list -->
<ul class="crm-user-cards" id="userCardsMobile">
  <% users.forEach(u => { %>
  <% const platesM = (u.vehicles || []).map(v => v.plate).filter(Boolean); %>
  <% const fechaISOM = u.createdAt ? new Date(u.createdAt).toISOString().slice(0,10) : ''; %>
  <li class="crm-user-card"
    data-search="<%= (u.name + ' ' + u.email + ' ' + (u.city || '') + ' ' + platesM.join(' ')).toLowerCase() %>"
    data-rol="<%= u.role || 'user' %>"
    data-ciudad="<%= (u.city || '').toLowerCase().trim() %>"
    data-fecha="<%= fechaISOM %>">
    <div class="crm-uc-header">
      <div class="crm-user-circle crm-uc-avatar"><%= u.name.charAt(0).toUpperCase() %></div>
      <div class="crm-uc-identity">
        <strong class="crm-uc-name"><%= u.name %></strong>
        <span class="crm-uc-email"><%= u.email %></span>
      </div>
      <div class="crm-uc-btns">
        <button class="btn btn-sm btn-ghost" type="button" onclick="toggleEditMobile('<%= u.id %>')" title="Editar">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <form method="post" action="/admin/usuarios/eliminar" data-confirm="¿Eliminar a <%= u.name %>? Esta acción no se puede deshacer.">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="id" value="<%= u.id %>" />
          <button class="btn btn-sm btn-danger" type="submit" title="Eliminar">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
          </button>
        </form>
      </div>
    </div>

    <div class="crm-uc-badges">
      <% if (u.role === 'admin') { %>
        <span class="badge badge-orange">Admin</span>
      <% } else { %>
        <span class="badge badge-muted">Usuario</span>
      <% } %>
      <% const lvlM = u.membership && u.membership.level; %>
      <% if (lvlM) { %><span class="badge badge-info"><%= lvlM %></span><% } %>
      <% platesM.forEach(p => { %>
        <span class="badge badge-muted" style="font-size:.68rem;letter-spacing:.5px;font-weight:700"><%= p %></span>
      <% }) %>
    </div>

    <% if (u.phone || u.city || u.createdAt) { %>
    <div class="crm-uc-detail">
      <% if (u.phone) { %><span class="crm-uc-meta-item">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 011 1.18 2 2 0 013 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <%= u.phone %>
      </span><% } %>
      <% if (u.city) { %><span class="crm-uc-meta-item">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <%= u.city %>
      </span><% } %>
      <% if (u.createdAt) { %><span class="crm-uc-meta-item">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <%= new Date(u.createdAt).toLocaleDateString('es-CO') %>
      </span><% } %>
    </div>
    <% } %>

    <div class="crm-inline-edit" id="editm-<%= u.id %>">
      <form method="post" action="/admin/usuarios/actualizar">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="id" value="<%= u.id %>" />
        <div style="margin-bottom:12px">
          <%- include('../partials/profile-fields', { u: u, admin: true }) %>
        </div>
        <div class="crm-form-actions">
          <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
          <button class="btn btn-ghost btn-sm" type="button" onclick="toggleEditMobile('<%= u.id %>')">Cancelar</button>
        </div>
      </form>
    </div>
  </li>
  <% }) %>
</ul>

<script>
  function toggleEdit(id) {
    const el = document.getElementById('edit-' + id);
    if (el) el.classList.toggle('open');
  }

  function toggleEditMobile(id) {
    const el = document.getElementById('editm-' + id);
    if (el) el.classList.toggle('open');
  }

  // Populate city dropdown from data
  (function () {
    const cities = new Set();
    document.querySelectorAll('[data-ciudad]').forEach(el => {
      const c = el.dataset.ciudad;
      if (c) cities.add(c);
    });
    const sel = document.getElementById('filterCiudad');
    [...cities].sort().forEach(c => {
      const opt = document.createElement('option');
      opt.value = c;
      opt.textContent = c.charAt(0).toUpperCase() + c.slice(1);
      sel.appendChild(opt);
    });
  })();

  function applyFilters() {
    const q      = document.getElementById('userSearch').value.toLowerCase().trim();
    const rol    = document.getElementById('filterRol').value;
    const ciudad = document.getElementById('filterCiudad').value;
    const desde  = document.getElementById('filterDesde').value;
    const hasta  = document.getElementById('filterHasta').value;

    function matches(el) {
      if (q      && !el.dataset.search.includes(q))         return false;
      if (rol    && el.dataset.rol    !== rol)               return false;
      if (ciudad && el.dataset.ciudad !== ciudad)            return false;
      const fecha = el.dataset.fecha || '';
      if (desde  && fecha < desde)                           return false;
      if (hasta  && fecha > hasta)                           return false;
      return true;
    }

    // Desktop table rows
    document.querySelectorAll('#usersTable tbody tr[data-search]').forEach(row => {
      const show = matches(row);
      row.style.display = show ? '' : 'none';
      const next = row.nextElementSibling;
      if (next && !next.dataset.search) next.style.display = show ? '' : 'none';
    });

    // Mobile cards
    document.querySelectorAll('#userCardsMobile .crm-user-card').forEach(card => {
      card.style.display = matches(card) ? '' : 'none';
    });
  }

  document.getElementById('userSearch').addEventListener('input', applyFilters);
  document.getElementById('filterRol').addEventListener('change', applyFilters);
  document.getElementById('filterCiudad').addEventListener('change', applyFilters);
  document.getElementById('filterDesde').addEventListener('change', applyFilters);
  document.getElementById('filterHasta').addEventListener('change', applyFilters);

  document.getElementById('clearFilters').addEventListener('click', function () {
    document.getElementById('userSearch').value   = '';
    document.getElementById('filterRol').value    = '';
    document.getElementById('filterCiudad').value = '';
    document.getElementById('filterDesde').value  = '';
    document.getElementById('filterHasta').value  = '';
    applyFilters();
  });
</script>

<%- include('../partials/admin-foot') %>
