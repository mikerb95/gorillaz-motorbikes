<%- include('../partials/admin-head', { title: 'Eventos' }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css" />

<div class="crm-page-header">
  <h1 class="crm-page-title">Eventos</h1>
  <button class="btn btn-primary btn-sm" type="button"
    onclick="document.getElementById('newEventCard').classList.toggle('hidden-card')">
    + Nuevo evento
  </button>
</div>

<!-- Create form -->
<div class="crm-card hidden-card" id="newEventCard">
  <div class="crm-card-title">Crear evento</div>
  <form method="post" action="/admin/eventos/crear" id="createEventForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="lat" id="createLat" value="" />
    <input type="hidden" name="lng" id="createLng" value="" />

    <!-- Category selector -->
    <div class="ev-category-selector" style="margin-bottom:18px">
      <label style="font-weight:600;font-size:.85rem;display:block;margin-bottom:8px">Categoría del evento <span class="required">*</span></label>
      <div class="ev-cat-tabs" id="createCatTabs">
        <button type="button" class="ev-cat-btn active" data-cat="club" onclick="selectCategory('create','club')">
          <span class="ev-cat-icon">🏍️</span> Club
        </button>
        <button type="button" class="ev-cat-btn" data-cat="taller" onclick="selectCategory('create','taller')">
          <span class="ev-cat-icon">🔧</span> Taller
        </button>
      </div>
      <input type="hidden" name="category" id="createCategory" value="club" />
    </div>

    <div class="crm-form-grid">
      <div class="crm-form-group">
        <label>Título <span class="required">*</span></label>
        <input name="title" required placeholder="Nombre del evento" />
      </div>
      <div class="crm-form-group">
        <label>Fecha <span class="required">*</span></label>
        <input type="date" name="date" required />
      </div>
      <div class="crm-form-group" id="createTypeGroup">
        <label>Tipo</label>
        <select name="type" id="createType">
          <option value="rodada">🏍️ Rodada (+30 pts)</option>
          <option value="encuentro">⚽ Encuentro (+25 pts)</option>
          <option value="caminata">🥾 Caminata (+25 pts)</option>
          <option value="actividad">🎉 Actividad (+25 pts)</option>
        </select>
      </div>
      <div class="crm-form-group crm-form-full">
        <label>Descripción</label>
        <textarea name="description" rows="2" placeholder="Detalles del evento…"></textarea>
      </div>
      <!-- Location map picker -->
      <div class="crm-form-group crm-form-full">
        <label>Lugar</label>
        <div class="ev-search-wrap" id="createSearchWrap">
          <input name="location" id="createLocation" placeholder="Escribe una dirección o haz clic en el mapa…" autocomplete="off" oninput="searchLocation('create', this.value)" />
          <ul class="ev-search-dropdown" id="createDropdown"></ul>
        </div>
        <div id="createMapContainer" class="ev-map-container">
          <div id="createMap" class="ev-map">
            <div class="ev-map-overlay" id="createMapOverlay">📍 Haz clic para fijar la ubicación</div>
          </div>
        </div>
        <p class="ev-map-hint">Busca una dirección arriba o haz clic en el mapa para fijar la ubicación exacta.</p>
      </div>
    </div>
    <div class="crm-form-actions">
      <button class="btn btn-primary btn-sm" type="submit">Crear evento</button>
    </div>
  </form>
</div>

<!-- Events list -->
<div class="crm-card" style="padding:0;overflow:hidden">
  <% if (!events.length) { %>
    <div style="padding:32px;text-align:center;color:#71717a">No hay eventos registrados.</div>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr>
          <th>Título</th>
          <th>Categoría</th>
          <th>Tipo</th>
          <th>Fecha</th>
          <th>Lugar</th>
          <th>Asistencias</th>
          <th style="width:100px">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% events.sort((a,b) => (a.date > b.date ? -1 : 1)).forEach(ev => { %>
          <tr>
            <td>
              <strong><%= ev.title %></strong>
              <% if (ev.description) { %>
                <br><span style="font-size:.75rem;color:#71717a"><%= ev.description.substring(0, 60) %><%= ev.description.length > 60 ? '…' : '' %></span>
              <% } %>
            </td>
            <td>
              <% if (ev.category === 'taller') { %>
                <span class="badge badge-warning">🔧 Taller</span>
              <% } else { %>
                <span class="badge badge-info">🏍️ Club</span>
              <% } %>
            </td>
            <td style="font-size:.82rem">
              <% if (ev.type === 'rodada') { %>Rodada
              <% } else if (ev.type === 'encuentro') { %>Encuentro
              <% } else if (ev.type === 'caminata') { %>Caminata
              <% } else if (ev.type === 'actividad') { %>Actividad
              <% } else if (ev.type === 'descuento') { %>Descuento
              <% } else if (ev.type === 'beneficio') { %>Beneficio
              <% } else if (ev.type === 'oportunidad') { %>Oportunidad
              <% } else { %>Evento<% } %>
            </td>
            <td style="font-size:.82rem;white-space:nowrap"><%= ev.date %></td>
            <td style="font-size:.82rem;color:#52525b">
              <%= ev.location || '—' %>
              <% if (ev.lat && ev.lng) { %>
                <a href="https://www.google.com/maps?q=<%= ev.lat %>,<%= ev.lng %>" target="_blank" rel="noopener" style="margin-left:4px;font-size:.7rem;color:var(--accent)">ver mapa</a>
              <% } %>
            </td>
            <td>
              <% if (ev.category !== 'taller') { %>
                <a class="btn btn-sm btn-ghost" href="/admin/eventos/<%= ev.id %>/asistencias">Ver</a>
              <% } else { %>
                <span style="font-size:.75rem;color:#a1a1aa">N/A</span>
              <% } %>
            </td>
            <td>
              <div class="crm-table-actions">
                <button class="btn btn-sm btn-ghost" type="button" onclick="toggleEvEdit('<%= ev.id %>')" title="Editar">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <form method="post" action="/admin/eventos/eliminar" data-confirm="¿Eliminar el evento «<%= ev.title %>»?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="id" value="<%= ev.id %>" />
                  <button class="btn btn-sm btn-danger" type="submit" title="Eliminar">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <tr>
            <td colspan="7" style="padding:0;border:none">
              <div class="crm-inline-edit" id="ev-edit-<%= ev.id %>">
                <form method="post" action="/admin/eventos/actualizar">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="id" value="<%= ev.id %>" />
                  <input type="hidden" name="lat" id="editLat-<%= ev.id %>" value="<%= ev.lat || '' %>" />
                  <input type="hidden" name="lng" id="editLng-<%= ev.id %>" value="<%= ev.lng || '' %>" />

                  <!-- Category selector -->
                  <div class="ev-category-selector" style="margin-bottom:14px">
                    <label style="font-weight:600;font-size:.85rem;display:block;margin-bottom:8px">Categoría</label>
                    <div class="ev-cat-tabs" id="editCatTabs-<%= ev.id %>">
                      <button type="button" class="ev-cat-btn <%= ev.category !== 'taller' ? 'active' : '' %>" data-cat="club" onclick="selectCategory('edit-<%= ev.id %>','club')">
                        <span class="ev-cat-icon">🏍️</span> Club
                      </button>
                      <button type="button" class="ev-cat-btn <%= ev.category === 'taller' ? 'active' : '' %>" data-cat="taller" onclick="selectCategory('edit-<%= ev.id %>','taller')">
                        <span class="ev-cat-icon">🔧</span> Taller
                      </button>
                    </div>
                    <input type="hidden" name="category" id="editCategory-<%= ev.id %>" value="<%= ev.category || 'club' %>" />
                  </div>

                  <div class="crm-form-grid" style="margin-bottom:12px">
                    <div class="crm-form-group">
                      <label>Título</label>
                      <input name="title" value="<%= ev.title %>" />
                    </div>
                    <div class="crm-form-group">
                      <label>Fecha</label>
                      <input type="date" name="date" value="<%= ev.date %>" />
                    </div>
                    <div class="crm-form-group" id="editTypeGroup-<%= ev.id %>">
                      <label>Tipo</label>
                      <select name="type" id="editType-<%= ev.id %>">
                        <% if (ev.category === 'taller') { %>
                          <option value="descuento" <%= ev.type === 'descuento' ? 'selected' : '' %>>💰 Descuento</option>
                          <option value="beneficio" <%= ev.type === 'beneficio' ? 'selected' : '' %>>🎁 Beneficio</option>
                          <option value="oportunidad" <%= ev.type === 'oportunidad' ? 'selected' : '' %>>⚡ Oportunidad única</option>
                        <% } else { %>
                          <option value="rodada" <%= ev.type === 'rodada' ? 'selected' : '' %>>🏍️ Rodada (+30 pts)</option>
                          <option value="encuentro" <%= (ev.type === 'encuentro' || ev.type === 'evento') ? 'selected' : '' %>>⚽ Encuentro (+25 pts)</option>
                          <option value="caminata" <%= ev.type === 'caminata' ? 'selected' : '' %>>🥾 Caminata (+25 pts)</option>
                          <option value="actividad" <%= ev.type === 'actividad' ? 'selected' : '' %>>🎉 Actividad (+25 pts)</option>
                        <% } %>
                      </select>
                    </div>
                    <div class="crm-form-group crm-form-full">
                      <label>Descripción</label>
                      <textarea name="description" rows="2"><%= ev.description || '' %></textarea>
                    </div>
                    <div class="crm-form-group crm-form-full">
                      <label>Lugar</label>
                      <div class="ev-search-wrap" id="editSearchWrap-<%= ev.id %>">
                        <input name="location" id="editLocation-<%= ev.id %>" value="<%= ev.location || '' %>" placeholder="Escribe una dirección o haz clic en el mapa…" autocomplete="off" oninput="searchLocation('edit-<%= ev.id %>', this.value)" />
                        <ul class="ev-search-dropdown" id="editDropdown-<%= ev.id %>"></ul>
                      </div>
                      <div id="editMapContainer-<%= ev.id %>" class="ev-map-container">
                        <div id="editMap-<%= ev.id %>" class="ev-map" data-lat="<%= ev.lat || '' %>" data-lng="<%= ev.lng || '' %>">
                          <% if (!ev.lat || !ev.lng) { %>
                          <div class="ev-map-overlay" id="editMapOverlay-<%= ev.id %>">📍 Haz clic para fijar la ubicación</div>
                          <% } %>
                        </div>
                      </div>
                      <p class="ev-map-hint">Busca una dirección arriba o haz clic en el mapa para fijar la ubicación exacta.</p>
                    </div>
                  </div>
                  <div class="crm-form-actions">
                    <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
                    <button class="btn btn-ghost btn-sm" type="button" onclick="toggleEvEdit('<%= ev.id %>')">Cancelar</button>
                  </div>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<style>
.hidden-card { display: none !important; }
.ev-category-selector { }
.ev-cat-tabs { display: flex; gap: 8px; }
.ev-cat-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 16px; border-radius: 8px; border: 2px solid #e4e4e7;
  background: #fff; cursor: pointer; font-size: .85rem; font-weight: 600;
  color: #52525b; transition: all .15s;
}
.ev-cat-btn.active[data-cat="club"] { border-color: #3b82f6; background: #eff6ff; color: #1d4ed8; }
.ev-cat-btn.active[data-cat="taller"] { border-color: #f59e0b; background: #fffbeb; color: #92400e; }
.ev-cat-btn:hover { border-color: #a1a1aa; }

.ev-map-container { margin-top: 8px; border-radius: 10px; overflow: hidden; border: 1px solid #e4e4e7; }
.ev-map { height: 260px; width: 100%; background: #f4f4f5; }
.ev-map-hint { font-size: .75rem; color: #71717a; margin: 4px 0 0; }

.ev-map-overlay {
  position: absolute; inset: 0; z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.55); backdrop-filter: blur(2px);
  font-size: .85rem; font-weight: 600; color: #3b82f6;
  pointer-events: none; border-radius: 10px;
  transition: opacity .2s;
}
.ev-map-overlay.hidden { opacity: 0; pointer-events: none; }

.ev-search-wrap { position: relative; }
.ev-search-wrap input { width: 100%; }
.ev-search-dropdown {
  display: none; position: absolute; top: 100%; left: 0; right: 0; z-index: 1000;
  background: #fff; border: 1px solid #e4e4e7; border-top: none;
  border-radius: 0 0 8px 8px; margin: 0; padding: 0; list-style: none;
  box-shadow: 0 4px 12px rgba(0,0,0,.1); max-height: 220px; overflow-y: auto;
}
.ev-search-dropdown.open { display: block; }
.ev-search-dropdown li {
  padding: 9px 12px; font-size: .82rem; color: #18181b; cursor: pointer;
  border-bottom: 1px solid #f4f4f5; line-height: 1.35;
}
.ev-search-dropdown li:last-child { border-bottom: none; }
.ev-search-dropdown li:hover { background: #f4f4f5; }
.ev-search-dropdown li.ev-search-msg { color: #71717a; cursor: default; }
.ev-search-dropdown li.ev-search-msg:hover { background: none; }
</style>

<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js"></script>
<script>
const BOGOTA = [4.711, -74.0721];
const maps = {};
const markers = {};

function initMap(mapId, latInputId, lngInputId, locationInputId, initLat, initLng) {
  if (maps[mapId]) {
    maps[mapId].invalidateSize();
    return;
  }
  const el = document.getElementById(mapId);
  if (!el) return;

  const isTouch = L.Browser.touch;
  const map = L.map(mapId, { zoomControl: true, scrollWheelZoom: !isTouch });
  map.setView(initLat && initLng ? [initLat, initLng] : BOGOTA, initLat && initLng ? 15 : 12);

  const primaryTiles = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 19
  });
  const fallbackTiles = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
    maxZoom: 19,
    subdomains: 'abcd'
  });

  let usingFallback = false;
  primaryTiles.addTo(map);
  primaryTiles.on('tileerror', () => {
    if (!usingFallback) {
      usingFallback = true;
      primaryTiles.remove();
      fallbackTiles.addTo(map);
    }
  });

  maps[mapId] = map;

  function hideOverlay() {
    const overlay = document.getElementById(mapId.replace('Map', 'MapOverlay'));
    if (overlay) overlay.classList.add('hidden');
  }

  if (initLat && initLng) {
    const m = L.marker([initLat, initLng], { draggable: true }).addTo(map);
    markers[mapId] = m;
    m.on('dragend', () => {
      const p = m.getLatLng();
      document.getElementById(latInputId).value = p.lat.toFixed(6);
      document.getElementById(lngInputId).value = p.lng.toFixed(6);
      reverseGeocode(p.lat, p.lng, locationInputId);
    });
  }

  map.on('click', e => {
    const { lat, lng } = e.latlng;
    document.getElementById(latInputId).value = lat.toFixed(6);
    document.getElementById(lngInputId).value = lng.toFixed(6);
    reverseGeocode(lat, lng, locationInputId);
    hideOverlay();
    if (markers[mapId]) {
      markers[mapId].setLatLng(e.latlng);
    } else {
      const m = L.marker(e.latlng, { draggable: true }).addTo(map);
      markers[mapId] = m;
      m.on('dragend', () => {
        const p = m.getLatLng();
        document.getElementById(latInputId).value = p.lat.toFixed(6);
        document.getElementById(lngInputId).value = p.lng.toFixed(6);
        reverseGeocode(p.lat, p.lng, locationInputId);
      });
    }
  });

  requestAnimationFrame(() => map.invalidateSize());
}

function showMapWhenVisible(mapId, latInputId, lngInputId, locationInputId, initLat, initLng) {
  const el = document.getElementById(mapId);
  if (!el) return;
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      initMap(mapId, latInputId, lngInputId, locationInputId, initLat, initLng);
    });
  });
}

const _searchTimers = {};

function searchLocation(prefix, value) {
  const isCreate = prefix === 'create';
  const evId = isCreate ? '' : prefix.replace('edit-', '');
  const dropdownId = isCreate ? 'createDropdown' : `editDropdown-${evId}`;
  const mapId = isCreate ? 'createMap' : `editMap-${evId}`;
  const latInputId = isCreate ? 'createLat' : `editLat-${evId}`;
  const lngInputId = isCreate ? 'createLng' : `editLng-${evId}`;
  const locationInputId = isCreate ? 'createLocation' : `editLocation-${evId}`;

  const dropdown = document.getElementById(dropdownId);
  if (!dropdown) return;

  const q = (value || '').trim();
  clearTimeout(_searchTimers[prefix]);

  if (q.length < 3) {
    dropdown.innerHTML = '';
    dropdown.classList.remove('open');
    return;
  }

  _searchTimers[prefix] = setTimeout(async () => {
    dropdown.innerHTML = '<li class="ev-search-msg">Buscando…</li>';
    dropdown.classList.add('open');
    try {
      const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=5&countrycodes=co&accept-language=es`;
      const res = await fetch(url, { headers: { 'Accept-Language': 'es' } });
      const results = await res.json();

      if (!results.length) {
        dropdown.innerHTML = '<li class="ev-search-msg">Sin resultados.</li>';
        return;
      }

      dropdown.innerHTML = '';
      results.forEach(r => {
        const li = document.createElement('li');
        const label = r.display_name.split(',').slice(0, 3).join(', ').trim();
        li.textContent = label;
        li.title = r.display_name;
        li.addEventListener('mousedown', e => {
          e.preventDefault();
          const lat = parseFloat(r.lat);
          const lng = parseFloat(r.lon);
          document.getElementById(locationInputId).value = label;
          document.getElementById(latInputId).value = lat.toFixed(6);
          document.getElementById(lngInputId).value = lng.toFixed(6);
          dropdown.innerHTML = '';
          dropdown.classList.remove('open');
          const overlayId = isCreate ? 'createMapOverlay' : `editMapOverlay-${evId}`;
          const overlay = document.getElementById(overlayId);
          if (overlay) overlay.classList.add('hidden');

          if (maps[mapId]) {
            maps[mapId].setView([lat, lng], 15);
            if (markers[mapId]) {
              markers[mapId].setLatLng([lat, lng]);
            } else {
              const m = L.marker([lat, lng], { draggable: true }).addTo(maps[mapId]);
              markers[mapId] = m;
              m.on('dragend', () => {
                const p = m.getLatLng();
                document.getElementById(latInputId).value = p.lat.toFixed(6);
                document.getElementById(lngInputId).value = p.lng.toFixed(6);
                reverseGeocode(p.lat, p.lng, locationInputId);
              });
            }
          }
        });
        dropdown.appendChild(li);
      });
    } catch {
      dropdown.innerHTML = '<li class="ev-search-msg">Error al buscar. Intenta de nuevo.</li>';
    }
  }, 350);
}

document.addEventListener('click', e => {
  document.querySelectorAll('.ev-search-dropdown.open').forEach(d => {
    if (!d.closest('.ev-search-wrap').contains(e.target)) {
      d.classList.remove('open');
    }
  });
});

async function reverseGeocode(lat, lng, inputId) {
  try {
    const r = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&accept-language=es`, { headers: { 'Accept-Language': 'es' } });
    const data = await r.json();
    if (data && data.display_name) {
      const el = document.getElementById(inputId);
      if (el && !el.dataset.userEdited) el.value = data.display_name.split(',').slice(0, 3).join(',').trim();
    }
  } catch {}
}

function selectCategory(prefix, cat) {
  const id = prefix === 'create' ? '' : prefix.replace('edit-', '');
  const tabs = document.getElementById(prefix === 'create' ? 'createCatTabs' : `editCatTabs-${id}`);
  if (!tabs) return;
  tabs.querySelectorAll('.ev-cat-btn').forEach(b => b.classList.toggle('active', b.dataset.cat === cat));

  const catInput = document.getElementById(prefix === 'create' ? 'createCategory' : `editCategory-${id}`);
  if (catInput) catInput.value = cat;

  const typeSelect = document.getElementById(prefix === 'create' ? 'createType' : `editType-${id}`);
  if (!typeSelect) return;

  if (cat === 'taller') {
    typeSelect.innerHTML = `
      <option value="descuento">💰 Descuento</option>
      <option value="beneficio">🎁 Beneficio</option>
      <option value="oportunidad">⚡ Oportunidad única</option>`;
  } else {
    typeSelect.innerHTML = `
      <option value="rodada">🏍️ Rodada (+30 pts)</option>
      <option value="encuentro">⚽ Encuentro (+25 pts)</option>
      <option value="caminata">🥾 Caminata (+25 pts)</option>
      <option value="actividad">🎉 Actividad (+25 pts)</option>`;
  }
}

function toggleEvEdit(id) {
  const el = document.getElementById('ev-edit-' + id);
  el.classList.toggle('open');
  if (el.classList.contains('open')) {
    const mapEl = document.getElementById('editMap-' + id);
    if (mapEl) {
      const lat = parseFloat(mapEl.dataset.lat) || null;
      const lng = parseFloat(mapEl.dataset.lng) || null;
      showMapWhenVisible('editMap-' + id, 'editLat-' + id, 'editLng-' + id, 'editLocation-' + id, lat, lng);
    }
  }
}

(function () {
  const btn = document.querySelector('[onclick*="newEventCard"]');
  if (!btn) return;
  btn.addEventListener('click', () => {
    const card = document.getElementById('newEventCard');
    const isNowVisible = !card.classList.contains('hidden-card');
    if (isNowVisible) {
      showMapWhenVisible('createMap', 'createLat', 'createLng', 'createLocation', null, null);
    }
  });
})();
</script>

