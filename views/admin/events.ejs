<%- include('../partials/head', { title: 'Admin — Eventos' }) %>
<main class="container section">
  <h1 class="section-title">Eventos del Club</h1>

  <section class="card stack">
    <h3>Crear evento</h3>
    <form class="stack" method="post" action="/admin/eventos/crear">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Título<input name="title" required /></label>
      <div class="grid two">
        <label>Fecha<input type="date" name="date" required /></label>
        <label>
          Tipo
          <select name="type">
            <option value="evento">Evento del club (+25 pts)</option>
            <option value="rodada">Rodada (+30 pts)</option>
          </select>
        </label>
      </div>
      <label>Lugar (opcional)<input name="location" /></label>
      <label>Descripción<textarea name="description" rows="3"></textarea></label>
      <button class="btn btn-primary" type="submit">Crear</button>
    </form>
  </section>

  <section class="section">
    <h3>Lista de eventos</h3>
    <div class="grid three">
      <% events.forEach(ev => { %>
        <article class="card stack">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
            <h4 class="tight" style="margin:0"><%= ev.title %></h4>
            <% if (ev.type === 'rodada') { %>
              <span class="chip" style="background:#e0f2fe;color:#0891b2;font-size:.75em">🏍️ Rodada</span>
            <% } else { %>
              <span class="chip" style="background:#ede9fe;color:#7c3aed;font-size:.75em">🎉 Evento</span>
            <% } %>
          </div>
          <div class="muted"><%= ev.date %><% if (ev.location) { %> · <%= ev.location %><% } %></div>
          <p><%= ev.description %></p>

          <a class="btn btn-sm btn-outline" href="/admin/eventos/<%= ev.id %>/asistencias">Ver asistencias</a>

          <div class="row gap" style="margin-top:8px">
            <form method="post" action="/admin/eventos/actualizar" class="stack compact">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="id" value="<%= ev.id %>" />
              <input name="title" value="<%= ev.title %>" />
              <input type="date" name="date" value="<%= ev.date %>" />
              <input name="location" value="<%= ev.location || '' %>" placeholder="Lugar" />
              <select name="type">
                <option value="evento" <%= ev.type !== 'rodada' ? 'selected' : '' %>>Evento (+25 pts)</option>
                <option value="rodada" <%= ev.type === 'rodada' ? 'selected' : '' %>>Rodada (+30 pts)</option>
              </select>
              <textarea name="description" rows="2"><%= ev.description %></textarea>
              <button class="btn" type="submit">Actualizar</button>
            </form>
            <form method="post" action="/admin/eventos/eliminar" data-confirm="¿Eliminar este evento?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="id" value="<%= ev.id %>" />
              <button class="btn btn-danger" type="submit">Eliminar</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
