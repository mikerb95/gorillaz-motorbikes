<%- include('../partials/admin-head', { title: 'Órdenes de Servicio' }) %>

<%
const STATUS = {
  ingreso_taller:   { label: 'Ingreso a taller',  cls: 'badge-warning' },
  trabajo_en_curso: { label: 'Trabajo en curso',  cls: 'badge-info'    },
  en_pausa:         { label: 'En pausa',           cls: 'badge-warning' },
  trabajo_completo: { label: 'Trabajo completo',  cls: 'badge-success' },
  entregado:        { label: 'Entregado',          cls: 'badge-success' },
  facturado:        { label: 'Facturado',          cls: 'badge-success' },
};
const counts = { ingreso_taller: 0, trabajo_en_curso: 0, en_pausa: 0, trabajo_completo: 0, entregado: 0 };
orders.forEach(o => { if (counts[o.status] !== undefined) counts[o.status]++; });
%>

<div class="crm-page-header">
  <div></div>
  <a class="btn btn-primary btn-sm" href="/admin/ordenes-servicio/nueva">+ Nueva orden</a>
</div>

<div class="crm-kpi-row" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px">
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.ingreso_taller %></div><div class="crm-kpi-label">Ingreso a taller</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.trabajo_en_curso %></div><div class="crm-kpi-label">Trabajo en curso</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.en_pausa %></div><div class="crm-kpi-label">En pausa</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.trabajo_completo %></div><div class="crm-kpi-label">Trabajo completo</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.entregado %></div><div class="crm-kpi-label">Entregados</div></div>
</div>

<div class="crm-card">
  <% if (orders.length === 0) { %>
    <p class="muted" style="padding:32px;text-align:center">No hay órdenes de servicio aún. Crea una con <a href="/admin/ordenes-servicio/nueva" style="color:var(--brand);font-weight:700">+ Nueva orden</a> o desde el detalle de una cotización.</p>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr>
          <th>N° Orden</th>
          <th>Fecha</th>
          <th>Moto / Placa</th>
          <th>Mecánico</th>
          <th>Ítems</th>
          <th>Total</th>
          <th>Entrega est.</th>
          <th>Estado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => {
          const st = STATUS[o.status] || { label: o.status, cls: 'badge-warning' };
        %>
        <tr>
          <td><span class="badge badge-info" style="font-weight:900;font-size:.8rem"><%= o.label %></span></td>
          <td class="muted" style="font-size:.82rem;white-space:nowrap">
            <%= fechaCO(o.createdAt, { day:'2-digit', month:'short', year:'numeric' }) %>
          </td>
          <td style="font-weight:700;font-size:.85rem"><%= o.motorcycle || '—' %></td>
          <td style="font-size:.85rem"><% if (o.mechanic) { %><%= o.mechanic %><% } else { %><span class="muted">Sin asignar</span><% } %></td>
          <td style="font-size:.85rem">
            <% o.items.slice(0,2).forEach(it => { %><div><%= it.qty %>× <%= it.name %></div><% }) %>
            <% if (o.items.length > 2) { %><span class="muted">+<%= o.items.length-2 %> más</span><% } %>
          </td>
          <td><strong>$<%= o.total.toLocaleString('es-CO') %></strong></td>
          <td class="muted" style="font-size:.82rem"><%= o.estimatedDate || '—' %></td>
          <td>
            <span class="badge <%= st.cls %>"><%= st.label %></span>
            <% if (o.pendingReview) { %>
              <span class="badge badge-success" style="display:block;margin-top:4px;font-size:.7rem">✅ Listo para revisar</span>
            <% } %>
          </td>
          <td><a class="btn btn-ghost btn-sm" href="/admin/ordenes-servicio/<%= o.id %>">Ver</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
