<%- include('../partials/admin-head', { title: 'Órdenes de Servicio' }) %>

<%
const STATUS = {
  pendiente:  { label: 'Pendiente',   cls: 'badge-warning' },
  en_proceso: { label: 'En proceso',  cls: 'badge-info'    },
  completado: { label: 'Completado',  cls: 'badge-success' },
  facturado:  { label: 'Facturado',   cls: 'badge-success' },
};
const counts = { pendiente: 0, en_proceso: 0, completado: 0, facturado: 0 };
orders.forEach(o => { if (counts[o.status] !== undefined) counts[o.status]++; });
%>

<div class="crm-page-header">
  <h1 class="crm-page-title">Órdenes de Servicio</h1>
</div>

<div class="crm-kpi-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:20px">
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.pendiente %></div><div class="crm-kpi-label">Pendientes</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.en_proceso %></div><div class="crm-kpi-label">En proceso</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.completado %></div><div class="crm-kpi-label">Completadas</div></div>
  <div class="crm-kpi-card" style="cursor:default"><div class="crm-kpi-value"><%= counts.facturado %></div><div class="crm-kpi-label">Facturadas</div></div>
</div>

<div class="crm-card">
  <% if (orders.length === 0) { %>
    <p class="muted" style="padding:32px;text-align:center">No hay órdenes de servicio aún. Crea una desde el detalle de una cotización.</p>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr>
          <th>N° Orden</th>
          <th>Fecha</th>
          <th>Moto / Placa</th>
          <th>Mecánico</th>
          <th>Ítems</th>
          <th>Total</th>
          <th>Entrega est.</th>
          <th>Estado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => {
          const st = STATUS[o.status] || { label: o.status, cls: 'badge-warning' };
        %>
        <tr>
          <td><span class="badge badge-info" style="font-weight:900;font-size:.8rem"><%= o.label %></span></td>
          <td class="muted" style="font-size:.82rem;white-space:nowrap">
            <%= new Date(o.createdAt).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' }) %>
          </td>
          <td style="font-weight:700;font-size:.85rem"><%= o.motorcycle || '—' %></td>
          <td style="font-size:.85rem"><% if (o.mechanic) { %><%= o.mechanic %><% } else { %><span class="muted">Sin asignar</span><% } %></td>
          <td style="font-size:.85rem">
            <% o.items.slice(0,2).forEach(it => { %><div><%= it.qty %>× <%= it.name %></div><% }) %>
            <% if (o.items.length > 2) { %><span class="muted">+<%= o.items.length-2 %> más</span><% } %>
          </td>
          <td><strong>$<%= o.total.toLocaleString('es-CO') %></strong></td>
          <td class="muted" style="font-size:.82rem"><%= o.estimatedDate || '—' %></td>
          <td><span class="badge <%= st.cls %>"><%= st.label %></span></td>
          <td><a class="btn btn-ghost btn-sm" href="/admin/ordenes-servicio/<%= o.id %>">Ver</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
