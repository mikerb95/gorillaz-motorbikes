<%- include('../partials/admin-head', { title: 'Factura ' + invoice.label }) %>

<%
const PAYMENT_OPTS = ['efectivo','nequi','daviplata','tarjeta','transferencia'];
const STATUS_OPTS  = [{v:'pendiente',l:'Pendiente'},{v:'pagada',l:'Pagada'},{v:'anulada',l:'Anulada'}];
const STATUS_LABEL = { pendiente:'Pendiente', pagada:'Pagada', anulada:'Anulada', proforma:'Proforma' };
const STATUS_CLS   = { pendiente:'badge-warning', pagada:'badge-success', anulada:'badge-danger', proforma:'badge-warning' };
const isProforma = invoice.status === 'proforma';
%>

<div class="crm-page-header" style="flex-wrap:wrap;gap:10px">
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
    <a class="btn btn-ghost btn-sm" href="/admin/facturas">← Facturas</a>
    <span class="badge <%= STATUS_CLS[invoice.status] %>"><%= STATUS_LABEL[invoice.status] || invoice.status %></span>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="btn btn-ghost btn-sm" id="btnPdf">Descargar PDF</button>
    <% if (invoice.status !== 'anulada') { %>
      <button class="btn btn-sm" id="btnWa" style="background:#25D366;color:#fff;border-color:#25D366">Enviar por WhatsApp</button>
    <% } %>
  </div>
</div>

<% if (isProforma) { %>
<div style="max-width:860px;margin-bottom:16px;padding:14px 18px;background:#fffbeb;border:1px solid #fde68a;border-radius:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
  <span style="font-size:20px">🧾</span>
  <div style="font-size:13px;color:#92400e;font-weight:700">
    Esta es una <strong>factura proforma</strong>: el total todavía no incluye parqueadero y no se puede marcar como pagada.
    Puedes enviarla igual como documento preliminar; se cierra definitivamente desde la orden de servicio al entregar la moto.
    <% if (order) { %><a href="/admin/ordenes-servicio/<%= order.id %>" style="color:#92400e;text-decoration:underline">Ir a la orden →</a><% } %>
  </div>
</div>
<% } %>

<div style="display:grid;gap:16px;max-width:860px">

  <!-- Cabecera -->
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:13px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px">Información</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px">
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Fecha</div>
        <div style="font-weight:700;font-size:13px"><%= fechaCO(invoice.createdAt, {day:'2-digit',month:'long',year:'numeric'}) %></div>
      </div>
      <% if (order) { %>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Orden de servicio</div>
        <div style="font-weight:700;font-size:13px"><a href="/admin/ordenes-servicio/<%= order.id %>" style="color:var(--brand)"><%= order.label %></a></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Moto / Placa</div>
        <div style="font-weight:800;font-size:14px"><%= order.motorcycle || '—' %></div>
      </div>
      <% if (order.clientPhone) { %>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Cliente (WA)</div>
        <div style="font-weight:700;font-size:13px"><%= order.clientPhoneCountry %> <%= order.clientPhone %></div>
      </div>
      <% } %>
      <% } %>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Método de pago</div>
        <div style="font-weight:700;font-size:13px;text-transform:capitalize"><%= invoice.paymentMethod %></div>
      </div>
    </div>
    <% if (invoice.notes) { %>
    <div style="margin-top:14px;padding-top:14px;border-top:1px solid #f3f4f6">
      <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Notas</div>
      <div style="font-size:13px;color:#374151"><%= invoice.notes %></div>
    </div>
    <% } %>
  </div>

  <!-- Ítems -->
  <div class="crm-card" style="padding:20px 24px">
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead><tr><th>Ítem</th><th style="text-align:center">Cant.</th><th style="text-align:right">Precio unit.</th><th style="text-align:right">Subtotal</th></tr></thead>
        <tbody>
          <% invoice.items.forEach(it => { %>
          <tr>
            <td style="font-weight:700"><%= it.name %></td>
            <td style="text-align:center;font-weight:700"><%= it.qty %></td>
            <td style="text-align:right">$<%= Number(it.price).toLocaleString('es-CO') %></td>
            <td style="text-align:right;font-weight:800;color:var(--brand)">$<%= (it.price*it.qty).toLocaleString('es-CO') %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" style="text-align:right;font-weight:700;padding:10px;font-size:13px;color:#6b7280">SUBTOTAL</td>
            <td style="text-align:right;font-weight:800;padding:10px">$<%= invoice.subtotal.toLocaleString('es-CO') %></td>
          </tr>
          <% if (invoice.tax > 0) { %>
          <tr>
            <td colspan="3" style="text-align:right;font-weight:700;padding:10px;font-size:13px;color:#6b7280">IVA</td>
            <td style="text-align:right;font-weight:800;padding:10px">$<%= invoice.tax.toLocaleString('es-CO') %></td>
          </tr>
          <% } %>
          <% if (invoice.parkingAmount > 0) { %>
          <tr>
            <td colspan="3" style="text-align:right;font-weight:700;padding:10px;font-size:13px;color:#6b7280">Parqueadero</td>
            <td style="text-align:right;font-weight:800;padding:10px">$<%= invoice.parkingAmount.toLocaleString('es-CO') %></td>
          </tr>
          <% } %>
          <tr style="background:#f9fafb">
            <td colspan="3" style="text-align:right;font-weight:900;padding:12px 10px;font-size:14px">TOTAL</td>
            <td style="text-align:right;font-weight:900;font-size:20px;color:var(--brand);padding:12px 10px">$<%= invoice.total.toLocaleString('es-CO') %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Cambiar estado / método de pago -->
  <% if (invoice.status !== 'anulada' && !isProforma) { %>
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:13px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px">Actualizar pago</h2>
    <form method="post" action="/admin/facturas/<%= invoice.id %>/estado" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end" data-require-pin data-pin-title="Autoriza el cambio de estado" data-pin-msg="Ingresa tu PIN para cambiar el estado de la factura (pagada/anulada).">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div>
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Estado</label>
        <select name="status" style="padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none">
          <% STATUS_OPTS.forEach(s=>{%><option value="<%= s.v %>"<%= invoice.status===s.v?' selected':'' %>><%= s.l %></option><%})%>
        </select>
      </div>
      <div>
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Método de pago</label>
        <select name="paymentMethod" style="padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none">
          <% PAYMENT_OPTS.forEach(p=>{%><option value="<%= p %>"<%= invoice.paymentMethod===p?' selected':'' %> style="text-transform:capitalize"><%= p %></option><%})%>
        </select>
      </div>
      <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
    </form>
  </div>
  <% } %>

  <!-- Anular proforma: única acción de estado permitida antes de la entrega -->
  <% if (isProforma) { %>
  <div class="crm-card" style="padding:20px 24px;border:1px solid #fecaca;background:#fef2f2">
    <h2 style="font-size:13px;font-weight:800;color:#b91c1c;text-transform:uppercase;letter-spacing:.5px;margin:0 0 8px">Anular proforma</h2>
    <p style="margin:0 0 12px;font-size:13px;color:#7f1d1d">Si la orden se canceló antes de entregar la moto, anula esta proforma. La orden vuelve a «Trabajo completo» y queda editable.</p>
    <form method="post" action="/admin/facturas/<%= invoice.id %>/estado" data-require-pin data-pin-title="Autoriza la anulación" data-pin-msg="Ingresa tu PIN para anular esta factura proforma.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="status" value="anulada" />
      <button class="btn btn-sm" type="submit" style="background:#dc2626;color:#fff;border:none">Anular proforma</button>
    </form>
  </div>
  <% } %>

</div>

<!-- jsPDF -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
(function(){
  const INV   = <%- JSON.stringify({ id: invoice.id, label: invoice.label, createdAt: invoice.createdAt, items: invoice.items, subtotal: invoice.subtotal, tax: invoice.tax, parkingAmount: invoice.parkingAmount, total: invoice.total, paymentMethod: invoice.paymentMethod, notes: invoice.notes, isProforma: isProforma }) %>;
  const ORDER = <%- JSON.stringify(order ? { label: order.label, motorcycle: order.motorcycle, clientPhone: order.clientPhone, clientPhoneCountry: order.clientPhoneCountry } : null) %>;

  document.getElementById('btnPdf').addEventListener('click', () => {
    if (typeof window.jspdf === 'undefined') { alert('PDF cargando, intenta en un momento.'); return; }
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'mm', format: 'a4' });

    doc.setFillColor(242,92,5); doc.rect(0,0,210,28,'F');
    doc.setTextColor(255,255,255); doc.setFontSize(18); doc.setFont('helvetica','bold');
    doc.text('GORILLAZ MOTORBIKES',14,12);
    doc.setFontSize(9); doc.setFont('helvetica','normal');
    doc.text('gorillazmotorbikes.com  |  Bogotá, Colombia',14,20);
    const dateStr = new Date(INV.createdAt).toLocaleDateString('es-CO',{year:'numeric',month:'long',day:'numeric',timeZone:'America/Bogota'});
    doc.text('Fecha: '+dateStr,196,12,{align:'right'});
    doc.text('FACTURA N° '+INV.label,196,20,{align:'right'});

    doc.setTextColor(17,17,17); doc.setFontSize(14); doc.setFont('helvetica','bold');
    doc.text(INV.isProforma ? 'FACTURA PROFORMA (preliminar)' : 'FACTURA DE SERVICIO',14,40);
    if (ORDER) {
      doc.setFontSize(10); doc.setFont('helvetica','normal'); doc.setTextColor(107,114,128);
      const infoLine = [ORDER.motorcycle && 'Moto: '+ORDER.motorcycle, ORDER.clientPhone && 'Tel: '+(ORDER.clientPhoneCountry||'+57')+' '+ORDER.clientPhone].filter(Boolean).join('   |   ');
      if (infoLine) doc.text(infoLine,14,47);
    }

    let y = ORDER ? 57 : 50;
    doc.setFillColor(245,245,245); doc.rect(14,y-6,182,9,'F');
    doc.setFontSize(9); doc.setFont('helvetica','bold'); doc.setTextColor(107,114,128);
    doc.text('ÍTEM',16,y); doc.text('CANT.',126,y,{align:'center'}); doc.text('PRECIO UNIT.',158,y,{align:'right'}); doc.text('SUBTOTAL',196,y,{align:'right'});
    y+=6; doc.setDrawColor(229,231,235); doc.setLineWidth(0.3); doc.line(14,y,196,y);

    doc.setFontSize(10); doc.setTextColor(17,17,17);
    INV.items.forEach((it,idx)=>{
      y+=8;
      if(idx%2===1){doc.setFillColor(250,250,250);doc.rect(14,y-5.5,182,8,'F');}
      doc.setFont('helvetica','normal'); doc.text(it.name,16,y);
      doc.text(String(it.qty),126,y,{align:'center'});
      doc.text(Number(it.price).toLocaleString('es-CO'),158,y,{align:'right'});
      doc.setFont('helvetica','bold'); doc.text((it.price*it.qty).toLocaleString('es-CO'),196,y,{align:'right'});
    });

    y+=10;
    doc.setFont('helvetica','normal'); doc.setFontSize(10);
    if(INV.tax>0 || INV.parkingAmount>0){
      doc.text('Subtotal:',148,y,{align:'right'}); doc.text('$'+INV.subtotal.toLocaleString('es-CO'),196,y,{align:'right'}); y+=7;
      if(INV.tax>0){ doc.text('IVA:',148,y,{align:'right'}); doc.text('$'+INV.tax.toLocaleString('es-CO'),196,y,{align:'right'}); y+=7; }
      if(INV.parkingAmount>0){ doc.text('Parqueadero:',148,y,{align:'right'}); doc.text('$'+INV.parkingAmount.toLocaleString('es-CO'),196,y,{align:'right'}); y+=5; }
    }
    doc.setFillColor(242,92,5); doc.rect(120,y-6,76,11,'F');
    doc.setTextColor(255,255,255); doc.setFontSize(11); doc.setFont('helvetica','bold');
    doc.text('TOTAL:',128,y); doc.text('COP '+INV.total.toLocaleString('es-CO'),196,y,{align:'right'});

    y+=14; doc.setTextColor(107,114,128); doc.setFont('helvetica','normal'); doc.setFontSize(9);
    if (INV.isProforma) {
      doc.text('Documento preliminar: el total puede variar por cobro de parqueadero al entregar la moto.',14,y);
    } else {
      doc.text('Método de pago: '+INV.paymentMethod.charAt(0).toUpperCase()+INV.paymentMethod.slice(1),14,y);
    }
    if(INV.notes){y+=7; doc.text('Nota: '+INV.notes,14,y);}

    doc.setFontSize(8); doc.text('Gorillaz Motorbikes — Bogotá, Colombia',14,285); doc.text('gorillazmotorbikes.com',196,285,{align:'right'});
    doc.save('factura-'+INV.label+'.pdf');
  });

  // ── Enviar por WhatsApp ──────────────────────────────────────────────
  const btnWa = document.getElementById('btnWa');
  if (btnWa) {
    btnWa.addEventListener('click', async () => {
      let digits = (ORDER && ORDER.clientPhone ? String(ORDER.clientPhone) : '').replace(/\D/g, '');
      let country = (ORDER && ORDER.clientPhoneCountry) || '+57';
      let enteredManually = false;
      if (!digits) {
        const input = prompt('Número de WhatsApp del cliente (con indicativo, ej: +57 300 1234567):', '+57 ');
        if (input === null) return;
        const raw = input.trim();
        const m = raw.match(/^\+(\d{1,3})/);
        if (m) { country = '+' + m[1]; digits = raw.replace(/\D/g, '').slice(m[1].length); }
        else  { digits = raw.replace(/\D/g, ''); }
        enteredManually = true;
      }
      if (digits.length < 7) { alert('Número de WhatsApp inválido.'); return; }

      // Persistir el número en la orden cuando se ingresa a mano (igual que el liquidador).
      if (enteredManually) {
        try {
          const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
          const res = await fetch('/admin/facturas/' + INV.id + '/telefono', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
            body: JSON.stringify({ clientPhone: digits, clientPhoneCountry: country }),
          });
          if (!res.ok) throw new Error('HTTP ' + res.status);
        } catch {
          alert('No se pudo guardar el número en la orden. Anótalo manualmente.');
        }
      }

      const link = window.location.origin + '/factura/' + INV.id;
      const lines = [
        '🧾 *Factura Gorillaz Motorbikes*',
        'N° ' + INV.label,
      ];
      if (ORDER && ORDER.motorcycle) lines.push('🏍️ ' + ORDER.motorcycle);
      lines.push('');
      INV.items.forEach(it => lines.push('• ' + it.name + ' ×' + it.qty + ' — $' + (it.price * it.qty).toLocaleString('es-CO')));
      lines.push('');
      if (INV.tax > 0 || INV.parkingAmount > 0) {
        lines.push('Subtotal: $' + INV.subtotal.toLocaleString('es-CO'));
        if (INV.tax > 0) lines.push('IVA: $' + INV.tax.toLocaleString('es-CO'));
        if (INV.parkingAmount > 0) lines.push('Parqueadero: $' + INV.parkingAmount.toLocaleString('es-CO'));
      }
      lines.push('*Total: $' + INV.total.toLocaleString('es-CO') + '*');
      lines.push('Pago: ' + INV.paymentMethod.charAt(0).toUpperCase() + INV.paymentMethod.slice(1));
      lines.push('');
      lines.push('📄 *Ver factura y descargar PDF:*');
      lines.push(link);
      lines.push('');
      lines.push('gorillazmotorbikes.com');

      const url = 'https://wa.me/' + country.replace('+', '') + digits + '?text=' + encodeURIComponent(lines.join('\n'));
      window.open(url, '_blank', 'noopener,noreferrer');
    });
  }
})();
</script>

<%- include('../partials/admin-foot') %>
