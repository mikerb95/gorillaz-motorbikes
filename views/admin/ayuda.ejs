</div><!-- /tab-cliente -->

<script>
  function toggleSection(header) {
    const body = header.nextElementSibling;
    const isOpen = header.classList.contains('open');
    header.classList.toggle('open', !isOpen);
    body.classList.toggle('open', !isOpen);
  }

  document.getElementById('helpTabs').addEventListener('click', function(e) {
    const btn = e.target.closest('.help-tab-btn');
    if (!btn) return;
    const tab = btn.dataset.tab;
    document.querySelectorAll('.help-tab-btn').forEach(b => b.classList.toggle('active', b === btn));
    document.querySelectorAll('.help-panel').forEach(p => p.classList.toggle('active', p.id === 'tab-' + tab));
  });
</script>

