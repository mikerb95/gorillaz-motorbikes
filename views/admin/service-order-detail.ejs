<%- include('../partials/admin-head', { title: 'Orden ' + order.label }) %>

<%
// 'facturado' y 'entregado' no son editables a mano en el selector: el primero
// se alcanza solo al generarse la factura proforma (automático), el segundo
// solo desde el formulario dedicado de entrega (que cierra esa factura).
const STATUS_OPTS = [
  { v: 'ingreso_taller',   l: 'Ingreso a taller'  },
  { v: 'trabajo_en_curso', l: 'Trabajo en curso'  },
  { v: 'en_pausa',         l: 'En pausa'          },
  { v: 'trabajo_completo', l: 'Trabajo completo'  },
];
const STATUS_ALL_LABELS = { ingreso_taller:'Ingreso a taller', trabajo_en_curso:'Trabajo en curso', en_pausa:'En pausa', trabajo_completo:'Trabajo completo', facturado:'Facturado (proforma)', entregado:'Entregado' };
const STATUS_CLS = { ingreso_taller:'badge-warning', trabajo_en_curso:'badge-info', en_pausa:'badge-warning', trabajo_completo:'badge-success', facturado:'badge-success', entregado:'badge-success' };
%>

<div class="crm-page-header" style="flex-wrap:wrap;gap:10px">
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
    <a class="btn btn-ghost btn-sm" href="/admin/ordenes-servicio">← Órdenes</a>
    <span class="badge <%= STATUS_CLS[order.status] || 'badge-warning' %>" style="font-size:.85rem"><%= STATUS_ALL_LABELS[order.status] || order.status %></span>
  </div>
  <% if (order.quotationId) { %>
    <a class="btn btn-ghost btn-sm" href="/admin/cotizaciones/<%= order.quotationId %>">Ver cotización origen →</a>
  <% } %>
</div>

<% if (order.pendingReview) { %>
  <div style="max-width:920px;margin-bottom:16px;padding:14px 18px;background:#ecfdf5;border:1px solid #6ee7b7;border-radius:12px;display:flex;align-items:center;gap:10px">
    <span style="font-size:20px">✅</span>
    <div style="font-size:13px;color:#065f46;font-weight:700">
      Un empleado marcó esta orden como <strong>Trabajo completo</strong>. Ya se generó la factura proforma;
      ya puedes contactar al cliente. El aviso se quita al guardar cambios.
    </div>
  </div>
<% } %>

<div style="display:grid;gap:16px;max-width:920px">

  <!-- Info general -->
  <div class="crm-card" style="padding:20px 24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <h2 style="font-size:13px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:0">Información</h2>
      <button class="btn btn-ghost btn-sm" type="button" data-modal-open="#editOrderModal">✏️ Editar</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:16px">
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Creada</div>
        <div style="font-weight:700;font-size:13px"><%= fechaCO(order.createdAt, {day:'2-digit',month:'short',year:'numeric'}) %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Moto / Placa</div>
        <div style="font-weight:800;font-size:14px"><%= order.motorcycle || '—' %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Cliente (WA)</div>
        <% if (order.clientPhone) { %>
          <div style="font-weight:700;font-size:13px"><%= order.clientPhoneCountry %> <%= order.clientPhone %></div>
          <a href="https://wa.me/<%= (order.clientPhoneCountry||'+57').replace('+','') %><%= order.clientPhone %>" target="_blank" rel="noopener" style="font-size:12px;color:#25D366;font-weight:700">Abrir →</a>
        <% } else { %><div class="muted" style="font-size:13px">—</div><% } %>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Mecánico</div>
        <div style="font-weight:700;font-size:13px"><%= empleadoAsignado ? empleadoAsignado.name : (order.mechanic || '—') %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Entrega estimada</div>
        <div style="font-weight:700;font-size:13px"><%= order.estimatedDate || '—' %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Total</div>
        <div style="font-weight:900;font-size:18px;color:var(--brand)">$<%= order.total.toLocaleString('es-CO') %></div>
      </div>
    </div>
    <% if (order.notes) { %>
      <div style="margin-top:14px;padding-top:14px;border-top:1px solid #f3f4f6">
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Notas</div>
        <div style="font-size:13px;color:#374151"><%= order.notes %></div>
      </div>
    <% } %>
    <% if (invoice && invoice.status === 'proforma') { %>
      <div style="margin-top:14px;padding:10px 14px;background:#fffbeb;border:1px solid #fde68a;border-radius:10px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
        <span style="font-size:13px;font-weight:700;color:#92400e">Factura <strong><%= invoice.label %></strong>: proforma, pendiente de entrega</span>
        <a class="btn btn-ghost btn-sm" href="/admin/facturas/<%= invoice.id %>">Ver proforma →</a>
      </div>
    <% } else if (invoice) { %>
      <div style="margin-top:14px;padding:10px 14px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;display:flex;align-items:center;justify-content:space-between;gap:12px">
        <span style="font-size:13px;font-weight:700;color:#166534">Factura generada: <strong><%= invoice.label %></strong></span>
        <a class="btn btn-ghost btn-sm" href="/admin/facturas/<%= invoice.id %>">Ver factura →</a>
      </div>
    <% } %>
  </div>

  <!-- Trazabilidad -->
  <%
  const STATUS_LABEL = {
    pendiente:'Pendiente', ingreso_taller:'Ingreso a taller', trabajo_en_curso:'Trabajo en curso',
    en_pausa:'En pausa', trabajo_completo:'Trabajo completo', entregado:'Entregado', facturado:'Facturado (proforma)',
    editado:'Orden editada', factura_generada:'Factura proforma generada', factura_anulada:'Factura anulada',
    factura_cerrada:'Factura cerrada al entregar'
  };
  const STATUS_COLOR = {
    pendiente:'#9ca3af', ingreso_taller:'#f59e0b', trabajo_en_curso:'#3b82f6',
    en_pausa:'#f59e0b', trabajo_completo:'#22c55e', entregado:'#16a34a', facturado:'#16a34a',
    editado:'#8b5cf6', factura_generada:'#16a34a', factura_anulada:'#dc2626', factura_cerrada:'#16a34a'
  };
  const STATUS_ICON = { editado:'✏️', factura_generada:'🧾', factura_anulada:'🚫', factura_cerrada:'🔒' };
  // Título de un evento: los hitos de factura anteponen su etiqueta (guardada
  // en detail) para que el historial siga leyéndose aunque la orden ya no esté
  // vinculada a esa factura.
  const eventTitle = e => {
    if (e.status === 'factura_generada') return e.detail ? 'Factura ' + e.detail + ' generada (proforma)' : 'Factura proforma generada';
    if (e.status === 'factura_anulada')  return e.detail ? 'Factura ' + e.detail + ' anulada'  : 'Factura anulada';
    if (e.status === 'factura_cerrada')  return e.detail ? 'Factura ' + e.detail + ' cerrada al entregar' : 'Factura cerrada al entregar';
    return STATUS_LABEL[e.status] || e.status;
  };
  const evs = typeof events !== 'undefined' ? events : [];
  const timeline = [];
  if (quotation) timeline.push({ at: quotation.createdAt, icon:'📝', color:'#6366f1', title:'Cotización ' + quotation.label + ' creada' });
  timeline.push({ at: order.createdAt, icon:'🔧', color:'#0ea5e9', title:'Orden de servicio creada' + (order.quotationId ? ' · desde cotización' : ' · manual') });
  evs.forEach(e => timeline.push({ at: e.createdAt, icon: STATUS_ICON[e.status] || '●', color: STATUS_COLOR[e.status] || '#9ca3af', title: eventTitle(e), actor: e.actor }));
  // Respaldo para órdenes anteriores al registro de eventos: usa el sello de trabajo completado.
  if (evs.length === 0 && order.trabajoCompletoAt) timeline.push({ at: order.trabajoCompletoAt, icon:'●', color:'#22c55e', title:'Trabajo completo' });
  // Respaldo del hito de factura solo para órdenes previas al evento persistente:
  // si ya hay un 'factura_generada' en el historial, no se duplica.
  if (invoice && !evs.some(e => e.status === 'factura_generada')) {
    timeline.push({ at: invoice.createdAt, icon:'🧾', color:'#16a34a', title:'Factura ' + invoice.label + ' generada' });
  }
  timeline.sort((a, b) => new Date(a.at) - new Date(b.at));
  %>
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:13px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:0 0 18px">Trazabilidad</h2>
    <div style="position:relative;padding-left:6px">
      <% timeline.forEach((t, i) => { const last = i === timeline.length - 1; %>
        <div style="position:relative;display:flex;gap:14px;<%= last ? '' : 'padding-bottom:18px' %>">
          <% if (!last) { %><span style="position:absolute;left:12px;top:22px;bottom:0;width:2px;background:#e5e7eb"></span><% } %>
          <span style="flex:0 0 auto;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;background:<%= t.color %>1a;color:<%= t.color %>;border:2px solid <%= t.color %>;z-index:1"><%= t.icon %></span>
          <div style="flex:1;min-width:0;padding-top:2px">
            <div style="font-weight:800;font-size:13.5px;color:#1f2937"><%= t.title %></div>
            <div style="font-size:12px;color:#9ca3af;margin-top:1px">
              <%= fechaHoraCO(t.at) %><% if (t.actor) { %> · por <%= t.actor %><% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <div style="margin-top:6px;padding-top:14px;border-top:1px solid #f3f4f6;display:flex;align-items:center;gap:8px">
      <span style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px">Estado actual</span>
      <span class="badge <%= STATUS_CLS[order.status] || 'badge-warning' %>"><%= STATUS_LABEL[order.status] || order.status %></span>
    </div>
    <% if (evs.length === 0) { %>
      <p style="margin:10px 0 0;font-size:11.5px;color:#9ca3af">El detalle por estado se registra desde ahora; las órdenes anteriores muestran solo los hitos disponibles.</p>
    <% } %>
  </div>

  <!-- Ítems -->
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:13px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px">Ítems (<%= order.items.length %>)</h2>
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead><tr><th>Ítem</th><th>Tipo</th><th style="text-align:center">Cant.</th><th style="text-align:right">Precio unit.</th><th style="text-align:right">Subtotal</th></tr></thead>
        <tbody>
          <% order.items.forEach(it => { %>
          <tr>
            <td style="font-weight:700"><%= it.name %></td>
            <td><span class="badge <%= it.type==='service'?'badge-warning':'badge-success' %>" style="font-size:.75rem"><%= it.type==='service'?'Servicio':it.type==='product'?'Producto':'Custom' %></span></td>
            <td style="text-align:center;font-weight:700"><%= it.qty %></td>
            <td style="text-align:right">$<%= Number(it.price).toLocaleString('es-CO') %></td>
            <td style="text-align:right;font-weight:800;color:var(--brand)">$<%= (it.price*it.qty).toLocaleString('es-CO') %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr><td colspan="4" style="text-align:right;font-weight:800;padding:12px 10px;font-size:13px">TOTAL</td>
          <td style="text-align:right;font-weight:900;font-size:17px;color:var(--brand);padding:12px 10px">$<%= order.total.toLocaleString('es-CO') %></td></tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Actualizar estado -->
  <% if (order.status !== 'facturado' && order.status !== 'entregado') { %>
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:13px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px">Actualizar orden</h2>
    <form method="post" action="/admin/ordenes-servicio/<%= order.id %>/actualizar" data-require-pin data-pin-title="Autoriza el cambio de estado" data-pin-msg="Ingresa tu PIN para registrar y confirmar la actualización de la orden.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:12px">
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Estado</label>
          <select name="status" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none">
            <% STATUS_OPTS.forEach(s => { %><option value="<%= s.v %>"<%= order.status===s.v?' selected':'' %>><%= s.l %></option><% }) %>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Mecánico</label>
          <select name="employeeId" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none">
            <option value="">— Sin asignar —</option>
            <% empleados.forEach(e => { %>
              <option value="<%= e.id %>"<%= order.employeeId === e.id ? ' selected' : '' %>><%= e.name %></option>
            <% }) %>
            <% if (empleadoAsignado && !empleados.some(e => e.id === empleadoAsignado.id)) { %>
              <option value="<%= empleadoAsignado.id %>" selected><%= empleadoAsignado.name %> (inactivo)</option>
            <% } %>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Fecha entrega</label>
          <input type="date" name="estimatedDate" value="<%= order.estimatedDate || '' %>" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
        </div>
      </div>
      <div style="margin-bottom:12px">
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Observaciones</label>
        <textarea name="notes" rows="2" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box"><%= order.notes || '' %></textarea>
      </div>
      <button class="btn btn-primary btn-sm" type="submit">Guardar cambios</button>
    </form>
  </div>
  <% } %>

  <!-- Parqueadero -->
  <% if (order.trabajoCompletoAt) {
    const tcAt        = new Date(order.trabajoCompletoAt);
    const ahora       = new Date();
    const msTotal     = ahora - tcAt;
    const diasTotal   = Math.floor(msTotal / (1000 * 60 * 60 * 24));
    const diasGratis  = parqueaderoConfig.diasGratis;
    const tarifa      = parqueaderoConfig.tarifaPorDia;
    const diasCobro   = Math.max(0, diasTotal - diasGratis);
    const totalParq   = diasCobro * tarifa;
    const diasRestantes = Math.max(0, diasGratis - diasTotal);
    const cobrando    = diasTotal > diasGratis;
  %>
  <div class="crm-card" style="padding:20px 24px;border-left:4px solid <%= cobrando ? '#f59e0b' : '#22c55e' %>">
    <h2 style="font-size:13px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.5px;margin:0 0 12px">
      Parqueadero
    </h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;font-size:13px">
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Trabajo completado</div>
        <div style="font-weight:700"><%= tcAt.toLocaleString('es-CO', { timeZone:'America/Bogota', day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Días en taller</div>
        <div style="font-weight:700"><%= diasTotal %> día<%= diasTotal !== 1 ? 's' : '' %></div>
      </div>
      <% if (!cobrando) { %>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Días gratis restantes</div>
        <div style="font-weight:700;color:#16a34a"><%= diasRestantes %> día<%= diasRestantes !== 1 ? 's' : '' %></div>
      </div>
      <% } else { %>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Días cobrados</div>
        <div style="font-weight:700;color:#d97706"><%= diasCobro %> día<%= diasCobro !== 1 ? 's' : '' %> × $<%= tarifa.toLocaleString('es-CO') %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">Total parqueadero</div>
        <div style="font-weight:900;font-size:16px;color:#b45309">$<%= totalParq.toLocaleString('es-CO') %></div>
      </div>
      <% } %>
    </div>
    <% if (cobrando) { %>
    <p style="margin:10px 0 0;font-size:12px;color:#92400e;background:#fef3c7;border-radius:8px;padding:8px 12px">
      La moto lleva <strong><%= diasCobro %> día<%= diasCobro !== 1 ? 's' : '' %></strong> cobrando parqueadero
      (<%= diasGratis %> día<%= diasGratis !== 1 ? 's' : '' %> gratis agotados).
    </p>
    <% } else { %>
    <p style="margin:10px 0 0;font-size:12px;color:#166534;background:#f0fdf4;border-radius:8px;padding:8px 12px">
      Parqueadero gratuito por <%= diasGratis - diasTotal > 0 ? diasGratis - diasTotal + ' día' + (diasGratis - diasTotal !== 1 ? 's' : '') + ' más' : 'hoy' %>.
    </p>
    <% } %>
  </div>
  <% } %>

  <!-- Recuperación manual: la orden quedó en trabajo_completo sin factura (p. ej. -->
  <!-- se anuló la proforma). En el flujo normal la proforma se genera sola.     -->
  <% if (order.status === 'trabajo_completo' && !order.invoiceId) { %>
  <div class="crm-card" style="padding:20px 24px;border-top:3px solid #22c55e">
    <h2 style="font-size:13px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.5px;margin:0 0 8px">Generar factura proforma</h2>
    <p style="margin:0 0 14px;font-size:12.5px;color:#9ca3af">Esta orden no tiene factura asociada (normalmente se genera sola al quedar «Trabajo completo»). El IVA, el parqueadero y el método de pago se confirman al entregar la moto.</p>
    <form method="post" action="/admin/ordenes-servicio/<%= order.id %>/convertir-factura" data-require-pin data-pin-title="Autoriza la facturación" data-pin-msg="Ingresa tu PIN para emitir la factura de esta orden.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div style="margin-bottom:12px">
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Notas de factura</label>
        <textarea name="notes" rows="2" placeholder="Observaciones, opcional" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box"></textarea>
      </div>
      <button class="btn btn-primary" type="submit">Generar factura proforma →</button>
    </form>
  </div>
  <% } %>

  <!-- Entregar moto: cierra la factura proforma con el parqueadero, IVA y pago -->
  <% if (order.status === 'facturado' && invoice && invoice.status === 'proforma') { %>
  <div class="crm-card" style="padding:20px 24px;border-top:3px solid #22c55e">
    <h2 style="font-size:13px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.5px;margin:0 0 8px">Entregar moto y cerrar factura</h2>
    <p style="margin:0 0 14px;font-size:12.5px;color:#9ca3af">Factura proforma <strong><%= invoice.label %></strong> · subtotal $<%= invoice.subtotal.toLocaleString('es-CO') %>. Al confirmar la entrega se agrega el parqueadero y el IVA, y la factura queda definitiva.</p>
    <form method="post" action="/admin/ordenes-servicio/<%= order.id %>/entregar" id="deliverForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="paidNow" id="paidNowField" value="" />
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:12px">
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Parqueadero (COP)</label>
          <input type="number" name="parkingAmount" id="parkingInput" value="<%= parking.aplica ? parking.totalParq : 0 %>" min="0" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          <span style="font-size:11px;color:#9ca3af;margin-top:3px;display:block"><% if (parking.aplica) { %><%= parking.diasCobro %> día<%= parking.diasCobro !== 1 ? 's' : '' %> × $<%= parking.tarifaPorDia.toLocaleString('es-CO') %> (calculado, editable)<% } else { %>Sin cobro calculado (editable)<% } %></span>
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Método de pago</label>
          <select name="paymentMethod" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none">
            <option value="efectivo">Efectivo</option>
            <option value="nequi">Nequi</option>
            <option value="daviplata">Daviplata</option>
            <option value="tarjeta">Tarjeta</option>
            <option value="transferencia">Transferencia</option>
          </select>
        </div>
      </div>
      <div style="margin-bottom:12px">
        <label style="display:flex;align-items:center;gap:8px;font-size:13px;font-weight:700;color:#374151;cursor:pointer">
          <input type="checkbox" id="ivaToggle" onchange="toggleIva(this)" style="width:16px;height:16px;cursor:pointer" />
          Cobrar IVA (19%)
        </label>
        <div id="ivaField" style="display:none;margin-top:8px;max-width:240px">
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">IVA (COP)</label>
          <input type="number" name="tax" id="ivaInput" value="0" min="0" disabled placeholder="0" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          <span style="font-size:11px;color:#9ca3af;margin-top:3px;display:block">Subtotal: $<%= invoice.subtotal.toLocaleString('es-CO') %></span>
        </div>
      </div>
      <script>
        function toggleIva(cb) {
          var field = document.getElementById('ivaField');
          var input = document.getElementById('ivaInput');
          if (cb.checked) {
            field.style.display = 'block';
            input.disabled = false;
            if (!Number(input.value)) input.value = Math.round(<%= invoice.subtotal %> * 0.19);
          } else {
            field.style.display = 'none';
            input.disabled = true;
            input.value = 0;
          }
        }
      </script>
      <div style="margin-bottom:12px">
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Notas de factura</label>
        <textarea name="notes" rows="2" placeholder="Observaciones finales, garantía, etc." style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box"><%= invoice.notes || '' %></textarea>
      </div>
      <button class="btn btn-primary" type="button" data-modal-open="#payNowModal">Entregar y cerrar factura →</button>
    </form>
  </div>

  <!-- Modal: ¿se pagó al entregar? -->
  <div class="modal" id="payNowModal" aria-hidden="true" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:12px;max-width:440px;width:90%;padding:0">
      <div style="padding:20px 24px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center">
        <h3 style="margin:0;font-size:16px;font-weight:800;color:#374151">💰 Confirmar entrega</h3>
        <button type="button" data-modal-close style="background:none;border:none;font-size:20px;cursor:pointer;color:#6b7280">✕</button>
      </div>
      <div style="padding:20px 24px">
        <p style="margin:0 0 18px;font-size:14px;color:#374151;line-height:1.5">
          ¿El cliente <strong>pagó en este momento</strong>?
          Si confirmas, la factura quedará marcada como <strong>pagada</strong> de una vez.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px">
          <button type="button" id="payYesBtn" class="btn btn-primary"
                  style="background:#16a34a;border-color:#16a34a">Sí, pagó ahora → Factura pagada</button>
          <button type="button" id="payNoBtn" class="btn btn-ghost">No, dejar pendiente</button>
        </div>
      </div>
    </div>
  </div>
  <script>
  (function () {
    var form  = document.getElementById('deliverForm');
    var field = document.getElementById('paidNowField');
    var yes   = document.getElementById('payYesBtn');
    var no    = document.getElementById('payNoBtn');
    if (!form || !field) return;
    if (yes) yes.addEventListener('click', function () { field.value = '1'; form.submit(); });
    if (no)  no.addEventListener('click',  function () { field.value = '0'; form.submit(); });
  })();
  </script>
  <% } %>

  <!-- Zona de peligro -->
  <div class="crm-card" style="padding:20px 24px;border:1px solid #fecaca;background:#fef2f2">
    <h2 style="font-size:13px;font-weight:800;color:#b91c1c;text-transform:uppercase;letter-spacing:.5px;margin:0 0 6px">Zona de peligro</h2>
    <% if (order.invoiceId) { %>
      <p style="margin:0;font-size:13px;color:#7f1d1d">
        Esta orden ya está <strong>facturada</strong> (<%= invoice ? invoice.label : 'factura asociada' %>) y no se puede borrar.
        Si necesitas eliminarla, primero anula la factura.
      </p>
    <% } else { %>
      <p style="margin:0 0 12px;font-size:13px;color:#7f1d1d">
        Borrar esta orden la elimina de forma permanente junto con su historial de trazabilidad. Esta acción no se puede deshacer.
      </p>
      <button type="button" id="openDeleteModal" data-modal-open="#deleteOrderModal" class="btn btn-sm"
              style="background:#dc2626;color:#fff;border:none">🗑 Borrar orden</button>
    <% } %>
  </div>

</div>

<!-- Modal borrar orden -->
<% if (!order.invoiceId) { %>
<div class="modal" id="deleteOrderModal" aria-hidden="true" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:12px;max-width:460px;width:90%;padding:0">
    <div style="padding:20px 24px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center">
      <h3 style="margin:0;font-size:16px;font-weight:800;color:#b91c1c">⚠️ Borrar orden de servicio</h3>
      <button type="button" data-modal-close style="background:none;border:none;font-size:20px;cursor:pointer;color:#6b7280">✕</button>
    </div>
    <form method="post" action="/admin/ordenes-servicio/<%= order.id %>/borrar" style="padding:20px 24px" data-require-pin data-pin-title="Autoriza el borrado" data-pin-msg="Ingresa tu PIN para eliminar esta orden y su historial. Esta acción no se puede deshacer.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <p style="margin:0 0 14px;font-size:13.5px;color:#374151;line-height:1.5">
        Vas a borrar la orden <strong><%= order.label %></strong> (<%= order.items.length %> ítem<%= order.items.length === 1 ? '' : 's' %>,
        total $<%= order.total.toLocaleString('es-CO') %>) y todo su historial de trazabilidad.
        <strong>Esta operación es permanente y no se puede deshacer.</strong>
      </p>
      <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:9px;padding:10px 14px;margin-bottom:18px;font-size:12.5px;color:#7f1d1d">
        Por seguridad, el botón se habilita después de 10 segundos. Tómate ese tiempo para confirmar que es la orden correcta.
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn btn-ghost" type="button" data-modal-close>Cancelar</button>
        <button id="confirmDeleteBtn" type="submit" class="btn btn-sm" disabled
                style="background:#dc2626;color:#fff;border:none;opacity:.5;cursor:not-allowed">Espera 10 s…</button>
      </div>
    </form>
  </div>
</div>
<script>
(function () {
  var openBtn = document.getElementById('openDeleteModal');
  var btn = document.getElementById('confirmDeleteBtn');
  if (!openBtn || !btn) return;
  var timer = null;

  function start() {
    var left = 10;
    clearInterval(timer);
    btn.disabled = true;
    btn.style.opacity = '.5';
    btn.style.cursor = 'not-allowed';
    btn.textContent = 'Espera ' + left + ' s…';
    timer = setInterval(function () {
      left--;
      if (left <= 0) {
        clearInterval(timer);
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
        btn.textContent = 'Borrar definitivamente';
      } else {
        btn.textContent = 'Espera ' + left + ' s…';
      }
    }, 1000);
  }

  // Reinicia la cuenta cada vez que se abre, y la detiene al cerrar.
  openBtn.addEventListener('click', start);
  document.querySelectorAll('#deleteOrderModal [data-modal-close]').forEach(function (c) {
    c.addEventListener('click', function () { clearInterval(timer); });
  });
})();
</script>
<% } %>

<!-- Modal editar orden -->
<div class="modal" id="editOrderModal" aria-hidden="true" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:12px;max-width:760px;width:92%;padding:0;max-height:90vh;overflow-y:auto">
    <div style="padding:20px 24px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center">
      <h3 style="margin:0;font-size:16px;font-weight:800">Editar orden</h3>
      <button type="button" data-modal-close style="background:none;border:none;font-size:20px;cursor:pointer;color:#6b7280">✕</button>
    </div>
    <form method="post" action="/admin/ordenes-servicio/<%= order.id %>/editar-datos" id="editOrderForm" style="padding:20px 24px" data-require-pin data-pin-title="Autoriza la edición" data-pin-msg="Ingresa tu PIN para guardar los cambios de la orden.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="items" id="editItemsField" />
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:20px">
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Placa</label>
          <input type="text" name="plate" value="<%= (order.motorcycle || '').split(' — ')[0] || '' %>" maxlength="20" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box;text-transform:uppercase" oninput="this.value=this.value.toUpperCase()" />
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Moto (marca/modelo)</label>
          <input type="text" name="motorcycle" value="<%= (order.motorcycle || '').split(' — ').slice(1).join(' — ') || '' %>" maxlength="80" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">WhatsApp cliente</label>
          <div style="display:flex;gap:6px">
            <input type="text" name="clientPhoneCountry" value="<%= order.clientPhoneCountry || '+57' %>" style="width:62px;padding:9px 8px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box;text-align:center" />
            <input type="text" name="clientPhone" inputmode="numeric" value="<%= order.clientPhone || '' %>" placeholder="3001234567" style="flex:1;min-width:0;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          </div>
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Mecánico</label>
          <select name="employeeId" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box">
            <option value="">— Sin asignar —</option>
            <% empleados.forEach(e => { %>
              <option value="<%= e.id %>"<%= order.employeeId === e.id ? ' selected' : '' %>><%= e.name %></option>
            <% }) %>
            <% if (empleadoAsignado && !empleados.some(e => e.id === empleadoAsignado.id)) { %>
              <option value="<%= empleadoAsignado.id %>" selected><%= empleadoAsignado.name %> (inactivo)</option>
            <% } %>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Entrega estimada</label>
          <input type="date" name="estimatedDate" value="<%= order.estimatedDate || '' %>" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
        </div>
      </div>

      <% if (order.invoiceId) { %>
        <div style="padding:12px 14px;background:#fef3c7;border:1px solid #fde68a;border-radius:9px;font-size:12.5px;color:#92400e;margin-bottom:20px">
          Esta orden ya está facturada; los ítems no se pueden modificar para no descuadrar la factura.
        </div>
      <% } else { %>
        <div style="margin-bottom:20px">
          <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px">Ítems</label>
          <div class="crm-table-wrap">
            <table class="crm-table" id="editItemsTable">
              <thead>
                <tr>
                  <th style="min-width:160px">Ítem</th>
                  <th style="width:120px">Tipo</th>
                  <th style="width:70px;text-align:center">Cant.</th>
                  <th style="width:120px;text-align:right">Precio</th>
                  <th style="width:110px;text-align:right">Subtotal</th>
                  <th style="width:36px"></th>
                </tr>
              </thead>
              <tbody id="editItemsBody"></tbody>
              <tfoot>
                <tr>
                  <td colspan="4" style="text-align:right;font-weight:800;padding:12px 10px;font-size:13px;color:#374151">TOTAL</td>
                  <td style="text-align:right;font-weight:900;font-size:16px;color:var(--brand);padding:12px 10px" id="editGrandTotal">$0</td>
                  <td></td>
                </tr>
              </tfoot>
            </table>
          </div>
          <datalist id="editCatalogList"></datalist>
          <button type="button" class="btn btn-ghost btn-sm" id="editAddRow" style="margin-top:10px">+ Agregar ítem</button>
        </div>
      <% } %>

      <div style="display:flex;gap:10px">
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
        <button class="btn btn-ghost" type="button" data-modal-close>Cancelar</button>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('[data-modal-open]').forEach(btn => {
  btn.addEventListener('click', () => {
    const target = btn.getAttribute('data-modal-open');
    const modal = document.querySelector(target);
    if (modal) modal.style.display = 'flex';
  });
});
document.querySelectorAll('[data-modal-close]').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.closest('[id]').style.display = 'none';
  });
});
</script>

<% if (!order.invoiceId) { %>
<script>
(function () {
  const body       = document.getElementById('editItemsBody');
  const addBtn     = document.getElementById('editAddRow');
  const grandTotal = document.getElementById('editGrandTotal');
  const catalog    = document.getElementById('editCatalogList');
  const form       = document.getElementById('editOrderForm');
  const itemsField = document.getElementById('editItemsField');
  const initial    = <%- JSON.stringify(order.items || []) %>;

  const fmt = n => '$' + (Number(n) || 0).toLocaleString('es-CO');

  function recalc() {
    let total = 0;
    body.querySelectorAll('tr').forEach(tr => {
      const price = Number(tr.querySelector('.it-price').value) || 0;
      const qty   = Number(tr.querySelector('.it-qty').value)   || 0;
      const sub   = price * qty;
      tr.querySelector('.it-sub').textContent = fmt(sub);
      total += sub;
    });
    grandTotal.textContent = fmt(total);
  }

  function esc(s) { return String(s == null ? '' : s).replace(/"/g, '&quot;'); }

  function addRow(data = {}) {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><input class="it-name" list="editCatalogList" autocomplete="off" placeholder="Nombre del ítem" style="width:100%;padding:7px 10px;border:1.5px solid #e5e7eb;border-radius:7px;font-size:13px;font-family:inherit;outline:none;box-sizing:border-box" value="${esc(data.name)}"></td>
      <td><select class="it-type" style="width:100%;padding:7px 8px;border:1.5px solid #e5e7eb;border-radius:7px;font-size:13px;font-family:inherit;outline:none;box-sizing:border-box">
        <option value="service">Servicio</option>
        <option value="product">Producto</option>
        <option value="custom">Personalizado</option>
      </select></td>
      <td><input class="it-qty" type="number" min="1" value="${data.qty || 1}" style="width:100%;padding:7px 8px;border:1.5px solid #e5e7eb;border-radius:7px;font-size:13px;font-family:inherit;outline:none;box-sizing:border-box;text-align:center"></td>
      <td><input class="it-price" type="number" min="0" step="1" value="${data.price || ''}" placeholder="0" style="width:100%;padding:7px 8px;border:1.5px solid #e5e7eb;border-radius:7px;font-size:13px;font-family:inherit;outline:none;box-sizing:border-box;text-align:right"></td>
      <td class="it-sub" style="text-align:right;font-weight:800;color:var(--brand)">$0</td>
      <td><button type="button" class="it-del btn btn-ghost btn-sm" style="color:#dc2626;padding:4px 8px">✕</button></td>`;
    if (data.type) tr.querySelector('.it-type').value = data.type;
    body.appendChild(tr);

    tr.querySelector('.it-del').addEventListener('click', () => { tr.remove(); recalc(); });
    tr.querySelectorAll('.it-price, .it-qty').forEach(el => el.addEventListener('input', recalc));

    const nameInput = tr.querySelector('.it-name');
    let t;
    nameInput.addEventListener('input', () => {
      clearTimeout(t);
      const q = nameInput.value.trim();
      if (q.length < 3) return;
      t = setTimeout(async () => {
        try {
          const r = await fetch('/api/liquidador/search?q=' + encodeURIComponent(q));
          const list = await r.json();
          catalog.innerHTML = '';
          list.forEach(item => {
            const o = document.createElement('option');
            o.value = item.name;
            catalog.appendChild(o);
          });
          const match = list.find(i => i.name === nameInput.value);
          if (match) tr.querySelector('.it-type').value = match.type;
        } catch {}
      }, 250);
    });
    recalc();
  }

  addBtn.addEventListener('click', () => addRow());
  if (initial.length) initial.forEach(it => addRow(it)); else addRow();

  form.addEventListener('submit', e => {
    const items = [];
    body.querySelectorAll('tr').forEach(tr => {
      const name  = tr.querySelector('.it-name').value.trim();
      const price = Math.round(Number(tr.querySelector('.it-price').value));
      const qty   = Math.round(Number(tr.querySelector('.it-qty').value));
      if (name && price >= 1 && qty >= 1) {
        items.push({ name, type: tr.querySelector('.it-type').value, price, qty });
      }
    });
    if (items.length === 0) {
      e.preventDefault();
      alert('Agrega al menos un ítem válido (nombre, cantidad y precio).');
      return;
    }
    itemsField.value = JSON.stringify(items);
  });
})();
</script>
<% } %>

<%- include('../partials/admin-foot') %>
