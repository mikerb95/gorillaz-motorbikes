<%- include('../partials/admin-head', { title: 'Ítems del Liquidador' }) %>

<%
const flashMap = {
  created:    { msg: 'Ítem añadido.',        color: '#ecfdf5', border: '#6ee7b7', text: '#065f46' },
  updated:    { msg: 'Ítem actualizado.',     color: '#ecfdf5', border: '#6ee7b7', text: '#065f46' },
  deleted:    { msg: 'Ítem eliminado.',       color: '#fef2f2', border: '#fca5a5', text: '#991b1b' },
  'error-name': { msg: 'El nombre no puede estar vacío.', color: '#fef2f2', border: '#fca5a5', text: '#991b1b' },
};
const alertInfo = flash ? flashMap[flash] : null;
const catalogServices  = services.filter(s => s.type === 'service');
const catalogProducts  = services.filter(s => s.type === 'product');
%>

<div class="crm-page-header">
  <h1 class="crm-page-title">Ítems del Liquidador</h1>
</div>

<% if (alertInfo) { %>
  <div style="background:<%= alertInfo.color %>;border:1px solid <%= alertInfo.border %>;color:<%= alertInfo.text %>;border-radius:10px;padding:11px 16px;margin-bottom:16px;font-weight:700;font-size:13px">
    <%= alertInfo.msg %>
  </div>
<% } %>

<!-- Tabs -->
<div style="display:flex;gap:4px;margin-bottom:18px;border-bottom:2px solid #e5e7eb">
  <button class="liq-tab active" data-tab="servicios" style="padding:9px 18px;border:none;background:none;font-size:13px;font-weight:800;cursor:pointer;border-bottom:2px solid var(--brand);margin-bottom:-2px;color:var(--brand);font-family:inherit">
    Servicios (<%= catalogServices.length %>)
  </button>
  <button class="liq-tab" data-tab="repuestos" style="padding:9px 18px;border:none;background:none;font-size:13px;font-weight:700;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;color:#6b7280;font-family:inherit">
    Repuestos / Materiales (<%= catalogProducts.length %>)
  </button>
  <button class="liq-tab" data-tab="productos" style="padding:9px 18px;border:none;background:none;font-size:13px;font-weight:700;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;color:#6b7280;font-family:inherit">
    Productos del catálogo (<%= products.length %>)
  </button>
</div>

<!-- ── TAB: Servicios ──────────────────────────────────────────────────── -->
<div id="tab-servicios">

  <!-- Añadir servicio -->
  <div class="crm-card" style="padding:18px 20px;margin-bottom:16px">
    <h2 style="font-size:13px;font-weight:800;color:#374151;margin:0 0 12px;text-transform:uppercase;letter-spacing:.4px">Añadir servicio</h2>
    <form method="post" action="/admin/cotizador-items/servicio/crear" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div style="flex:1;min-width:200px">
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Nombre del servicio</label>
        <input
          type="text"
          name="name"
          placeholder="Ej: Revisión de suspensión"
          required
          style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box"
        />
      </div>
      <button class="btn btn-primary btn-sm" type="submit">Añadir</button>
    </form>
  </div>

  <!-- Lista de servicios -->
  <div class="crm-card">
    <% if (catalogServices.length === 0) { %>
      <p class="muted" style="padding:28px;text-align:center">No hay servicios configurados.</p>
    <% } else { %>
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead>
          <tr>
            <th style="width:40px">#</th>
            <th>Nombre</th>
            <th style="width:160px"></th>
          </tr>
        </thead>
        <tbody>
          <% catalogServices.forEach((svc, idx) => { %>
          <tr id="row-<%= svc.id %>">
            <td class="muted" style="font-size:.8rem"><%= idx + 1 %></td>

            <!-- Modo lectura -->
            <td class="svc-display-<%= svc.id %>">
              <span style="font-weight:700"><%= svc.name %></span>
            </td>

            <!-- Modo edición (oculto por defecto) -->
            <td class="svc-edit-<%= svc.id %>" style="display:none">
              <form method="post" action="/admin/cotizador-items/servicio/actualizar" style="display:flex;gap:8px;align-items:center">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="id" value="<%= svc.id %>" />
                <input
                  type="text"
                  name="name"
                  value="<%= svc.name %>"
                  required
                  style="flex:1;padding:6px 10px;border:1.5px solid var(--brand);border-radius:8px;font-size:13px;font-family:inherit;outline:none"
                />
                <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
                <button type="button" class="btn btn-ghost btn-sm svc-cancel" data-id="<%= svc.id %>">×</button>
              </form>
            </td>

            <!-- Acciones -->
            <td class="svc-actions-<%= svc.id %>" style="text-align:right">
              <div style="display:flex;gap:6px;justify-content:flex-end">
                <button class="btn btn-ghost btn-sm svc-edit-btn" data-id="<%= svc.id %>">Renombrar</button>
                <form method="post" action="/admin/cotizador-items/servicio/eliminar"
                      data-confirm="¿Eliminar el servicio '<%= svc.name %>'?"
                      style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="id" value="<%= svc.id %>" />
                  <button class="btn btn-ghost btn-sm" type="submit" style="color:#ef4444">Eliminar</button>
                </form>
              </div>
            </td>
            <td class="svc-edit-<%= svc.id %>" style="display:none"></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<!-- ── TAB: Repuestos / Materiales ───────────────────────────────────── -->
<div id="tab-repuestos" style="display:none">

  <!-- Añadir repuesto -->
  <div class="crm-card" style="padding:18px 20px;margin-bottom:16px">
    <h2 style="font-size:13px;font-weight:800;color:#374151;margin:0 0 12px;text-transform:uppercase;letter-spacing:.4px">Añadir repuesto o material</h2>
    <form method="post" action="/admin/cotizador-items/producto/crear" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div style="flex:1;min-width:200px">
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Nombre del repuesto / material</label>
        <input
          type="text"
          name="name"
          placeholder="Ej: Filtro de combustible"
          required
          style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box"
        />
      </div>
      <button class="btn btn-primary btn-sm" type="submit">Añadir</button>
    </form>
  </div>

  <!-- Lista de repuestos -->
  <div class="crm-card">
    <% if (catalogProducts.length === 0) { %>
      <p class="muted" style="padding:28px;text-align:center">No hay repuestos configurados.</p>
    <% } else { %>
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead>
          <tr>
            <th style="width:40px">#</th>
            <th>Nombre</th>
            <th style="width:160px"></th>
          </tr>
        </thead>
        <tbody>
          <% catalogProducts.forEach((prd, idx) => { %>
          <tr id="row-<%= prd.id %>">
            <td class="muted" style="font-size:.8rem"><%= idx + 1 %></td>

            <td class="prd-display-<%= prd.id %>">
              <span style="font-weight:700"><%= prd.name %></span>
            </td>

            <td class="prd-edit-<%= prd.id %>" style="display:none">
              <form method="post" action="/admin/cotizador-items/producto/actualizar" style="display:flex;gap:8px;align-items:center">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="id" value="<%= prd.id %>" />
                <input
                  type="text"
                  name="name"
                  value="<%= prd.name %>"
                  required
                  style="flex:1;padding:6px 10px;border:1.5px solid var(--brand);border-radius:8px;font-size:13px;font-family:inherit;outline:none"
                />
                <button class="btn btn-primary btn-sm" type="submit">Guardar</button>
                <button type="button" class="btn btn-ghost btn-sm prd-cancel" data-id="<%= prd.id %>">×</button>
              </form>
            </td>

            <td class="prd-actions-<%= prd.id %>" style="text-align:right">
              <div style="display:flex;gap:6px;justify-content:flex-end">
                <button class="btn btn-ghost btn-sm prd-edit-btn" data-id="<%= prd.id %>">Renombrar</button>
                <form method="post" action="/admin/cotizador-items/producto/eliminar"
                      data-confirm="¿Eliminar '<%= prd.name %>'?"
                      style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="id" value="<%= prd.id %>" />
                  <button class="btn btn-ghost btn-sm" type="submit" style="color:#ef4444">Eliminar</button>
                </form>
              </div>
            </td>
            <td class="prd-edit-<%= prd.id %>" style="display:none"></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<!-- ── TAB: Productos ─────────────────────────────────────────────────── -->
<div id="tab-productos" style="display:none">
  <div class="crm-card" style="padding:16px 20px;margin-bottom:14px;background:#f8fafc;border:1px solid #e2e8f0">
    <p style="margin:0;font-size:13px;color:#6b7280">
      Los productos provienen del catálogo de la tienda. Para añadir, editar o eliminar productos
      usá el panel de gestión de tienda.
      <a href="/admin/tienda" style="color:var(--brand);font-weight:700">Ir a Tienda →</a>
    </p>
  </div>

  <div class="crm-card">
    <% if (products.length === 0) { %>
      <p class="muted" style="padding:28px;text-align:center">No hay productos en el catálogo.</p>
    <% } else { %>
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead>
          <tr>
            <th style="width:40px">#</th>
            <th>Nombre</th>
            <th>Marca</th>
            <th>Categoría</th>
            <th style="width:100px"></th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((p, idx) => { %>
          <tr>
            <td class="muted" style="font-size:.8rem"><%= idx + 1 %></td>
            <td style="font-weight:700"><%= p.name %></td>
            <td class="muted" style="font-size:.85rem"><%= p.brand || '—' %></td>
            <td>
              <span class="badge badge-info" style="font-size:.75rem;text-transform:capitalize"><%= p.category %></span>
            </td>
            <td>
              <a class="btn btn-ghost btn-sm" href="/admin/tienda/<%= p.id %>/editar">Editar</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<script>
(function () {
  // ── Tabs ──────────────────────────────────────────────────────────
  document.querySelectorAll('.liq-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.liq-tab').forEach(t => {
        t.classList.remove('active');
        t.style.borderBottomColor = 'transparent';
        t.style.color = '#6b7280';
        t.style.fontWeight = '700';
      });
      tab.classList.add('active');
      tab.style.borderBottomColor = 'var(--brand)';
      tab.style.color = 'var(--brand)';
      tab.style.fontWeight = '800';
      document.getElementById('tab-servicios').style.display = tab.dataset.tab === 'servicios' ? '' : 'none';
      document.getElementById('tab-productos').style.display  = tab.dataset.tab === 'productos'  ? '' : 'none';
    });
  });

  // ── Inline edit ───────────────────────────────────────────────────
  document.querySelectorAll('.svc-edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id;
      toggleEdit(id, true);
    });
  });

  document.querySelectorAll('.svc-cancel').forEach(btn => {
    btn.addEventListener('click', () => toggleEdit(btn.dataset.id, false));
  });

  function toggleEdit(id, editing) {
    document.querySelectorAll('.svc-display-' + id).forEach(el => el.style.display = editing ? 'none' : '');
    document.querySelectorAll('.svc-edit-' + id).forEach(el => el.style.display = editing ? '' : 'none');
    document.querySelectorAll('.svc-actions-' + id).forEach(el => el.style.display = editing ? 'none' : '');
    if (editing) {
      const input = document.querySelector('.svc-edit-' + id + ' input[name=name]');
      if (input) { input.focus(); input.select(); }
    }
  }
})();
</script>

<%- include('../partials/admin-foot') %>
