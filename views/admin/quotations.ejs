<%- include('../partials/admin-head', { title: 'Cotizaciones' }) %>

<%
  const s = summary;
  const fmt = n => '$' + Number(n || 0).toLocaleString('es-CO');
  const periods = [
    { key: 'mes',          label: 'Este mes' },
    { key: 'mes-anterior', label: 'Mes anterior' },
    { key: 'anio',         label: 'Este año' },
    { key: 'todo',         label: 'Todo' },
  ];
  const sparkMax = Math.max(1, ...s.spark.map(p => p.value));
  function deltaTag(d) {
    if (d === null || typeof d === 'undefined') return '';
    const cls = d > 0 ? 'up' : (d < 0 ? 'down' : 'flat');
    const arrow = d > 0 ? '▲' : (d < 0 ? '▼' : '—');
    return `<span class="qsum-delta ${cls}">${arrow} ${Math.abs(d)}%</span>`;
  }
%>

<div class="crm-page-header">
  <a class="btn btn-primary btn-sm" href="/liquidador" target="_blank" rel="noopener">+ Nueva cotización</a>
  <nav class="qsum-periods" aria-label="Periodo del resumen">
    <% periods.forEach(p => { %>
      <a class="qsum-period <%= s.periodo === p.key ? 'active' : '' %>" href="/admin/cotizaciones?periodo=<%= p.key %>"><%= p.label %></a>
    <% }) %>
  </nav>
</div>

<!-- Fila 1 · KPIs inteligentes -->
<div class="crm-kpi-row qsum-kpis" style="margin-bottom:14px">
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value" style="font-size:1.25rem"><%= fmt(s.value) %></div>
    <div class="crm-kpi-label">Cotizado · <%= s.periodoLabel %></div>
    <div class="qsum-foot">
      <%- deltaTag(s.valueDelta) %>
      <% if (s.prevLabel && s.valueDelta !== null) { %><span class="qsum-sub">vs <%= s.prevLabel %></span><% } %>
    </div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= s.convRate %>%</div>
    <div class="crm-kpi-label">Conversión a orden</div>
    <div class="qsum-foot"><span class="qsum-sub"><%= s.converted %> de <%= s.count %> cotizaciones</span></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value" style="font-size:1.25rem"><%= fmt(s.avg) %></div>
    <div class="crm-kpi-label">Ticket promedio</div>
    <div class="qsum-foot"><%- deltaTag(s.avgDelta) %></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= s.pendientes %></div>
    <div class="crm-kpi-label">Pendientes de seguimiento</div>
    <div class="qsum-foot">
      <% if (s.pendientesOld > 0) { %><span class="qsum-sub qsum-warn">⚠ <%= s.pendientesOld %> con +7 días</span><% } else { %><span class="qsum-sub">Sin atrasos</span><% } %>
    </div>
  </div>
</div>

<!-- Fila 2 · embudo + tendencia + top servicios -->
<div class="qsum-insights">
  <div class="qsum-insight">
    <div class="qsum-insight-title">Embudo de conversión</div>
    <%
      const fMax = Math.max(1, s.count);
      const steps = [
        { n: s.count,     lbl: 'Cotizadas',  cls: '',   pct: null },
        { n: s.converted, lbl: 'Órdenes',    cls: 'b2', pct: s.convRate },
        { n: s.invoiced,  lbl: 'Facturadas', cls: 'b3', pct: s.winRate },
      ];
    %>
    <% steps.forEach(st => { %>
      <div class="qsum-funnel-step">
        <div class="qsum-funnel-bar <%= st.cls %>" style="width:<%= Math.round((st.n / fMax) * 100) %>%"></div>
        <div class="qsum-funnel-meta"><b><%= st.n %></b> <%= st.lbl %><% if (st.pct !== null) { %> <span class="qsum-funnel-pct"><%= st.pct %>%</span><% } %></div>
      </div>
    <% }) %>
  </div>

  <div class="qsum-insight">
    <div class="qsum-insight-title">Cotizado · últimos 6 meses</div>
    <div class="qsum-spark">
      <% s.spark.forEach((p, i) => { %>
        <div class="qsum-spark-col <%= i === s.spark.length - 1 ? 'is-last' : '' %>" title="<%= p.label %>: <%= fmt(p.value) %>">
          <div class="qsum-spark-bar" style="height:<%= Math.max(3, Math.round((p.value / sparkMax) * 40)) %>px"></div>
          <div class="qsum-spark-label"><%= p.label %></div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="qsum-insight">
    <div class="qsum-insight-title">Top servicios · <%= s.periodoLabel %></div>
    <% if (!s.topItems || s.topItems.length === 0) { %>
      <div class="qsum-empty">Sin datos en el periodo.</div>
    <% } else { %>
      <ol class="qsum-top">
        <% s.topItems.forEach(t => { %>
          <li><span class="nm" title="<%= t.name %>"><%= t.name %></span><span class="vl"><%= fmt(t.value) %></span></li>
        <% }) %>
      </ol>
    <% } %>
  </div>
</div>

<% if (typeof drafts !== 'undefined' && drafts.length > 0) { %>
<div class="crm-card" style="margin-bottom:18px;border-left:3px solid #f59e0b">
  <div style="display:flex;align-items:center;gap:8px;padding:14px 16px 0">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#b45309" stroke-width="2.2"
      stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
    </svg>
    <strong style="color:#b45309">Borradores sin terminar (<%= drafts.length %>)</strong>
    <span class="muted" style="font-size:.8rem">No cuentan en los totales hasta confirmarse.</span>
  </div>
  <div class="crm-table-wrap" style="margin-top:10px">
    <table class="crm-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Iniciada</th>
          <th>Moto / Placa</th>
          <th>Ítems</th>
          <th>Total</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% drafts.forEach(d => { %>
        <tr>
          <td>
            <span class="badge badge-warning" style="font-size:.8rem;font-weight:900">#<%= d.label %></span>
          </td>
          <td class="muted" style="font-size:.82rem;white-space:nowrap">
            <%= fechaCO(d.createdAt, { day:'2-digit', month:'short', year:'numeric' }) %><br>
            <span style="font-size:.76rem"><%= horaCO(d.createdAt, { hour:'2-digit', minute:'2-digit' }) %></span>
          </td>
          <td>
            <% if (d.plate) { %>
              <span class="badge badge-info" style="font-size:.78rem;font-weight:900;letter-spacing:.5px"><%= d.plate %></span>
            <% } %>
            <% if (d.motorcycle) { %>
              <div style="font-size:.82rem;margin-top:<%= d.plate ? '3px' : '0' %>"><%= d.motorcycle %></div>
            <% } %>
            <% if (!d.plate && !d.motorcycle) { %>
              <span class="muted" style="font-size:.82rem">—</span>
            <% } %>
          </td>
          <td style="font-size:.85rem"><%= d.items.length %></td>
          <td><strong>$<%= d.total.toLocaleString('es-CO') %></strong></td>
          <td style="white-space:nowrap;display:flex;gap:6px;align-items:center">
            <a class="btn btn-primary btn-sm" href="/liquidador?id=<%= d.id %>" target="_blank" rel="noopener">Continuar</a>
            <form method="post" action="/admin/cotizaciones/<%= d.id %>/eliminar" style="display:inline" data-confirm="¿Descartar el borrador #<%= d.label %>?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-danger btn-sm" type="submit">Descartar</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="crm-card">
  <% if (quotations.length === 0) { %>
    <p class="muted" style="padding:32px;text-align:center">No hay cotizaciones aún. <a href="/liquidador">Crear la primera</a></p>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Fecha</th>
          <th>Moto / Placa</th>
          <th>Ítems</th>
          <th>Total</th>
          <th>Cliente (WA)</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% quotations.forEach(q => { %>
        <tr>
          <td>
            <span class="badge badge-info" style="font-size:.8rem;font-weight:900">
              #<%= q.label %>
            </span>
          </td>
          <td class="muted" style="font-size:.82rem;white-space:nowrap">
            <%= fechaCO(q.createdAt, { day:'2-digit', month:'short', year:'numeric' }) %><br>
            <span style="font-size:.76rem"><%= horaCO(q.createdAt, { hour:'2-digit', minute:'2-digit' }) %></span>
          </td>
          <td>
            <% if (q.plate) { %>
              <span class="badge badge-info" style="font-size:.78rem;font-weight:900;letter-spacing:.5px"><%= q.plate %></span>
            <% } %>
            <% if (q.motorcycle) { %>
              <div style="font-size:.82rem;margin-top:<%= q.plate ? '3px' : '0' %>"><%= q.motorcycle %></div>
            <% } %>
            <% if (!q.plate && !q.motorcycle) { %>
              <span class="muted" style="font-size:.82rem">—</span>
            <% } %>
          </td>
          <td style="font-size:.85rem;max-width:200px">
            <% q.items.slice(0,3).forEach(it => { %>
              <div><%= it.qty %> × <%= it.name %></div>
            <% }) %>
            <% if (q.items.length > 3) { %>
              <span class="muted">+<%= q.items.length - 3 %> más</span>
            <% } %>
          </td>
          <td><strong>$<%= q.total.toLocaleString('es-CO') %></strong></td>
          <td style="font-size:.82rem">
            <% if (q.clientPhone) { %>
              <span><%= q.clientPhoneCountry %> <%= q.clientPhone %></span>
            <% } else { %>
              <span class="muted">—</span>
            <% } %>
          </td>
          <td style="white-space:nowrap;display:flex;gap:6px;align-items:center">
            <a class="btn btn-ghost btn-sm" href="/admin/cotizaciones/<%= q.id %>">Ver detalle</a>
            <form method="post" action="/admin/cotizaciones/<%= q.id %>/eliminar" style="display:inline" data-confirm="¿Eliminar cotización #<%= q.label %>? Esta acción no se puede deshacer.">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-danger btn-sm" type="submit">Eliminar</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pager', { page, pages, params: { periodo: typeof periodo !== 'undefined' ? periodo : '' } }) %>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
