<%- include('../partials/admin-head', { title: 'Config PDF Cotización' }) %>

<div class="crm-page-header"></div>

<% if (flash === 'saved') { %>
  <div class="alert" style="background:#ecfdf5;border:1px solid #6ee7b7;color:#065f46;border-radius:10px;padding:12px 16px;margin-bottom:16px;font-weight:700">
    ✓ Configuración guardada correctamente.
  </div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:1100px;align-items:start">

  <!-- Formulario -->
  <form id="pdfForm" method="post" action="/admin/config-pdf-cotizacion" style="display:grid;gap:20px">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <!-- Empresa -->
    <div class="crm-card" style="padding:24px">
      <h2 style="font-size:15px;font-weight:800;margin:0 0 18px">Datos de la empresa</h2>
      <div style="display:grid;gap:14px">

        <div>
          <label class="pdf-label">Nombre de la empresa *</label>
          <input type="text" name="companyName" id="fCompanyName" value="<%= config.companyName %>"
            maxlength="60" required
            style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label class="pdf-label">NIT / RUT</label>
            <input type="text" name="nit" id="fNit" value="<%= config.nit %>"
              maxlength="30" placeholder="900.123.456-7"
              style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          </div>
          <div>
            <label class="pdf-label">Teléfono</label>
            <input type="text" name="phone" id="fPhone" value="<%= config.phone %>"
              maxlength="30" placeholder="+57 (601) 123 4567"
              style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label class="pdf-label">Correo electrónico</label>
            <input type="text" name="email" id="fEmail" value="<%= config.email %>"
              maxlength="80" placeholder="info@gorillazmotorbikes.com"
              style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          </div>
          <div>
            <label class="pdf-label">Sitio web</label>
            <input type="text" name="website" id="fWebsite" value="<%= config.website %>"
              maxlength="80" placeholder="gorillazmotorbikes.com"
              style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          </div>
        </div>

        <div>
          <label class="pdf-label">Dirección</label>
          <input type="text" name="address" id="fAddress" value="<%= config.address %>"
            maxlength="120" placeholder="Cra 7 # 45-23, Bogotá"
            style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
        </div>

        <div>
          <label class="pdf-label">Ciudad / País</label>
          <input type="text" name="city" id="fCity" value="<%= config.city %>"
            maxlength="60" placeholder="Bogotá, Colombia"
            style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
        </div>

      </div>
    </div>

    <!-- Apariencia -->
    <div class="crm-card" style="padding:24px">
      <h2 style="font-size:15px;font-weight:800;margin:0 0 18px">Apariencia</h2>
      <div>
        <label class="pdf-label">Color de cabecera</label>
        <div style="display:flex;align-items:center;gap:10px">
          <input type="color" name="headerColor" id="fHeaderColor" value="<%= config.headerColor %>"
            style="width:48px;height:38px;padding:2px;border:1.5px solid #e5e7eb;border-radius:8px;cursor:pointer" />
          <input type="text" id="fHeaderColorText" value="<%= config.headerColor %>"
            maxlength="7" placeholder="#F25C05"
            style="width:96px;padding:10px 10px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:13px;font-family:monospace;outline:none" />
          <span class="muted" style="font-size:12px">Se aplica a la cabecera y barra de total</span>
        </div>
      </div>
    </div>

    <!-- Pie y validez -->
    <div class="crm-card" style="padding:24px">
      <h2 style="font-size:15px;font-weight:800;margin:0 0 18px">Pie y validez</h2>
      <div style="display:grid;gap:14px">
        <div>
          <label class="pdf-label">Nota al pie</label>
          <input type="text" name="footerNote" id="fFooterNote" value="<%= config.footerNote %>"
            maxlength="140" placeholder="Válida por 30 días. Precios en COP."
            style="width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
          <p class="muted" style="font-size:12px;margin:4px 0 0">Aparece en la esquina inferior izquierda del PDF.</p>
        </div>
        <div>
          <label class="pdf-label">Validez de la cotización (días)</label>
          <input type="number" name="validityDays" id="fValidityDays" value="<%= config.validityDays %>"
            min="1" max="365"
            style="width:100px;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;outline:none" />
        </div>
      </div>
    </div>

    <!-- Datos opcionales -->
    <div class="crm-card" style="padding:24px">
      <h2 style="font-size:15px;font-weight:800;margin:0 0 16px">Datos opcionales en el PDF</h2>
      <div style="display:grid;gap:12px">
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:14px">
          <input type="checkbox" name="showPhone" id="fShowPhone" <%= config.showPhone ? 'checked' : '' %>
            style="width:16px;height:16px;accent-color:var(--brand);cursor:pointer" />
          Mostrar teléfono del cliente
        </label>
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:14px">
          <input type="checkbox" name="showNotes" id="fShowNotes" <%= config.showNotes ? 'checked' : '' %>
            style="width:16px;height:16px;accent-color:var(--brand);cursor:pointer" />
          Mostrar notas de la cotización
        </label>
      </div>
    </div>

    <button class="btn btn-primary" type="submit">Guardar cambios</button>
  </form>

  <!-- Preview -->
  <div style="position:sticky;top:80px">
    <div class="crm-card" style="padding:20px">
      <div style="font-size:11px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px">Vista previa del PDF</div>

      <div id="pdfPreview" style="background:#fff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;font-family:Arial,sans-serif;box-shadow:0 2px 12px rgba(0,0,0,.08)">

        <!-- Header -->
        <div id="previewHeader" style="padding:10px 14px 10px;display:flex;justify-content:space-between;align-items:flex-start">
          <div>
            <div id="previewCompany" style="font-size:13px;font-weight:900;color:#fff;line-height:1.2"></div>
            <div id="previewNitLine" style="font-size:8px;color:rgba(255,255,255,.85);margin-top:1px"></div>
            <div id="previewContactLine" style="font-size:8px;color:rgba(255,255,255,.8);margin-top:1px"></div>
            <div id="previewAddressLine" style="font-size:8px;color:rgba(255,255,255,.75);margin-top:1px"></div>
            <div id="previewWebCity" style="font-size:8px;color:rgba(255,255,255,.75);margin-top:1px"></div>
          </div>
          <div style="text-align:right;flex-shrink:0;margin-left:10px">
            <div style="font-size:8px;color:rgba(255,255,255,.85)">Fecha: <span id="previewDate"></span></div>
            <div style="font-size:8px;color:rgba(255,255,255,.85);margin-top:2px">Cotización N° <strong>0024-MAY26</strong></div>
          </div>
        </div>

        <!-- Body -->
        <div style="padding:12px 14px">
          <div style="font-size:11px;font-weight:900;color:#111;margin-bottom:4px">COTIZACIÓN</div>
          <div style="font-size:8px;color:#6b7280;margin-bottom:4px">Moto / Placa: <strong>ABC123 — Honda CB190R</strong></div>
          <div id="previewPhoneLine" style="font-size:8px;color:#6b7280;margin-bottom:10px">Cliente: +57 3001234567</div>

          <!-- Table -->
          <div style="background:#f5f5f5;padding:5px 6px;display:grid;grid-template-columns:1fr 36px 56px 56px;gap:4px;font-size:7.5px;font-weight:700;color:#6b7280;text-transform:uppercase">
            <span>Ítem</span><span style="text-align:center">Cant.</span><span style="text-align:right">Precio</span><span style="text-align:right">Subtotal</span>
          </div>
          <div style="border-bottom:1px solid #e5e7eb"></div>
          <div style="padding:5px 6px;display:grid;grid-template-columns:1fr 36px 56px 56px;gap:4px;font-size:8px">
            <span>Mecánica general</span><span style="text-align:center">1</span><span style="text-align:right">80.000</span><span style="text-align:right;font-weight:700">80.000</span>
          </div>
          <div style="background:#fafafa;padding:5px 6px;display:grid;grid-template-columns:1fr 36px 56px 56px;gap:4px;font-size:8px">
            <span>Cambio de aceite</span><span style="text-align:center">2</span><span style="text-align:right">40.000</span><span style="text-align:right;font-weight:700">80.000</span>
          </div>

          <!-- Total -->
          <div id="previewTotalBar" style="margin:8px 0;padding:5px 6px;display:flex;justify-content:space-between">
            <span style="font-size:9px;font-weight:700;color:#fff">TOTAL:</span>
            <span style="font-size:10px;font-weight:900;color:#fff">COP 160.000</span>
          </div>

          <!-- Notes -->
          <div id="previewNotesBlock" style="margin-top:6px;font-size:8px;color:#374151">
            <strong>Notas:</strong> Revisar también los frenos traseros.
          </div>
        </div>

        <!-- Footer -->
        <div style="padding:6px 14px;border-top:1px solid #f3f4f6;display:flex;justify-content:space-between">
          <div id="previewFooterLeft" style="font-size:7px;color:#9ca3af"></div>
          <div id="previewFooterRight" style="font-size:7px;color:#9ca3af;text-align:right"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
.pdf-label {
  display: block;
  font-size: 12px;
  font-weight: 800;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: .5px;
  margin-bottom: 6px;
}
</style>

<script>
(function () {
  const f = {
    companyName:    document.getElementById('fCompanyName'),
    nit:            document.getElementById('fNit'),
    phone:          document.getElementById('fPhone'),
    email:          document.getElementById('fEmail'),
    address:        document.getElementById('fAddress'),
    website:        document.getElementById('fWebsite'),
    city:           document.getElementById('fCity'),
    headerColor:    document.getElementById('fHeaderColor'),
    headerColorTxt: document.getElementById('fHeaderColorText'),
    validityDays:   document.getElementById('fValidityDays'),
    footerNote:     document.getElementById('fFooterNote'),
    showPhone:      document.getElementById('fShowPhone'),
    showNotes:      document.getElementById('fShowNotes'),
  };

  f.headerColor.addEventListener('input', () => { f.headerColorTxt.value = f.headerColor.value; update(); });
  f.headerColorTxt.addEventListener('input', () => {
    if (/^#[0-9a-fA-F]{6}$/.test(f.headerColorTxt.value)) f.headerColor.value = f.headerColorTxt.value;
    update();
  });

  const el = id => document.getElementById(id);
  el('previewDate').textContent = new Date().toLocaleDateString('es-CO', { year:'numeric', month:'long', day:'numeric', timeZone:'America/Bogota' });

  function update() {
    const color   = /^#[0-9a-fA-F]{6}$/.test(f.headerColorTxt.value) ? f.headerColorTxt.value : '#F25C05';
    const company = f.companyName.value.trim() || 'GORILLAZ MOTORBIKES';
    const nit     = f.nit.value.trim();
    const phone   = f.phone.value.trim();
    const email   = f.email.value.trim();
    const address = f.address.value.trim();
    const website = f.website.value.trim();
    const city    = f.city.value.trim();
    const days    = parseInt(f.validityDays.value, 10) || 30;
    const note    = f.footerNote.value.trim() || ('Válida por ' + days + ' días.');

    el('previewHeader').style.background   = color;
    el('previewTotalBar').style.background = color;
    el('previewCompany').textContent = company;
    el('previewNitLine').textContent = nit ? 'NIT: ' + nit : '';
    el('previewNitLine').style.display = nit ? '' : 'none';

    const contact = [phone, email].filter(Boolean).join('  ·  ');
    el('previewContactLine').textContent = contact;
    el('previewContactLine').style.display = contact ? '' : 'none';

    el('previewAddressLine').textContent = address;
    el('previewAddressLine').style.display = address ? '' : 'none';

    const webCity = [website, city].filter(Boolean).join('  |  ');
    el('previewWebCity').textContent = webCity;
    el('previewWebCity').style.display = webCity ? '' : 'none';

    el('previewPhoneLine').style.display   = f.showPhone.checked ? '' : 'none';
    el('previewNotesBlock').style.display  = f.showNotes.checked ? '' : 'none';
    el('previewFooterLeft').textContent    = note;
    el('previewFooterRight').textContent   = [company, city].filter(Boolean).join(' — ');
  }

  const textFields = ['companyName','nit','phone','email','address','website','city','footerNote','validityDays'];
  textFields.forEach(k => f[k] && f[k].addEventListener('input', update));
  ['showPhone','showNotes'].forEach(k => f[k] && f[k].addEventListener('change', update));
  update();
})();
</script>

<%- include('../partials/admin-foot') %>
