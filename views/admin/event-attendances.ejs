<%- include('../partials/admin-head', { title: 'Asistencias: ' + ev.title }) %>

<div class="crm-page-header">
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <a href="/admin/eventos" style="color:#71717a;text-decoration:none;font-size:.85rem;display:flex;align-items:center;gap:4px">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      Eventos
    </a>
    <span style="color:#d4d4d8">›</span>
    <h1 class="crm-page-title" style="margin:0"><%= ev.title %></h1>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
    <% const typeLabels = { rodada:'🏍️ Rodada', encuentro:'⚽ Encuentro', caminata:'🥾 Caminata', actividad:'🎉 Actividad', evento:'🎉 Actividad' }; %>
    <span class="badge <%= ev.category === 'taller' ? 'badge-warning' : 'badge-info' %>">
      <%= typeLabels[ev.type] || ('🎉 ' + ev.type) %>
    </span>
    <span class="badge badge-muted"><%= ev.date %><% if (ev.location) { %> · <%= ev.location %><% } %></span>
  </div>
</div>

<% if (!attendances || attendances.length === 0) { %>
  <div class="crm-card" style="text-align:center;padding:40px;color:#71717a">
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:12px;opacity:.4"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    <p style="margin:0;font-weight:700">Ningún miembro se ha inscrito aún a este evento.</p>
  </div>
<% } else { %>
  <div style="display:flex;gap:14px;margin-bottom:18px">
    <div class="crm-kpi-card" style="cursor:default;flex:1">
      <div class="crm-kpi-value"><%= attendances.length %></div>
      <div class="crm-kpi-label">Inscritos</div>
    </div>
    <div class="crm-kpi-card" style="cursor:default;flex:1">
      <div class="crm-kpi-value"><%= attendances.filter(a => a.status === 'confirmed').length %></div>
      <div class="crm-kpi-label">Confirmados</div>
    </div>
    <div class="crm-kpi-card" style="cursor:default;flex:1">
      <div class="crm-kpi-value"><%= attendances.filter(a => a.status !== 'confirmed').length %></div>
      <div class="crm-kpi-label">Pendientes</div>
    </div>
  </div>

  <div class="crm-card" style="padding:0;overflow:hidden">
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead>
          <tr>
            <th>Miembro</th>
            <th>Inscrito</th>
            <th>Estado</th>
            <th style="width:180px">Acción</th>
          </tr>
        </thead>
        <tbody>
          <% attendances.forEach(a => { %>
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  <div class="crm-user-circle"><%= (a.nickname || a.name).charAt(0).toUpperCase() %></div>
                  <div>
                    <strong><%= a.nickname || a.name %></strong>
                    <% if (a.nickname) { %><br><span style="font-size:.75rem;color:#71717a"><%= a.name %></span><% } %>
                  </div>
                </div>
              </td>
              <td style="font-size:.82rem;color:#71717a"><%= a.registeredAt.slice(0, 10) %></td>
              <td>
                <% if (a.status === 'confirmed') { %>
                  <span class="badge badge-success">✓ Confirmada</span>
                <% } else { %>
                  <span class="badge badge-warning">⏳ Pendiente</span>
                <% } %>
              </td>
              <td>
                <% if (a.status !== 'confirmed') { %>
                  <form method="post" action="/admin/eventos/asistencia/confirmar">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="attendanceId" value="<%= a.id %>" />
                    <input type="hidden" name="eventId" value="<%= ev.id %>" />
                    <input type="hidden" name="userId" value="<%= a.userId %>" />
                    <input type="hidden" name="eventType" value="<%= ev.type %>" />
                    <button class="btn btn-sm btn-primary" type="submit">Confirmar + puntos</button>
                  </form>
                <% } else { %>
                  <span style="font-size:.8rem;color:#16a34a;font-weight:700">Puntos otorgados ✓</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/admin-foot') %>
