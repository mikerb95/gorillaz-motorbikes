<%- include('../../partials/admin-head', { title: 'Finanzas — Estado de Resultados' }) %>
<% const fmt = n => '$' + Number(n).toLocaleString('es-CO'); %>
<% const delta = (v, cls) => v === null ? '' : `<span style="font-size:.72rem;color:${v>0?'#16a34a':'#dc2626'};margin-left:6px">${v>0?'↑':'↓'}${Math.abs(v)}%</span>`; %>

<div class="crm-page-header">

  <form method="get" action="/admin/finanzas/estado-resultados" style="display:flex;gap:8px;align-items:center">
    <select name="period" class="crm-select" onchange="this.form.submit()">
      <% availablePeriods.forEach(p => { %>
        <option value="<%= p %>" <%= p === periodParam ? 'selected' : '' %>>
          <% const [py,pm] = p.split('-').map(Number); %><%= MONTH_NAMES[pm-1] %> <%= py %>
        </option>
      <% }) %>
    </select>
  </form>
</div>

<%- include('../../partials/finanzas-nav') %>

<!-- Comparación con período anterior -->
<div style="background:#f8fafc;border:1px solid #e4e4e7;border-radius:12px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
  <div style="font-size:.8rem;color:#52525b">Comparado con <strong><%= prevLabel %></strong>: Ingresos <%= prevIng > 0 ? fmt(prevIng) : 'sin datos' %> · Egresos <%= prevGas > 0 ? fmt(prevGas) : 'sin datos' %> · Utilidad <%= fmt(prevUtil) %></div>
  <a href="/admin/finanzas/estado-resultados?period=<%= pYear %>-<%= String(pMonth===1?12:pMonth-1).padStart(2,'0') %>" style="font-size:.78rem;color:#F25C05;text-decoration:none;font-weight:700">Ver período anterior →</a>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">

  <!-- Estado de resultados principal -->
  <div class="crm-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <span class="crm-card-title" style="margin-bottom:0">Estado de Resultados</span>
      <span style="font-size:.78rem;color:#71717a;font-weight:700"><%= periodLabel %></span>
    </div>

    <!-- Ingresos -->
    <div style="margin-bottom:16px">
      <div style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#a1a1aa;margin-bottom:8px">Ingresos</div>
      <table style="width:100%;font-size:.83rem;border-collapse:collapse">
        <tr style="border-bottom:1px solid #f4f4f5">
          <td style="padding:7px 0;color:#52525b">(+) Servicios (subtotal sin IVA)</td>
          <td style="text-align:right;font-weight:600"><%= fmt(ingServicios) %></td>
        </tr>
        <tr style="border-bottom:1px solid #f4f4f5">
          <td style="padding:7px 0;color:#52525b">(+) Ventas online (pedidos)</td>
          <td style="text-align:right;font-weight:600"><%= fmt(ingVentas) %></td>
        </tr>
        <tr style="border-bottom:2px solid #e4e4e7;background:#f0fdf4">
          <td style="padding:9px 0;font-weight:800;color:#16a34a">TOTAL INGRESOS<%- delta(ingDelta) %></td>
          <td style="text-align:right;font-weight:900;color:#16a34a;font-size:.9rem"><%= fmt(totalIngresos) %></td>
        </tr>
      </table>
    </div>

    <!-- Egresos por categoría -->
    <div style="margin-bottom:16px">
      <div style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#a1a1aa;margin-bottom:8px">Egresos Operacionales</div>
      <table style="width:100%;font-size:.83rem;border-collapse:collapse">
        <% if (Object.keys(gastosPorCat).length === 0) { %>
          <tr><td colspan="2" style="padding:12px 0;color:#a1a1aa;font-style:italic;font-size:.8rem">Sin egresos registrados en este período.</td></tr>
        <% } else { %>
          <% Object.entries(gastosPorCat).sort((a,b) => b[1]-a[1]).forEach(([cat,amt]) => { %>
          <tr style="border-bottom:1px solid #f4f4f5">
            <td style="padding:7px 0;color:#52525b">(-) <%= GASTO_CATS[cat] || cat %></td>
            <td style="text-align:right;font-weight:600;color:#dc2626"><%= fmt(amt) %></td>
          </tr>
          <% }) %>
        <% } %>
        <tr style="background:#fef2f2;border-top:1px solid #fecaca">
          <td style="padding:9px 0;font-weight:800;color:#dc2626">TOTAL EGRESOS<%- delta(gasDelta) %></td>
          <td style="text-align:right;font-weight:900;color:#dc2626;font-size:.9rem"><%= fmt(totalEgresos) %></td>
        </tr>
      </table>
    </div>

    <!-- Resultado -->
    <div style="background:<%= utilidadBruta >= 0 ? '#f0fdf4' : '#fef2f2' %>;border:2px solid <%= utilidadBruta >= 0 ? '#bbf7d0' : '#fecaca' %>;border-radius:10px;padding:14px 16px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <span style="font-weight:900;font-size:.95rem;color:<%= utilidadBruta >= 0 ? '#16a34a' : '#dc2626' %>">UTILIDAD NETA<%- delta(netDelta) %></span>
        <span style="font-weight:900;font-size:1.1rem;color:<%= utilidadBruta >= 0 ? '#16a34a' : '#dc2626' %>"><%= fmt(utilidadBruta) %></span>
      </div>
      <div style="font-size:.8rem;color:#52525b">Margen de utilidad: <strong style="color:<%= utilidadBruta >= 0 ? '#16a34a' : '#dc2626' %>"><%= margen %>%</strong></div>
    </div>
  </div>

  <!-- Panel adicional -->
  <div>

    <!-- Indicadores clave -->
    <div class="crm-card" style="margin-bottom:20px">
      <span class="crm-card-title">Indicadores del período</span>
      <table style="width:100%;font-size:.83rem;border-collapse:collapse">
        <tr style="border-bottom:1px solid #f4f4f5">
          <td style="padding:9px 0;color:#52525b">Facturas emitidas</td>
          <td style="text-align:right;font-weight:700"><%= invCount %></td>
        </tr>
        <tr style="border-bottom:1px solid #f4f4f5">
          <td style="padding:9px 0;color:#52525b">Pedidos online</td>
          <td style="text-align:right;font-weight:700"><%= ordCount %></td>
        </tr>
        <tr style="border-bottom:1px solid #f4f4f5">
          <td style="padding:9px 0;color:#52525b">IVA recaudado (informativo)</td>
          <td style="text-align:right;font-weight:700;color:#3b82f6"><%= fmt(ingIVA) %></td>
        </tr>
        <tr style="border-bottom:1px solid #f4f4f5">
          <td style="padding:9px 0;color:#52525b">Cuentas por cobrar (total)</td>
          <td style="text-align:right;font-weight:700;color:#d97706"><%= fmt(cuentasPorCobrar) %></td>
        </tr>
        <tr>
          <td style="padding:9px 0;color:#52525b">Margen operativo</td>
          <td style="text-align:right;font-weight:700;color:<%= parseFloat(margen) >= 0 ? '#16a34a' : '#dc2626' %>"><%= margen %>%</td>
        </tr>
      </table>
    </div>

    <!-- Comparación con mes anterior -->
    <div class="crm-card">
      <span class="crm-card-title">vs. Período anterior (<%= prevLabel %>)</span>
      <table style="width:100%;font-size:.83rem;border-collapse:collapse">
        <thead>
          <tr style="border-bottom:1px solid #f4f4f5">
            <th style="text-align:left;padding:6px 0;font-size:.72rem;color:#a1a1aa;font-weight:700">Concepto</th>
            <th style="text-align:right;padding:6px 0;font-size:.72rem;color:#a1a1aa;font-weight:700">Actual</th>
            <th style="text-align:right;padding:6px 0;font-size:.72rem;color:#a1a1aa;font-weight:700">Anterior</th>
            <th style="text-align:right;padding:6px 0;font-size:.72rem;color:#a1a1aa;font-weight:700">Δ</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid #f4f4f5">
            <td style="padding:8px 0;color:#52525b">Ingresos</td>
            <td style="text-align:right;font-weight:600;font-size:.82rem"><%= fmt(totalIngresos) %></td>
            <td style="text-align:right;font-size:.82rem" class="muted"><%= fmt(prevIng) %></td>
            <td style="text-align:right;font-size:.8rem;font-weight:700;color:<%= ingDelta!==null?(ingDelta>=0?'#16a34a':'#dc2626'):'#a1a1aa' %>">
              <%= ingDelta !== null ? (ingDelta > 0 ? '+' : '') + ingDelta + '%' : 'N/A' %>
            </td>
          </tr>
          <tr style="border-bottom:1px solid #f4f4f5">
            <td style="padding:8px 0;color:#52525b">Egresos</td>
            <td style="text-align:right;font-weight:600;font-size:.82rem"><%= fmt(totalEgresos) %></td>
            <td style="text-align:right;font-size:.82rem" class="muted"><%= fmt(prevGas) %></td>
            <td style="text-align:right;font-size:.8rem;font-weight:700;color:<%= gasDelta!==null?(gasDelta<=0?'#16a34a':'#dc2626'):'#a1a1aa' %>">
              <%= gasDelta !== null ? (gasDelta > 0 ? '+' : '') + gasDelta + '%' : 'N/A' %>
            </td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-weight:700">Utilidad</td>
            <td style="text-align:right;font-weight:700;font-size:.82rem;color:<%= utilidadBruta>=0?'#16a34a':'#dc2626' %>"><%= fmt(utilidadBruta) %></td>
            <td style="text-align:right;font-size:.82rem" class="muted"><%= fmt(prevUtil) %></td>
            <td style="text-align:right;font-size:.8rem;font-weight:700;color:<%= netDelta!==null?(netDelta>=0?'#16a34a':'#dc2626'):'#a1a1aa' %>">
              <%= netDelta !== null ? (netDelta > 0 ? '+' : '') + netDelta + '%' : 'N/A' %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap">
      <a class="btn btn-ghost btn-sm" href="/admin/finanzas/flujo-caja?year=<%= pYear %>">Ver flujo de caja <%= pYear %></a>
      <a class="btn btn-ghost btn-sm" href="/admin/finanzas/egresos?period=<%= periodParam %>">Gestionar egresos</a>
    </div>
  </div>

</div>

<%- include('../../partials/admin-foot') %>
