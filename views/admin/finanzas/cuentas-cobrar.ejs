<%- include('../../partials/admin-head', { title: 'Finanzas — Cuentas por Cobrar' }) %>
<% const fmt = n => '$' + Number(n).toLocaleString('es-CO'); %>

<div class="crm-page-header">
  <h1 class="crm-page-title">Cuentas por Cobrar</h1>
  <a class="btn btn-ghost btn-sm" href="/admin/facturas">Ver todas las facturas</a>
</div>

<%- include('../../partials/finanzas-nav') %>

<!-- KPIs de aging -->
<div class="crm-kpi-row" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px">
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #f59e0b">
    <div class="crm-kpi-value" style="font-size:.95rem;color:#d97706"><%= fmt(totalPendiente) %></div>
    <div class="crm-kpi-label">Total por cobrar (<%= pending.length %>)</div>
  </div>
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #22c55e">
    <div class="crm-kpi-value"><%= aging['0-30'].length %></div>
    <div class="crm-kpi-label" style="font-size:.72rem">0–30 días · <span style="font-weight:700"><%= fmt(aging['0-30'].reduce((s,i)=>s+i.total,0)) %></span></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #f59e0b">
    <div class="crm-kpi-value"><%= aging['31-60'].length %></div>
    <div class="crm-kpi-label" style="font-size:.72rem">31–60 días · <span style="font-weight:700"><%= fmt(aging['31-60'].reduce((s,i)=>s+i.total,0)) %></span></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #F25C05">
    <div class="crm-kpi-value"><%= aging['61-90'].length %></div>
    <div class="crm-kpi-label" style="font-size:.72rem">61–90 días · <span style="font-weight:700"><%= fmt(aging['61-90'].reduce((s,i)=>s+i.total,0)) %></span></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #ef4444">
    <div class="crm-kpi-value"><%= aging['+90'].length %></div>
    <div class="crm-kpi-label" style="font-size:.72rem">+90 días · <span style="font-weight:700"><%= fmt(aging['+90'].reduce((s,i)=>s+i.total,0)) %></span></div>
  </div>
</div>

<!-- Visualización de aging -->
<% const agingTotal = pending.length; %>
<% if (agingTotal > 0) { %>
<div class="crm-card" style="margin-bottom:20px">
  <span class="crm-card-title">Distribución por antigüedad</span>
  <div style="display:flex;height:28px;border-radius:8px;overflow:hidden;gap:2px;margin-bottom:10px">
    <% if (aging['0-30'].length > 0) { %>
      <div style="flex:<%= aging['0-30'].length %>;background:#22c55e;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.72rem;font-weight:700;min-width:2px" title="0-30 días"></div>
    <% } %>
    <% if (aging['31-60'].length > 0) { %>
      <div style="flex:<%= aging['31-60'].length %>;background:#f59e0b;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.72rem;font-weight:700;min-width:2px" title="31-60 días"></div>
    <% } %>
    <% if (aging['61-90'].length > 0) { %>
      <div style="flex:<%= aging['61-90'].length %>;background:#F25C05;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.72rem;font-weight:700;min-width:2px" title="61-90 días"></div>
    <% } %>
    <% if (aging['+90'].length > 0) { %>
      <div style="flex:<%= aging['+90'].length %>;background:#ef4444;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.72rem;font-weight:700;min-width:2px" title="+90 días"></div>
    <% } %>
  </div>
  <div style="display:flex;gap:16px;font-size:.72rem">
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#22c55e;border-radius:2px;display:inline-block"></span>0–30 días</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#f59e0b;border-radius:2px;display:inline-block"></span>31–60 días</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#F25C05;border-radius:2px;display:inline-block"></span>61–90 días</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:#ef4444;border-radius:2px;display:inline-block"></span>+90 días (vencida)</span>
  </div>
</div>
<% } %>

<!-- Tabla de cuentas por cobrar -->
<div class="crm-card">
  <span class="crm-card-title">Facturas pendientes de pago</span>
  <% if (pending.length === 0) { %>
    <p class="muted" style="text-align:center;padding:48px 0;font-size:.88rem">No hay facturas pendientes. ¡Excelente!</p>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr><th>N° Factura</th><th>Fecha</th><th>Orden</th><th style="text-align:right">Total</th><th>Días</th><th>Antigüedad</th><th></th></tr>
      </thead>
      <tbody>
        <% pending.forEach(inv => { %>
          <%
            let ageBadge, ageCls;
            if (inv.days <= 30)       { ageBadge = '0–30 días';    ageCls = 'badge-success'; }
            else if (inv.days <= 60)  { ageBadge = '31–60 días';   ageCls = 'badge-warning'; }
            else if (inv.days <= 90)  { ageBadge = '61–90 días';   ageCls = 'badge-orange'; }
            else                      { ageBadge = '+90 días';      ageCls = 'badge-danger'; }
          %>
        <tr>
          <td><span class="badge badge-warning" style="font-weight:900;font-size:.78rem"><%= inv.label %></span></td>
          <td class="muted" style="font-size:.78rem;white-space:nowrap"><%= new Date(inv.createdAt).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'}) %></td>
          <td><a href="/admin/ordenes-servicio/<%= inv.serviceOrderId %>" style="color:#F25C05;font-size:.82rem;text-decoration:none">Ver orden</a></td>
          <td style="text-align:right;font-weight:700;color:#d97706"><%= fmt(inv.total) %></td>
          <td style="font-weight:700;color:<%= inv.days > 90 ? '#dc2626' : inv.days > 60 ? '#ea580c' : inv.days > 30 ? '#d97706' : '#16a34a' %>"><%= inv.days %>d</td>
          <td><span class="badge <%= ageCls %>" style="font-size:.7rem"><%= ageBadge %></span></td>
          <td><a class="btn btn-ghost btn-sm" href="/admin/facturas/<%= inv.id %>">Ver factura</a></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr style="background:#fffbeb">
          <td colspan="3" style="font-weight:800;padding:10px 14px">TOTAL PENDIENTE</td>
          <td style="text-align:right;font-weight:900;color:#d97706;font-size:.9rem;padding:10px 14px"><%= fmt(totalPendiente) %></td>
          <td colspan="3"></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% } %>
</div>

<%- include('../../partials/admin-foot') %>
