<%- include('../../partials/admin-head', { title: 'Finanzas — Ingresos' }) %>
<% const fmt = n => '$' + Number(n).toLocaleString('es-CO'); %>

<div class="crm-page-header">
  <h1 class="crm-page-title">Ingresos</h1>
  <form method="get" action="/admin/finanzas/ingresos" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
    <select name="period" class="crm-select" onchange="this.form.submit()">
      <% availablePeriods.forEach(p => { %>
        <option value="<%= p %>" <%= p === periodParam ? 'selected' : '' %>>
          <% const [py,pm] = p.split('-').map(Number); %><%= MONTH_NAMES[pm-1] %> <%= py %>
        </option>
      <% }) %>
    </select>
    <select name="source" class="crm-select" onchange="this.form.submit()">
      <option value="todos" <%= source==='todos' ? 'selected':'' %>>Todas las fuentes</option>
      <option value="facturas" <%= source==='facturas' ? 'selected':'' %>>Solo Facturas</option>
      <option value="pedidos" <%= source==='pedidos' ? 'selected':'' %>>Solo Pedidos online</option>
    </select>
  </form>
</div>

<%- include('../../partials/finanzas-nav') %>

<!-- KPIs -->
<div class="crm-kpi-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:20px">
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #22c55e">
    <div class="crm-kpi-value" style="font-size:.95rem;color:#16a34a"><%= fmt(totalIng) %></div>
    <div class="crm-kpi-label">Total ingresos — <%= periodLabel %></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value" style="font-size:.95rem"><%= fmt(totalSubtot) %></div>
    <div class="crm-kpi-label">Subtotal (sin IVA)</div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value" style="font-size:.95rem"><%= fmt(totalTax) %></div>
    <div class="crm-kpi-label">IVA recaudado</div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= invCount + ordCount %></div>
    <div class="crm-kpi-label"><%= invCount %> factura<%= invCount!==1?'s':'' %> + <%= ordCount %> pedido<%= ordCount!==1?'s':'' %></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 260px;gap:20px;margin-bottom:20px">

  <!-- Tabla movimientos -->
  <div class="crm-card" style="margin-bottom:0">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <span class="crm-card-title" style="margin-bottom:0">Movimientos — <%= periodLabel %></span>
      <span class="badge <%= movements.length>0?'badge-success':'badge-muted' %>"><%= movements.length %> movimiento<%= movements.length!==1?'s':'' %></span>
    </div>
    <% if (movements.length === 0) { %>
      <p class="muted" style="text-align:center;padding:40px 0">No hay ingresos registrados para este período y fuente.</p>
    <% } else { %>
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead>
          <tr><th>Tipo</th><th>Referencia</th><th>Fecha</th><th>Método</th><th style="text-align:right">Subtotal</th><th style="text-align:right">IVA</th><th style="text-align:right">Total</th><th></th></tr>
        </thead>
        <tbody>
          <% movements.forEach(mov => { %>
          <tr>
            <td><span class="badge <%= mov.type==='factura'?'badge-success':'badge-info' %>" style="font-size:.7rem"><%= mov.type==='factura'?'Factura':'Pedido' %></span></td>
            <td style="font-weight:700;font-size:.82rem"><%= mov.ref %></td>
            <td class="muted" style="font-size:.78rem;white-space:nowrap"><%= new Date(mov.date).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'}) %></td>
            <td style="font-size:.8rem;text-transform:capitalize"><%= METHOD_LABELS[mov.method] || mov.method %></td>
            <td style="text-align:right;font-size:.82rem"><%= fmt(mov.subtotal) %></td>
            <td style="text-align:right;font-size:.8rem" class="muted"><%= mov.tax > 0 ? fmt(mov.tax) : '—' %></td>
            <td style="text-align:right;font-weight:700;color:#16a34a"><%= fmt(mov.total) %></td>
            <td><% if (mov.link) { %><a class="btn btn-ghost btn-sm" href="<%= mov.link %>">Ver</a><% } %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr style="background:#fafafa">
            <td colspan="4" style="font-weight:800;font-size:.82rem;padding:10px 14px">TOTAL del período</td>
            <td style="text-align:right;font-weight:700;padding:10px 14px"><%= fmt(totalSubtot) %></td>
            <td style="text-align:right;font-weight:700;padding:10px 14px"><%= fmt(totalTax) %></td>
            <td style="text-align:right;font-weight:900;color:#16a34a;font-size:.9rem;padding:10px 14px"><%= fmt(totalIng) %></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Panel lateral -->
  <div>
    <!-- Por método de pago -->
    <div class="crm-card">
      <span class="crm-card-title">Por método de pago</span>
      <% if (Object.keys(byMethod).length === 0) { %>
        <p class="muted" style="font-size:.83rem;text-align:center;padding:16px 0">Sin datos</p>
      <% } else { %>
        <% Object.entries(byMethod).sort((a,b) => b[1]-a[1]).forEach(([m2, amt]) => { %>
          <% const pct = Math.round((amt/methodMax)*100); %>
          <div style="margin-bottom:12px">
            <div style="display:flex;justify-content:space-between;font-size:.76rem;margin-bottom:4px">
              <span style="color:#52525b"><%= METHOD_LABELS[m2] || m2 %></span>
              <span style="font-weight:700"><%= fmt(amt) %></span>
            </div>
            <div style="height:5px;background:#f4f4f5;border-radius:3px;overflow:hidden">
              <div style="height:100%;width:<%= pct %>%;background:#22c55e;border-radius:3px"></div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- Totales históricos -->
    <div class="crm-card">
      <span class="crm-card-title">Histórico acumulado</span>
      <div style="font-size:.82rem">
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f4f4f5"><span class="muted">Facturas</span><strong><%= fmt(allTimeInv) %></strong></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f4f4f5"><span class="muted">Pedidos online</span><strong><%= fmt(allTimeOrd) %></strong></div>
        <div style="display:flex;justify-content:space-between;padding:10px 0"><span style="font-weight:800">Total</span><strong style="color:#16a34a;font-size:.9rem"><%= fmt(allTimeTotal) %></strong></div>
      </div>
    </div>
  </div>

</div>

<%- include('../../partials/admin-foot') %>
