<%- include('../../partials/admin-head', { title: 'Finanzas — Egresos' }) %>
<% const fmt = n => '$' + Number(n).toLocaleString('es-CO'); %>

<div class="crm-page-header">
  <h1 class="crm-page-title">Egresos</h1>
  <form method="get" action="/admin/finanzas/egresos" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
    <select name="period" class="crm-select" onchange="this.form.submit()">
      <% availablePeriods.forEach(p => { %>
        <option value="<%= p %>" <%= p === periodParam ? 'selected' : '' %>>
          <% const [py,pm] = p.split('-').map(Number); %><%= MONTH_NAMES[pm-1] %> <%= py %>
        </option>
      <% }) %>
    </select>
    <select name="cat" class="crm-select" onchange="this.form.submit()">
      <option value="">Todas las categorías</option>
      <% Object.entries(GASTO_CATS).forEach(([k,v]) => { %>
        <option value="<%= k %>" <%= catFilter===k?'selected':'' %>><%= v %></option>
      <% }) %>
    </select>
  </form>
</div>

<%- include('../../partials/finanzas-nav') %>

<% if (flash === 'created') { %>
  <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:10px 16px;margin-bottom:16px;font-size:.83rem;color:#16a34a;font-weight:700">Gasto registrado correctamente.</div>
<% } else if (flash === 'updated') { %>
  <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:10px 16px;margin-bottom:16px;font-size:.83rem;color:#1d4ed8;font-weight:700">Gasto actualizado.</div>
<% } else if (flash === 'deleted') { %>
  <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 16px;margin-bottom:16px;font-size:.83rem;color:#dc2626;font-weight:700">Gasto eliminado.</div>
<% } else if (flash === 'error') { %>
  <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 16px;margin-bottom:16px;font-size:.83rem;color:#dc2626;font-weight:700">Faltan campos obligatorios.</div>
<% } %>

<!-- KPIs -->
<div class="crm-kpi-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px">
  <div class="crm-kpi-card" style="cursor:default;border-left:4px solid #ef4444">
    <div class="crm-kpi-value" style="font-size:.95rem;color:#dc2626"><%= fmt(totalPeriodo) %></div>
    <div class="crm-kpi-label">Total egresos — <%= periodLabel %></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= filtered.length %></div>
    <div class="crm-kpi-label">Gastos del período<% if (catFilter) { %> (<%= GASTO_CATS[catFilter] || catFilter %>)<% } %></div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value" style="font-size:.95rem"><%= fmt(totalAllTime) %></div>
    <div class="crm-kpi-label">Total histórico</div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 280px;gap:20px">

  <div>
    <!-- Formulario nuevo gasto -->
    <div class="crm-card" style="margin-bottom:20px">
      <span class="crm-card-title"><%= editGasto ? 'Editar gasto' : 'Registrar nuevo gasto' %></span>
      <form method="post" action="<%= editGasto ? '/admin/finanzas/egresos/'+editGasto.id+'/actualizar' : '/admin/finanzas/egresos/crear' %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="period" value="<%= periodParam %>" />
        <div class="crm-form-grid cols-3">
          <div class="crm-form-group">
            <label>Descripción *</label>
            <input type="text" name="description" required placeholder="Ej: Pago arriendo marzo" value="<%= editGasto ? editGasto.description : '' %>">
          </div>
          <div class="crm-form-group">
            <label>Monto (COP) *</label>
            <input type="number" name="amount" required min="0" placeholder="0" value="<%= editGasto ? editGasto.amount : '' %>">
          </div>
          <div class="crm-form-group">
            <label>Fecha *</label>
            <input type="date" name="date" required value="<%= editGasto ? editGasto.date : new Date().toISOString().slice(0,10) %>">
          </div>
          <div class="crm-form-group">
            <label>Categoría</label>
            <select name="category">
              <% Object.entries(GASTO_CATS).forEach(([k,v]) => { %>
                <option value="<%= k %>" <%= (editGasto ? editGasto.category : 'otros') === k ? 'selected':'' %>><%= v %></option>
              <% }) %>
            </select>
          </div>
          <div class="crm-form-group">
            <label>Método de pago</label>
            <select name="paymentMethod">
              <% Object.entries(METHOD_LABELS).forEach(([k,v]) => { %>
                <option value="<%= k %>" <%= (editGasto ? editGasto.paymentMethod : 'efectivo') === k ? 'selected':'' %>><%= v %></option>
              <% }) %>
            </select>
          </div>
          <div class="crm-form-group">
            <label>Notas</label>
            <input type="text" name="notes" placeholder="Opcional" value="<%= editGasto ? (editGasto.notes || '') : '' %>">
          </div>
        </div>
        <div class="crm-form-actions">
          <% if (editGasto) { %>
            <a class="btn btn-ghost btn-sm" href="/admin/finanzas/egresos?period=<%= periodParam %>">Cancelar</a>
          <% } %>
          <button type="submit" class="btn btn-sm"><%= editGasto ? 'Guardar cambios' : 'Registrar gasto' %></button>
        </div>
      </form>
    </div>

    <!-- Tabla de gastos -->
    <div class="crm-card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <span class="crm-card-title" style="margin-bottom:0">Gastos — <%= periodLabel %><% if(catFilter){%> · <%= GASTO_CATS[catFilter]||catFilter %><% } %></span>
        <span class="badge <%= filtered.length>0?'badge-warning':'badge-muted' %>"><%= filtered.length %> registros</span>
      </div>
      <% if (filtered.length === 0) { %>
        <p class="muted" style="text-align:center;padding:32px 0">No hay egresos para este período.</p>
      <% } else { %>
      <div class="crm-table-wrap">
        <table class="crm-table">
          <thead>
            <tr><th>Fecha</th><th>Descripción</th><th>Categoría</th><th>Método</th><th style="text-align:right">Monto</th><th>Notas</th><th></th></tr>
          </thead>
          <tbody>
            <% filtered.forEach(g => { %>
            <tr>
              <td class="muted" style="font-size:.78rem;white-space:nowrap"><%= new Date(g.date+'T12:00:00').toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'}) %></td>
              <td style="font-weight:600;font-size:.83rem"><%= g.description %></td>
              <td><span class="badge badge-muted" style="font-size:.68rem"><%= GASTO_CATS[g.category] || g.category %></span></td>
              <td style="font-size:.8rem"><%= METHOD_LABELS[g.paymentMethod] || g.paymentMethod %></td>
              <td style="text-align:right;font-weight:700;color:#dc2626"><%= fmt(g.amount) %></td>
              <td class="muted" style="font-size:.78rem;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= g.notes || '—' %></td>
              <td>
                <div class="crm-table-actions">
                  <a class="btn btn-ghost btn-xs" href="/admin/finanzas/egresos?edit=<%= g.id %>&period=<%= periodParam %>&cat=<%= catFilter %>">Editar</a>
                  <form method="post" action="/admin/finanzas/egresos/<%= g.id %>/eliminar" data-confirm="¿Eliminar este gasto?">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="period" value="<%= periodParam %>" />
                    <button type="submit" class="btn btn-ghost btn-xs" style="color:#dc2626">Eliminar</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr style="background:#fafafa">
              <td colspan="4" style="font-weight:800;font-size:.82rem;padding:10px 14px">TOTAL</td>
              <td style="text-align:right;font-weight:900;color:#dc2626;font-size:.9rem;padding:10px 14px"><%= fmt(totalPeriodo) %></td>
              <td colspan="2"></td>
            </tr>
          </tfoot>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Panel lateral: distribución por categoría -->
  <div class="crm-card" style="align-self:start">
    <span class="crm-card-title">Distribución por categoría</span>
    <p class="muted" style="font-size:.75rem;margin:-8px 0 14px">Período: <%= periodLabel %></p>
    <% if (Object.keys(byCategory).length === 0) { %>
      <p class="muted" style="text-align:center;padding:20px 0;font-size:.83rem">Sin datos</p>
    <% } else { %>
      <% Object.entries(byCategory).sort((a,b) => b[1]-a[1]).forEach(([cat, amt]) => { %>
        <% const pct = Math.round((amt / catMax) * 100); %>
        <div style="margin-bottom:14px">
          <div style="display:flex;justify-content:space-between;font-size:.76rem;margin-bottom:5px">
            <a href="/admin/finanzas/egresos?period=<%= periodParam %>&cat=<%= cat %>" style="color:#52525b;text-decoration:none;font-weight:<%= catFilter===cat?'800':'400' %>"><%= GASTO_CATS[cat] || cat %></a>
            <span style="font-weight:700;color:#dc2626"><%= fmt(amt) %></span>
          </div>
          <div style="height:6px;background:#f4f4f5;border-radius:3px;overflow:hidden">
            <div style="height:100%;width:<%= pct %>%;background:<%= catFilter===cat?'#dc2626':'#f87171' %>;border-radius:3px"></div>
          </div>
          <div style="font-size:.68rem;color:#a1a1aa;margin-top:2px"><%= pct %>% del total</div>
        </div>
      <% }) %>
    <% } %>
  </div>

</div>

<%- include('../../partials/admin-foot') %>
