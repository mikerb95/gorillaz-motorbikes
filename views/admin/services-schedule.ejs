<%- include('../partials/admin-head', { title: 'Agenda de Servicios' }) %>

<div class="crm-page-header">
  <h1 class="crm-page-title">Agenda de Servicios — <%= monthYear %></h1>
</div>

<!-- Stats -->
<div class="crm-kpi-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:18px">
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= appointments.length %></div>
    <div class="crm-kpi-label">Total citas</div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= appointments.filter(a => a.status === 'pendiente' || !a.status).length %></div>
    <div class="crm-kpi-label">Pendientes</div>
  </div>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value"><%= appointments.filter(a => a.status === 'confirmada').length %></div>
    <div class="crm-kpi-label">Confirmadas</div>
  </div>
</div>

<!-- Filters -->
<div class="crm-card" style="margin-bottom:18px">
  <form method="get" action="/admin/agenda-servicios" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end">
    <div class="crm-form-group" style="flex:1;min-width:160px">
      <label>Servicio</label>
      <select name="service">
        <option value="">Todos</option>
        <% services.forEach(s => { %>
          <option value="<%= s %>" <%= selectedService === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
    <div class="crm-form-group" style="flex:1;min-width:160px">
      <label>Mes</label>
      <input type="month" name="month" value="<%= currentMonth %>" />
    </div>
    <button class="btn btn-primary btn-sm" type="submit" style="align-self:flex-end;margin-bottom:0">Filtrar</button>
    <% if (selectedService) { %>
      <a href="/admin/agenda-servicios?month=<%= currentMonth %>" class="btn btn-ghost btn-sm" style="align-self:flex-end;margin-bottom:0">Limpiar</a>
    <% } %>
  </form>
</div>

<!-- Calendar grid -->
<div class="crm-card" style="margin-bottom:18px">
  <div class="crm-card-title"><%= monthYear %></div>
  <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px">
    <% ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'].forEach(d => { %>
      <div style="font-weight:800;font-size:.72rem;color:#71717a;text-align:center;padding:6px;text-transform:uppercase;letter-spacing:.05em"><%= d %></div>
    <% }) %>
    <% calendarDays.forEach(day => { %>
      <div style="border:1px solid <%= day.appointments && day.appointments.length > 0 ? '#F25C05' : '#e4e4e7' %>;
           border-radius:8px;padding:6px;min-height:70px;
           background:<%= !day.isCurrentMonth ? '#fafafa' : day.appointments && day.appointments.length > 0 ? '#fff8f5' : '#fff' %>;
           opacity:<%= day.isCurrentMonth ? 1 : 0.45 %>">
        <div style="font-weight:800;font-size:.78rem;color:<%= day.isCurrentMonth ? '#18181b' : '#a1a1aa' %>;margin-bottom:4px"><%= day.date %></div>
        <% if (day.isCurrentMonth && day.appointments && day.appointments.length > 0) { %>
          <div style="display:flex;flex-direction:column;gap:2px">
            <% day.appointments.slice(0, 2).forEach(apt => { %>
              <div style="background:#F25C05;color:#fff;border-radius:4px;padding:2px 4px;font-size:.65rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="<%= apt.customer %> — <%= apt.service %>">
                <%= apt.service.substring(0, 10) %>
              </div>
            <% }) %>
            <% if (day.appointments.length > 2) { %>
              <div style="background:#e4e4e7;border-radius:4px;padding:2px 4px;font-size:.65rem;text-align:center;color:#52525b">
                +<%= day.appointments.length - 2 %>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>

<!-- Appointments list -->
<div class="crm-card" style="padding:0;overflow:hidden">
  <div style="padding:12px 16px;font-weight:800;font-size:.85rem;border-bottom:1px solid #e4e4e7">
    Citas — <%= monthYear %><% if (selectedService) { %> · <%= selectedService %><% } %>
    <span style="font-weight:400;font-size:.8rem;color:#71717a;margin-left:8px"><%= filteredAppointments.length %> resultado(s)</span>
  </div>
  <% if (!filteredAppointments.length) { %>
    <div style="padding:24px;text-align:center;color:#71717a;font-size:.85rem">No hay citas para este período.</div>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Hora</th>
          <th>Cliente</th>
          <th>Teléfono</th>
          <th>Servicio</th>
          <th>Estado</th>
          <th style="width:90px">Eliminar</th>
        </tr>
      </thead>
      <tbody>
        <% filteredAppointments.forEach(apt => { %>
          <tr>
            <td style="font-size:.82rem;white-space:nowrap">
              <%= new Date(apt.date + 'T12:00:00').toLocaleDateString('es-CO', { year:'numeric', month:'short', day:'numeric' }) %>
            </td>
            <td style="font-size:.82rem"><%= apt.time || '—' %></td>
            <td><strong><%= apt.customer || apt.name %></strong></td>
            <td style="font-size:.82rem">
              <% if (apt.phone) { %><a href="tel:<%= apt.phone %>" style="color:#2563eb"><%= apt.phone %></a><% } else { %><span style="color:#71717a">—</span><% } %>
            </td>
            <td><span class="badge badge-muted"><%= apt.service %></span></td>
            <td>
              <form method="post" action="/admin/citas/estado" style="display:flex;gap:5px;align-items:center">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="id" value="<%= apt.id %>" />
                <select name="status" onchange="this.form.submit()" style="font-size:.75rem;padding:4px 6px;border:1px solid #e4e4e7;border-radius:6px;background:#fafafa">
                  <% ['pendiente','confirmada','completada','cancelada'].forEach(s => { %>
                    <option value="<%= s %>" <%= apt.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
              </form>
            </td>
            <td>
              <form method="post" action="/admin/citas/eliminar" data-confirm="¿Eliminar cita de <%= apt.customer %>?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="id" value="<%= apt.id %>" />
                <button class="btn btn-sm btn-danger" type="submit">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
