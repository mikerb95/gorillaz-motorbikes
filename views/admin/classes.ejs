<%- include('../partials/admin-head', { title: 'Clases / Presentaciones' }) %>

<div class="crm-page-header">

</div>

<p style="color:#71717a;font-size:.85rem;margin:0 0 18px">Selecciona un curso y un tema para iniciar la presentación de clases.</p>

<% Object.entries(classesData).forEach(([courseKey, course]) => { %>
  <div class="crm-card" style="margin-bottom:14px">
    <div class="crm-card-title"><%= course.title %></div>
    <% const topics = Object.entries(course.topics || {}); %>
    <% if (!topics.length) { %>
      <p style="color:#71717a;font-size:.85rem;margin:0">Sin temas disponibles.</p>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:6px">
        <% topics.forEach(([topicKey, topic]) => { %>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:#fafafa;border:1px solid #e4e4e7;border-radius:8px">
            <strong style="font-size:.85rem"><%= topic.title %></strong>
            <a class="btn btn-sm btn-primary" href="/clases/<%= courseKey %>/<%= topicKey %>">Iniciar presentación</a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
<% }) %>

<%- include('../partials/admin-foot') %>
