<%- include('../partials/head', { title: 'Admin — Tienda' }) %>
<main class="container section">
  <div class="admin-top">
    <h1 class="section-title">Artículos de la Tienda</h1>
    <a href="#crear" class="btn btn-primary" onclick="document.getElementById('crearSection').toggleAttribute('hidden');return false">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nuevo producto
    </a>
  </div>

  <!-- Search & Filters bar -->
  <div class="admin-filters card" style="margin-top:16px">
    <form method="get" action="/admin/tienda" class="admin-filters-form">
      <input name="q" value="<%= search || '' %>" placeholder="Buscar por nombre o SKU..." class="admin-search-input" />
      <select name="cat">
        <option value="">Todas las categorías</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.slug %>" <%= filterCat === c.slug ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
      <button class="btn btn-sm" type="submit">Filtrar</button>
      <% if (search || filterCat) { %>
        <a href="/admin/tienda" class="btn btn-ghost btn-sm">Limpiar</a>
      <% } %>
    </form>
  </div>

  <!-- Create product form (hidden by default) -->
  <section id="crearSection" class="card stack" hidden style="margin-top:16px">
    <h3>Crear artículo</h3>
    <form class="admin-create-form" method="post" action="/admin/tienda/crear" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="grid two">
        <label>Nombre <span class="required">*</span><input name="name" required /></label>
        <label>Precio (COP) <span class="required">*</span><input type="number" name="price" min="0" required /></label>
        <label>Categoría <span class="required">*</span>
          <select name="category" required>
            <option value="">— Seleccionar —</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.slug %>"><%= c.name %></option>
            <% }) %>
          </select>
        </label>
        <label>SKU<input name="sku" placeholder="Ej: NK-CAS-001" /></label>
        <label>Marca<input name="brand" placeholder="Ej: Gorillaz" /></label>
        <label>Stock<input type="number" name="stock" min="0" value="0" /></label>
        <label>Descuento (%)<input type="number" name="discount" min="0" max="100" value="0" /></label>
        <label>Tags (separadas por coma)<input name="tags" placeholder="casco, protección" /></label>
      </div>
      <label class="full">Descripción<textarea name="description" rows="3"></textarea></label>
      <label>Imágenes<input type="file" name="images" accept="image/*" multiple /></label>
      <button class="btn btn-primary" type="submit">Crear producto</button>
    </form>
  </section>

  <!-- Products table -->
  <section class="section" style="margin-top:16px">
    <p class="muted"><%= products.length %> producto(s)</p>
    <% if (products.length === 0) { %>
      <p>No hay productos que coincidan con tu búsqueda.</p>
    <% } else { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width:60px">Imagen</th>
              <th>Nombre</th>
              <th>SKU</th>
              <th>Categoría</th>
              <th>Precio</th>
              <th>Dto.</th>
              <th>Stock</th>
              <th>Estado</th>
              <th style="width:120px">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(p => { %>
              <tr>
                <td>
                  <img src="<%= p.image || '/images/download.png' %>" alt="<%= p.name %>" class="admin-table-thumb" />
                </td>
                <td>
                  <strong><%= p.name %></strong>
                  <% if (p.brand) { %><br/><span class="muted" style="font-size:.8rem"><%= p.brand %></span><% } %>
                </td>
                <td class="muted"><%= p.sku || '—' %></td>
                <td>
                  <% const cat = categories.find(c => c.slug === p.category); %>
                  <span class="chip"><%= cat ? cat.name : p.category %></span>
                </td>
                <td>
                  <% if (p.discount > 0) { %>
                    <span class="price">$<%= Math.round(p.price * (1 - p.discount / 100)).toLocaleString('es-CO') %></span>
                    <br/><span class="price-old">$<%= p.price.toLocaleString('es-CO') %></span>
                  <% } else { %>
                    <span class="price">$<%= p.price.toLocaleString('es-CO') %></span>
                  <% } %>
                </td>
                <td><%= p.discount || 0 %>%</td>
                <td><%= typeof p.stock === 'number' ? p.stock : '—' %></td>
                <td>
                  <% if (typeof p.stock === 'number' && p.stock === 0) { %>
                    <span class="chip chip-danger">Agotado</span>
                  <% } else if (typeof p.stock === 'number' && p.stock <= 5) { %>
                    <span class="chip chip-warning">Poco stock</span>
                  <% } else { %>
                    <span class="chip chip-success">En stock</span>
                  <% } %>
                </td>
                <td>
                  <div class="admin-table-actions">
                    <a href="/admin/tienda/<%= p.id %>/editar" class="btn btn-sm btn-ghost" title="Editar">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </a>
                    <form method="post" action="/admin/tienda/eliminar" data-confirm="¿Eliminar este artículo?" style="display:inline">
                      <input type="hidden" name="id" value="<%= p.id %>" />
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button class="btn btn-sm btn-danger" type="submit" title="Eliminar">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>
<%- include('../partials/footer') %>
