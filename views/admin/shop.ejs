<%- include('../partials/admin-head', { title: 'Tienda' }) %>

  <div class="crm-page-header">

    <button class="btn btn-primary btn-sm" type="button"
      onclick="document.getElementById('newProductCard').classList.toggle('hidden-card')">
      + Nuevo producto
    </button>
  </div>

  <!-- Create form -->
  <div class="crm-card" id="newProductCard" style="margin-bottom:18px">
    <div class="crm-card-title">Crear producto</div>
    <form method="post" action="/admin/tienda/crear" id="createForm"
      onsubmit="document.getElementById('createPriceInput').value = document.getElementById('createPriceInput').value.replace(/[^\d]/g, '')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="crm-form-grid">
        <div class="crm-form-group">
          <label>Nombre <span class="required">*</span></label>
          <input name="name" required placeholder="Ej: Casco Gorillaz Pro" />
        </div>
        <div class="crm-form-group">
          <label>Precio (COP) <span class="required">*</span></label>
          <input type="text" name="price" id="createPriceInput" min="0" required placeholder="0"
            oninput="formatCreatePrice(); updateCreatePricePreview()" />
        </div>
        <div class="crm-form-group">
          <label>Categoría <span class="required">*</span></label>
          <select name="category" required>
            <option value="">— Seleccionar —</option>
            <% categories.forEach(c=> { %>
              <option value="<%= c.slug %>">
                <%= c.name %>
              </option>
              <% }) %>
          </select>
        </div>
        <div class="crm-form-group">
          <label>SKU</label>
          <input name="sku" placeholder="NK-CAS-001" />
        </div>
        <div class="crm-form-group">
          <label>Marca</label>
          <input name="brand" placeholder="Ej: Gorillaz" />
        </div>
        <div class="crm-form-group">
          <label>Stock</label>
          <input type="number" name="stock" min="0" value="0" />
        </div>
        <div class="crm-form-group">
          <label>Descuento (%)</label>
          <input type="number" name="discount" id="createDiscountInput" min="0" max="100" value="0"
            oninput="updateCreatePricePreview()" />
        </div>
        <div class="crm-form-group">
          <label>Tags (coma)</label>
          <input name="tags" placeholder="casco, protección" />
        </div>
        <div class="crm-form-group crm-form-full">
          <label>Descripción</label>
          <textarea name="description" rows="2" placeholder="Descripción del producto…"></textarea>
        </div>
        <div id="createPricePreview"
          style="display:none;padding:10px 12px;background:#f0fdf4;border-radius:8px;font-size:.85rem;color:#16a34a;font-weight:700;margin-bottom:12px">
        </div>
        <div class="crm-form-group crm-form-full">
          <label>Imágenes</label>
          <div id="createGalleryPreview" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px"></div>
          <label class="btn btn-ghost btn-sm" style="cursor:pointer" id="createUploadLabel">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
              <polyline points="17 8 12 3 7 8" />
              <line x1="12" y1="3" x2="12" y2="15" />
            </svg>
            <span id="createUploadText">Agregar imágenes</span>
            <input type="file" accept="image/*" multiple style="display:none" onchange="handleCreateImages(this)" />
          </label>
        </div>
      </div>
      <div class="crm-form-actions">
        <button class="btn btn-primary btn-sm" type="submit">Crear producto</button>
      </div>
    </form>
  </div>

  <!-- Search & filters -->
  <div class="crm-search-row">
    <form method="get" action="/admin/tienda" style="display:contents">
      <input name="q" value="<%= search || '' %>" placeholder="Buscar por nombre o SKU…" class="crm-search-input" />
      <select name="cat"
        style="border:1px solid #e4e4e7;border-radius:8px;padding:8px 11px;font-size:.85rem;font-family:inherit;background:#fff">
        <option value="">Todas las categorías</option>
        <% categories.forEach(c=> { %>
          <option value="<%= c.slug %>" <%=filterCat===c.slug ? 'selected' : '' %>><%= c.name %>
          </option>
          <% }) %>
      </select>
      <button class="btn btn-sm" type="submit">Filtrar</button>
      <% if (search || filterCat) { %>
        <a href="/admin/tienda" class="btn btn-ghost btn-sm">Limpiar</a>
        <% } %>
    </form>
  </div>

  <!-- Products table -->
  <div class="crm-card" style="padding:0;overflow:hidden">
    <% if (!products.length) { %>
      <div style="padding:32px;text-align:center;color:#71717a">
        No hay productos que coincidan con tu búsqueda.
      </div>
      <% } else { %>
        <div
          style="padding:10px 16px;background:#fafafa;border-bottom:1px solid #e4e4e7;font-size:.75rem;color:#71717a;font-weight:700">
          <%= products.length %> producto(s) encontrado(s)
        </div>
        <div class="crm-table-wrap">
          <table class="crm-table">
            <thead>
              <tr>
                <th style="width:54px">Imagen</th>
                <th>Nombre</th>
                <th>SKU</th>
                <th>Categoría</th>
                <th>Precio</th>
                <th>Dto.</th>
                <th>Stock</th>
                <th>Estado</th>
                <th style="width:110px">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(p=> { %>
                <tr>
                  <td>
                    <img src="<%= p.image || '/images/download.png' %>" alt="<%= p.name %>" class="crm-table-thumb" />
                  </td>
                  <td>
                    <strong>
                      <%= p.name %>
                    </strong>
                    <% if (p.brand) { %><br><span style="font-size:.75rem;color:#71717a">
                        <%= p.brand %>
                      </span>
                      <% } %>
                  </td>
                  <td style="font-size:.8rem;color:#71717a">
                    <%= p.sku || '—' %>
                  </td>
                  <td>
                    <% const cat=categories.find(c=> c.slug === p.category); %>
                      <span class="badge badge-muted">
                        <%= cat ? cat.name : p.category %>
                      </span>
                  </td>
                  <td style="white-space:nowrap">
                    <% if (p.discount> 0) { %>
                      <strong style="color:#16a34a">$<%= Math.round(p.price * (1 - p.discount /
                          100)).toLocaleString('es-CO') %></strong>
                      <br><span style="font-size:.72rem;color:#71717a;text-decoration:line-through">$<%=
                          p.price.toLocaleString('es-CO') %></span>
                      <% } else { %>
                        <strong>$<%= p.price.toLocaleString('es-CO') %></strong>
                        <% } %>
                  </td>
                  <td style="font-size:.8rem">
                    <%= p.discount || 0 %>%
                  </td>
                  <td style="font-size:.85rem">
                    <%= typeof p.stock==='number' ? p.stock : '—' %>
                  </td>
                  <td>
                    <% if (typeof p.stock==='number' && p.stock===0) { %>
                      <span class="badge badge-danger">Agotado</span>
                      <% } else if (typeof p.stock==='number' && p.stock <=5) { %>
                        <span class="badge badge-warning">Poco stock</span>
                        <% } else { %>
                          <span class="badge badge-success">En stock</span>
                          <% } %>
                  </td>
                  <td>
                    <div class="crm-table-actions">
                      <a href="/admin/tienda/<%= p.id %>/editar" class="btn btn-sm btn-primary" title="Editar producto">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                      </a>
                      <form method="post" action="/admin/tienda/eliminar"
                        data-confirm="¿Eliminar «<%= p.name %>»? Esta acción no se puede deshacer.">
                        <input type="hidden" name="id" value="<%= p.id %>" />
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button class="btn btn-sm btn-danger" type="submit" title="Eliminar">
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" />
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </div>

  <script>  function formatCreatePrice() {
      const input = document.getElementById('createPriceInput');
      const value = input.value.replace(/[^\d]/g, '');
      const numValue = parseInt(value, 10);
      if (!isNaN(numValue)) {
        input.value = numValue.toLocaleString('es-CO');
      }
    }

    function updateCreatePricePreview() {
      const priceText = document.getElementById('createPriceInput').value.replace(/[^\d]/g, '');
      const price = parseFloat(priceText) || 0;
      const disc = parseFloat(document.getElementById('createDiscountInput').value) || 0;
      const preview = document.getElementById('createPricePreview');
      if (disc > 0) {
        const final = Math.round(price * (1 - disc / 100));
        preview.style.display = 'block';
        preview.textContent = 'Precio final con ' + disc + '% dto: $' + final.toLocaleString('es-CO');
      } else {
        preview.style.display = 'none';
      }
    }
    async function handleCreateImages(input) {
      const gallery = document.getElementById('createGalleryPreview');
      const currentCount = gallery.querySelectorAll('.create-img-item').length;
      const files = Array.from(input.files).slice(0, 5 - currentCount);
      if (!files.length) return;

      const textEl = document.getElementById('createUploadText');
      const label = document.getElementById('createUploadLabel');
      textEl.textContent = 'Subiendo…';
      label.style.pointerEvents = 'none';
      input.value = '';

      const csrf = document.querySelector('#createForm input[name="_csrf"]').value;
      const formData = new FormData();
      files.forEach(f => formData.append('images', f));

      try {
        const res = await fetch('/admin/tienda/upload-image', {
          method: 'POST',
          headers: { 'X-CSRF-Token': csrf },
          body: formData,
        });
        const data = await res.json();
        if (!data.ok) throw new Error('Upload failed');
        (data.urls || []).forEach(url => {
          const div = document.createElement('div');
          div.className = 'create-img-item admin-gallery-item';
          div.innerHTML = `<img src="${url}" alt="" style="width:64px;height:64px;object-fit:cover;border-radius:6px" />
          <input type="hidden" name="existingImages" value="${url}" />
          <button type="button" class="admin-gallery-remove" onclick="this.closest('.create-img-item').remove()">✕</button>`;
          gallery.appendChild(div);
        });
      } catch {
        alert('Error al subir imágenes. Intenta de nuevo.');
      } finally {
        textEl.textContent = 'Agregar imágenes';
        label.style.pointerEvents = '';
      }
    }
  </script>

  <%- include('../partials/admin-foot') %>