<%- include('../partials/admin-head', { title: 'Cotización ' + quotation.label }) %>

<div class="crm-page-header">
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
    <a class="btn btn-ghost btn-sm" href="/admin/cotizaciones">← Cotizaciones</a>
    <h1 class="crm-page-title" style="margin:0">
      Cotización <span style="color:var(--brand)">#<%= quotation.label %></span>
    </h1>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <button id="btnDownloadPdf" class="btn btn-ghost btn-sm">
      ⬇ Descargar PDF
    </button>
    <form method="post" action="/admin/cotizaciones/<%= quotation.id %>/eliminar" data-confirm="¿Eliminar cotización #<%= quotation.label %>? Esta acción no se puede deshacer.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="btn btn-danger btn-sm" type="submit">Eliminar cotización</button>
    </form>
  </div>
</div>

<div style="display:grid;gap:16px;grid-template-columns:1fr;max-width:860px">

  <!-- Metadata -->
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:14px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:0 0 16px">Información general</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px">
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px">Consecutivo</div>
        <div style="font-size:20px;font-weight:900;color:var(--brand)">#<%= quotation.label %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px">Fecha de creación</div>
        <div style="font-weight:700"><%= new Date(quotation.createdAt).toLocaleDateString('es-CO', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %></div>
        <div style="font-size:12px;color:#6b7280"><%= new Date(quotation.createdAt).toLocaleTimeString('es-CO', { hour:'2-digit', minute:'2-digit' }) %></div>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px">Moto / Placa</div>
        <% if (quotation.plate) { %>
          <div style="font-weight:900;font-size:18px;letter-spacing:1px"><%= quotation.plate %></div>
        <% } %>
        <% if (quotation.motorcycle) { %>
          <div style="font-weight:<%= quotation.plate ? '600' : '800' %>;font-size:<%= quotation.plate ? '13px' : '16px' %>;color:<%= quotation.plate ? '#6b7280' : 'inherit' %>"><%= quotation.motorcycle %></div>
        <% } %>
        <% if (!quotation.plate && !quotation.motorcycle) { %>
          <div style="color:#9ca3af;font-size:13px">No especificada</div>
        <% } %>
      </div>
      <div>
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px">Cliente (WhatsApp)</div>
        <% if (quotation.clientPhone) { %>
          <div style="font-weight:700"><%= quotation.clientPhoneCountry %> <%= quotation.clientPhone %></div>
          <a href="https://wa.me/<%= (quotation.clientPhoneCountry||'+57').replace('+','') %><%= quotation.clientPhone %>"
             target="_blank" rel="noopener"
             style="font-size:12px;color:#25D366;font-weight:700">Abrir chat →</a>
        <% } else { %>
          <div style="color:#9ca3af;font-size:13px">No registrado</div>
        <% } %>
      </div>
    </div>

    <% if (quotation.notes) { %>
    <div style="margin-top:16px;padding-top:16px;border-top:1px solid #f3f4f6">
      <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px">Notas</div>
      <div style="font-size:14px;color:#374151"><%= quotation.notes %></div>
    </div>
    <% } %>
  </div>

  <!-- Items -->
  <div class="crm-card" style="padding:20px 24px">
    <h2 style="font-size:14px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:0 0 16px">
      Ítems (<%= quotation.items.length %>)
    </h2>
    <div class="crm-table-wrap">
      <table class="crm-table">
        <thead>
          <tr>
            <th>Ítem</th>
            <th>Tipo</th>
            <th style="text-align:center">Cant.</th>
            <th style="text-align:right">Precio unit.</th>
            <th style="text-align:right">Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <% quotation.items.forEach((it, idx) => { %>
          <tr>
            <td style="font-weight:700"><%= it.name %></td>
            <td>
              <span class="badge <%= it.type === 'service' ? 'badge-warning' : it.type === 'product' ? 'badge-success' : 'badge-info' %>" style="font-size:.75rem">
                <%= it.type === 'service' ? 'Servicio' : it.type === 'product' ? 'Producto' : 'Personalizado' %>
              </span>
            </td>
            <td style="text-align:center;font-weight:700"><%= it.qty %></td>
            <td style="text-align:right">$<%= Number(it.price).toLocaleString('es-CO') %></td>
            <td style="text-align:right;font-weight:800;color:var(--brand)">$<%= (it.price * it.qty).toLocaleString('es-CO') %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="4" style="text-align:right;font-weight:800;padding:12px 10px;font-size:13px;color:#374151">TOTAL</td>
            <td style="text-align:right;font-weight:900;font-size:17px;color:var(--brand);padding:12px 10px">
              $<%= quotation.total.toLocaleString('es-CO') %>
            </td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

</div>

<!-- Convertir en Orden de Servicio -->
<div class="crm-card" style="padding:20px 24px;max-width:860px;margin-top:0;border-top:3px solid var(--brand)">
  <h2 style="font-size:14px;font-weight:800;color:#374151;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px">
    Convertir en Orden de Servicio
  </h2>
  <form method="post" action="/admin/cotizaciones/<%= quotation.id %>/convertir-orden">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:14px">
      <div>
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Mecánico asignado</label>
        <input type="text" name="mechanic" placeholder="Nombre del mecánico" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
      </div>
      <div>
        <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Fecha estimada de entrega</label>
        <input type="date" name="estimatedDate" style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;box-sizing:border-box" />
      </div>
    </div>
    <div style="margin-bottom:14px">
      <label style="display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px">Observaciones iniciales</label>
      <textarea name="notes" rows="2" placeholder="Diagnóstico inicial, observaciones del cliente..." style="width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box"></textarea>
    </div>
    <button class="btn btn-primary" type="submit">Crear Orden de Servicio →</button>
  </form>
</div>

<%- include('../partials/admin-foot') %>
