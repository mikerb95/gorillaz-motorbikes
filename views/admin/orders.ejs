<%- include('../partials/admin-head', { title: 'Pedidos' }) %>

<%
const STATUS_MAP = {
  pending:              { label: 'Pendiente',      cls: 'badge-warning' },
  pending_confirmation: { label: 'En confirmación',cls: 'badge-info' },
  paid:                 { label: 'Pagado',          cls: 'badge-success' },
  failed:               { label: 'Fallido',         cls: 'badge-danger' },
};
// `stats` (agregados en SQL) y `status`/`page`/`pages`/`total` llegan del servidor.
const st_ = typeof stats !== 'undefined' ? stats : { pending:0, pending_confirmation:0, paid:0, totalRecaudado:0 };
const activeStatus = typeof status !== 'undefined' ? status : '';
const KPI = [
  { k:'pending',              l:'Pendientes' },
  { k:'pending_confirmation', l:'En confirmación' },
  { k:'paid',                 l:'Pagados' },
];
%>

<div class="crm-page-header">

</div>

<div class="crm-kpi-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:12px">
  <% KPI.forEach(k => { const on = activeStatus === k.k; %>
    <a class="crm-kpi-card" href="<%= on ? '/admin/pedidos' : '?status=' + k.k %>" style="text-decoration:none;color:inherit;<%= on ? 'outline:2px solid var(--brand);outline-offset:-2px' : '' %>">
      <div class="crm-kpi-value"><%= st_[k.k] || 0 %></div>
      <div class="crm-kpi-label"><%= k.l %></div>
    </a>
  <% }) %>
  <div class="crm-kpi-card" style="cursor:default">
    <div class="crm-kpi-value">$<%= (st_.totalRecaudado || 0).toLocaleString('es-CO') %></div>
    <div class="crm-kpi-label">Total recaudado</div>
  </div>
</div>

<% if (activeStatus) { %>
  <div style="margin-bottom:16px;font-size:.85rem;color:#6b7280">
    Filtrando por <strong><%= (KPI.find(k=>k.k===activeStatus)||{l:activeStatus}).l %></strong>
    · <a href="/admin/pedidos" style="color:var(--brand);font-weight:700">Ver todos</a>
  </div>
<% } %>

<div class="crm-card">
  <% if (total === 0) { %>
    <p class="muted" style="padding:24px;text-align:center"><%= activeStatus ? 'No hay pedidos con este estado.' : 'No hay pedidos aún.' %></p>
  <% } else { %>
  <div class="crm-table-wrap">
    <table class="crm-table">
      <thead>
        <tr>
          <th>Orden</th>
          <th>Cliente</th>
          <th>Contacto</th>
          <th>Envío</th>
          <th>Productos</th>
          <th>Total</th>
          <th>Estado</th>
          <th>Fecha</th>
          <th>Acción</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => {
          const st = STATUS_MAP[o.status] || { label: o.status, cls: 'badge-warning' };
        %>
        <tr>
          <td><code style="font-size:.8rem"><%= o.id.slice(0,8).toUpperCase() %></code></td>
          <td>
            <strong><%= o.customerName %></strong>
          </td>
          <td>
            <span class="muted" style="font-size:.85rem"><%= o.customerEmail %><br><%= o.customerPhone %></span>
          </td>
          <td>
            <span class="muted" style="font-size:.85rem"><%= o.customerAddress %><br><%= o.customerCity %></span>
          </td>
          <td style="font-size:.85rem">
            <% o.items.forEach(item => { %>
              <div><%= item.qty %> × <%= item.name %></div>
            <% }) %>
          </td>
          <td><strong>$<%= o.total.toLocaleString('es-CO') %></strong></td>
          <td><span class="badge <%= st.cls %>"><%= st.label %></span></td>
          <td class="muted" style="font-size:.82rem;white-space:nowrap"><%= fechaCO(o.createdAt, { day:'2-digit', month:'short', year:'numeric' }) %></td>
          <td>
            <form method="post" action="/admin/pedidos/estado" style="display:flex;gap:4px;align-items:center">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="id" value="<%= o.id %>" />
              <select name="status" class="crm-select-inline">
                <% Object.entries(STATUS_MAP).forEach(([val, info]) => { %>
                  <option value="<%= val %>" <%= o.status === val ? 'selected' : '' %>><%= info.label %></option>
                <% }) %>
              </select>
              <button class="btn btn-ghost btn-sm" type="submit">OK</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pager', { page, pages, params: { status: activeStatus } }) %>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
