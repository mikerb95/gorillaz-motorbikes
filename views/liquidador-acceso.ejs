<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
      font-family: Montserrat, system-ui, sans-serif; background: #0f1115; padding: 20px;
    }
    .tl-card {
      width: 100%; max-width: 360px; background: #fff; border-radius: 18px;
      padding: 32px 26px; box-shadow: 0 20px 60px rgba(0,0,0,.4);
    }
    .tl-logo { text-align: center; margin-bottom: 18px; }
    .tl-logo img { height: 54px; }
    .tl-title { text-align: center; font-size: 18px; font-weight: 900; margin: 0 0 4px; color: #111; }
    .tl-sub { text-align: center; font-size: 13px; color: #6b7280; margin: 0 0 22px; }
    .tl-pin {
      width: 100%; padding: 16px; font-size: 28px; text-align: center; letter-spacing: 10px;
      border: 2px solid #e5e7eb; border-radius: 14px; outline: none; font-family: inherit; font-weight: 800;
    }
    .tl-pin:focus { border-color: #F25C05; }
    .tl-btn {
      width: 100%; margin-top: 16px; padding: 15px; font-size: 16px; font-weight: 800;
      background: #F25C05; color: #fff; border: none; border-radius: 14px; cursor: pointer;
    }
    .tl-btn:active { transform: scale(.99); }
    .tl-error {
      background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c;
      border-radius: 10px; padding: 10px 14px; font-size: 13px; font-weight: 700; margin-bottom: 16px; text-align: center;
    }
    .tl-switch {
      display: block; width: 100%; margin-top: 18px; background: none; border: none; cursor: pointer;
      color: #6b7280; font-size: 13px; font-weight: 700; font-family: inherit; text-decoration: underline; text-align: center;
    }
  </style>
</head>
<body>
  <div class="tl-card">
    <div class="tl-logo"><img src="/images/nobg_logo/logo_transp.png" alt="Gorillaz" /></div>
    <h1 class="tl-title">Liquidador</h1>

    <% if (error) { %><div class="tl-error"><%= error %></div><% } %>

    <% if (pinConfigured) { %>
      <p class="tl-sub">Ingresa el PIN de acceso</p>
      <form method="post" action="/liquidador/acceso">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="returnTo" value="<%= returnTo %>" />
        <input type="password" name="pin" class="tl-pin" inputmode="numeric" pattern="[0-9]*"
               autocomplete="off" maxlength="6" placeholder="••••" autofocus />
        <button type="submit" class="tl-btn">Entrar</button>
      </form>
    <% } else { %>
      <p class="tl-sub">El PIN del liquidador aún no está configurado. Inicia sesión como administrador para usarlo o defínelo desde la configuración.</p>
    <% } %>

    <a class="tl-switch" href="/club/login?return=<%= encodeURIComponent(returnTo) %>">
      Soy administrador, iniciar sesión
    </a>
  </div>
</body>
</html>
