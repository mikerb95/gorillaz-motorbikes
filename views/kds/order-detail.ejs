<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title><%= order.label %> — Panel de Producción</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/kds.css?v=<%= assetV('css/kds.css') %>">
  <link rel="manifest" href="/manifest-kds.webmanifest">
  <meta name="theme-color" content="#15181d">
  <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="/static/js/kds-pwa.js?v=<%= assetV('js/kds-pwa.js') %>" defer></script>
</head>
<body>
  <div class="kds-top">
    <a class="kds-back" href="/kds">←</a>
    <span class="label"><%= order.label %></span>
    <% const st = EMP_STATUS.find(s => s.v === order.status) || { l: order.status }; %>
    <span class="badge b-<%= order.status %>" style="margin-left:auto"><%= st.l %></span>
  </div>
  <div class="kds-hazard"></div>

  <div class="kds-wrap">

    <div class="card">
      <h2>Información</h2>
      <div class="row">
        <div><div class="k">Moto / Placa</div><div class="v"><span class="plate-badge"><%= order.motorcycle || '—' %></span></div></div>
        <div><div class="k">Ingreso</div><div class="v"><%= fechaCO(order.createdAt, {day:'2-digit',month:'short',year:'numeric'}) %></div></div>
        <div><div class="k">Mecánico asignado</div><div class="v"><%= order.mechanic || '—' %></div></div>
      </div>
      <% if (order.notes) { %>
        <div style="margin-top:14px;padding-top:14px;border-top:1px solid #f3f4f6">
          <div class="k">Notas</div>
          <div style="font-size:14px;color:#374151"><%= order.notes %></div>
        </div>
      <% } %>
    </div>

    <div class="card">
      <h2>Ítems (<%= order.items.length %>)</h2>
      <% order.items.forEach(it => { %>
        <div class="item">
          <span><%= it.name %></span>
          <span class="q">×<%= it.qty %></span>
        </div>
      <% }) %>
      <% if (!order.items.length) { %><div class="item">Sin ítems todavía.</div><% } %>
    </div>

    <% if (employee) { %>

      <div class="card">
        <h2>Añadir ítem</h2>
        <div class="cat-grid" id="catGrid">
          <% catalog.forEach(c => { %>
            <button type="button" class="cat-btn" data-name="<%= c.name %>" data-type="<%= c.type || 'service' %>"><%= c.name %></button>
          <% }) %>
          <button type="button" class="cat-btn other" id="otherBtn">Otro ítem…</button>
        </div>

        <form method="post" action="/kds/orden/<%= order.id %>/items" class="quick-add" id="quickAdd" data-require-pin data-pin-title="Autoriza con tu PIN" data-pin-msg="Ingresa tu PIN para agregar este ítem a la orden.">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="type" id="qaType" />
          <label class="k">Ítem</label>
          <input type="text" name="name" id="qaName" style="margin-bottom:12px" />
          <div class="qty-row">
            <button type="button" class="qty-btn" id="qtyMinus">−</button>
            <input type="number" name="qty" id="qaQty" value="1" min="1" style="width:70px" />
            <button type="button" class="qty-btn" id="qtyPlus">+</button>
          </div>
          <input type="number" name="price" id="qaPrice" min="0" step="1" placeholder="Precio unitario" />
          <button type="submit" class="save">+ Agregar a la orden</button>
        </form>
      </div>

      <div class="card">
        <h2>Cambiar estado</h2>
        <form method="post" action="/kds/orden/<%= order.id %>/estado" data-require-pin data-pin-title="Autoriza con tu PIN" data-pin-msg="Ingresa tu PIN para registrar y confirmar el cambio de estado.">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="status-grid">
            <% EMP_STATUS.forEach(s => { %>
              <button type="submit" name="status" value="<%= s.v %>" class="status-btn <%= order.status === s.v ? 'active' : '' %>"><%= s.l %></button>
            <% }) %>
          </div>
        </form>
      </div>

      <% if (order.invoiceId) { %>
        <div class="card" style="text-align:center;color:#166534;font-weight:800">✓ Factura proforma generada. El admin la cierra al entregar la moto.</div>
      <% } %>

    <% } else { %>
      <div class="login-note">
        <a href="/kds/login">Inicia sesión</a> con tu PIN para gestionar esta orden (cambiar estado o añadir ítems).
      </div>
    <% } %>

  </div>

  <% if (employee) { %>
  <script>
  (function () {
    const quickAdd = document.getElementById('quickAdd');
    const qaName   = document.getElementById('qaName');
    const qaType   = document.getElementById('qaType');
    const qaQty    = document.getElementById('qaQty');
    const qaPrice  = document.getElementById('qaPrice');

    function openQuickAdd(name, type, editableName) {
      qaName.value = name;
      qaName.readOnly = !editableName;
      qaType.value = type;
      qaQty.value = 1;
      qaPrice.value = '';
      quickAdd.style.display = 'block';
      qaPrice.focus();
    }

    document.querySelectorAll('.cat-btn[data-name]').forEach(btn => {
      btn.addEventListener('click', () => openQuickAdd(btn.dataset.name, btn.dataset.type, false));
    });
    document.getElementById('otherBtn').addEventListener('click', () => openQuickAdd('', 'custom', true));

    document.getElementById('qtyMinus').addEventListener('click', () => { qaQty.value = Math.max(1, Number(qaQty.value) - 1); });
    document.getElementById('qtyPlus').addEventListener('click', () => { qaQty.value = Number(qaQty.value) + 1; });
  })();
  </script>
  <% } %>
<script>
  window.PIN_VERIFY_URL = '/kds/verificar-pin';
  // Con sesión de mecánico abierta esta orden es una operación en curso: el
  // protector de pantalla solo se retoma aquí, sin caer a modo kiosco.
  window.KDS_SCREENSAVER = { hasActiveOperation: <%- JSON.stringify(!!employee) %> };
</script>
<script src="/static/js/pin-gate.js"></script>
<script src="/static/js/kds-screensaver.js?v=<%= assetV('js/kds-screensaver.js') %>"></script>
</body>
</html>
