<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Nueva orden — Panel de Taller</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/kds.css?v=<%= assetV('css/kds.css') %>">
  <link rel="manifest" href="/manifest-kds.webmanifest">
  <meta name="theme-color" content="#15181d">
  <meta name="color-scheme" content="dark">
  <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="/static/js/kds-pwa.js?v=<%= assetV('js/kds-pwa.js') %>" defer></script>
  <script src="/static/js/kds-fullscreen.js?v=<%= assetV('js/kds-fullscreen.js') %>"></script>
</head>
<body>
  <div class="kds-top">
    <a class="kds-back" href="/kds/placa">←</a>
    <span class="label">Nueva orden de servicio</span>
    <a class="kds-back" href="/kds" title="Inicio" aria-label="Inicio" style="margin-left:auto">⌂</a>
  </div>
  <div class="kds-hazard"></div>

  <div class="kds-wrap">
    <% if (error) { %><div class="kds-error"><%= error %></div><% } %>

    <form method="post" action="/kds/orden/nueva" id="soForm" data-require-pin data-pin-title="Autoriza con tu PIN" data-pin-msg="Ingresa tu PIN para crear esta orden de servicio.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="items" id="itemsField" />

      <div class="card">
        <h2>Datos de ingreso</h2>
        <% if (returning) { %>
          <div class="returning-note" style="background:rgba(242,92,5,.12);border:1px solid rgba(242,92,5,.45);border-radius:10px;padding:10px 12px;font-size:13px;font-weight:700;margin-bottom:12px">
            ↻ Esta placa ya visitó el taller<%= returning.clientName ? ' — ' + returning.clientName : '' %>.
            <%= returning.clientPhone ? 'Teléfono precargado de la última visita.' : '' %>
          </div>
        <% } %>
        <label class="k">Placa</label>
        <input type="text" name="placa" value="<%= placa %>" required class="plate-input"
          readonly data-kds-kbd="qwerty" data-kds-label="Placa" />
        <label class="k">Teléfono del cliente (opcional)</label>
        <input type="tel" name="clientPhone" placeholder="3001234567" value="<%= prefill.clientPhone %>"
          readonly data-kds-kbd="qwerty" data-kds-label="Teléfono del cliente" />
        <label class="k">Notas (opcional)</label>
        <textarea name="notes" rows="2" placeholder="Detalles del ingreso..."
          readonly data-kds-kbd="qwerty" data-kds-label="Notas"><%= prefill.notes %></textarea>
      </div>

      <div class="card">
        <h2>Servicios / repuestos</h2>
        <div class="cat-grid" id="catGrid">
          <% catalog.forEach(c => { %>
            <button type="button" class="cat-btn" data-name="<%= c.name %>" data-type="<%= c.type || 'service' %>"><%= c.name %></button>
          <% }) %>
          <button type="button" class="cat-btn other" id="otherBtn">Otro ítem…</button>
        </div>

        <div class="quick-add" id="quickAdd">
          <label class="k">Ítem</label>
          <input type="text" id="qaName" readonly data-kds-kbd="qwerty" data-kds-label="Nombre del ítem" data-kds-locked />
          <div class="qty-row">
            <button type="button" class="qty-btn" id="qtyMinus">−</button>
            <input type="text" id="qaQty" value="1" style="width:70px"
              readonly data-kds-kbd="qwerty" data-kds-label="Cantidad" />
            <button type="button" class="qty-btn" id="qtyPlus">+</button>
          </div>
          <label class="k">Precio unitario</label>
          <input type="text" id="qaPrice" placeholder="0"
            readonly data-kds-kbd="qwerty" data-kds-label="Precio unitario" />
          <button type="button" class="save" id="qaAdd">+ Agregar a la orden</button>
        </div>

        <div class="item-list" id="itemList"></div>
        <div class="total-row"><span>Total</span><span id="grandTotal">$0</span></div>
      </div>

      <button class="save" type="submit">Crear orden de servicio →</button>
    </form>
  </div>

  <script>
  (function () {
    let items = [];
    const itemsField = document.getElementById('itemsField');
    const itemList   = document.getElementById('itemList');
    const grandTotal = document.getElementById('grandTotal');
    const quickAdd   = document.getElementById('quickAdd');
    const qaName     = document.getElementById('qaName');
    const qaQty      = document.getElementById('qaQty');
    const qaPrice    = document.getElementById('qaPrice');
    let qaType = 'service';

    const fmt = n => '$' + (Number(n) || 0).toLocaleString('es-CO');

    // Toast propio (esta vista no carga el FAB): evita el alert() nativo, que en
    // PWA fullscreen delata el origen web y rompe la estética del kiosco.
    let toastEl = null, toastTimer = null;
    function toast(msg) {
      if (!toastEl) {
        toastEl = document.createElement('div');
        toastEl.setAttribute('role', 'status');
        toastEl.setAttribute('aria-live', 'polite');
        toastEl.style.cssText = 'position:fixed;left:50%;bottom:24px;transform:translateX(-50%);z-index:100001;' +
          'background:#15181d;color:#fff;font-family:Montserrat,system-ui,sans-serif;font-weight:800;font-size:14px;' +
          'padding:13px 20px;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,.4);max-width:90vw;text-align:center;' +
          'opacity:0;transition:opacity .18s ease;pointer-events:none';
        document.body.appendChild(toastEl);
      }
      toastEl.textContent = msg;
      toastEl.style.opacity = '1';
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => { toastEl.style.opacity = '0'; }, 2200);
    }

    function openQuickAdd(name, type, editableName) {
      qaName.value = name;
      if (editableName) qaName.removeAttribute('data-kds-locked');
      else qaName.setAttribute('data-kds-locked', '');
      qaType = type;
      qaQty.value = 1;
      qaPrice.value = '';
      quickAdd.style.display = 'block';
      if (window.KDSKeyboard) {
        window.KDSKeyboard.open(editableName ? qaName : qaPrice, {
          type: 'qwerty',
          label: editableName ? 'Nombre del ítem' : 'Precio unitario'
        });
      }
    }

    document.querySelectorAll('.cat-btn[data-name]').forEach(btn => {
      btn.addEventListener('click', () => openQuickAdd(btn.dataset.name, btn.dataset.type, false));
    });
    document.getElementById('otherBtn').addEventListener('click', () => openQuickAdd('', 'custom', true));

    document.getElementById('qtyMinus').addEventListener('click', () => { qaQty.value = Math.max(1, Number(qaQty.value) - 1); });
    document.getElementById('qtyPlus').addEventListener('click', () => { qaQty.value = Number(qaQty.value) + 1; });

    function renderItems() {
      itemList.innerHTML = '';
      let total = 0;
      items.forEach((it, idx) => {
        total += it.price * it.qty;
        const row = document.createElement('div');
        row.className = 'item-row';
        // textContent para el nombre (dato del empleado): con innerHTML, escribir
        // markup en "Otro ítem" inyectaría HTML en la lista.
        const nameSpan = document.createElement('span');
        nameSpan.textContent = it.name + ' ×' + it.qty;
        const priceSpan = document.createElement('span');
        priceSpan.textContent = fmt(it.price * it.qty) + ' ';
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'del';
        del.dataset.idx = idx;
        del.textContent = '✕';
        priceSpan.appendChild(del);
        row.appendChild(nameSpan);
        row.appendChild(priceSpan);
        itemList.appendChild(row);
      });
      itemList.querySelectorAll('.del').forEach(b => {
        b.addEventListener('click', () => { items.splice(Number(b.dataset.idx), 1); renderItems(); });
      });
      grandTotal.textContent = fmt(total);
      itemsField.value = JSON.stringify(items);
    }

    document.getElementById('qaAdd').addEventListener('click', () => {
      const name  = qaName.value.trim();
      const qty   = Math.round(Number(qaQty.value));
      const price = Math.round(Number(qaPrice.value));
      if (!name || !(qty >= 1) || !(price >= 1)) { toast('Completa nombre, cantidad y precio.'); return; }
      items.push({ name, type: qaType, qty, price });
      quickAdd.style.display = 'none';
      renderItems();
    });

    document.getElementById('soForm').addEventListener('submit', e => {
      if (items.length === 0) {
        e.preventDefault();
        toast('Agrega al menos un ítem del catálogo o "Otro".');
      }
    });

    renderItems();
  })();
  </script>
<script>window.PIN_VERIFY_URL = '/kds/verificar-pin';</script>
<script src="/static/js/kds-keyboard.js?v=<%= assetV('js/kds-keyboard.js') %>"></script>
<script src="/static/js/pin-gate.js"></script>
</body>
</html>
