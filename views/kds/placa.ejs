<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Buscar placa — Panel de Taller</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/kds.css?v=<%= assetV('css/kds.css') %>">
  <link rel="manifest" href="/manifest-kds.webmanifest">
  <meta name="theme-color" content="#15181d">
  <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="/static/js/kds-pwa.js?v=<%= assetV('js/kds-pwa.js') %>" defer></script>
  <script src="/static/js/kds-fullscreen.js?v=<%= assetV('js/kds-fullscreen.js') %>"></script>
</head>
<body>
  <div class="kds-top">
    <a class="kds-back" href="/kds">←</a>
    <span class="label">Buscar por placa</span>
  </div>
  <div class="kds-hazard"></div>

  <div class="kds-wrap">
    <% if (error) { %><div class="kds-error"><%= error %></div><% } %>

    <div class="plate-display empty" id="plateDisplay">Digita la placa</div>

    <div class="plate-keypad" id="keypad"></div>

    <div class="plate-actions">
      <button type="button" class="plate-clear" id="clearBtn">Borrar todo</button>
      <button type="button" class="plate-go" id="goBtn">Buscar →</button>
    </div>
  </div>

  <script>
  (function () {
    const chars   = 'QWERTYUIOPASDFGHJKLZXCVBNM1234567890'.split('');
    const keypad  = document.getElementById('keypad');
    const display = document.getElementById('plateDisplay');
    let plate = '';

    chars.forEach(c => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'plate-key';
      btn.textContent = c;
      btn.addEventListener('click', () => {
        if (plate.length >= 8) return;
        plate += c;
        render();
      });
      keypad.appendChild(btn);
    });

    function render() {
      if (plate) { display.textContent = plate; display.classList.remove('empty'); }
      else { display.textContent = 'Digita la placa'; display.classList.add('empty'); }
    }

    document.getElementById('clearBtn').addEventListener('click', () => { plate = ''; render(); });
    document.getElementById('goBtn').addEventListener('click', () => {
      if (!plate) return;
      window.location.href = '/kds/placa/buscar?placa=' + encodeURIComponent(plate);
    });
  })();
  </script>
</body>
</html>
