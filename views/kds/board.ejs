<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Panel de Taller — Gorillaz</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/kds.css?v=<%= assetV('css/kds.css') %>">
  <link rel="manifest" href="/manifest-kds.webmanifest">
  <meta name="theme-color" content="#15181d">
  <meta name="color-scheme" content="dark">
  <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="/static/js/kds-pwa.js?v=<%= assetV('js/kds-pwa.js') %>" defer></script>
  <script src="/static/js/kds-fullscreen.js?v=<%= assetV('js/kds-fullscreen.js') %>"></script>
</head>
<body>
  <div class="kds-top">
    <div>
      <div class="brand">Panel de Taller</div>
      <div class="who">Sesión: <%= employee.name %></div>
    </div>
    <div class="actions">
      <a class="kds-btn dark" href="/kds">Pantalla principal</a>
      <form method="post" action="/kds/logout" style="margin:0">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="kds-btn dark">Cambiar de mecánico</button>
      </form>
    </div>
  </div>
  <div class="kds-hazard"></div>

  <% if (flash === 'facturada') { %>
    <div class="kds-flash">✓ Orden facturada correctamente.</div>
  <% } %>

  <div class="kds-board" id="board"></div>

  <a class="kds-fab" href="/kds/placa">+ Placa</a>

  <script>
  const EMP_STATUS = <%- JSON.stringify(EMP_STATUS) %>;
  let initialOrders = <%- JSON.stringify(orders.map(o => ({
    id: o.id, label: o.label, motorcycle: o.motorcycle, mechanic: o.mechanic,
    status: o.status, total: o.total, itemCount: o.items.length, createdAt: o.createdAt,
  }))) %>;

  const board = document.getElementById('board');

  function elapsed(iso) {
    const mins = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
    if (mins < 60) return mins + ' min';
    const hrs = Math.floor(mins / 60);
    return hrs + 'h ' + (mins % 60) + 'min';
  }

  function renderBoard(orders) {
    board.innerHTML = '';
    EMP_STATUS.forEach(st => {
      const col = document.createElement('div');
      col.className = 'kds-col';
      const inCol = orders.filter(o => o.status === st.v);
      col.innerHTML = '<h2><span>' + st.l + '</span><span>' + inCol.length + '</span></h2>';
      if (!inCol.length) {
        col.innerHTML += '<div class="kds-empty">Sin órdenes</div>';
      } else {
        inCol.forEach(o => {
          const a = document.createElement('a');
          a.className = 'kds-card st-' + o.status;
          a.href = '/kds/orden/' + encodeURIComponent(o.id);
          // textContent (no innerHTML): placa y mecánico son datos de usuario;
          // interpolarlos como HTML permitiría inyectar markup en el tablero.
          const mk = (cls, text) => {
            const d = document.createElement('div');
            d.className = cls;
            d.textContent = text;
            return d;
          };
          a.appendChild(mk('label', o.label));
          a.appendChild(mk('moto', o.motorcycle || 'Sin placa'));
          a.appendChild(mk('meta', o.itemCount + ' ítem(s) · ' + (o.mechanic || 'Sin asignar') + ' · ' + elapsed(o.createdAt)));
          col.appendChild(a);
        });
      }
      board.appendChild(col);
    });
  }

  renderBoard(initialOrders);

  setInterval(async () => {
    try {
      const res = await fetch('/kds/orders.json');
      initialOrders = await res.json();
      renderBoard(initialOrders);
    } catch { /* red intermitente: se reintenta en el próximo ciclo */ }
  }, 8000);
  </script>
</body>
</html>
