<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Panel de Producción — Gorillaz</title>
  <link rel="icon" href="/favicons/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    body { margin: 0; font-family: Montserrat, system-ui, sans-serif; background: #f3f4f6; color: #111; }
    .kds-top {
      background: #0f1115; color: #fff; padding: 16px 20px; display: flex; align-items: center;
      justify-content: space-between; gap: 12px; position: sticky; top: 0; z-index: 10;
    }
    .kds-top .brand { font-weight: 900; font-size: 17px; }
    .kds-top .who { font-size: 12px; color: #9ca3af; }
    .kds-top .actions { display: flex; align-items: center; gap: 10px; }
    .kds-btn {
      border: none; border-radius: 10px; padding: 10px 16px; font-weight: 800; font-size: 13px;
      cursor: pointer; font-family: inherit; text-decoration: none; display: inline-block;
    }
    .kds-btn.orange { background: #F25C05; color: #fff; }
    .kds-btn.dark   { background: rgba(255,255,255,.12); color: #fff; }
    .kds-flash {
      background: #f0fdf4; border-bottom: 1px solid #bbf7d0; color: #166534; text-align: center;
      font-weight: 700; font-size: 13px; padding: 10px;
    }
    .kds-board { display: grid; grid-template-columns: repeat(4, minmax(240px,1fr)); gap: 14px; padding: 16px; overflow-x: auto; }
    .kds-col { background: #fff; border-radius: 14px; padding: 12px; min-height: 200px; border: 1px solid #eef0f2; }
    .kds-col h2 { font-size: 12px; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: .5px; margin: 4px 4px 12px; display: flex; justify-content: space-between; }
    .kds-card {
      display: block; text-decoration: none; color: inherit; background: #f9fafb; border-radius: 12px;
      padding: 12px 14px; margin-bottom: 10px; border: 1px solid #eef0f2;
    }
    .kds-card:active { background: #f3f4f6; }
    .kds-card .label { font-weight: 900; font-size: 14px; }
    .kds-card .moto { font-size: 13px; color: #374151; font-weight: 700; margin-top: 2px; }
    .kds-card .meta { font-size: 11px; color: #9ca3af; margin-top: 6px; }
    .kds-empty { text-align: center; color: #9ca3af; font-size: 12px; padding: 20px 8px; }
    .badge { font-size: 11px; font-weight: 800; padding: 3px 8px; border-radius: 999px; white-space: nowrap; }
    .b-ingreso_taller   { background: #fef3c7; color: #92400e; }
    .b-trabajo_en_curso { background: #dbeafe; color: #1e40af; }
    .b-en_pausa         { background: #f3f4f6; color: #4b5563; }
    .b-trabajo_completo { background: #dcfce7; color: #166534; }
    .kds-fab {
      position: fixed; right: 20px; bottom: 20px; background: #F25C05; color: #fff; text-decoration: none;
      font-weight: 800; font-size: 16px; padding: 18px 26px; border-radius: 999px; box-shadow: 0 8px 24px rgba(242,92,5,.4);
    }
    @media (max-width: 900px) { .kds-board { grid-template-columns: repeat(2, minmax(220px,1fr)); } }
  </style>
</head>
<body>
  <div class="kds-top">
    <div>
      <div class="brand">Panel de Producción</div>
      <div class="who">
        <% if (employee) { %>Sesión: <%= employee.name %><% } else { %>Sin sesión activa<% } %>
      </div>
    </div>
    <div class="actions">
      <% if (employee) { %>
        <form method="post" action="/kds/logout" style="margin:0">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="kds-btn dark">Cambiar de mecánico</button>
        </form>
      <% } else { %>
        <a class="kds-btn dark" href="/kds/login">Iniciar sesión</a>
      <% } %>
    </div>
  </div>

  <% if (flash === 'facturada') { %>
    <div class="kds-flash">✓ Orden facturada correctamente.</div>
  <% } %>

  <div class="kds-board" id="board"></div>

  <a class="kds-fab" href="/kds/placa">+ Placa</a>

  <script>
  const EMP_STATUS = <%- JSON.stringify(EMP_STATUS) %>;
  let initialOrders = <%- JSON.stringify(orders.map(o => ({
    id: o.id, label: o.label, motorcycle: o.motorcycle, mechanic: o.mechanic,
    status: o.status, total: o.total, itemCount: o.items.length, createdAt: o.createdAt,
  }))) %>;

  const board = document.getElementById('board');

  function elapsed(iso) {
    const mins = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
    if (mins < 60) return mins + ' min';
    const hrs = Math.floor(mins / 60);
    return hrs + 'h ' + (mins % 60) + 'min';
  }

  function renderBoard(orders) {
    board.innerHTML = '';
    EMP_STATUS.forEach(st => {
      const col = document.createElement('div');
      col.className = 'kds-col';
      const inCol = orders.filter(o => o.status === st.v);
      col.innerHTML = '<h2><span>' + st.l + '</span><span>' + inCol.length + '</span></h2>';
      if (!inCol.length) {
        col.innerHTML += '<div class="kds-empty">Sin órdenes</div>';
      } else {
        inCol.forEach(o => {
          const a = document.createElement('a');
          a.className = 'kds-card';
          a.href = '/kds/orden/' + o.id;
          a.innerHTML =
            '<div class="label">' + o.label + '</div>' +
            '<div class="moto">' + (o.motorcycle || 'Sin placa') + '</div>' +
            '<div class="meta">' + o.itemCount + ' ítem(s) · ' + (o.mechanic || 'Sin asignar') + ' · ' + elapsed(o.createdAt) + '</div>';
          col.appendChild(a);
        });
      }
      board.appendChild(col);
    });
  }

  renderBoard(initialOrders);

  setInterval(async () => {
    try {
      const res = await fetch('/kds/orders.json');
      initialOrders = await res.json();
      renderBoard(initialOrders);
    } catch { /* red intermitente: se reintenta en el próximo ciclo */ }
  }, 8000);
  </script>
</body>
</html>
