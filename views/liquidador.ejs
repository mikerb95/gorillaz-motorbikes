<%- include('partials/head', { title, description, canonicalPath }) %>
<script>
  window.__WA_CONFIG__ = <%- JSON.stringify(waConfig) %>;
  window.__EDIT_QUOTATION__ = <%- JSON.stringify(typeof editQuotation !== 'undefined' ? editQuotation : null) %>;
</script>

<style>
/* ── Liquidador ─────────────────────────────────────────────── */
.liq-page {
  padding-top: calc(var(--header-offset) + 24px);
  padding-bottom: 60px;
  min-height: 100vh;
  background: #fafafa;
}
.liq-wrap {
  max-width: 680px;
  margin: 0 auto;
  padding: 0 16px;
}

/* Steps indicator */
.liq-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28px;
}
.liq-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  flex: 1;
  max-width: 130px;
}
.liq-step-dot {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #e5e7eb;
  color: #9ca3af;
  font-weight: 800;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .2s, color .2s;
}
.liq-step.active .liq-step-dot { background: var(--brand); color: #fff; }
.liq-step.done   .liq-step-dot { background: #22c55e; color: #fff; }
.liq-step-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .4px;
  text-transform: uppercase;
  color: #9ca3af;
  text-align: center;
}
.liq-step.active .liq-step-label { color: var(--brand); }
.liq-step.done   .liq-step-label { color: #22c55e; }
.liq-step-line {
  flex: 1;
  height: 2px;
  background: #e5e7eb;
  margin-bottom: 18px;
  max-width: 60px;
  transition: background .3s;
}
.liq-step-line.done { background: #22c55e; }

/* Card panels */
.liq-panel {
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 2px 16px rgba(0,0,0,.07);
  padding: 24px 20px;
  display: none;
}
.liq-panel.active { display: block; }

.liq-panel-title {
  font-size: 20px;
  font-weight: 800;
  color: #111;
  margin: 0 0 6px;
}
.liq-panel-sub {
  font-size: 13px;
  color: #6b7280;
  margin: 0 0 20px;
}

/* Search box */
.liq-search-wrap {
  position: relative;
  margin-bottom: 0;
}
.liq-search-input {
  width: 100%;
  padding: 14px 48px 14px 48px;
  border: 2px solid #e5e7eb;
  border-radius: 999px;
  font-size: 16px;
  font-family: inherit;
  font-weight: 600;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
  background: #fafafa;
}
.liq-search-input:focus {
  border-color: var(--brand);
  box-shadow: 0 0 0 3px rgba(242,92,5,.12);
  background: #fff;
}
.liq-search-input:disabled {
  opacity: .45;
  cursor: not-allowed;
}
.liq-search-icon {
  position: absolute;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  color: #9ca3af;
  pointer-events: none;
}
.liq-search-clear {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  background: #e5e7eb;
  border: none;
  border-radius: 50%;
  width: 26px;
  height: 26px;
  cursor: pointer;
  font-size: 14px;
  color: #6b7280;
  display: none;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.liq-search-clear.visible { display: flex; }

/* Autocomplete dropdown */
.liq-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  right: 0;
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  box-shadow: 0 8px 30px rgba(0,0,0,.12);
  z-index: 50;
  overflow: hidden;
  display: none;
}
.liq-dropdown.open { display: block; }
.liq-dd-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  cursor: pointer;
  border-bottom: 1px solid #f3f4f6;
  transition: background .12s;
}
.liq-dd-item:last-child { border-bottom: none; }
.liq-dd-item:hover, .liq-dd-item.focused { background: #fff7f0; }
.liq-dd-name {
  font-size: 14px;
  font-weight: 700;
  color: #111;
  flex: 1;
}
.liq-dd-brand {
  font-size: 12px;
  font-weight: 400;
  color: #6b7280;
}
.liq-dd-type {
  font-size: 11px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: .4px;
  flex-shrink: 0;
}
.liq-dd-type.service { background: #fff7ed; color: #ea580c; }
.liq-dd-type.product { background: #f0fdf4; color: #16a34a; }
.liq-dd-empty, .liq-dd-searching {
  padding: 14px 16px;
  font-size: 13px;
  color: #9ca3af;
  text-align: center;
}

/* ── Staging form (ítem seleccionado, pendiente de precio) ── */
.liq-staging {
  display: none;
  margin-top: 14px;
  border: 2px solid var(--brand);
  border-radius: 14px;
  padding: 16px;
  background: #fff8f5;
  animation: stagePop .18s ease;
}
.liq-staging.visible { display: block; }

@keyframes stagePop {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.liq-staging-name {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #111;
  color: #fff;
  border-radius: 999px;
  padding: 5px 12px;
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 14px;
}
.liq-staging-fields {
  display: flex;
  gap: 10px;
  align-items: flex-end;
  flex-wrap: wrap;
}
.liq-staging-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.liq-staging-field label {
  font-size: 11px;
  font-weight: 700;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.liq-price-input {
  border: 2px solid #e5e7eb;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 16px;
  font-family: inherit;
  font-weight: 800;
  outline: none;
  color: #111;
  background: #fff;
  width: 160px;
  transition: border-color .2s, box-shadow .2s;
}
.liq-price-input:focus {
  border-color: var(--brand);
  box-shadow: 0 0 0 3px rgba(242,92,5,.12);
}
.liq-price-input.error {
  border-color: #ef4444;
  box-shadow: 0 0 0 3px rgba(239,68,68,.12);
}
.liq-qty-select {
  border: 2px solid #e5e7eb;
  border-radius: 10px;
  padding: 10px 10px;
  font-size: 15px;
  font-family: inherit;
  font-weight: 700;
  background: #fff;
  cursor: pointer;
  outline: none;
  color: #111;
  width: 80px;
  transition: border-color .2s;
}
.liq-qty-select:focus { border-color: var(--brand); }
.liq-staging-actions {
  display: flex;
  gap: 8px;
  margin-top: 14px;
}

/* Item cards (confirmados) */
.liq-items-area { margin-top: 18px; }
.liq-item-card {
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 8px;
  background: #fafafa;
  display: flex;
  align-items: center;
  gap: 12px;
  animation: itemIn .16s ease;
}
@keyframes itemIn {
  from { opacity: 0; transform: translateX(-8px); }
  to   { opacity: 1; transform: translateX(0); }
}
.liq-item-info { flex: 1; min-width: 0; }
.liq-item-name {
  font-size: 14px;
  font-weight: 800;
  color: #111;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.liq-item-meta {
  font-size: 12px;
  color: #6b7280;
  margin-top: 2px;
}
.liq-item-right {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.liq-item-qty-sel {
  border: 1.5px solid #e5e7eb;
  border-radius: 8px;
  padding: 5px 8px;
  font-size: 13px;
  font-family: inherit;
  font-weight: 700;
  background: #fff;
  cursor: pointer;
  outline: none;
  color: #111;
}
.liq-item-qty-sel:focus { border-color: var(--brand); }
.liq-item-subtotal {
  font-size: 15px;
  font-weight: 800;
  color: var(--brand);
  white-space: nowrap;
  min-width: 88px;
  text-align: right;
}
.liq-item-remove {
  background: none;
  border: none;
  cursor: pointer;
  color: #d1d5db;
  font-size: 18px;
  padding: 2px 4px;
  border-radius: 6px;
  transition: color .15s;
  line-height: 1;
}
.liq-item-remove:hover { color: #ef4444; }

/* Total bar */
.liq-total-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  background: #111;
  color: #fff;
  border-radius: 12px;
  margin-top: 14px;
}
.liq-total-label { font-size: 14px; font-weight: 700; }
.liq-total-value { font-size: 20px; font-weight: 900; color: var(--brand); }

/* Bottom actions */
.liq-footer-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 16px;
}

/* Buttons */
.liq-btn {
  flex: 1;
  min-width: 130px;
  padding: 13px 18px;
  border-radius: 999px;
  border: none;
  font-size: 14px;
  font-weight: 800;
  font-family: inherit;
  cursor: pointer;
  transition: opacity .15s, transform .1s;
  text-align: center;
  letter-spacing: .3px;
  line-height: 1.2;
}
.liq-btn:active { transform: scale(.97); }
.liq-btn-primary { background: var(--brand); color: #fff; }
.liq-btn-primary:hover { opacity: .88; }
.liq-btn-ghost { background: #f3f4f6; color: #374151; }
.liq-btn-ghost:hover { background: #e5e7eb; }
.liq-btn-green { background: #22c55e; color: #fff; }
.liq-btn-green:hover { opacity: .88; }
.liq-btn-sm { min-width: 0; flex: none; padding: 10px 16px; font-size: 13px; }
.liq-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

/* Summary table */
.liq-summary-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 14px;
  font-size: 13px;
}
.liq-summary-table th {
  text-align: left;
  padding: 8px 10px;
  font-weight: 800;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: .4px;
  font-size: 11px;
  border-bottom: 1px solid #e5e7eb;
}
.liq-summary-table td {
  padding: 10px;
  border-bottom: 1px solid #f3f4f6;
  vertical-align: middle;
  color: #111;
}
.liq-summary-table tr:last-child td { border-bottom: none; }
.liq-summary-table .td-name { font-weight: 700; }
.liq-summary-table .td-price,
.liq-summary-table .td-sub  { font-weight: 800; color: var(--brand); white-space: nowrap; }
.liq-summary-table .td-qty  { text-align: center; }

/* Consecutive badge */
.liq-consecutive {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--brand);
  color: #fff;
  border-radius: 999px;
  padding: 8px 20px;
  font-size: 15px;
  font-weight: 900;
  margin-bottom: 20px;
}

/* WhatsApp */
.liq-wa-section {
  border: 1.5px solid #e5e7eb;
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 16px;
}
.liq-wa-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}
.liq-wa-toggle input[type=checkbox] {
  width: 18px; height: 18px;
  accent-color: #25D366;
  cursor: pointer;
  flex-shrink: 0;
}
.liq-wa-toggle-label { font-size: 14px; font-weight: 700; color: #111; }
.liq-wa-fields {
  display: none;
  margin-top: 14px;
  gap: 8px;
}
.liq-wa-fields.open { display: flex; }
.liq-country-select {
  border: 1.5px solid #e5e7eb;
  border-radius: 10px;
  padding: 10px 8px;
  font-size: 14px;
  font-family: inherit;
  font-weight: 700;
  background: #fff;
  cursor: pointer;
  outline: none;
  color: #111;
  flex-shrink: 0;
  width: 96px;
}
.liq-country-select:focus { border-color: var(--brand); }
.liq-phone-input {
  flex: 1;
  border: 1.5px solid #e5e7eb;
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 15px;
  font-family: inherit;
  font-weight: 700;
  outline: none;
  color: #111;
  background: #fafafa;
}
.liq-phone-input:focus {
  border-color: #25D366;
  box-shadow: 0 0 0 3px rgba(37,211,102,.12);
  background: #fff;
}
.liq-hint {
  font-size: 12px;
  color: #9ca3af;
  margin-top: 8px;
  display: flex;
  align-items: center;
  gap: 4px;
}

/* Success icon */
.liq-success-icon {
  width: 56px; height: 56px;
  background: #22c55e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
}

/* Review moto/placa (paso resumen) */
.liq-review-moto {
  display: flex;
  align-items: center;
  gap: 18px;
  flex-wrap: wrap;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 16px;
  background: #fafafa;
}
.liq-review-moto > div { display: flex; flex-direction: column; gap: 2px; }
.liq-review-label {
  font-size: 10px; font-weight: 800; color: #9ca3af;
  text-transform: uppercase; letter-spacing: .5px;
}
.liq-review-value { font-size: 14px; font-weight: 800; color: #111; }
.liq-review-moto button { margin-left: auto; }

/* Botón flotante "Borradores" */
.liq-drafts-fab {
  position: fixed;
  left: 14px;
  bottom: 14px;
  z-index: 60;
  display: none;
  align-items: center;
  gap: 7px;
  background: #fff;
  color: #111;
  border: 1.5px solid #e5e7eb;
  font-size: 13px;
  font-weight: 800;
  font-family: inherit;
  padding: 9px 14px;
  border-radius: 999px;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,0,0,.12);
}
.liq-drafts-fab.visible { display: flex; }
.liq-drafts-fab:hover { border-color: var(--brand); }
.liq-drafts-fab-count {
  background: var(--brand);
  color: #fff;
  border-radius: 999px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  font-size: 11px;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* Modal de borradores */
.liq-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(0,0,0,.45);
  display: none;
  align-items: flex-end;
  justify-content: center;
}
.liq-modal-overlay.open { display: flex; }
.liq-modal {
  background: #fff;
  width: 100%;
  max-width: 600px;
  max-height: 80vh;
  border-radius: 18px 18px 0 0;
  padding: 20px 16px calc(16px + env(safe-area-inset-bottom));
  overflow-y: auto;
  animation: modalUp .2s ease;
}
@keyframes modalUp { from { transform: translateY(24px); opacity: .6; } to { transform: translateY(0); opacity: 1; } }
.liq-modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}
.liq-modal-title { font-size: 16px; font-weight: 900; color: #111; }
.liq-modal-close {
  background: #f3f4f6;
  border: none;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  font-size: 18px;
  color: #6b7280;
  cursor: pointer;
  line-height: 1;
}
.liq-modal-empty { text-align: center; color: #9ca3af; font-size: 14px; padding: 28px 0; }
@media (min-width: 640px) {
  .liq-modal-overlay { align-items: center; }
  .liq-modal { border-radius: 18px; }
}

/* Autosave badge */
.liq-sync {
  position: fixed;
  right: 14px;
  bottom: 14px;
  z-index: 60;
  display: none;
  align-items: center;
  gap: 6px;
  background: #111;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  padding: 8px 14px;
  border-radius: 999px;
  box-shadow: 0 4px 16px rgba(0,0,0,.18);
  pointer-events: none;
}
.liq-sync.visible { display: flex; }
.liq-sync.error   { background: #ef4444; }
.liq-sync .liq-sync-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #22c55e;
}
.liq-sync.saving .liq-sync-dot { background: #f59e0b; animation: syncPulse .9s infinite; }
.liq-sync.error  .liq-sync-dot { background: #fff; }
@keyframes syncPulse { 0%,100%{opacity:1} 50%{opacity:.3} }

/* Editing banner */
.liq-edit-banner {
  display: none;
  align-items: center;
  gap: 8px;
  background: #fff7ed;
  border: 1.5px solid #fdba74;
  color: #9a3412;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 16px;
}
.liq-edit-banner.visible { display: flex; }

/* Drafts resume list */
.liq-drafts {
  display: none;
  margin-bottom: 18px;
}
.liq-drafts.visible { display: block; }
.liq-drafts-title {
  font-size: 11px;
  font-weight: 800;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: .5px;
  margin: 0 0 10px;
}
.liq-draft-card {
  display: flex;
  align-items: center;
  gap: 10px;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 10px 12px;
  margin-bottom: 8px;
  background: #fafafa;
}
.liq-draft-info { flex: 1; min-width: 0; cursor: pointer; }
.liq-draft-label {
  font-size: 13px; font-weight: 800; color: #111;
}
.liq-draft-meta {
  font-size: 12px; color: #6b7280; margin-top: 1px;
}
.liq-draft-discard {
  background: none; border: none; cursor: pointer;
  color: #d1d5db; font-size: 18px; line-height: 1;
  padding: 2px 4px; border-radius: 6px; transition: color .15s;
}
.liq-draft-discard:hover { color: #ef4444; }

/* Desktop */
@media (min-width: 640px) {
  .liq-panel { padding: 32px 32px; }
  .liq-panel-title { font-size: 24px; }
  .liq-search-input { font-size: 18px; padding: 16px 54px; }
  .liq-price-input { width: 180px; }
  .liq-btn { font-size: 15px; }
}
</style>

<div class="liq-page">
  <div class="liq-wrap">

    <!-- Indicador de pasos -->
    <div class="liq-steps">
      <div class="liq-step active" data-step="1">
        <div class="liq-step-dot">1</div>
        <div class="liq-step-label">Moto</div>
      </div>
      <div class="liq-step-line" data-line="1"></div>
      <div class="liq-step" data-step="2">
        <div class="liq-step-dot">2</div>
        <div class="liq-step-label">Ítems</div>
      </div>
      <div class="liq-step-line" data-line="2"></div>
      <div class="liq-step" data-step="3">
        <div class="liq-step-dot">3</div>
        <div class="liq-step-label">Resumen</div>
      </div>
      <div class="liq-step-line" data-line="3"></div>
      <div class="liq-step" data-step="4">
        <div class="liq-step-dot">4</div>
        <div class="liq-step-label">Confirmar</div>
      </div>
    </div>

    <!-- ── PASO 1: Moto / Placa ───────────────────────────────── -->
    <div class="liq-panel active" id="panel1" data-panel="1">
      <h1 class="liq-panel-title" id="liqPanel1Title">Nueva cotización</h1>
      <p class="liq-panel-sub">Empieza por la placa o la moto. La cotización se guarda sola desde aquí: aunque cierres sin confirmar, no se pierde.</p>

      <!-- Banner: editando cotización existente -->
      <div class="liq-edit-banner" id="liqEditBanner" aria-live="polite">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
        </svg>
        <span id="liqEditBannerText">Editando cotización</span>
      </div>

      <!-- Borradores sin terminar (retomar desde cualquier dispositivo) -->
      <div class="liq-drafts" id="liqDrafts">
        <p class="liq-drafts-title">Continuar cotización sin terminar</p>
        <div id="liqDraftsList"></div>
      </div>

      <!-- Moto / Placa (datos del cliente, se piden primero) -->
      <div style="display:grid;grid-template-columns:auto 1fr;gap:10px;align-items:end">
        <div>
          <label for="plateField" style="display:block;font-size:11px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">
            Placa
          </label>
          <input
            id="plateField"
            type="text"
            placeholder="ABC123"
            style="width:120px;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:15px;font-family:inherit;outline:none;background:#fafafa;box-sizing:border-box;text-transform:uppercase;letter-spacing:1px;font-weight:700"
            maxlength="20"
            aria-label="Placa del cliente"
          />
        </div>
        <div>
          <label for="motoField" style="display:block;font-size:11px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">
            Moto <span style="font-weight:400;color:#9ca3af">(opcional)</span>
          </label>
          <input
            id="motoField"
            type="text"
            placeholder="Ej: Honda CB190R"
            style="width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:15px;font-family:inherit;outline:none;background:#fafafa;box-sizing:border-box"
            maxlength="80"
            aria-label="Modelo de la moto"
          />
        </div>
      </div>

      <!-- Acciones paso 1 -->
      <div class="liq-footer-actions" style="margin-top:20px">
        <button class="liq-btn liq-btn-primary" id="btnMotoContinue">Continuar a ítems →</button>
      </div>
    </div>

    <!-- ── PASO 2: Agregar ítems ─────────────────────────────── -->
    <div class="liq-panel" id="panel2" data-panel="2">
      <h2 class="liq-panel-title">Agregar ítems</h2>
      <p class="liq-panel-sub">Busca el ítem (3 letras mínimo) y luego fija el valor.</p>

      <!-- Buscador -->
      <div class="liq-search-wrap">
        <svg class="liq-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="liqSearch"
          class="liq-search-input"
          type="text"
          placeholder="Buscar producto o servicio…"
          autocomplete="off"
          aria-label="Buscar producto o servicio"
          aria-autocomplete="list"
          aria-controls="liqDropdown"
        />
        <button class="liq-search-clear" id="liqClear" aria-label="Limpiar búsqueda" tabindex="-1">×</button>
        <div class="liq-dropdown" id="liqDropdown" role="listbox"></div>
      </div>

      <!-- Formulario de staging (aparece al seleccionar del dropdown) -->
      <div class="liq-staging" id="liqStaging" aria-live="polite">
        <div class="liq-staging-name" id="stagingName">—</div>
        <div class="liq-staging-fields">
          <div class="liq-staging-field">
            <label for="stagingPrice">Valor (COP)</label>
            <input
              id="stagingPrice"
              class="liq-price-input"
              type="text"
              inputmode="numeric"
              placeholder="0"
              autocomplete="off"
              aria-label="Valor del ítem en pesos colombianos"
            />
          </div>
          <div class="liq-staging-field">
            <label for="stagingQty">Cantidad</label>
            <select id="stagingQty" class="liq-qty-select" aria-label="Cantidad">
              <% for (let n = 1; n <= 20; n++) { %>
                <option value="<%= n %>"><%= n %></option>
              <% } %>
            </select>
          </div>
        </div>
        <div class="liq-staging-actions">
          <button class="liq-btn liq-btn-primary liq-btn-sm" id="btnStagingAdd">Añadir ítem</button>
          <button class="liq-btn liq-btn-ghost liq-btn-sm" id="btnStagingCancel">Cancelar</button>
        </div>
      </div>

      <!-- Lista de ítems confirmados -->
      <div class="liq-items-area" id="liqItemsList"></div>

      <!-- Total -->
      <div class="liq-total-bar" id="liqTotalBar" style="display:none">
        <span class="liq-total-label">Total</span>
        <span class="liq-total-value" id="liqTotalVal">COP 0</span>
      </div>

      <!-- Acciones paso 1 -->
      <div class="liq-footer-actions" style="margin-top:16px">
        <button class="liq-btn liq-btn-ghost" id="btnItemsBack">← Moto / placa</button>
        <button class="liq-btn liq-btn-primary" id="btnFinish" disabled>Ver resumen →</button>
      </div>
    </div>

    <!-- ── PASO 3: Resumen ────────────────────────────────────── -->
    <div class="liq-panel" id="panel3" data-panel="3">
      <h2 class="liq-panel-title">Resumen de cotización</h2>
      <p class="liq-panel-sub">Verifica los ítems antes de confirmar.</p>

      <table class="liq-summary-table">
        <thead>
          <tr>
            <th>Ítem</th>
            <th class="td-qty">Cant.</th>
            <th>Precio unit.</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody id="liqSummaryBody"></tbody>
      </table>

      <div class="liq-total-bar">
        <span class="liq-total-label">Total cotización</span>
        <span class="liq-total-value" id="liqSummaryTotal">COP 0</span>
      </div>

      <!-- Moto / Placa (solo lectura: se capturan en el paso 1) -->
      <div class="liq-review-moto" id="liqReviewMoto" style="display:none">
        <div>
          <span class="liq-review-label">Placa</span>
          <span class="liq-review-value" id="liqReviewPlate">—</span>
        </div>
        <div>
          <span class="liq-review-label">Moto</span>
          <span class="liq-review-value" id="liqReviewMotoVal">—</span>
        </div>
        <button class="liq-btn liq-btn-ghost liq-btn-sm" id="btnEditMoto" type="button" style="flex:none">Editar</button>
      </div>

      <div class="liq-footer-actions" style="margin-top:16px">
        <button class="liq-btn liq-btn-ghost" id="btnEditItems">← Editar ítems</button>
        <button class="liq-btn liq-btn-primary" id="btnConfirmSummary">Confirmar →</button>
      </div>
    </div>

    <!-- ── PASO 4: Confirmación ──────────────────────────────── -->
    <div class="liq-panel" id="panel4" data-panel="4">
      <div class="liq-success-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff"
          stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h2 class="liq-panel-title" style="text-align:center">¡Cotización confirmada!</h2>

      <div style="text-align:center;margin-bottom:22px">
        <div class="liq-consecutive">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8"  y1="2" x2="8"  y2="6"/>
            <line x1="3"  y1="10" x2="21" y2="10"/>
          </svg>
          Cotización #<span id="liqConsecNum">—</span>
        </div>
      </div>

      <!-- WhatsApp -->
      <div class="liq-wa-section">
        <label class="liq-wa-toggle">
          <input type="checkbox" id="waToggle" />
          <svg width="20" height="20" viewBox="0 0 32 32" fill="#25D366" aria-hidden="true">
            <path d="M19.11 17.63c-.3-.15-1.73-.85-2-.94-.27-.1-.47-.15-.67.15-.2.3-.77.94-.94 1.14-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.47-.89-.79-1.48-1.77-1.65-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.6-.92-2.2-.24-.58-.48-.5-.67-.5-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.5 0 1.48 1.07 2.92 1.22 3.12.15.2 2.1 3.2 5.08 4.49.71.31 1.26.5 1.69.64.71.23 1.35.2 1.86.12.57-.09 1.73-.71 1.98-1.4.24-.69.24-1.28.17-1.4-.07-.12-.27-.2-.57-.35z"/>
            <path d="M27.25 4.75C24.77 2.27 21.48 1 18.02 1 9.83 1 3.2 7.63 3.2 15.82c0 2.71.71 5.36 2.07 7.71L3 31l7.65-2.01c2.29 1.25 4.88 1.92 7.38 1.92h.01c8.19 0 14.82-6.63 14.82-14.82 0-3.46-1.27-6.75-3.65-9.24zm-9.6 23.72h-.01c-2.29 0-4.55-.62-6.52-1.8l-.47-.28-4.54 1.19 1.21-4.43-.31-.46c-1.25-1.95-1.91-4.22-1.91-6.56 0-6.77 5.51-12.28 12.29-12.28 3.28 0 6.35 1.28 8.67 3.6 2.31 2.31 3.59 5.38 3.59 8.66 0 6.77-5.51 12.29-12.28 12.29z"/>
          </svg>
          <span class="liq-wa-toggle-label">Enviar por WhatsApp al cliente</span>
        </label>

        <div class="liq-wa-fields" id="waFields">
          <select class="liq-country-select" id="waCountry" aria-label="Código de país">
            <option value="+57"  selected>🇨🇴 +57</option>
            <option value="+1">🇺🇸 +1</option>
            <option value="+52">🇲🇽 +52</option>
            <option value="+34">🇪🇸 +34</option>
            <option value="+54">🇦🇷 +54</option>
            <option value="+56">🇨🇱 +56</option>
            <option value="+51">🇵🇪 +51</option>
            <option value="+58">🇻🇪 +58</option>
            <option value="+593">🇪🇨 +593</option>
            <option value="+502">🇬🇹 +502</option>
            <option value="+44">🇬🇧 +44</option>
            <option value="+55">🇧🇷 +55</option>
          </select>
          <input
            id="waPhone"
            class="liq-phone-input"
            type="tel"
            placeholder="Número celular"
            maxlength="15"
            inputmode="numeric"
            aria-label="Número de celular del cliente"
          />
        </div>
        <div class="liq-hint" id="waHint" style="display:none">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          El número quedará guardado con esta cotización.
        </div>
      </div>

      <!-- Acciones paso 3 -->
      <div class="liq-footer-actions">
        <button class="liq-btn liq-btn-ghost" id="btnDownloadPdf">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
            style="display:inline;vertical-align:middle;margin-right:5px" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar PDF
        </button>
        <button class="liq-btn liq-btn-green" id="btnSendOrFinish">Finalizar</button>
      </div>

      <div style="text-align:center;margin-top:18px">
        <button class="liq-btn liq-btn-ghost" id="btnNewQuote" style="max-width:220px;flex:none">
          Nueva cotización
        </button>
      </div>
    </div>

  </div>
</div>

<!-- Indicador de autosave -->
<div class="liq-sync" id="liqSyncStatus" aria-live="polite">
  <span class="liq-sync-dot"></span><span id="liqSyncText">Guardado</span>
</div>

<!-- Botón flotante: ver borradores (disponible en cualquier paso) -->
<button class="liq-drafts-fab" id="liqDraftsFab" type="button" aria-label="Ver borradores sin terminar">
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
  </svg>
  Borradores
  <span class="liq-drafts-fab-count" id="liqDraftsFabCount">0</span>
</button>

<!-- Modal de borradores -->
<div class="liq-modal-overlay" id="liqDraftsModal" role="dialog" aria-modal="true" aria-label="Borradores sin terminar">
  <div class="liq-modal">
    <div class="liq-modal-head">
      <span class="liq-modal-title">Continuar cotización sin terminar</span>
      <button class="liq-modal-close" id="liqDraftsModalClose" type="button" aria-label="Cerrar">×</button>
    </div>
    <div id="liqModalDraftsList"></div>
  </div>
</div>

<!-- jsPDF via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
(function () {
  'use strict';

  // ── Estado ────────────────────────────────────────────────────────
  let items = [];            // [{ id, name, type, price, qty }]
  let staged = null;         // ítem seleccionado pendiente de precio
  let currentStep = 1;
  let savedConsecutive = null;
  let savedLabel = null;
  let savedQuoteId = null;
  let searchDebounce = null;
  let ddResults = [];
  let ddFocusIdx = -1;

  // Persistencia / autosave
  let currentQuoteId = null;   // id de la cotización en DB (borrador o confirmada)
  let isConfirmed = false;     // true si se está editando una ya confirmada
  let syncTimer = null;        // debounce del autosave
  let syncSeq = 0;             // descarta respuestas de sync obsoletas
  const DRAFT_LS_KEY = 'liq_draft_id';

  // ── DOM ───────────────────────────────────────────────────────────
  const searchInput    = document.getElementById('liqSearch');
  const clearBtn       = document.getElementById('liqClear');
  const dropdown       = document.getElementById('liqDropdown');
  const staging        = document.getElementById('liqStaging');
  const stagingName    = document.getElementById('stagingName');
  const stagingPrice   = document.getElementById('stagingPrice');
  const stagingQty     = document.getElementById('stagingQty');
  const btnStagingAdd  = document.getElementById('btnStagingAdd');
  const btnStagingCanc = document.getElementById('btnStagingCancel');
  const itemsList      = document.getElementById('liqItemsList');
  const totalBar       = document.getElementById('liqTotalBar');
  const totalVal       = document.getElementById('liqTotalVal');
  const btnMotoCont    = document.getElementById('btnMotoContinue');
  const btnItemsBack   = document.getElementById('btnItemsBack');
  const btnFinish      = document.getElementById('btnFinish');
  const summaryBody    = document.getElementById('liqSummaryBody');
  const summaryTotal   = document.getElementById('liqSummaryTotal');
  const reviewMoto     = document.getElementById('liqReviewMoto');
  const reviewPlate    = document.getElementById('liqReviewPlate');
  const reviewMotoVal  = document.getElementById('liqReviewMotoVal');
  const btnEditMoto    = document.getElementById('btnEditMoto');
  const btnEditItems   = document.getElementById('btnEditItems');
  const btnConfirm     = document.getElementById('btnConfirmSummary');
  const consecNum      = document.getElementById('liqConsecNum');
  const motoField      = document.getElementById('motoField');
  const plateField     = document.getElementById('plateField');
  if (motoField) {
    motoField.addEventListener('input', () => {
      const pos = motoField.selectionStart;
      motoField.value = motoField.value.toUpperCase();
      motoField.setSelectionRange(pos, pos);
      scheduleSync();
    });
  }
  if (plateField) {
    plateField.addEventListener('input', () => {
      const pos = plateField.selectionStart;
      plateField.value = plateField.value.toUpperCase();
      plateField.setSelectionRange(pos, pos);
      scheduleSync();
    });
  }
  const waToggle       = document.getElementById('waToggle');
  const waFields       = document.getElementById('waFields');
  const waCountry      = document.getElementById('waCountry');
  const waPhone        = document.getElementById('waPhone');
  const waHint         = document.getElementById('waHint');
  const btnDownload    = document.getElementById('btnDownloadPdf');
  const btnSendOrFin   = document.getElementById('btnSendOrFinish');
  const btnNewQuote    = document.getElementById('btnNewQuote');
  const syncBadge      = document.getElementById('liqSyncStatus');
  const syncText       = document.getElementById('liqSyncText');
  const editBanner     = document.getElementById('liqEditBanner');
  const editBannerText = document.getElementById('liqEditBannerText');
  const panel1Title    = document.getElementById('liqPanel1Title');
  const draftsBox      = document.getElementById('liqDrafts');
  const draftsList     = document.getElementById('liqDraftsList');
  const draftsFab      = document.getElementById('liqDraftsFab');
  const draftsFabCount = document.getElementById('liqDraftsFabCount');
  const draftsModal    = document.getElementById('liqDraftsModal');
  const draftsModalClose = document.getElementById('liqDraftsModalClose');
  const modalDraftsList  = document.getElementById('liqModalDraftsList');

  function csrfToken() {
    return document.querySelector('meta[name="csrf-token"]')?.content || '';
  }

  // ── Autosave / sincronización ─────────────────────────────────────
  let syncHideTimer = null;
  function setSyncStatus(state) {
    clearTimeout(syncHideTimer);
    syncBadge.classList.remove('saving', 'error');
    if (state === 'idle') { syncBadge.classList.remove('visible'); return; }
    syncBadge.classList.add('visible');
    if (state === 'saving') { syncBadge.classList.add('saving'); syncText.textContent = 'Guardando…'; }
    else if (state === 'error') { syncBadge.classList.add('error'); syncText.textContent = 'Error al guardar'; }
    else { syncText.textContent = 'Guardado'; syncHideTimer = setTimeout(() => syncBadge.classList.remove('visible'), 2000); }
  }

  function scheduleSync() {
    clearTimeout(syncTimer);
    setSyncStatus('saving');
    syncTimer = setTimeout(syncNow, 700);
  }

  async function syncNow() {
    // Nada que persistir todavía: borrador nuevo y completamente vacío
    const hasContent = items.length > 0
      || (motoField && motoField.value.trim())
      || (plateField && plateField.value.trim());
    if (!currentQuoteId && !hasContent) { setSyncStatus('idle'); return; }
    const seq = ++syncSeq;
    const payload = {
      id: currentQuoteId,
      items: items.map(it => ({ id: it.id, name: it.name, price: it.price, type: it.type, qty: it.qty })),
      total: calcTotal(),
      motorcycle: motoField ? motoField.value.trim() || null : null,
      plate: plateField ? plateField.value.trim().toUpperCase() || null : null,
    };
    const editingConfirmed = isConfirmed && currentQuoteId;
    const url    = editingConfirmed ? '/api/liquidador/quotation/' + currentQuoteId : '/api/liquidador/draft';
    const method = editingConfirmed ? 'PUT' : 'POST';
    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken() },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || 'sync');
      if (seq !== syncSeq) return; // respuesta obsoleta
      if (!currentQuoteId && data.id) {
        currentQuoteId = data.id;
        if (!isConfirmed) localStorage.setItem(DRAFT_LS_KEY, currentQuoteId);
        history.replaceState(null, '', '/liquidador?id=' + currentQuoteId);
      }
      setSyncStatus('saved');
    } catch {
      if (seq === syncSeq) setSyncStatus('error');
    }
  }

  // ── Utilidades ────────────────────────────────────────────────────
  function fmt(n) {
    return 'COP ' + Number(n).toLocaleString('es-CO');
  }

  function calcTotal() {
    return items.reduce((s, it) => s + it.price * it.qty, 0);
  }

  function escHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function goToStep(n) {
    currentStep = n;
    document.querySelectorAll('[data-panel]').forEach(el => {
      el.classList.toggle('active', Number(el.dataset.panel) === n);
    });
    document.querySelectorAll('[data-step]').forEach(el => {
      const s = Number(el.dataset.step);
      el.classList.remove('active', 'done');
      if (s === n) el.classList.add('active');
      else if (s < n) el.classList.add('done');
    });
    document.querySelectorAll('[data-line]').forEach(el => {
      el.classList.toggle('done', n > Number(el.dataset.line));
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Renderizar lista de ítems confirmados ─────────────────────────
  function renderItems() {
    if (items.length === 0) {
      itemsList.innerHTML = '';
      totalBar.style.display = 'none';
      btnFinish.disabled = true;
      return;
    }

    itemsList.innerHTML = items.map((it, idx) => `
      <div class="liq-item-card">
        <div class="liq-item-info">
          <div class="liq-item-name">${escHtml(it.name)}</div>
          <div class="liq-item-meta">${fmt(it.price)} × unidad</div>
        </div>
        <div class="liq-item-right">
          <select class="liq-item-qty-sel" data-qty-idx="${idx}" aria-label="Cantidad de ${escHtml(it.name)}">
            ${Array.from({length:20},(_,i)=>i+1).map(n =>
              `<option value="${n}"${n===it.qty?' selected':''}>${n}</option>`
            ).join('')}
          </select>
          <span class="liq-item-subtotal">${fmt(it.price * it.qty)}</span>
          <button class="liq-item-remove" data-rm-idx="${idx}" aria-label="Eliminar ${escHtml(it.name)}">×</button>
        </div>
      </div>
    `).join('');

    itemsList.querySelectorAll('[data-qty-idx]').forEach(sel => {
      sel.addEventListener('change', e => {
        items[Number(e.target.dataset.qtyIdx)].qty = Number(e.target.value);
        renderItems();
        scheduleSync();
      });
    });
    itemsList.querySelectorAll('[data-rm-idx]').forEach(btn => {
      btn.addEventListener('click', e => {
        items.splice(Number(e.currentTarget.dataset.rmIdx), 1);
        renderItems();
        scheduleSync();
        if (items.length === 0) focusSearch();
      });
    });

    totalVal.textContent = fmt(calcTotal());
    totalBar.style.display = 'flex';
    btnFinish.disabled = false;
  }

  // ── Buscador ──────────────────────────────────────────────────────
  function focusSearch() {
    searchInput.disabled = false;
    searchInput.value = '';
    clearBtn.classList.remove('visible');
    searchInput.focus();
  }

  function closeDropdown() {
    dropdown.classList.remove('open');
    dropdown.innerHTML = '';
    ddResults = [];
    ddFocusIdx = -1;
  }

  function renderDropdown(results) {
    ddResults = results;
    ddFocusIdx = -1;
    const q = searchInput.value.trim();

    let html = results.map((r, i) => `
      <div class="liq-dd-item" data-dd-idx="${i}" role="option" tabindex="-1">
        <span class="liq-dd-name">${escHtml(r.name)}${r.brand ? ` <span class="liq-dd-brand">— ${escHtml(r.brand)}</span>` : ''}</span>
        <span class="liq-dd-type ${r.type}">${r.type === 'service' ? 'Servicio' : 'Producto'}</span>
      </div>
    `).join('');

    // Always append the "use as custom item" option when there's text typed
    if (q.length >= 3) {
      html += `
        <div class="liq-dd-item liq-dd-custom" data-dd-custom="1" role="option" tabindex="-1"
             style="${results.length ? 'border-top:1px solid #e5e7eb;' : ''}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/>
            <line x1="8" y1="12" x2="16" y2="12"/>
          </svg>
          <span class="liq-dd-name" style="color:#374151">Usar "<strong>${escHtml(q)}</strong>"</span>
          <span class="liq-dd-type" style="background:#f3f4f6;color:#6b7280">Personalizado</span>
        </div>
      `;
    }

    if (!html) {
      dropdown.innerHTML = '<div class="liq-dd-empty">Escribe al menos 3 caracteres.</div>';
    } else {
      dropdown.innerHTML = html;
      dropdown.querySelectorAll('.liq-dd-item:not([data-dd-custom])').forEach(el => {
        el.addEventListener('mousedown', e => {
          e.preventDefault();
          pickFromDropdown(Number(el.dataset.ddIdx));
        });
      });
      const customEl = dropdown.querySelector('[data-dd-custom]');
      if (customEl) {
        customEl.addEventListener('mousedown', e => {
          e.preventDefault();
          pickCustom(q);
        });
      }
    }
    dropdown.classList.add('open');
  }

  function moveDdFocus(dir) {
    // Count all focusable items (catalog results + custom option)
    const all = dropdown.querySelectorAll('.liq-dd-item');
    if (!all.length) return;
    ddFocusIdx = (ddFocusIdx + dir + all.length) % all.length;
    all.forEach((el, i) => el.classList.toggle('focused', i === ddFocusIdx));
  }

  function pickCustom(name) {
    const trimmed = name.trim();
    if (!trimmed) return;
    staged = { id: 'custom-' + Date.now(), name: trimmed, type: 'custom' };
    stagingName.textContent = trimmed;
    stagingPrice.value = '';
    stagingQty.value = '1';
    staging.classList.add('visible');
    closeDropdown();
    searchInput.value = '';
    clearBtn.classList.remove('visible');
    searchInput.disabled = true;
    stagingPrice.classList.remove('error');
    stagingPrice.focus();
  }

  function pickFromDropdown(idx) {
    const r = ddResults[idx];
    if (!r) return;
    staged = { id: r.id, name: r.name, type: r.type };
    stagingName.textContent = r.name;
    stagingPrice.value = '';
    stagingQty.value = '1';
    staging.classList.add('visible');
    closeDropdown();
    searchInput.value = '';
    clearBtn.classList.remove('visible');
    searchInput.disabled = true;
    stagingPrice.classList.remove('error');
    stagingPrice.focus();
  }

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim();
    clearBtn.classList.toggle('visible', q.length > 0);
    clearTimeout(searchDebounce);
    if (q.length < 3) { closeDropdown(); return; }
    dropdown.innerHTML = '<div class="liq-dd-searching">Buscando…</div>';
    dropdown.classList.add('open');
    searchDebounce = setTimeout(async () => {
      try {
        const res = await fetch('/api/liquidador/search?q=' + encodeURIComponent(q));
        renderDropdown(await res.json());
      } catch {
        dropdown.innerHTML = '<div class="liq-dd-empty">Error al buscar. Intenta de nuevo.</div>';
      }
    }, 220);
  });

  searchInput.addEventListener('keydown', e => {
    if (!dropdown.classList.contains('open')) return;
    if (e.key === 'ArrowDown')  { e.preventDefault(); moveDdFocus(1); }
    else if (e.key === 'ArrowUp')   { e.preventDefault(); moveDdFocus(-1); }
    else if (e.key === 'Enter') {
      e.preventDefault();
      const allItems = dropdown.querySelectorAll('.liq-dd-item');
      const focusedEl = ddFocusIdx >= 0 ? allItems[ddFocusIdx] : null;
      if (focusedEl && focusedEl.dataset.ddCustom) {
        pickCustom(searchInput.value.trim());
      } else if (ddFocusIdx >= 0 && ddFocusIdx < ddResults.length) {
        pickFromDropdown(ddFocusIdx);
      } else if (ddResults.length === 1) {
        pickFromDropdown(0);
      }
    }
    else if (e.key === 'Escape') { closeDropdown(); }
  });

  searchInput.addEventListener('blur', () => setTimeout(closeDropdown, 150));

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    clearBtn.classList.remove('visible');
    closeDropdown();
    searchInput.focus();
  });

  // ── Staging: confirmar precio y añadir ────────────────────────────
  btnStagingAdd.addEventListener('click', confirmStaging);
  // Formato de miles en tiempo real
  stagingPrice.addEventListener('input', () => {
    const raw = stagingPrice.value.replace(/\D/g, '');
    const cursor = stagingPrice.selectionStart;
    const prevLen = stagingPrice.value.length;
    if (raw === '') { stagingPrice.value = ''; return; }
    const formatted = Number(raw).toLocaleString('es-CO');
    stagingPrice.value = formatted;
    // Reposicionar el cursor considerando los separadores añadidos
    const diff = formatted.length - prevLen;
    stagingPrice.setSelectionRange(cursor + diff, cursor + diff);
  });

  stagingPrice.addEventListener('keydown', e => {
    if (e.key === 'Enter') confirmStaging();
  });

  function confirmStaging() {
    const price = parseInt(stagingPrice.value.replace(/\D/g, ''), 10);
    if (!price || price <= 0) {
      stagingPrice.classList.add('error');
      stagingPrice.focus();
      setTimeout(() => stagingPrice.classList.remove('error'), 1800);
      return;
    }
    items.push({
      id: staged.id,
      name: staged.name,
      type: staged.type,
      price,
      qty: Number(stagingQty.value),
    });
    staged = null;
    staging.classList.remove('visible');
    renderItems();
    scheduleSync();
    focusSearch();
  }

  btnStagingCanc.addEventListener('click', () => {
    staged = null;
    staging.classList.remove('visible');
    focusSearch();
  });

  // ── Paso 1: Moto / Placa ──────────────────────────────────────────
  btnMotoCont.addEventListener('click', () => {
    goToStep(2);
    focusSearch();
  });

  // ── Paso 2: Ítems ─────────────────────────────────────────────────
  btnItemsBack.addEventListener('click', () => goToStep(1));

  btnFinish.addEventListener('click', () => {
    if (items.length === 0) return;
    summaryBody.innerHTML = items.map(it => `
      <tr>
        <td class="td-name">${escHtml(it.name)}</td>
        <td class="td-qty">${it.qty}</td>
        <td class="td-price">${fmt(it.price)}</td>
        <td class="td-sub">${fmt(it.price * it.qty)}</td>
      </tr>
    `).join('');
    summaryTotal.textContent = fmt(calcTotal());
    // Revisión de moto/placa (capturadas en el paso 1)
    const plateVal = plateField ? plateField.value.trim() : '';
    const motoVal  = motoField ? motoField.value.trim() : '';
    if (plateVal || motoVal) {
      reviewPlate.textContent = plateVal || '—';
      reviewMotoVal.textContent = motoVal || '—';
      reviewMoto.style.display = 'flex';
    } else {
      reviewMoto.style.display = 'none';
    }
    goToStep(3);
  });

  // ── Paso 3: Resumen ───────────────────────────────────────────────
  btnEditItems.addEventListener('click', () => goToStep(2));
  btnEditMoto.addEventListener('click', () => goToStep(1));

  btnConfirm.addEventListener('click', async () => {
    // Forzar el guardado pendiente antes de confirmar
    clearTimeout(syncTimer);
    btnConfirm.disabled = true;
    btnConfirm.textContent = 'Guardando…';
    try {
      const res = await fetch('/api/liquidador/quotation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken() },
        body: JSON.stringify({
          id: currentQuoteId,
          items: items.map(it => ({ id: it.id, name: it.name, price: it.price, type: it.type, qty: it.qty })),
          total: calcTotal(),
          clientPhone: null,
          clientPhoneCountry: '+57',
          motorcycle: motoField ? motoField.value.trim() || null : null,
          plate: plateField ? plateField.value.trim().toUpperCase() || null : null,
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || 'Error desconocido');
      savedConsecutive = data.consecutive;
      savedLabel = data.label;
      savedQuoteId = data.id;
      currentQuoteId = data.id;
      isConfirmed = true;
      localStorage.removeItem(DRAFT_LS_KEY); // ya no es un borrador
      history.replaceState(null, '', '/liquidador?id=' + currentQuoteId);
      consecNum.textContent = savedLabel;
      goToStep(4);
    } catch (err) {
      alert('No se pudo guardar: ' + err.message);
      btnConfirm.disabled = false;
      btnConfirm.textContent = 'Confirmar →';
    }
  });

  // ── Paso 3: WhatsApp ──────────────────────────────────────────────
  waToggle.addEventListener('change', () => {
    const on = waToggle.checked;
    waFields.classList.toggle('open', on);
    waHint.style.display = on ? 'flex' : 'none';
    btnSendOrFin.textContent = on ? 'Enviar por WhatsApp' : 'Finalizar';
    btnSendOrFin.className = 'liq-btn ' + (on ? 'liq-btn-green' : 'liq-btn-primary');
  });

  btnSendOrFin.addEventListener('click', async () => {
    if (!waToggle.checked) { resetAll(); return; }
    const digits = waPhone.value.replace(/\D/g, '');
    if (digits.length < 7) {
      waPhone.focus();
      waPhone.style.borderColor = '#ef4444';
      setTimeout(() => waPhone.style.borderColor = '', 1600);
      return;
    }
    const country = waCountry.value;
    const url = 'https://wa.me/' + country.replace('+', '') + digits + '?text=' + encodeURIComponent(buildWhatsAppMsg());

    // Persistir el número asociado a la cotización
    if (savedQuoteId) {
      try {
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
        const phoneRes = await fetch('/api/liquidador/quotation/' + savedQuoteId + '/phone', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
          body: JSON.stringify({ clientPhone: digits, clientPhoneCountry: country }),
        });
        if (!phoneRes.ok) throw new Error('HTTP ' + phoneRes.status);
      } catch {
        alert('No se pudo guardar el número en la cotización. Anótalo manualmente.');
      }
    }

    const a = document.createElement('a');
    a.href = url;
    a.target = '_blank';
    a.rel = 'noopener noreferrer';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  });

  function buildWhatsAppMsg() {
    const cfg    = window.__WA_CONFIG__ || {};
    const header = cfg.waHeader || '🏍️ *Cotización Gorillaz Motorbikes*';
    const prefix = cfg.waItemPrefix || '•';
    const footer = cfg.waFooter || 'gorillazmotorbikes.com';
    const note   = (cfg.waNote || '').trim();
    const moto   = motoField ? motoField.value.trim() : '';
    const link   = savedQuoteId
      ? window.location.origin + '/cotizacion/' + savedQuoteId
      : null;

    const lines = [header, 'N° ' + (savedLabel || savedConsecutive)];
    if (moto) lines.push('🏍️ ' + moto);
    lines.push('');
    items.forEach(it => lines.push(`${prefix} ${it.name} ×${it.qty} — ${fmt(it.price * it.qty)}`));
    lines.push('');
    lines.push('*Total: ' + fmt(calcTotal()) + '*');
    if (note) { lines.push(''); lines.push(note); }
    if (link) {
      lines.push('');
      lines.push('📄 *Ver cotización completa y descargar PDF:*');
      lines.push(link);
    }
    lines.push(''); lines.push(footer);
    return lines.join('\n');
  }

  // ── PDF ───────────────────────────────────────────────────────────
  btnDownload.addEventListener('click', () => {
    if (typeof window.jspdf === 'undefined') {
      alert('La librería PDF aún está cargando, intenta en un momento.');
      return;
    }
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'mm', format: 'a4' });

    // Header
    doc.setFillColor(242, 92, 5);
    doc.rect(0, 0, 210, 28, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(18); doc.setFont('helvetica', 'bold');
    doc.text('GORILLAZ MOTORBIKES', 14, 12);
    doc.setFontSize(9); doc.setFont('helvetica', 'normal');
    doc.text('gorillazmotorbikes.com  |  Bogotá, Colombia', 14, 20);
    const dateStr = new Date().toLocaleDateString('es-CO', { year:'numeric', month:'long', day:'numeric' });
    doc.text('Fecha: ' + dateStr, 196, 12, { align: 'right' });
    doc.text('Cotización N° ' + (savedLabel || savedConsecutive), 196, 20, { align: 'right' });

    // Title + moto
    doc.setTextColor(17, 17, 17);
    doc.setFontSize(14); doc.setFont('helvetica', 'bold');
    doc.text('COTIZACIÓN', 14, 40);
    const motoVal = motoField ? motoField.value.trim() : '';
    if (motoVal) {
      doc.setFontSize(10); doc.setFont('helvetica', 'normal');
      doc.setTextColor(107, 114, 128);
      doc.text('Moto / Placa: ' + motoVal, 14, 47);
    }

    // Table header helper
    function drawTableHeader(doc, startY) {
      doc.setFillColor(245, 245, 245);
      doc.rect(14, startY - 6, 182, 9, 'F');
      doc.setFontSize(9); doc.setFont('helvetica', 'bold');
      doc.setTextColor(107, 114, 128);
      doc.text('ÍTEM', 16, startY);
      doc.text('CANT.', 126, startY, { align: 'center' });
      doc.text('PRECIO UNIT.', 158, startY, { align: 'right' });
      doc.text('SUBTOTAL', 196, startY, { align: 'right' });
      const lineY = startY + 6;
      doc.setDrawColor(229, 231, 235); doc.setLineWidth(0.3);
      doc.line(14, lineY, 196, lineY);
      return lineY;
    }

    // Table header
    let y = motoVal ? 57 : 50;
    y = drawTableHeader(doc, y);

    // Rows
    doc.setFontSize(10); doc.setTextColor(17, 17, 17);
    let rowIdx = 0;
    items.forEach((it) => {
      if (y + 8 > 270) {
        doc.addPage();
        y = drawTableHeader(doc, 20);
        rowIdx = 0;
      }
      y += 8;
      if (rowIdx % 2 === 1) {
        doc.setFillColor(250, 250, 250);
        doc.rect(14, y - 5.5, 182, 8, 'F');
      }
      doc.setFont('helvetica', 'normal');
      doc.text(it.name, 16, y);
      doc.text(String(it.qty), 126, y, { align: 'center' });
      doc.text(it.price.toLocaleString('es-CO'), 158, y, { align: 'right' });
      doc.setFont('helvetica', 'bold');
      doc.text((it.price * it.qty).toLocaleString('es-CO'), 196, y, { align: 'right' });
      rowIdx++;
    });

    // Total
    y += 12;
    doc.setFillColor(242, 92, 5);
    doc.rect(120, y - 6, 76, 11, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(11); doc.setFont('helvetica', 'bold');
    doc.text('TOTAL:', 128, y);
    doc.text('COP ' + calcTotal().toLocaleString('es-CO'), 196, y, { align: 'right' });

    // Footer
    doc.setTextColor(107, 114, 128);
    doc.setFont('helvetica', 'normal'); doc.setFontSize(8);
    doc.text('Válida por 30 días. Precios en COP.', 14, 285);
    doc.text('Gorillaz Motorbikes — Bogotá, Colombia', 196, 285, { align: 'right' });

    doc.save('cotizacion-' + (savedLabel || savedConsecutive) + '.pdf');
  });

  // ── Nueva cotización ──────────────────────────────────────────────
  btnNewQuote.addEventListener('click', resetAll);

  function resetAll() {
    items = [];
    staged = null;
    savedConsecutive = null;
    savedLabel = null;
    savedQuoteId = null;
    currentQuoteId = null;
    isConfirmed = false;
    clearTimeout(syncTimer);
    syncSeq++;
    localStorage.removeItem(DRAFT_LS_KEY);
    history.replaceState(null, '', '/liquidador');
    setSyncStatus('idle');
    editBanner.classList.remove('visible');
    panel1Title.textContent = 'Nueva cotización';
    staging.classList.remove('visible');
    if (motoField) motoField.value = '';
    if (plateField) plateField.value = '';
    waToggle.checked = false;
    waFields.classList.remove('open');
    waPhone.value = '';
    waCountry.value = '+57';
    waHint.style.display = 'none';
    btnSendOrFin.textContent = 'Finalizar';
    btnSendOrFin.className = 'liq-btn liq-btn-primary';
    btnConfirm.disabled = false;
    btnConfirm.textContent = 'Confirmar →';
    renderItems();
    goToStep(1);
    fetchDrafts();
    if (plateField) plateField.focus();
  }

  // ── Hidratar una cotización existente (borrador o confirmada) ─────
  function hydrate(q) {
    items = (q.items || []).map(it => ({
      id: it.id,
      name: it.name,
      type: it.type || 'custom',
      price: Number(it.price),
      qty: Number(it.qty) || 1,
    }));
    currentQuoteId = q.id;
    isConfirmed = q.status !== 'draft';
    if (isConfirmed) localStorage.removeItem(DRAFT_LS_KEY);
    else localStorage.setItem(DRAFT_LS_KEY, q.id);
    if (motoField)  motoField.value  = q.motorcycle || '';
    if (plateField) plateField.value = q.plate || '';
    if (isConfirmed) {
      panel1Title.textContent = 'Editar cotización';
      editBannerText.textContent = 'Editando cotización #' + q.label + ' — los cambios se guardan automáticamente';
    } else {
      editBannerText.textContent = 'Borrador retomado — continúa donde lo dejaste';
    }
    editBanner.classList.add('visible');
    renderItems();
  }

  // ── Lista de borradores sin terminar ──────────────────────────────
  function draftCardHtml(d) {
    const meta = [`${d.itemCount} ítem${d.itemCount === 1 ? '' : 's'}`];
    if (d.itemCount > 0) meta.push(fmt(d.total));
    if (d.plate) meta.push(escHtml(d.plate));
    else if (d.motorcycle) meta.push(escHtml(d.motorcycle));
    return `
      <div class="liq-draft-card">
        <div class="liq-draft-info" data-draft-id="${escHtml(d.id)}" role="button" tabindex="0">
          <div class="liq-draft-label">Cotización #${escHtml(d.label)}</div>
          <div class="liq-draft-meta">${meta.join(' · ')}</div>
        </div>
        <button class="liq-draft-discard" data-discard-id="${escHtml(d.id)}" aria-label="Descartar borrador">×</button>
      </div>`;
  }

  function wireDraftCards(container, onChange) {
    container.querySelectorAll('[data-draft-id]').forEach(el => {
      const go = () => { window.location.href = '/liquidador?id=' + el.dataset.draftId; };
      el.addEventListener('click', go);
      el.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); } });
    });
    container.querySelectorAll('[data-discard-id]').forEach(btn => {
      btn.addEventListener('click', async e => {
        e.stopPropagation();
        try {
          await fetch('/api/liquidador/draft/' + btn.dataset.discardId, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken() },
            body: '{}',
          });
        } catch {}
        if (onChange) onChange();
      });
    });
  }

  async function loadDraftList() {
    try {
      const res = await fetch('/api/liquidador/drafts');
      const drafts = await res.json();
      return Array.isArray(drafts)
        ? drafts.filter(d => d.id !== currentQuoteId && (d.itemCount > 0 || d.motorcycle || d.plate))
        : [];
    } catch { return []; }
  }

  function renderModalDrafts(list) {
    modalDraftsList.innerHTML = list.length
      ? list.map(draftCardHtml).join('')
      : '<p class="liq-modal-empty">No hay cotizaciones sin terminar.</p>';
    wireDraftCards(modalDraftsList, fetchDrafts);
  }

  // Refresca la sección inline (paso 1), el contador del botón flotante y, si está abierto, el modal.
  async function fetchDrafts() {
    const list = await loadDraftList();
    if (list.length) {
      draftsList.innerHTML = list.map(draftCardHtml).join('');
      wireDraftCards(draftsList, fetchDrafts);
      draftsBox.classList.add('visible');
    } else {
      draftsBox.classList.remove('visible');
    }
    draftsFabCount.textContent = list.length;
    draftsFab.classList.toggle('visible', list.length > 0);
    if (draftsModal.classList.contains('open')) renderModalDrafts(list);
  }

  async function openDraftsModal() {
    renderModalDrafts(await loadDraftList());
    draftsModal.classList.add('open');
  }
  function closeDraftsModal() { draftsModal.classList.remove('open'); }

  draftsFab.addEventListener('click', openDraftsModal);
  draftsModalClose.addEventListener('click', closeDraftsModal);
  draftsModal.addEventListener('click', e => { if (e.target === draftsModal) closeDraftsModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && draftsModal.classList.contains('open')) closeDraftsModal(); });

  // ── Init ──────────────────────────────────────────────────────────
  (function init() {
    const params = new URLSearchParams(window.location.search);
    const urlId  = params.get('id');
    const EDIT   = window.__EDIT_QUOTATION__;

    if (EDIT) {
      hydrate(EDIT);
      fetchDrafts();
      return;
    }
    if (urlId) {
      // Se pidió un id que ya no existe como cotización (borrador descartado/expirado)
      if (localStorage.getItem(DRAFT_LS_KEY) === urlId) localStorage.removeItem(DRAFT_LS_KEY);
      history.replaceState(null, '', '/liquidador');
    } else {
      // Reanudar automáticamente el borrador de este dispositivo
      const savedId = localStorage.getItem(DRAFT_LS_KEY);
      if (savedId) { window.location.replace('/liquidador?id=' + savedId); return; }
    }
    fetchDrafts();
    if (plateField) plateField.focus();
  })();
})();
</script>

<%- include('partials/footer') %>
