<%# Shared personal-data fields for member self-edit and admin edit.
     Same `name=` attributes on both sides keep DB mapping consistent.
     Pass: u (user object), admin (bool — show id-sensitive + management fields). %>
<div class="crm-form-grid">
  <div class="crm-form-group">
    <label>Nombre completo</label>
    <input name="name" value="<%= u.name || '' %>" maxlength="100" required />
  </div>
  <div class="crm-form-group">
    <label>Nickname / Apodo</label>
    <input name="nickname" value="<%= u.nickname || '' %>" />
  </div>
  <% if (admin) { %>
  <div class="crm-form-group">
    <label>Cédula</label>
    <input name="cedula" value="<%= u.cedula || '' %>" inputmode="numeric" />
  </div>
  <% } %>
  <div class="crm-form-group">
    <label>Celular</label>
    <input name="phone" type="tel" value="<%= u.phone || '' %>" />
  </div>
  <div class="crm-form-group">
    <label>Ciudad</label>
    <input name="city" value="<%= u.city || '' %>" />
  </div>
  <% if (admin) { %>
  <div class="crm-form-group">
    <label>Fecha de nacimiento</label>
    <input name="birthdate" type="date" value="<%= u.birthdate || '' %>" />
  </div>
  <% } %>
  <div class="crm-form-group">
    <label>RH (Grupo sanguíneo)</label>
    <select name="bloodType">
      <option value="">— Seleccionar —</option>
      <% ['O+','O-','A+','A-','B+','B-','AB+','AB-'].forEach(function (bt) { %>
        <option value="<%= bt %>" <%= u.bloodType === bt ? 'selected' : '' %>><%= bt %></option>
      <% }); %>
    </select>
  </div>
  <div class="crm-form-group">
    <label>Contacto emergencia — Nombre</label>
    <input name="emergencyName" value="<%= u.emergencyName || '' %>" />
  </div>
  <div class="crm-form-group">
    <label>Contacto emergencia — Celular</label>
    <input name="emergencyPhone" type="tel" value="<%= u.emergencyPhone || '' %>" />
  </div>
  <% if (admin) { %>
  <div class="crm-form-group">
    <label>Nivel membresía</label>
    <input name="membershipLevel" value="<%= (u.membership && u.membership.level) || '' %>" placeholder="Básica / Premium…" />
  </div>
  <div class="crm-form-group">
    <label>Rol</label>
    <select name="role">
      <option value="user" <%= u.role !== 'admin' ? 'selected' : '' %>>Usuario</option>
      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
    </select>
  </div>
  <% } %>
  <div class="crm-form-group" style="flex-direction:row;align-items:center;gap:8px">
    <input type="checkbox" name="clubNotifications" value="true" <%= u.clubNotifications !== false ? 'checked' : '' %> style="width:auto;margin:0" />
    <label style="text-transform:none">Recibir notificaciones del club por correo</label>
  </div>
</div>
