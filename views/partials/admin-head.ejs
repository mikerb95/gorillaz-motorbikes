      </a>

      <div class="crm-nav-divider" style="height:1px;background:rgba(255,255,255,.12);margin:6px 12px"></div>

      <a class="crm-nav-link" href="/admin/ayuda" data-path="/admin/ayuda" data-keywords="soporte documentación faq preguntas">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
