    <div class="crm-sidebar-footer">
      <div class="crm-sidebar-user">
        <div class="crm-avatar"><%= user ? user.name.charAt(0).toUpperCase() : 'A' %></div>
        <div class="crm-user-info">
          <span class="crm-user-name"><%= user ? user.name : 'Admin' %></span>
          <span class="crm-user-role">Administrador</span>
        </div>
      </div>
      <div class="crm-sidebar-actions">
        <a class="crm-sidebar-btn" href="/" target="_blank" title="Ver sitio">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Sitio
        </a>
        <form method="post" action="/club/logout" style="display:contents">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="crm-sidebar-btn crm-logout-btn" title="Cerrar sesión">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Salir
          </button>
        </form>
      </div>
