    <header class="crm-topbar">
      <button class="crm-menu-toggle" id="crmMenuToggle" aria-label="Menú">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="crm-topbar-title"><%= title || 'Admin' %></div>
      <div class="crm-topbar-right">
        <div class="crm-avatar crm-avatar-sm"><%= user ? user.name.charAt(0).toUpperCase() : 'A' %></div>
      </div>
    </header>

    <!-- Page content -->
    <div class="crm-content">
