    </div><!-- /crm-content -->
  </div><!-- /crm-main -->
</div><!-- /crm-shell -->

<!-- iOS Tab Bar (visible only on mobile via CSS) -->
<nav class="crm-ios-tab-bar" id="crmTabBar" style="display:none">
  <a class="crm-ios-tab-item" href="/admin" data-tab="/admin">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
    Inicio
  </a>
  <a class="crm-ios-tab-item" href="/admin/citas" data-tab="/admin/citas">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 16 11 18 15 14"/></svg>
    Citas
  </a>
  <a class="crm-ios-tab-item" href="/admin/eventos" data-tab="/admin/eventos">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    Eventos
  </a>
  <a class="crm-ios-tab-item" href="/admin/usuarios" data-tab="/admin/usuarios">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    Usuarios
  </a>
  <a class="crm-ios-tab-item" href="/admin/tienda" data-tab="/admin/tienda">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    Tienda
  </a>
</nav>

<script>
  // Sidebar toggle (desktop only)
  const toggle = document.getElementById('crmMenuToggle');
  const sidebar = document.getElementById('crmSidebar');
  const overlay = document.getElementById('crmOverlay');
  if (toggle && sidebar && overlay) {
    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('open');
    });
    overlay.addEventListener('click', () => {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
    });
  }

  // Active nav link (sidebar)
  const path = window.location.pathname.replace(/\/$/, '');
  document.querySelectorAll('.crm-nav-link').forEach(link => {
    const lp = (link.dataset.path || '').replace(/\/$/, '');
    if (lp && (path === lp || (lp !== '/admin' && path.startsWith(lp)))) {
      link.classList.add('active');
    }
  });

  // iOS Tab Bar — show on mobile, mark active tab
  (function () {
    const tabBar = document.getElementById('crmTabBar');
    if (!tabBar) return;

    function applyTabBar() {
      if (window.innerWidth <= 900) {
        tabBar.style.display = 'flex';
        tabBar.querySelectorAll('.crm-ios-tab-item').forEach(item => {
          const tp = (item.dataset.tab || '').replace(/\/$/, '');
          const isActive = tp === '/admin'
            ? path === '/admin'
            : (tp && path.startsWith(tp));
          if (isActive) item.classList.add('active');
        });
      } else {
        tabBar.style.display = 'none';
      }
    }

    applyTabBar();
    window.addEventListener('resize', applyTabBar);

    // Press effect for tab items
    tabBar.querySelectorAll('.crm-ios-tab-item').forEach(item => {
      item.addEventListener('touchstart', () => item.classList.add('pressed'), { passive: true });
      item.addEventListener('touchend', () => item.classList.remove('pressed'), { passive: true });
      item.addEventListener('touchcancel', () => item.classList.remove('pressed'), { passive: true });
    });
  })();

  // Press effect for quick-links (iOS grid)
  document.querySelectorAll('.crm-quick-link').forEach(link => {
    link.addEventListener('touchstart', () => link.classList.add('pressed'), { passive: true });
    link.addEventListener('touchend', () => link.classList.remove('pressed'), { passive: true });
    link.addEventListener('touchcancel', () => link.classList.remove('pressed'), { passive: true });
  });

  // Confirm dialogs
  document.querySelectorAll('[data-confirm]').forEach(form => {
    form.addEventListener('submit', e => {
      if (!confirm(form.dataset.confirm || '¿Confirmar?')) e.preventDefault();
    });
  });
</script>
</body>
</html>
