<!-- Sidebar search (filter nav + configs + actions) -->
<style>
  .crm-nav-search {
    position: relative;
    margin: 4px 12px 8px;
  }
  .crm-nav-search-icon {
    position: absolute;
    left: 11px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255,255,255,.7);
    pointer-events: none;
  }
  .crm-nav-search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 9px 32px 9px 34px;
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 8px;
    background: rgba(0,0,0,.16);
    color: #fff;
    font-family: inherit;
    font-size: .83rem;
    font-weight: 600;
    outline: none;
    transition: background .15s, border-color .15s;
  }
  .crm-nav-search-input::placeholder { color: rgba(255,255,255,.6); }
  .crm-nav-search-input:focus {
    background: rgba(0,0,0,.28);
    border-color: rgba(255,255,255,.5);
  }
  .crm-nav-search-clear {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: rgba(255,255,255,.75);
    cursor: pointer;
    transition: background .15s, color .15s;
  }
  .crm-nav-search-clear:hover { background: rgba(0,0,0,.2); color: #fff; }

  /* Filtered-out items / dividers */
  .crm-nav-link.is-hidden,
  .crm-nav-divider.is-hidden { display: none; }

  /* Keyboard highlight (shared by nav links + extra items) */
  .crm-nav-link.is-active-result,
  .crm-nav-extra-item.is-active-result {
    background: rgba(0,0,0,.28);
    color: #fff;
  }

  /* Extra results (configs + actions injected while searching) */
  .crm-nav-extra { display: flex; flex-direction: column; }
  .crm-nav-extra-group {
    margin: 10px 12px 2px;
    font-size: .62rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(255,255,255,.55);
  }
  .crm-nav-extra-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    color: rgba(255,255,255,.75);
    font-size: .83rem;
    font-weight: 700;
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .crm-nav-extra-item:hover { background: rgba(0,0,0,.15); color: #fff; }
  .crm-nav-extra-item svg { flex: 0 0 auto; }

  .crm-nav-empty {
    margin: 14px 12px;
    font-size: .8rem;
    font-weight: 600;
    color: rgba(255,255,255,.6);
    text-align: center;
  }
</style>
<script>
  (function () {
    const input    = document.getElementById('crmNavSearch');
    const clearBtn = document.getElementById('crmNavSearchClear');
    const extraBox = document.getElementById('crmNavExtra');
    const emptyEl  = document.getElementById('crmNavEmpty');
    const nav      = document.querySelector('.crm-nav');
    if (!input || !nav) return;

    const links    = Array.from(nav.querySelectorAll('.crm-nav-link'));
    const dividers = Array.from(nav.querySelectorAll('.crm-nav-divider'));

    // Strip accents + lowercase for forgiving matching
    const norm = s => (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

    // SVG icons reused for extra items
    const ICON = {
      cfg:    '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>',
      plus:   '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>',
      backup: '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
      user:   '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
      wrench: '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>',
      doc:    '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',
      arrow:  '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>'
    };

    // ── Búsqueda de placa (typeahead) ─────────────────────────────────────
    // Se dispara solo cuando el texto "parece placa" (alfanumérico corto con al
    // menos un dígito) para no golpear el backend en cada búsqueda de sección.
    const plateBox = document.createElement('div');
    plateBox.className = 'crm-nav-extra';
    plateBox.hidden = true;
    extraBox.parentNode.insertBefore(plateBox, extraBox);

    let plateTimer = null;
    let plateAbort = null;
    let textResults = [];
    let plateResults = [];

    function looksLikePlate(raw) {
      const compact = raw.replace(/\s/g, '');
      return /^[a-z0-9]{3,7}$/i.test(compact) && /\d/.test(compact);
    }

    function recomputeResults() {
      results = plateResults.concat(textResults);
      activeIdx = -1;
      emptyEl.hidden = results.length > 0 || !!plateTimer;
    }

    function clearPlatePanel() {
      plateBox.hidden = true;
      plateBox.innerHTML = '';
      plateResults = [];
    }

    function plateItem(href, icon, label) {
      const a = document.createElement('a');
      a.className = 'crm-nav-extra-item';
      a.href = href;
      a.innerHTML = icon + '<span>' + label + '</span>';
      plateBox.appendChild(a);
      return a;
    }

    function renderPlatePanel(data) {
      plateBox.innerHTML = '';
      const header = document.createElement('div');
      header.className = 'crm-nav-extra-group';
      header.textContent = 'Placa ' + data.plate;
      plateBox.appendChild(header);

      const created = [];
      if (data.member) {
        const lbl = data.member.name + (data.member.level ? ' · ' + data.member.level : '');
        created.push(plateItem('/admin/placa/' + data.plate + '#club', ICON.user, lbl));
      }
      if (data.counts.orders > 0) {
        const lbl = data.counts.orders + (data.counts.orders === 1 ? ' orden de servicio' : ' órdenes de servicio');
        created.push(plateItem('/admin/placa/' + data.plate + '#ordenes', ICON.wrench, lbl));
      }
      if (data.counts.quotations > 0) {
        const lbl = data.counts.quotations + (data.counts.quotations === 1 ? ' cotización' : ' cotizaciones');
        created.push(plateItem('/admin/placa/' + data.plate + '#cotizaciones', ICON.doc, lbl));
      }
      created.push(plateItem('/admin/placa/' + data.plate, ICON.arrow, 'Ver historial completo'));

      plateBox.hidden = false;
      plateResults = created;
      recomputeResults();
    }

    function schedulePlateSearch(raw) {
      clearTimeout(plateTimer);
      if (plateAbort) plateAbort.abort();
      plateBox.hidden = true;
      plateResults = [];

      if (!looksLikePlate(raw)) { plateTimer = null; recomputeResults(); return; }

      plateTimer = setTimeout(() => {
        plateAbort = new AbortController();
        fetch('/admin/api/buscar-placa?q=' + encodeURIComponent(raw), { signal: plateAbort.signal })
          .then(r => r.ok ? r.json() : null)
          .then(data => {
            plateTimer = null;
            if (!data || !data.ok || input.value.trim() !== raw) { recomputeResults(); return; }
            renderPlatePanel(data);
          })
          .catch(() => { plateTimer = null; recomputeResults(); });
      }, 300);
      recomputeResults();
    }

    // Static index of things NOT in the sidebar: config tabs + quick actions
    const EXTRA = [
      { label: 'Liquidador',          path: '/admin/configuracion?tab=liquidador',   group: 'Configuración', icon: ICON.cfg,    keywords: 'cotizador whatsapp mensaje pin acceso' },
      { label: 'PDF Cotización',      path: '/admin/configuracion?tab=pdf',          group: 'Configuración', icon: ICON.cfg,    keywords: 'documento empresa nit logo color factura' },
      { label: 'Parqueadero',         path: '/admin/configuracion?tab=parqueadero',  group: 'Configuración', icon: ICON.cfg,    keywords: 'tarifa dias gratis taller cobro' },
      { label: 'Sistema de Puntos',   path: '/admin/configuracion?tab=puntos',       group: 'Configuración', icon: ICON.cfg,    keywords: 'niveles gamificacion rodada visita evento mantenimiento membresia' },
      { label: 'Empleados',           path: '/admin/configuracion?tab=empleados',    group: 'Configuración', icon: ICON.cfg,    keywords: 'pin taller mecanicos personal acceso' },
      { label: 'Nueva orden de servicio', path: '/admin/ordenes-servicio/nueva',     group: 'Acciones',      icon: ICON.plus,   keywords: 'crear taller ingreso moto trabajo ot' },
      { label: 'Descargar backup',    path: '/admin/dev/backup',                     group: 'Acciones',      icon: ICON.backup, keywords: 'respaldo base datos exportar json copia' }
    ];

    let results = [];   // currently visible matches (for keyboard nav)
    let activeIdx = -1;

    function renderExtra(q) {
      extraBox.innerHTML = '';
      const matches = EXTRA.filter(e => norm(e.label + ' ' + e.keywords).includes(q));
      if (!matches.length) { extraBox.hidden = true; return []; }

      const created = [];
      let lastGroup = null;
      matches.forEach(e => {
        if (e.group !== lastGroup) {
          const h = document.createElement('div');
          h.className = 'crm-nav-extra-group';
          h.textContent = e.group;
          extraBox.appendChild(h);
          lastGroup = e.group;
        }
        const a = document.createElement('a');
        a.className = 'crm-nav-extra-item';
        a.href = e.path;
        a.innerHTML = e.icon + '<span>' + e.label + '</span>';
        extraBox.appendChild(a);
        created.push(a);
      });
      extraBox.hidden = false;
      return created;
    }

    function clearHighlight() {
      results.forEach(el => el.classList.remove('is-active-result'));
    }

    function setActive(idx) {
      clearHighlight();
      if (!results.length) { activeIdx = -1; return; }
      activeIdx = (idx + results.length) % results.length;
      const el = results[activeIdx];
      el.classList.add('is-active-result');
      el.scrollIntoView({ block: 'nearest' });
    }

    function apply() {
      const raw = input.value.trim();
      const q = norm(raw);
      clearBtn.hidden = !raw;

      if (!q) {
        // Restore original sidebar
        links.forEach(l => l.classList.remove('is-hidden', 'is-active-result'));
        dividers.forEach(d => d.classList.remove('is-hidden'));
        extraBox.hidden = true;
        extraBox.innerHTML = '';
        emptyEl.hidden = true;
        results = [];
        activeIdx = -1;
        return;
      }

      // Filter existing nav links
      const visibleLinks = [];
      links.forEach(l => {
        const hay = norm(l.textContent + ' ' + (l.dataset.keywords || ''));
        const show = hay.includes(q);
        l.classList.toggle('is-hidden', !show);
        l.classList.remove('is-active-result');
        if (show) visibleLinks.push(l);
      });
      // Hide structural dividers while searching
      dividers.forEach(d => d.classList.add('is-hidden'));

      const extraEls = renderExtra(q);
      results = visibleLinks.concat(extraEls);
      activeIdx = -1;
      emptyEl.hidden = results.length > 0;
    }

    input.addEventListener('input', apply);

    input.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown')      { e.preventDefault(); setActive(activeIdx + 1); }
      else if (e.key === 'ArrowUp')   { e.preventDefault(); setActive(activeIdx - 1); }
      else if (e.key === 'Enter') {
        e.preventDefault();
        const target = activeIdx >= 0 ? results[activeIdx] : results[0];
        if (target) window.location.href = target.getAttribute('href');
      } else if (e.key === 'Escape') {
        if (input.value) { input.value = ''; apply(); }
        else input.blur();
      }
    });

    clearBtn.addEventListener('click', () => { input.value = ''; apply(); input.focus(); });

    // Ctrl/Cmd+K focuses the search
    document.addEventListener('keydown', e => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        input.focus();
        input.select();
      }
    });
  })();
</script>

<!-- Delete confirmation modal -->
<style>
  .crm-modal-wrap {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    pointer-events: none;
    opacity: 0;
    transition: opacity .18s ease;
  }
  .crm-modal-wrap.is-open {
    pointer-events: auto;
    opacity: 1;
  }
  .crm-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }
  .crm-modal-card {
    position: relative;
    background: #fff;
    border-radius: 18px;
    padding: 28px 28px 24px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 24px 60px rgba(0,0,0,.22);
    transform: scale(.93) translateY(8px);
    transition: transform .2s cubic-bezier(.34,1.3,.64,1), opacity .18s ease;
    opacity: 0;
  }
  .crm-modal-wrap.is-open .crm-modal-card {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
  .crm-modal-icon {
    width: 48px;
    height: 48px;
    background: #fef2f2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }
  .crm-modal-icon svg { color: #dc2626; }
  .crm-modal-title {
    font-size: 17px;
    font-weight: 800;
    color: #111827;
    text-align: center;
    margin: 0 0 8px;
  }
  .crm-modal-msg {
    font-size: 14px;
    color: #6b7280;
    text-align: center;
    margin: 0 0 24px;
    line-height: 1.5;
  }
  .crm-modal-actions {
    display: flex;
    gap: 10px;
  }
  .crm-modal-actions .btn {
    flex: 1;
    justify-content: center;
  }
</style>

<div id="crmDeleteModal" class="crm-modal-wrap" role="dialog" aria-modal="true" aria-labelledby="crmDeleteModalTitle" aria-hidden="true">
  <div id="crmDeleteModalBackdrop" class="crm-modal-backdrop"></div>
  <div class="crm-modal-card">
    <div class="crm-modal-icon">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
    </div>
    <h2 id="crmDeleteModalTitle" class="crm-modal-title">¿Confirmar eliminación?</h2>
    <p id="crmDeleteModalMsg" class="crm-modal-msg"></p>
    <div class="crm-modal-actions">
      <button id="crmDeleteModalCancel" class="btn btn-ghost btn-sm" type="button">Cancelar</button>
      <button id="crmDeleteModalConfirm" class="btn btn-danger btn-sm" type="button">Eliminar</button>
    </div>
  </div>
</div>

<script>
  // Sidebar toggle (desktop only)
  const toggle = document.getElementById('crmMenuToggle');
  const sidebar = document.getElementById('crmSidebar');
  const overlay = document.getElementById('crmOverlay');
  if (toggle && sidebar && overlay) {
    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('open');
    });
    overlay.addEventListener('click', () => {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
    });
  }

  // Active nav link (sidebar)
  const path = window.location.pathname.replace(/\/$/, '');
  document.querySelectorAll('.crm-nav-link').forEach(link => {
    const lp = (link.dataset.path || '').replace(/\/$/, '');
    if (lp && (path === lp || (lp !== '/admin' && path.startsWith(lp)))) {
      link.classList.add('active');
    }
  });

  // iOS Tab Bar — show on mobile, mark active tab
  (function () {
    const tabBar = document.getElementById('crmTabBar');
    if (!tabBar) return;

    function applyTabBar() {
      if (window.innerWidth <= 900) {
        tabBar.style.display = 'flex';
        tabBar.querySelectorAll('.crm-ios-tab-item').forEach(item => {
          const tp = (item.dataset.tab || '').replace(/\/$/, '');
          const isActive = tp === '/admin'
            ? path === '/admin'
            : (tp && path.startsWith(tp));
          if (isActive) item.classList.add('active');
        });
      } else {
        tabBar.style.display = 'none';
      }
    }

    applyTabBar();
    window.addEventListener('resize', applyTabBar);

    // Press effect for tab items
    tabBar.querySelectorAll('.crm-ios-tab-item').forEach(item => {
      item.addEventListener('touchstart', () => item.classList.add('pressed'), { passive: true });
      item.addEventListener('touchend', () => item.classList.remove('pressed'), { passive: true });
      item.addEventListener('touchcancel', () => item.classList.remove('pressed'), { passive: true });
    });
  })();

  // Press effect for quick-links (iOS grid)
  document.querySelectorAll('.crm-quick-link').forEach(link => {
    link.addEventListener('touchstart', () => link.classList.add('pressed'), { passive: true });
    link.addEventListener('touchend', () => link.classList.remove('pressed'), { passive: true });
    link.addEventListener('touchcancel', () => link.classList.remove('pressed'), { passive: true });
  });

  // Delete confirmation modal
  (function () {
    const modal   = document.getElementById('crmDeleteModal');
    const msgEl   = document.getElementById('crmDeleteModalMsg');
    const confirmBtn = document.getElementById('crmDeleteModalConfirm');
    if (!modal) return;

    let pendingForm = null;

    function openModal(form) {
      pendingForm = form;
      msgEl.textContent = form.dataset.confirm || '¿Confirmar esta acción?';
      const label = form.dataset.confirmLabel || 'Eliminar';
      confirmBtn.textContent = label;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      confirmBtn.focus();
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      pendingForm = null;
    }

    document.querySelectorAll('form[data-confirm]').forEach(form => {
      form.addEventListener('submit', e => {
        e.preventDefault();
        openModal(form);
      });
    });

    confirmBtn.addEventListener('click', () => {
      if (!pendingForm) return;
      pendingForm.removeAttribute('data-confirm');
      pendingForm.submit();
      closeModal();
    });

    document.getElementById('crmDeleteModalCancel').addEventListener('click', closeModal);
    document.getElementById('crmDeleteModalBackdrop').addEventListener('click', closeModal);

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });
  })();
</script>

