<%- include('../partials/head', { title: 'Club — Tabla de posiciones' }) %>

<main class="container">

  <div style="text-align:center;padding:32px 0 20px">
    <h1 style="margin:0 0 8px">Tabla de posiciones</h1>
    <p class="muted">Los miembros más activos del club Gorillaz Motorbikes.</p>
    <% if (myRank) { %>
      <p>Tu posición: <strong>#<%= myRank %></strong></p>
    <% } %>
  </div>

  <!-- Puntos de referencia -->
  <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:28px">
    <span class="chip">🏍️ Rodada = +<%= scorePoints.rodada %> pts</span>
    <span class="chip">🎉 Evento = +<%= scorePoints.evento %> pts</span>
    <span class="chip">🔩 Mantenimiento = +<%= scorePoints.mantenimiento %> pts</span>
    <span class="chip">🏪 Visita = +<%= scorePoints.visita %> pts</span>
  </div>

  <% if (!board || board.length === 0) { %>
    <p class="muted" style="text-align:center">Aún no hay miembros con puntos. ¡Sé el primero!</p>
  <% } else { %>
    <div class="card" style="padding:0;overflow:hidden">
      <table style="width:100%;border-collapse:collapse">
        <thead>
          <tr style="background:var(--surface,#f9fafb);border-bottom:2px solid #e5e7eb">
            <th style="padding:12px 16px;text-align:left;font-size:.85em;color:var(--muted,#6b7280)">#</th>
            <th style="padding:12px 16px;text-align:left;font-size:.85em;color:var(--muted,#6b7280)">Miembro</th>
            <th style="padding:12px 16px;text-align:center;font-size:.85em;color:var(--muted,#6b7280)">Nivel</th>
            <th style="padding:12px 16px;text-align:right;font-size:.85em;color:var(--muted,#6b7280)">Puntos</th>
          </tr>
        </thead>
        <tbody>
          <% board.forEach((u, i) => { %>
            <tr style="border-bottom:1px solid #f3f4f6<%= i === 0 ? ';background:#fffbeb' : i === 1 ? ';background:#f9fafb' : '' %>">
              <td style="padding:14px 16px;font-weight:700;color:<%= i === 0 ? '#d97706' : i === 1 ? '#6b7280' : '#9ca3af' %>">
                <% if (i === 0) { %>🥇
                <% } else if (i === 1) { %>🥈
                <% } else if (i === 2) { %>🥉
                <% } else { %><%= i + 1 %>
                <% } %>
              </td>
              <td style="padding:14px 16px">
                <strong><%= u.nickname || u.name %></strong>
                <% if (u.nickname) { %><span class="muted" style="font-size:.82em;margin-left:6px"><%= u.name %></span><% } %>
              </td>
              <td style="padding:14px 16px;text-align:center">
                <span style="color:<%= u.level.color %>;font-weight:600"><%= u.level.icon %> <%= u.level.name %></span>
              </td>
              <td style="padding:14px 16px;text-align:right;font-weight:700;font-size:1.05em;color:<%= u.level.color %>">
                <%= u.score %> <span style="font-size:.75em;font-weight:400;color:var(--muted,#6b7280)">pts</span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div class="btn-row" style="margin-top:24px;justify-content:center">
    <a class="btn btn-outline" href="/club">Volver al club</a>
    <% if (!user) { %>
      <a class="btn" href="/club/registro">Únete y empieza a puntuar</a>
    <% } else { %>
      <a class="btn" href="/club/panel">Mi panel</a>
    <% } %>
  </div>

</main>

<%- include('../partials/footer') %>
