<%- include('../partials/head', { title: 'Mi panel — Gorillaz Motorbikes Club', user, noIndex: true }) %>

<div class="club-panel">

  <!-- ── Hero greeting ── -->
  <div class="cp-hero">
    <div class="container">
      <div class="cp-hero-greeting">
        <div class="cp-hero-avatar" aria-hidden="true"><%= (user.nickname || user.name).charAt(0).toUpperCase() %></div>
        <div>
          <h1>Bienvenido, <%= user.nickname ? user.nickname : user.name %></h1>
          <div class="cp-hero-sub">Gorillaz Motorbikes Club · Bogotá</div>
          <% if (myRank) { %>
            <div class="cp-hero-rank">Puesto <strong>#<%= myRank %></strong> en el club</div>
          <% } %>
        </div>
      </div>
      <div class="cp-hero-aside">
        <% if (user && user.role === 'admin') { %>
          <a class="cp-admin-link" href="/admin">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Panel admin
          </a>
        <% } %>
        <div class="cp-hero-badge">
          <div class="cp-hero-badge-icon" aria-hidden="true"><%= scoreLevel.icon %></div>
          <div>
            <div class="cp-hero-badge-name" style="color:<%= scoreLevel.color %>"><%= scoreLevel.name %></div>
            <div class="cp-hero-badge-pts"><%= user.score || 0 %> puntos</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Quick actions ── -->
  <nav class="cp-actions-bar" aria-label="Acciones rápidas">
    <div class="container">
      <a class="cp-action-chip" href="/servicios/agendar"><span aria-hidden="true">🔧</span> Agendar servicio</a>
      <a class="cp-action-chip" href="/eventos"><span aria-hidden="true">📅</span> Eventos</a>
      <a class="cp-action-chip" href="/tienda"><span aria-hidden="true">🛒</span> Tienda</a>
      <a class="cp-action-chip" href="/cursos"><span aria-hidden="true">🎓</span> Cursos</a>
      <a class="cp-action-chip" href="#vehiculos"><span aria-hidden="true">🏍️</span> Mi moto</a>
      <button class="cp-action-chip" type="button" data-modal-open="#editProfile" style="border:none;cursor:pointer;font:inherit"><span aria-hidden="true">✏️</span> Mi perfil</button>
    </div>
  </nav>

  <div class="container">

    <!-- ── Puntaje + Membresía ── -->
    <div class="cp-section">
      <div class="cp-grid-2">

        <!-- Score card -->
        <div class="cp-score-card" style="--score-color:<%= scoreLevel.color %>">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:20px">
            <div>
              <p class="cp-card-label">Tu puntaje</p>
              <div style="display:flex;align-items:baseline;gap:4px">
                <span class="cp-score-number"><%= user.score || 0 %></span>
                <span class="cp-score-label">pts</span>
              </div>
            </div>
            <div class="cp-rank-badge">
              <span class="cp-rank-icon" aria-hidden="true"><%= scoreLevel.icon %></span>
              <span class="cp-rank-name" style="color:<%= scoreLevel.color %>"><%= scoreLevel.name %></span>
            </div>
          </div>

          <%
            const thresholds = [0, 100, 300, 700, 1500, Infinity];
            const sc = user.score || 0;
            let fromPts = 0, toPts = null, nextName = null;
            for (let i = 0; i < thresholds.length - 1; i++) {
              if (sc < thresholds[i+1]) {
                fromPts = thresholds[i];
                toPts   = thresholds[i+1];
                const names = ['Prospecto','Miembro','Rider','Gorilla','Gorilla Legend'];
                nextName = names[i+1] || null;
                break;
              }
            }
            const pct = toPts && toPts !== Infinity ? Math.min(100, Math.round(((sc - fromPts) / (toPts - fromPts)) * 100)) : 100;
          %>
          <% if (nextName) { %>
            <div>
              <div class="cp-progress-label">
                <span>Hacia <%= nextName %></span>
                <span><%= sc - fromPts %> / <%= toPts - fromPts %></span>
              </div>
              <div class="cp-progress-track"
                   role="progressbar"
                   aria-valuenow="<%= pct %>"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   aria-label="Progreso hacia <%= nextName %>: <%= pct %>%">
                <div class="cp-progress-fill" style="width:<%= pct %>%"></div>
              </div>
            </div>
          <% } else { %>
            <div style="font-size:.82em;color:#9ca3af;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-top:4px">
              <span aria-hidden="true">⚡</span> Nivel máximo — Leyenda del club
            </div>
          <% } %>

          <!-- Levels roadmap -->
          <%
            const allLevels = [
              { name:'Prospecto', icon:'🌱', min:0 },
              { name:'Miembro',   icon:'✅', min:100 },
              { name:'Rider',     icon:'🏍️', min:300 },
              { name:'Gorilla',   icon:'🏆', min:700 },
              { name:'Legend',    icon:'🦍', min:1500 }
            ];
            const currentLvlIdx = allLevels.reduce((acc, lv, i) => sc >= lv.min ? i : acc, 0);
          %>
          <div class="cp-levels-map" aria-label="Mapa de niveles del club">
            <% allLevels.forEach((lv, i) => { %>
              <div class="cp-level-step<%= i <= currentLvlIdx ? ' active' : '' %><%= i === currentLvlIdx ? ' current' : '' %>">
                <span class="cp-level-icon" aria-hidden="true"><%= lv.icon %></span>
                <span class="cp-level-name"><%= lv.name %></span>
                <span class="cp-level-pts"><%= lv.min > 0 ? lv.min + ' pts' : 'Inicio' %></span>
              </div>
              <% if (i < allLevels.length - 1) { %>
                <div class="cp-level-connector<%= i < currentLvlIdx ? ' filled' : '' %>" aria-hidden="true"></div>
              <% } %>
            <% }) %>
          </div>

          <div style="margin-top:16px;padding-top:14px;border-top:1px solid #e5e7eb">
            <a class="btn btn-sm btn-outline" href="/club/tabla">Ver tabla de posiciones →</a>
          </div>
        </div>

        <!-- Membresía -->
        <div class="cp-card">
          <p class="cp-card-label">Membresía</p>
          <div class="cp-membership-level"><%= user.membership.level %></div>
          <div class="cp-info-row">
            <span class="cp-info-key">Miembro desde</span>
            <span class="cp-info-val"><%= user.membership.since %></span>
          </div>
          <div class="cp-info-row">
            <span class="cp-info-key">Vence</span>
            <span class="cp-info-val"><%= user.membership.expires || '—' %></span>
          </div>
          <h2 style="font-size:.78rem;font-weight:900;text-transform:uppercase;letter-spacing:.06em;color:#9ca3af;margin:14px 0 8px">Beneficios</h2>
          <% if (user.membership.benefits && user.membership.benefits.length > 0) { %>
            <ul class="cp-benefit-list">
              <% user.membership.benefits.forEach(b => { %>
                <li><%= b %></li>
              <% }) %>
            </ul>
          <% } else { %>
            <div style="margin-top:4px">
              <p class="cp-motivation-text">Alcanza <strong>100 puntos</strong> para subir a <strong>Miembro</strong> y desbloquear:</p>
              <ul class="cp-benefit-list cp-benefit-list--locked">
                <li>Descuentos en servicios de taller</li>
                <li>Acceso prioritario a rodadas</li>
                <li>Insignia de miembro activo</li>
              </ul>
            </div>
          <% } %>
        </div>

      </div>
    </div>

    <!-- ── Próximas actividades ── -->
    <% if (upcomingEvents && upcomingEvents.length > 0) { %>
    <div class="cp-section">
      <h2 class="cp-section-title">Próximas actividades</h2>
      <div class="cp-grid-3">
        <% upcomingEvents.forEach(ev => { %>
          <%
            const regStatus = registrations[ev.id] || null;
            const pts = ev.type === 'rodada' ? SCORE_POINTS.rodada : SCORE_POINTS.evento;
            const isRodada = ev.type === 'rodada';
          %>
          <article class="cp-event-card" style="--ev-color:<%= isRodada ? '#38bdf8' : '#a78bfa' %>">
            <div>
              <span class="cp-event-type <%= isRodada ? 'rodada' : 'evento' %>">
                <span aria-hidden="true"><%= isRodada ? '🏍️' : '🎉' %></span>
                <%= isRodada ? 'Rodada' : 'Evento' %>
                <strong>+<%= pts %> pts</strong>
              </span>
            </div>
            <h3 class="cp-event-title"><%= ev.title %></h3>
            <div class="cp-event-meta">
              <%= ev.date %><% if (ev.location) { %> · <%= ev.location %><% } %>
            </div>
            <% if (ev.description) { %>
              <p class="cp-event-desc"><%= ev.description %></p>
            <% } %>
            <div class="cp-event-footer">
              <% if (regStatus === 'confirmed') { %>
                <span class="cp-status-confirmed"><span aria-hidden="true">✓</span> Confirmado</span>
              <% } else if (regStatus === 'pending') { %>
                <span class="cp-status-pending"><span aria-hidden="true">⏳</span> Pendiente</span>
              <% } else { %>
                <form method="post" action="/club/eventos/<%= ev.id %>/asistencia">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn btn-sm" type="submit">Apuntarme</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- ── Historial + Puntos ── -->
    <div class="cp-section">
      <div class="cp-grid-2">

        <!-- Historial de actividades + Registro -->
        <div class="cp-card">
          <h2>Historial de actividades</h2>
          <% if (user.visits.length === 0) { %>
            <div class="cp-empty">
              <div class="cp-empty-icon" aria-hidden="true">🔩</div>
              <div class="cp-empty-text">Aún no hay actividades</div>
              <p class="cp-empty-hint">Visita el taller y registra tu servicio para ganar <strong>+<%= SCORE_POINTS.visita %> puntos</strong></p>
              <a class="btn btn-sm" href="/servicios/agendar">Agendar servicio</a>
            </div>
          <% } else { %>
            <ul class="cp-timeline">
              <% user.visits.forEach(v => { %>
                <li class="cp-timeline-item">
                  <div class="cp-timeline-dot <%= v.type === 'visita' ? 'green' : '' %>" aria-hidden="true"></div>
                  <div class="cp-timeline-content">
                    <div class="cp-timeline-date">
                      <%= v.date %>
                      <% if (v.type === 'mantenimiento') { %>
                        <span class="cp-activity-chip mtto"><span aria-hidden="true">🔩</span> Mtto</span>
                      <% } else { %>
                        <span class="cp-activity-chip visita"><span aria-hidden="true">🏪</span> Visita</span>
                      <% } %>
                    </div>
                    <div class="cp-timeline-desc"><%= v.service %></div>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>

          <div style="margin-top:20px;padding-top:16px;border-top:1px solid #e5e7eb">
            <div style="font-size:.75em;font-weight:900;color:var(--brand, #F25C05);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Registrar actividad</div>
            <form class="stack" method="post" action="/club/visitas">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <label>
                Tipo
                <select name="type">
                  <option value="visita">Visita al taller (+<%= SCORE_POINTS.visita %> pts)</option>
                  <option value="mantenimiento">Mantenimiento (+<%= SCORE_POINTS.mantenimiento %> pts)</option>
                </select>
              </label>
              <label>
                Fecha
                <input type="date" name="date" required />
              </label>
              <label>
                Descripción
                <input type="text" name="service" placeholder="Ej: Cambio de aceite y filtros" required />
              </label>
              <button class="btn" type="submit">Registrar</button>
            </form>
          </div>
        </div>

        <!-- Historial de puntos -->
        <div class="cp-card">
          <h2>Historial de puntos</h2>
          <% if (!user.scoreHistory || user.scoreHistory.length === 0) { %>
            <div class="cp-pts-empty">
              <div class="cp-pts-empty-icon" aria-hidden="true">⚡</div>
              <p class="cp-pts-empty-title">Aún no tienes puntos</p>
              <p class="cp-pts-empty-sub">Gana puntos participando en estas actividades</p>
              <div class="cp-earn-grid">
                <div class="cp-earn-item">
                  <span class="cp-earn-emoji" aria-hidden="true">🏪</span>
                  <span class="cp-earn-label">Visita al taller</span>
                  <span class="cp-earn-badge">+<%= SCORE_POINTS.visita %> pts</span>
                </div>
                <div class="cp-earn-item">
                  <span class="cp-earn-emoji" aria-hidden="true">🔩</span>
                  <span class="cp-earn-label">Mantenimiento</span>
                  <span class="cp-earn-badge">+<%= SCORE_POINTS.mantenimiento %> pts</span>
                </div>
                <div class="cp-earn-item">
                  <span class="cp-earn-emoji" aria-hidden="true">🏍️</span>
                  <span class="cp-earn-label">Rodada</span>
                  <span class="cp-earn-badge">+<%= SCORE_POINTS.rodada %> pts</span>
                </div>
                <div class="cp-earn-item">
                  <span class="cp-earn-emoji" aria-hidden="true">🎉</span>
                  <span class="cp-earn-label">Evento</span>
                  <span class="cp-earn-badge">+<%= SCORE_POINTS.evento %> pts</span>
                </div>
              </div>
            </div>
          <% } else { %>
            <div>
              <% user.scoreHistory.slice(0, 10).forEach(h => { %>
                <div class="cp-pts-row">
                  <div>
                    <div class="cp-pts-date"><%= h.date %></div>
                    <div class="cp-pts-desc"><%= h.description %></div>
                  </div>
                  <div class="cp-pts-value">+<%= h.points %></div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

      </div>
    </div>

    <!-- ── Recordatorios + Vehículos ── -->
    <div class="cp-section">
      <div class="cp-grid-2">

        <!-- Recordatorios -->
        <div class="cp-card">
          <h2>SOAT y Tecnomecánica</h2>
          <% if (!reminders || reminders.length === 0) { %>
            <div class="cp-empty">
              <div class="cp-empty-icon" aria-hidden="true">🏍️</div>
              <div class="cp-empty-text">Sin vehículos registrados</div>
              <p class="cp-empty-hint">Agrega tu moto para recibir alertas de SOAT y tecnomecánica</p>
              <a class="btn btn-sm btn-outline" href="#vehiculos">Agregar moto</a>
            </div>
          <% } else { %>
            <% reminders.forEach(r => { %>
              <% const soatState = (r.soat === null) ? 'none' : (r.soat < 0 ? 'expired' : (r.soat <= 30 ? 'soon' : 'ok')); %>
              <% const tecState  = (r.tecno === null) ? 'none' : (r.tecno < 0 ? 'expired' : (r.tecno <= 30 ? 'soon' : 'ok')); %>
              <div class="cp-reminder-item">
                <div class="cp-reminder-header">
                  <span class="cp-plate-badge"><%= r.plate %></span>
                  <button class="btn btn-xs btn-outline" type="button" data-modal-open="#edit-<%= r.plate %>">Editar</button>
                </div>
                <div style="display:flex;gap:8px;flex-wrap:wrap">
                  <span class="cp-stat <%= soatState %>">
                    SOAT: <%= r.soat === null ? '—' : (r.soat < 0 ? ('vencido hace ' + Math.abs(r.soat) + 'd') : ('en ' + r.soat + 'd')) %>
                  </span>
                  <span class="cp-stat <%= tecState %>">
                    Tecno: <%= r.tecno === null ? '—' : (r.tecno < 0 ? ('vencido hace ' + Math.abs(r.tecno) + 'd') : ('en ' + r.tecno + 'd')) %>
                  </span>
                </div>
              </div>

              <div class="modal" id="edit-<%= r.plate %>" aria-hidden="true">
                <div class="modal-backdrop" data-modal-close></div>
                <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="title-edit-<%= r.plate %>">
                  <div class="modal-header">
                    <h3 class="modal-title" id="title-edit-<%= r.plate %>">Editar fechas — <%= r.plate %></h3>
                    <button class="modal-close" type="button" aria-label="Cerrar" data-modal-close>✕</button>
                  </div>
                  <form method="post" action="/club/vehiculos/actualizar">
                    <div class="modal-body">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <input type="hidden" name="plate" value="<%= r.plate %>" />
                      <fieldset style="border:none;padding:0;margin:0">
                        <legend class="sr-only">Fechas de vencimiento de <%= r.plate %></legend>
                        <div class="grid two">
                          <label>Vence SOAT<input type="date" name="soatExpires" /></label>
                          <label>Vence Tecno<input type="date" name="tecnoExpires" /></label>
                        </div>
                      </fieldset>
                    </div>
                    <div class="modal-actions">
                      <button class="btn btn-outline" type="button" data-modal-close>Cancelar</button>
                      <button class="btn" type="submit">Guardar</button>
                    </div>
                  </form>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <!-- Mis vehículos -->
        <div class="cp-card" id="vehiculos">
          <h2>Mis vehículos</h2>
          <% if (user.vehicles && user.vehicles.length) { %>
            <div style="margin-bottom:16px">
              <% user.vehicles.forEach(v => { %>
                <div class="cp-vehicle-item">
                  <div>
                    <div class="cp-vehicle-plate"><%= v.plate %></div>
                    <div class="cp-vehicle-sub">QR de identificación</div>
                  </div>
                  <div class="cp-vehicle-actions">
                    <a class="btn btn-xs btn-outline" href="/club/vehiculos/<%= v.plate %>/qr.png" download="QR-<%= v.plate %>.png"><span aria-hidden="true">⬇</span> QR</a>
                    <button class="btn btn-xs btn-outline" type="button" data-modal-open="#qr-<%= v.plate %>">Ver QR</button>
                    <form method="post" action="/club/vehiculos/eliminar" data-confirm="¿Eliminar vehículo?" style="display:inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <input type="hidden" name="plate" value="<%= v.plate %>" />
                      <button class="btn btn-xs btn-outline" type="submit" style="color:#f87171;border-color:#3a1515">Eliminar</button>
                    </form>
                  </div>
                </div>

                <div class="modal" id="qr-<%= v.plate %>" aria-hidden="true">
                  <div class="modal-backdrop" data-modal-close></div>
                  <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="title-qr-<%= v.plate %>">
                    <div class="modal-header">
                      <h3 class="modal-title" id="title-qr-<%= v.plate %>">QR — <%= v.plate %></h3>
                      <button class="modal-close" type="button" aria-label="Cerrar" data-modal-close>✕</button>
                    </div>
                    <div class="modal-body" style="display:grid;justify-items:center;gap:10px">
                      <img src="/club/vehiculos/<%= v.plate %>/qr.png" alt="Código QR de la moto con placa <%= v.plate %>" style="width:260px;height:260px;image-rendering:pixelated;border-radius:12px;padding:8px;background:#fff" loading="lazy" />
                      <p style="text-align:center;margin:0;font-size:.84em;color:#6b7280">Usa este código para identificar tu moto en el taller y rodadas.</p>
                    </div>
                    <div class="modal-actions">
                      <a class="btn btn-outline" href="/club/vehiculos/<%= v.plate %>/qr.png" download="QR-<%= v.plate %>.png">Descargar</a>
                      <button class="btn" type="button" data-modal-close>Cerrar</button>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>

          <div style="padding-top:16px;border-top:1px solid #e5e7eb">
            <div style="font-size:.75em;font-weight:900;color:var(--brand, #F25C05);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Agregar vehículo</div>
            <form class="stack" method="post" action="/club/vehiculos">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <label>Placa<input name="plate" maxlength="8" placeholder="ABC123" required
                style="text-transform:uppercase"
                oninput="this.value=this.value.toUpperCase()" /></label>
              <fieldset style="border:none;padding:0;margin:0">
                <legend class="sr-only">Fechas de vencimiento de documentos</legend>
                <div class="grid two" style="align-items:end">
                  <label>Vence SOAT<input type="date" name="soatExpires" style="min-width:0" /></label>
                  <label>Vence Tecno<input type="date" name="tecnoExpires" style="min-width:0" /></label>
                </div>
              </fieldset>
              <button class="btn" type="submit">Agregar</button>
            </form>
          </div>
        </div>

      </div>
    </div>

    <!-- ── Cotizaciones ── -->
    <% if (quotationHistory && quotationHistory.length > 0) { %>
    <div class="cp-section" id="cotizaciones">
      <h2 class="cp-section-title">Historial de cotizaciones</h2>
      <p style="margin:-8px 0 20px;font-size:.82em;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;font-weight:700">Cotizaciones registradas con las placas de tus vehículos</p>
      <div class="cp-card">
        <% quotationHistory.forEach((q, idx) => { %>
          <div class="cp-quote-item">
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:8px">
                <span class="cp-quote-ref">#<%= q.label %></span>
                <% if (q.motorcycle) { %>
                  <span style="font-size:.72em;font-weight:900;text-transform:uppercase;letter-spacing:.06em;background:#f5f5f5;border:1px solid #e5e7eb;color:#6b7280;border-radius:4px;padding:2px 8px"><%= q.motorcycle %></span>
                <% } %>
                <span style="font-size:.75em;color:#9ca3af;font-weight:600">
                  <%= new Date(q.createdAt).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' }) %>
                </span>
              </div>
              <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:3px">
                <% q.items.slice(0, 3).forEach(it => { %>
                  <li style="font-size:.83em;color:#374151">
                    <span style="color:#9ca3af"><%= it.qty %>×</span> <%= it.name %>
                  </li>
                <% }) %>
                <% if (q.items.length > 3) { %>
                  <li style="font-size:.78em;color:#9ca3af">+ <%= q.items.length - 3 %> ítem<%= q.items.length - 3 > 1 ? 's' : '' %> más</li>
                <% } %>
              </ul>
            </div>
            <div style="text-align:right;flex-shrink:0">
              <div class="cp-quote-total" style="margin-bottom:10px">COP <%= q.total.toLocaleString('es-CO') %></div>
              <a href="/cotizacion/<%= q.id %>" target="_blank" rel="noopener" class="cp-link">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Ver detalle
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- ── Seguridad / Passkeys ── -->
    <div class="cp-section" id="seguridad">
      <h2 class="cp-section-title">Seguridad</h2>
      <div class="cp-card">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px">
          <div>
            <p class="cp-card-label" style="margin:0 0 2px">Llaves de acceso (Passkeys)</p>
            <p style="margin:0;font-size:.82em;color:#6b7280">Inicia sesión con huella dactilar, Face ID o PIN del dispositivo — sin contraseña.</p>
          </div>
          <button class="btn btn-sm btn-outline" type="button" id="addPasskeyBtn">+ Agregar passkey</button>
        </div>

        <div id="passkeyMsg" style="display:none;margin-bottom:12px"></div>

        <% if (passkeys && passkeys.length > 0) { %>
          <ul class="passkey-list">
            <% passkeys.forEach(pk => { %>
              <li class="passkey-item">
                <span class="passkey-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                </span>
                <div class="passkey-info">
                  <span class="passkey-name"><%= pk.name || 'Passkey' %></span>
                  <span class="passkey-date">Registrada el <%= new Date(pk.createdAt).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' }) %></span>
                </div>
                <form method="post" action="/club/auth/passkey/<%= pk.id %>/delete" style="margin:0" onsubmit="return confirm('¿Eliminar esta passkey?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn btn-sm" style="color:#ef4444;border-color:#fca5a5" type="submit">Eliminar</button>
                </form>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p style="font-size:.85em;color:#9ca3af;margin:0">No tienes passkeys registradas aún.</p>
        <% } %>
      </div>
    </div>

  </div><!-- /.container -->

  <!-- ── Editar perfil ── -->
  <div class="modal" id="editProfile" aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="title-editProfile">
      <div class="modal-header">
        <h3 class="modal-title" id="title-editProfile">Editar mi perfil</h3>
        <button class="modal-close" type="button" aria-label="Cerrar" data-modal-close>✕</button>
      </div>
      <form method="post" action="/club/perfil">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <%- include('../partials/profile-fields', { u: user, admin: false }) %>
        </div>
        <div class="modal-actions">
          <button class="btn btn-outline" type="button" data-modal-close>Cancelar</button>
          <button class="btn" type="submit">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>
</div><!-- /.club-panel -->

<%- include('../partials/footer') %>
