<%- include('../partials/head', { title: 'Club — Panel' , user }) %>

  <% if (user && user.role==='admin' ) { %>
    <div class="container">
      <div class="admin-top">
        <span class="muted">Usuario administrador</span>
        <a class="btn btn-sm" href="/admin">Ir al panel de administrador</a>
      </div>
    </div>
  <% } %>

  <main class="container">

    <!-- Saludo + Score card -->
    <section>
      <h1 style="margin-bottom:20px">Hola, <%= user.nickname ? user.nickname : user.name %></h1>
      <div class="grid two">

        <!-- Score card -->
        <div class="card" style="border-top:4px solid <%= scoreLevel.color %>">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px">
            <div>
              <h2 style="margin:0 0 4px">Tu puntaje</h2>
              <div style="font-size:2.8rem;font-weight:800;color:<%= scoreLevel.color %>;line-height:1"><%= user.score || 0 %> <span style="font-size:1rem;font-weight:400;color:var(--muted,#6b7280)">pts</span></div>
            </div>
            <div style="text-align:center;min-width:80px">
              <div style="font-size:2.4rem"><%= scoreLevel.icon %></div>
              <div style="font-weight:700;color:<%= scoreLevel.color %>;font-size:.95em"><%= scoreLevel.name %></div>
            </div>
          </div>

          <!-- Barra de progreso al siguiente nivel -->
          <%
            const thresholds = [0, 100, 300, 700, 1500, Infinity];
            const sc = user.score || 0;
            let fromPts = 0, toPts = null, nextName = null;
            for (let i = 0; i < thresholds.length - 1; i++) {
              if (sc < thresholds[i+1]) {
                fromPts = thresholds[i];
                toPts   = thresholds[i+1];
                const names = ['Prospecto','Miembro','Rider','Gorilla','Gorilla Legend'];
                nextName = names[i+1] || null;
                break;
              }
            }
            const pct = toPts && toPts !== Infinity ? Math.min(100, Math.round(((sc - fromPts) / (toPts - fromPts)) * 100)) : 100;
          %>
          <% if (nextName) { %>
            <div style="margin-top:16px">
              <div style="display:flex;justify-content:space-between;font-size:.82em;color:var(--muted,#6b7280);margin-bottom:4px">
                <span>Progreso a <%= nextName %></span>
                <span><%= sc - fromPts %> / <%= toPts - fromPts %> pts</span>
              </div>
              <div style="background:#e5e7eb;border-radius:99px;height:8px;overflow:hidden">
                <div style="background:<%= scoreLevel.color %>;height:8px;width:<%= pct %>%;border-radius:99px;transition:width .4s"></div>
              </div>
            </div>
          <% } else { %>
            <p class="muted" style="margin:12px 0 0;font-size:.85em">Nivel máximo alcanzado. ¡Leyenda del club!</p>
          <% } %>

          <div style="margin-top:16px;border-top:1px solid #e5e7eb;padding-top:12px">
            <a class="btn btn-outline btn-sm" href="/club/tabla">Ver tabla de posiciones</a>
          </div>
        </div>

        <!-- Membresía -->
        <div class="card">
          <h2>Tu membresía</h2>
          <p><strong>Nivel:</strong> <%= user.membership.level %></p>
          <p><strong>Desde:</strong> <%= user.membership.since %></p>
          <p><strong>Vence:</strong> <%= user.membership.expires || '—' %></p>
          <h3>Beneficios</h3>
          <ul>
            <% user.membership.benefits.forEach(b => { %>
              <li><%= b %></li>
            <% }) %>
          </ul>
        </div>

      </div>
    </section>

    <!-- Próximos eventos -->
    <% if (upcomingEvents && upcomingEvents.length > 0) { %>
    <section>
      <h2 class="section-title">Próximas actividades</h2>
      <div class="grid products-grid">
        <% upcomingEvents.forEach(ev => { %>
          <%
            const regStatus = registrations[ev.id] || null;
            const pts = ev.type === 'rodada' ? SCORE_POINTS.rodada : SCORE_POINTS.evento;
          %>
          <article class="card" style="position:relative">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
              <% if (ev.type === 'rodada') { %>
                <span class="chip" style="background:#e0f2fe;color:#0891b2">🏍️ Rodada <strong>+<%= pts %> pts</strong></span>
              <% } else { %>
                <span class="chip" style="background:#ede9fe;color:#7c3aed">🎉 Evento <strong>+<%= pts %> pts</strong></span>
              <% } %>
            </div>
            <h3 style="margin:0 0 4px"><%= ev.title %></h3>
            <p class="muted" style="margin:0 0 8px;font-size:.85em">
              <%= ev.date %><% if (ev.location) { %> · <%= ev.location %><% } %>
            </p>
            <% if (ev.description) { %><p style="font-size:.9em;margin:0 0 10px"><%= ev.description %></p><% } %>
            <% if (regStatus === 'confirmed') { %>
              <span class="chip" style="background:#dcfce7;color:#16a34a">✓ Asistencia confirmada</span>
            <% } else if (regStatus === 'pending') { %>
              <span class="chip" style="background:#fef9c3;color:#854d0e">⏳ Inscripción pendiente de confirmación</span>
            <% } else { %>
              <form method="post" action="/club/eventos/<%= ev.id %>/asistencia">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="btn btn-sm" type="submit">Apuntarme</button>
              </form>
            <% } %>
          </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- Historial de visitas + registro -->
    <section>
      <div class="grid two">
        <div class="card">
          <h2>Historial de actividades</h2>
          <ul class="list">
            <% if (user.visits.length === 0) { %>
              <li class="muted">Sin registros aún.</li>
            <% } %>
            <% user.visits.forEach(v => { %>
              <li>
                <span>
                  <strong><%= v.date %></strong>
                  <% if (v.type === 'mantenimiento') { %>
                    <span class="chip" style="margin-left:6px;background:#fef3c7;color:#92400e;font-size:.75em">🔩 Mtto</span>
                  <% } else if (v.type === 'visita') { %>
                    <span class="chip" style="margin-left:6px;background:#dcfce7;color:#166534;font-size:.75em">🏪 Visita</span>
                  <% } %>
                </span>
                <span><%= v.service %></span>
              </li>
            <% }) %>
          </ul>
          <form class="stack" method="post" action="/club/visitas" style="margin-top:16px">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label>
              Tipo de actividad
              <select name="type">
                <option value="visita">Visita al taller (+<%= SCORE_POINTS.visita %> pts)</option>
                <option value="mantenimiento">Mantenimiento (+<%= SCORE_POINTS.mantenimiento %> pts)</option>
              </select>
            </label>
            <label>
              Fecha
              <input type="date" name="date" required />
            </label>
            <label>
              Descripción
              <input type="text" name="service" placeholder="Ej: Cambio de aceite y filtros" required />
            </label>
            <button class="btn" type="submit">Registrar actividad</button>
          </form>
        </div>

        <!-- Historial de puntos -->
        <div class="card">
          <h2>Historial de puntos</h2>
          <% if (!user.scoreHistory || user.scoreHistory.length === 0) { %>
            <p class="muted">Aún no tienes puntos registrados. ¡Comienza a participar!</p>
          <% } else { %>
            <ul class="list">
              <% user.scoreHistory.slice(0, 10).forEach(h => { %>
                <li>
                  <span>
                    <strong><%= h.date %></strong>
                    <span class="muted" style="margin-left:6px;font-size:.82em"><%= h.description %></span>
                  </span>
                  <span style="font-weight:700;color:#16a34a">+<%= h.points %> pts</span>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </section>

    <!-- Recordatorios SOAT y Tecnomecánica -->
    <section>
      <div class="grid two">
        <div class="card">
          <h2>Recordatorios SOAT y Tecnomecánica</h2>
          <% if (!reminders || reminders.length===0) { %>
            <p class="muted">Aún no has registrado vehículos.</p>
          <% } else { %>
            <ul class="reminders-list">
              <% reminders.forEach(r => { %>
                <% const soatState=(r.soat===null) ? 'none' : (r.soat < 0 ? 'expired' : (r.soat <=30 ? 'soon' : 'ok')); %>
                <% const tecState=(r.tecno===null) ? 'none' : (r.tecno < 0 ? 'expired' : (r.tecno <=30 ? 'soon' : 'ok')); %>
                <li>
                  <div class="rem-row">
                    <div class="rem-plate"><%= r.plate %></div>
                    <div class="rem-stats">
                      <span class="stat <%= soatState %>">SOAT: <%= r.soat===null ? '—' : (r.soat < 0 ? ('hace ' + Math.abs(r.soat) + ' días') : ('en ' + r.soat + ' días')) %></span>
                      <span class="stat <%= tecState %>">Tecno: <%= r.tecno===null ? '—' : (r.tecno < 0 ? ('hace ' + Math.abs(r.tecno) + ' días') : ('en ' + r.tecno + ' días')) %></span>
                    </div>
                    <div class="rem-actions">
                      <button class="btn btn-xs btn-outline" type="button" data-modal-open="#edit-<%= r.plate %>">Editar fechas</button>
                    </div>
                  </div>
                </li>

                <div class="modal" id="edit-<%= r.plate %>" aria-hidden="true">
                  <div class="modal-backdrop" data-modal-close></div>
                  <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="title-edit-<%= r.plate %>">
                    <div class="modal-header">
                      <h3 class="modal-title" id="title-edit-<%= r.plate %>">Editar fechas — <%= r.plate %></h3>
                      <button class="modal-close" type="button" aria-label="Cerrar" data-modal-close>✕</button>
                    </div>
                    <form method="post" action="/club/vehiculos/actualizar">
                      <div class="modal-body">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <input type="hidden" name="plate" value="<%= r.plate %>" />
                        <div class="grid two">
                          <label>Vence SOAT<input type="date" name="soatExpires" /></label>
                          <label>Vence Tecno<input type="date" name="tecnoExpires" /></label>
                        </div>
                      </div>
                      <div class="modal-actions">
                        <button class="btn btn-outline" type="button" data-modal-close>Cancelar</button>
                        <button class="btn" type="submit">Guardar</button>
                      </div>
                    </form>
                  </div>
                </div>
              <% }) %>
            </ul>
          <% } %>
        </div>

        <div class="card" id="vehiculos">
          <h2>Mis vehículos</h2>
          <form class="stack" method="post" action="/club/vehiculos">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label>Placa<input name="plate" maxlength="8" placeholder="ABC123" required /></label>
            <div class="grid two" style="align-items:end">
              <label>Vence SOAT<input type="date" name="soatExpires" style="min-width:0" /></label>
              <label>Vence Tecno<input type="date" name="tecnoExpires" style="min-width:0" /></label>
            </div>
            <button class="btn" type="submit">Agregar</button>
          </form>
          <% if (user.vehicles && user.vehicles.length) { %>
            <ul class="list list-actions" style="margin-top:10px">
              <% user.vehicles.forEach(v => { %>
                <li>
                  <span>
                    <strong><%= v.plate %></strong>
                    <span class="muted" style="margin-left:8px;font-size:.86em">QR: identificación rápida</span>
                  </span>
                  <span style="display:inline-flex;align-items:center;gap:8px">
                    <a class="btn btn-xs btn-outline" href="/club/vehiculos/<%= v.plate %>/qr.png" download="QR-<%= v.plate %>.png">Descargar QR</a>
                    <button class="btn btn-xs btn-outline" type="button" data-modal-open="#qr-<%= v.plate %>">Ver QR</button>
                    <form method="post" action="/club/vehiculos/eliminar" data-confirm="¿Eliminar vehículo?" style="display:inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <input type="hidden" name="plate" value="<%= v.plate %>" />
                      <button class="btn btn-xs btn-outline" type="submit">Eliminar</button>
                    </form>
                  </span>
                </li>

                <div class="modal" id="qr-<%= v.plate %>" aria-hidden="true">
                  <div class="modal-backdrop" data-modal-close></div>
                  <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="title-qr-<%= v.plate %>">
                    <div class="modal-header">
                      <h3 class="modal-title" id="title-qr-<%= v.plate %>">QR de <%= v.plate %></h3>
                      <button class="modal-close" type="button" aria-label="Cerrar" data-modal-close>✕</button>
                    </div>
                    <div class="modal-body" style="display:grid;justify-items:center;gap:10px">
                      <img src="/club/vehiculos/<%= v.plate %>/qr.png" alt="Código QR de <%= v.plate %>" style="width:260px;height:260px;image-rendering:pixelated;border:1px solid #e5e7eb;border-radius:12px;padding:8px;background:#fff" />
                      <p class="muted" style="text-align:center;margin:0">Imprime o guarda este código para identificar tu moto en el taller, rodadas y actividades.</p>
                    </div>
                    <div class="modal-actions">
                      <a class="btn btn-outline" href="/club/vehiculos/<%= v.plate %>/qr.png" download="QR-<%= v.plate %>.png">Descargar</a>
                      <button class="btn" type="button" data-modal-close>Cerrar</button>
                    </div>
                  </div>
                </div>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>
