<%- include('../partials/head', { title: 'Club — Gorillaz Motorbikes' }) %>

  <%
    const icons = {
      wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94z"/>',
      route: '<path d="M3 11l19-9-9 19-2-8-8-2z"/>',
      book: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
      calendar: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/><path d="M9 16l2 2 4-4"/>',
      trophy: '<circle cx="12" cy="8" r="6"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/>',
      users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
      pin: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
      chevron: 'M6 9l6 6 6-6',
    };
    function icon(name) {
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[name]}</svg>`;
    }
    const benefits = [
      ['wrench', 'Descuentos en el taller', 'Hasta 15% en mecánica rápida y beneficios adicionales según tu nivel de membresía.'],
      ['route', 'Rodadas y eventos', 'Rodadas organizadas, paseos de fin de semana y eventos exclusivos en Bogotá y alrededores.'],
      ['book', 'Cursos y formación', 'Acceso prioritario y precios especiales en cursos técnicos de mecánica, seguridad vial y más.'],
      ['calendar', 'Prioridad en agenda', 'Reserva de citas preferencial para miembros activos y recordatorios automáticos de SOAT y tecno.'],
      ['trophy', 'Sistema de puntos', 'Acumula puntos con cada visita, rodada o evento y desbloquea beneficios exclusivos por nivel.'],
      ['users', 'Comunidad activa', 'Red de motociclistas en Bogotá. Comparte experiencias, rutas y conocimiento con la hermandad Gorillaz.'],
    ];
    const earnLabels = {
      rodada:       ['route',    'Rodada',            'Participa en una rodada organizada por el club.'],
      evento:       ['calendar', 'Evento del club',   'Asiste a eventos, reuniones y actividades del club.'],
      mantenimiento:['wrench',   'Mantenimiento',     'Realiza un mantenimiento o servicio en el taller.'],
      visita:       ['pin',      'Visita al taller',  'Cualquier visita o consulta en Gorillaz Motorbikes.'],
    };
    const earnKeys = ['rodada', 'evento', 'mantenimiento', 'visita'].filter(k => puntos.points[k] != null);
    const levels = [...puntos.levels].sort((a, b) => a.min - b.min);
    const typeLabel = { rodada: '🏍️ Rodada', encuentro: '⚽ Encuentro', caminata: '🥾 Caminata', actividad: '🎉 Actividad', evento: '🎉 Actividad' };
  %>

  <main>

    <section class="hero clp-hero" data-slideshow='<%- JSON.stringify(slidesClub||[]) %>'>
      <div class="hero-slides" aria-hidden="true"></div>
      <div class="hero-content">
        <span class="clp-hero-badge"><span class="dot" aria-hidden="true"></span> Club Gorillaz · Bogotá</span>
        <h1>Vive la moto con la <em>manada</em></h1>
        <p>Rutas exclusivas, descuentos en el taller, cursos y una comunidad que vive la moto. Acumula puntos con cada actividad y escala de nivel.</p>
        <div class="btn-row">
          <a class="btn" href="/club/registro">Quiero ser miembro</a>
          <a class="btn btn-outline" href="/club/login">Ya tengo cuenta</a>
        </div>
      </div>
      <button class="scroll-cue" aria-label="Desplázate para ver el contenido" title="Desplázate"
        onclick="(function(){var next=document.querySelector('.clp-benefits-section'); if(next){next.scrollIntoView({behavior:'smooth'});} else {window.scrollTo({top: window.innerHeight, behavior:'smooth'});} })()">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="currentColor" d="M12 16.5c-.3 0-.6-.1-.8-.3l-6-6a1.1 1.1 0 0 1 1.6-1.6L12 13.8l5.2-5.2a1.1 1.1 0 0 1 1.6 1.6l-6 6c-.2.2-.5.3-.8.3Z" />
        </svg>
      </button>
    </section>

    <section class="stats-strip" aria-label="El club en números">
      <div class="stats-inner cols-3">
        <div class="stat-item">
          <span class="stat-num"><%= memberCount %>+</span>
          <span class="stat-label">Miembros activos</span>
        </div>
        <div class="stat-item">
          <span class="stat-num"><%= events.length %></span>
          <span class="stat-label">Eventos y rodadas</span>
        </div>
        <div class="stat-item">
          <span class="stat-num"><%= levels.length %></span>
          <span class="stat-label">Niveles por escalar</span>
        </div>
      </div>
    </section>

    <!-- Beneficios -->
    <section class="container clp-benefits-section">
      <h2 class="section-title">Beneficios del club</h2>
      <div class="grid clp-benefits">
        <% benefits.forEach(([ic, title, desc]) => { %>
          <div class="clp-benefit">
            <div class="clp-icon"><%- icon(ic) %></div>
            <h3><%= title %></h3>
            <p><%= desc %></p>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- Sistema de puntos y niveles -->
    <section class="clp-points">
      <div class="container">
        <h2 class="section-title">Sistema de puntos</h2>
        <p class="section-subtitle" style="text-align:center;max-width:600px;margin:0 auto 28px">
          Cada actividad con Gorillaz suma puntos a tu perfil. Mientras más activo seas, más alto será tu nivel y mayores tus beneficios.
        </p>

        <div class="clp-earn-grid">
          <% earnKeys.forEach(k => { const [ic, label, desc] = earnLabels[k]; %>
            <div class="clp-earn-card">
              <div class="clp-earn-icon"><%- icon(ic) %></div>
              <div class="clp-earn-pts">+<%= puntos.points[k] %> pts</div>
              <div class="clp-earn-label"><%= label %></div>
              <p class="clp-earn-desc"><%= desc %></p>
            </div>
          <% }) %>
        </div>

        <h3 class="clp-ladder-title">Niveles del club</h3>
        <div class="clp-ladder">
          <% levels.forEach((lvl, i) => { const next = levels[i+1]; %>
            <div class="clp-ladder-node" style="--lvl-color: <%= lvl.color %>">
              <div class="clp-ladder-badge"><%= lvl.icon %></div>
              <div class="clp-ladder-name"><%= lvl.name %></div>
              <div class="clp-ladder-range"><%= next ? `${lvl.min} – ${next.min - 1} pts` : `${lvl.min}+ pts` %></div>
            </div>
          <% }) %>
        </div>

        <div class="clp-points-cta">
          <a class="btn btn-outline" href="/club/tabla">Ver tabla de posiciones</a>
        </div>
      </div>
    </section>

    <!-- Próximos eventos -->
    <section class="container">
      <h2 class="section-title">Próximos eventos</h2>
      <% if (!events || events.length===0) { %>
        <p class="muted" style="text-align:center">Muy pronto anunciaremos nuevas actividades del club.</p>
      <% } else { %>
        <div class="events-grid clp-events-grid">
          <% events.slice(0,3).forEach(ev => { %>
            <article class="ev-card ev-card--club">
              <div class="ev-card-accent"></div>
              <div class="ev-card-content">
                <div class="ev-card-body">
                  <div class="ev-card-meta">
                    <span class="ev-type-chip club"><%= typeLabel[ev.type] || '📅 Evento' %></span>
                  </div>
                  <h3 class="ev-card-title"><%= ev.title %></h3>
                  <% if (ev.description) { %><p class="ev-card-desc"><%= ev.description %></p><% } %>
                  <div class="ev-card-footer">
                    <div class="ev-card-info">
                      <span class="ev-info-item">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                          <line x1="16" y1="2" x2="16" y2="6" />
                          <line x1="8" y1="2" x2="8" y2="6" />
                          <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        <%= ev.date %>
                      </span>
                      <% if (ev.location) { %>
                        <span class="ev-info-item">
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                            <circle cx="12" cy="10" r="3" />
                          </svg>
                          <%= ev.location %>
                        </span>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
        <div class="btn-row" style="margin-top:20px;justify-content:center">
          <a class="btn btn-outline" href="/eventos">Ver todos los eventos</a>
          <a class="btn" href="/club/registro">Únete para apuntarte</a>
        </div>
      <% } %>
    </section>

    <!-- Cómo funciona -->
    <section class="container">
      <h2 class="section-title">¿Cómo funciona?</h2>
      <div class="clp-how-track">
        <% [
          ['Regístrate gratis', 'Crea tu cuenta en minutos con tus datos básicos y el de tu moto.'],
          ['Participa en actividades', 'Asiste a rodadas, eventos del club, lleva tu moto al taller.'],
          ['Acumula puntos', 'Cada actividad suma puntos automáticamente a tu perfil.'],
          ['Sube de nivel y gana beneficios', 'Más nivel = más descuentos, prioridad y reconocimiento en la comunidad.'],
        ].forEach(([t,d], i) => { %>
          <div class="clp-how-step">
            <div class="clp-how-num"><%= i+1 %></div>
            <h3><%= t %></h3>
            <p><%= d %></p>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- Testimonios -->
    <section class="container">
      <h2 class="section-title">Lo que dicen nuestros miembros</h2>
      <ul class="grid">
        <li class="card clp-testimonial">
          <span class="clp-quote-mark" aria-hidden="true">&ldquo;</span>
          <p>Llegué como prospecto y en 3 meses ya soy Gorilla. Las rodadas del club son lo máximo, ambiente increíble.</p>
          <strong>— Ana R., nivel Gorilla 🏆</strong>
        </li>
        <li class="card clp-testimonial">
          <span class="clp-quote-mark" aria-hidden="true">&ldquo;</span>
          <p>Aprendí más en los cursos técnicos que en años de mecánica empírica. Y los puntos de los eventos ayudan mucho.</p>
          <strong>— Carlos M., nivel Rider 🏍️</strong>
        </li>
        <li class="card clp-testimonial">
          <span class="clp-quote-mark" aria-hidden="true">&ldquo;</span>
          <p>Los recordatorios de SOAT y tecno me han salvado varias veces. El taller siempre tiene mi moto lista en el día.</p>
          <strong>— David P., nivel Miembro ✅</strong>
        </li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="container">
      <h2 class="section-title">Preguntas frecuentes</h2>
      <div class="clp-faq">
        <% [
          ['¿Cómo me inscribo?', 'Regístrate gratis en esta página. En minutos tendrás acceso a tu panel.'],
          ['¿Cuánto cuesta?', 'La membresía básica es gratuita. Los niveles Premium tienen beneficios adicionales.'],
          ['¿Cómo gano puntos?', 'Asistiendo a rodadas, eventos del club, llevando tu moto al taller o haciendo mantenimientos.'],
          ['¿Los puntos vencen?', 'No. Los puntos acumulados son permanentes en tu perfil.'],
          ['¿Hay requisitos?', 'Mayor de edad. Recomendamos experiencia básica en conducción.'],
        ].forEach(([q, a]) => { %>
          <details class="clp-faq-item">
            <summary>
              <span><%= q %></span>
              <svg class="clp-faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="<%= icons.chevron %>"/></svg>
            </summary>
            <div class="clp-faq-body"><%= a %></div>
          </details>
        <% }) %>
      </div>
    </section>

    <!-- CTA de cierre -->
    <section class="clp-cta">
      <div class="container">
        <h2>La manada te espera</h2>
        <p>Únete hoy y empieza a acumular puntos desde tu primera visita.</p>
        <div class="btn-row">
          <a class="btn" href="/club/registro">Únete gratis</a>
          <a class="btn btn-outline" href="/club/login">Ya tengo cuenta</a>
        </div>
        <p class="clp-cta-note">Gratis · Toma 2 minutos · Sin tarjeta de crédito</p>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>
