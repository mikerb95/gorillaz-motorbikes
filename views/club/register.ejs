<%- include('../partials/head', { title: 'Club — Registro', bodyClass: 'page-auth' }) %>

<section class="auth-wrap">
  <div class="auth-form-wrap auth-form-wrap--wide">

    <div class="auth-logo-wrap">
      <a href="/" class="auth-logo" aria-label="Gorillaz Motorbikes">
        <img src="/favicons/android-chrome-192x192.png" alt="Gorillaz Motorbikes" />
      </a>
      <h1 class="auth-title">Únete al Club</h1>
      <p class="auth-subtitle">Taller y comunidad Gorillaz Motorbikes</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="form-error-banner"><%= error %></div>
    <% } %>

    <div class="auth-social-btns">
      <a href="/club/auth/google" class="btn-google">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Registrarse con Google
      </a>
      <a href="/club/auth/apple" class="btn-apple">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.32.07 2.24.72 3.01.73.93-.04 1.82-.73 3.13-.79 1.34.04 2.66.61 3.43 1.73-2.98 1.77-2.24 5.67.51 6.71-.58 1.56-1.37 3.08-2.08 4.5zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
        Registrarse con Apple
      </a>
    </div>

    <div class="auth-divider"><span>o completa el formulario</span></div>

    <form method="post" action="/club/registro" class="register-form" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <!-- ── 1. DATOS PERSONALES ─────────────────────────────── -->
      <fieldset class="register-section">
        <legend class="register-legend">Datos personales</legend>
        <div class="register-grid">
          <div class="field">
            <label for="firstName">Nombre <span class="req">*</span></label>
            <input id="firstName" name="firstName" placeholder="Ej. Carlos" required />
          </div>
          <div class="field">
            <label for="lastName">Apellido <span class="req">*</span></label>
            <input id="lastName" name="lastName" placeholder="Ej. Rodríguez" required />
          </div>
          <div class="field">
            <label for="cedula">Cédula de ciudadanía <span class="req">*</span></label>
            <input id="cedula" name="cedula" placeholder="Ej. 1020304050" required inputmode="numeric" />
          </div>
          <div class="field">
            <label for="phone">Celular <span class="req">*</span></label>
            <input id="phone" name="phone" type="tel" placeholder="Ej. 3201234567" required />
          </div>
          <div class="field">
            <label for="dept-register">Departamento <span class="req">*</span></label>
            <select id="dept-register" class="dept-select" name="department" data-location-group="register">
              <option value="">— Seleccione —</option>
            </select>
          </div>
          <div class="field">
            <label for="city-register">Ciudad / Municipio <span class="req">*</span></label>
            <select id="city-register" class="city-select" name="city" data-location-group="register" required>
              <option value="">— Seleccione un departamento —</option>
            </select>
          </div>
          <div class="field">
            <label for="birthdate">Fecha de nacimiento</label>
            <input id="birthdate" name="birthdate" type="date" />
          </div>
        </div>
      </fieldset>

      <!-- ── 2. SECCIÓN CLUB ─────────────────────────────── -->
      <fieldset class="register-section">
        <legend class="register-legend">Club</legend>
        <div class="register-grid">
          <div class="field">
            <label for="nickname">Nickname / Apodo</label>
            <input id="nickname" name="nickname" placeholder="Ej. El Rayo" />
          </div>
          <div class="field">
            <label for="bloodType">RH (Grupo sanguíneo)</label>
            <select id="bloodType" name="bloodType">
              <option value="">— Seleccionar —</option>
              <option>O+</option><option>O-</option>
              <option>A+</option><option>A-</option>
              <option>B+</option><option>B-</option>
              <option>AB+</option><option>AB-</option>
            </select>
            <p class="field-hint">Información necesaria por seguridad durante las rodadas.</p>
          </div>
          <div class="field field--full checkbox-field">
            <input type="checkbox" id="clubNotifications" name="clubNotifications" value="true" checked>
            <label for="clubNotifications">Deseo recibir notificaciones del club vía correo electrónico</label>
          </div>
        </div>
      </fieldset>

      <!-- ── 3. CONTACTO DE EMERGENCIA ─────────────────────── -->
      <fieldset class="register-section">
        <legend class="register-legend">Contacto de emergencia</legend>
        <div class="register-grid">
          <div class="field">
            <label for="emergencyName">Nombre</label>
            <input id="emergencyName" name="emergencyName" placeholder="Ej. Ana Martínez" />
          </div>
          <div class="field">
            <label for="emergencyPhone">Celular</label>
            <input id="emergencyPhone" name="emergencyPhone" type="tel" placeholder="Ej. 3109876543" />
          </div>
        </div>
      </fieldset>

      <!-- ── 4. MOTOS ──────────────────────────────────────── -->
      <fieldset class="register-section" id="vehiclesSection">
        <legend class="register-legend">Mis motos <span class="legend-note">(opcional)</span></legend>
        <p class="section-hint">Registra una o varias motos. La información de documentos nos ayuda a recordarte sus vencimientos.</p>
        <div id="vehiclesList"></div>
        <button type="button" id="addVehicleBtn" class="btn btn-ghost btn-sm" style="margin-top:4px">
          + Agregar otra moto
        </button>
      </fieldset>

      <template id="vehicleTemplate">
        <div class="vehicle-block">
          <div class="vehicle-block-header">
            <span class="vehicle-block-num"></span>
            <button type="button" class="vehicle-remove-btn btn btn-ghost btn-sm">Eliminar</button>
          </div>
          <div class="register-grid">
            <div class="field"><label>Marca</label><input name="vehicleBrand[]" placeholder="Ej. Yamaha, Honda, Bajaj…" /></div>
            <div class="field"><label>Modelo</label><input name="vehicleModel[]" placeholder="Ej. MT-07, CB500F…" /></div>
            <div class="field"><label>Año</label><input name="vehicleYear[]" type="number" min="1990" max="2030" placeholder="Ej. 2022" /></div>
            <div class="field"><label>Placa</label><input name="vehiclePlate[]" placeholder="Ej. ABC12D" style="text-transform:uppercase" oninput="this.value=this.value.toUpperCase()" /></div>
            <div class="field"><label>Cilindraje (cc)</label><input name="vehicleCC[]" type="number" min="50" max="2500" placeholder="Ej. 600" /></div>
            <div class="field"><label>Color</label><input name="vehicleColor[]" placeholder="Ej. Negro mate" /></div>
            <div class="field"><label>Vencimiento SOAT</label><input name="soatExpires[]" type="date" /></div>
            <div class="field"><label>Vencimiento Tecnomecánica</label><input name="tecnoExpires[]" type="date" /></div>
          </div>
        </div>
      </template>

      <script>
        (function () {
          var list   = document.getElementById('vehiclesList');
          var tmpl   = document.getElementById('vehicleTemplate');
          var addBtn = document.getElementById('addVehicleBtn');
          function renumber() {
            list.querySelectorAll('.vehicle-block').forEach(function (block, i) {
              block.querySelector('.vehicle-block-num').textContent = 'Moto ' + (i + 1);
              var rmBtn = block.querySelector('.vehicle-remove-btn');
              rmBtn.style.display = list.children.length > 1 ? '' : 'none';
            });
          }
          function addBlock() {
            var clone = tmpl.content.cloneNode(true);
            clone.querySelector('.vehicle-remove-btn').addEventListener('click', function () {
              this.closest('.vehicle-block').remove();
              renumber();
            });
            list.appendChild(clone);
            renumber();
          }
          addBtn.addEventListener('click', addBlock);
          addBlock();
        })();
      </script>

      <!-- ── 5. ACCESO ─────────────────────────────────────── -->
      <fieldset class="register-section">
        <legend class="register-legend">Acceso a tu cuenta</legend>
        <div class="register-grid">
          <div class="field">
            <label for="email">Correo electrónico <span class="req">*</span></label>
            <input id="email" name="email" type="email" autocomplete="username" placeholder="tu@correo.com" required />
          </div>
          <div class="field">
            <label for="password">Contraseña <span class="req">*</span></label>
            <input id="password" name="password" type="password" autocomplete="new-password" placeholder="Mínimo 8 caracteres" required minlength="8" />
          </div>
          <div class="field">
            <label for="confirmPassword">Confirmar contraseña <span class="req">*</span></label>
            <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" placeholder="Repite tu contraseña" required minlength="8" />
          </div>
        </div>
      </fieldset>

      <p class="form-legal">
        Al registrarte aceptas nuestros
        <a class="link" href="/terminos" target="_blank">Términos y condiciones</a> y
        <a class="link" href="/privacidad" target="_blank">Política de privacidad</a>.
      </p>

      <button class="btn btn-primary btn--full" type="submit">Crear cuenta</button>
    </form>

    <div class="auth-alt">¿Ya tienes cuenta? <a class="link" href="/club/login">Inicia sesión</a></div>

  </div><!-- /.auth-form-wrap -->
</section>

<style>
  .auth-form-wrap--wide {
    max-width: 780px;
  }

  .auth-logo-wrap {
    text-align: center;
    margin-bottom: .4rem;
  }

  .auth-logo-wrap .auth-title {
    margin-top: .5rem;
  }

  .auth-subtitle {
    color: var(--muted, #888);
    font-size: .9rem;
    margin-top: .2rem;
    margin-bottom: .8rem;
  }

  .register-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .register-section {
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
    margin-bottom: 1.4rem;
  }

  .register-legend {
    font-weight: 800;
    font-size: 1rem;
    color: var(--brand);
    padding: 0 .4rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .legend-note {
    font-weight: 400;
    font-size: .8rem;
    color: var(--muted, #888);
    text-transform: none;
  }

  .register-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .9rem 1.2rem;
  }

  @media (max-width: 560px) {
    .register-grid { grid-template-columns: 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: .3rem;
  }

  .field--full { grid-column: 1 / -1; }

  .checkbox-field {
    flex-direction: row !important;
    align-items: center;
    gap: 8px;
  }

  .checkbox-field input[type="checkbox"] {
    width: auto;
    margin: 0;
    flex-shrink: 0;
  }

  .field label {
    font-size: .82rem;
    font-weight: 700;
    color: #ccc;
  }

  .field input,
  .field select {
    background: #f9fafb;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: .58rem .8rem;
    color: #111;
    font-size: .95rem;
  }

  .field input:focus,
  .field select:focus {
    outline: none;
    border-color: var(--brand);
  }

  .field select option {
    background: #fff;
    color: #111;
  }

  .field-hint {
    font-size: .8rem;
    opacity: .8;
    margin: 2px 0 0;
    color: var(--muted, #888);
  }

  .req { color: var(--brand); }

  .section-hint {
    font-size: .8rem;
    color: var(--muted, #888);
    margin: -.4rem 0 .8rem;
  }

  .vehicle-block {
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 1rem 1.2rem 1.2rem;
    margin-bottom: .8rem;
  }

  .vehicle-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .8rem;
  }

  .vehicle-block-num {
    font-weight: 700;
    font-size: .85rem;
    color: var(--brand);
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .form-error-banner {
    background: rgba(220, 50, 50, .15);
    border: 1px solid rgba(220, 50, 50, .4);
    color: #ff7f7f;
    border-radius: 8px;
    padding: .7rem 1rem;
    margin-bottom: 1rem;
    font-size: .9rem;
  }

  .form-legal {
    font-size: .78rem;
    color: var(--muted, #888);
    margin: .4rem 0 1rem;
  }

  .btn--full { width: 100%; }
</style>

<%- include('../partials/footer') %>
