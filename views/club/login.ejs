<%- include('../partials/head', { title: 'Club — Iniciar sesión', bodyClass: 'page-auth' }) %>

<section class="auth-wrap">

  <div class="auth-left">
    <div class="auth-left-inner">
      <a href="/" class="auth-brand">
        <img src="/favicons/android-chrome-192x192.png" alt="Gorillaz Motorbikes" />
        <span>Gorillaz Motorbikes</span>
      </a>
      <div class="auth-left-body">
        <h2 class="auth-left-title">El Club para los que viven sobre dos ruedas</h2>
        <p class="auth-left-desc">Rodadas exclusivas, beneficios para miembros y una comunidad que comparte tu pasión.</p>
        <ul class="auth-perks">
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Acceso a rodadas y eventos privados
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Descuentos en tienda y servicios
          </li>
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Sistema de niveles y logros
          </li>
        </ul>
      </div>
      <p class="auth-left-footer">© 2026 Gorillaz Motorbikes · Bogotá, Colombia</p>
    </div>
  </div>

  <div class="auth-right">
    <div class="auth-form-wrap">
      <div class="auth-form-header">
        <h1 class="auth-title">Iniciar sesión</h1>
        <p class="auth-subtitle">¿Nuevo en Gorillaz? <a class="link" href="/club/registro">Crea una cuenta</a></p>
      </div>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <div class="auth-social-btns">
        <button class="btn-passkey" type="button" id="passkeyLoginBtn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          Iniciar con passkey
        </button>
        <a href="/club/auth/google" class="btn-google">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Continuar con Google
        </a>
        <a href="/club/auth/apple" class="btn-apple">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.32.07 2.24.72 3.01.73.93-.04 1.82-.73 3.13-.79 1.34.04 2.66.61 3.43 1.73-2.98 1.77-2.24 5.67.51 6.71-.58 1.56-1.37 3.08-2.08 4.5zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
          Continuar con Apple
        </a>
      </div>
      <div id="passkeyError" style="display:none;font-size:.82em;color:#991b1b;text-align:center;margin-top:-6px"></div>

      <div class="auth-divider"><span>o ingresa con tu correo</span></div>

      <form method="post" action="/club/login" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <% if (typeof returnTo !== 'undefined' && returnTo) { %>
          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
        <% } %>

        <div class="auth-field">
          <label for="email">Correo electrónico</label>
          <input id="email" name="email" type="email" autocomplete="username" placeholder="tu@correo.com" required />
        </div>

        <div class="auth-field">
          <div class="password-label-row">
            <label for="password">Contraseña</label>
            <a class="link" href="/club/olvide">¿La olvidaste?</a>
          </div>
          <div class="password-input">
            <input id="password" name="password" type="password" autocomplete="current-password" placeholder="••••••••" required />
            <button type="button" class="password-toggle" aria-label="Mostrar u ocultar contraseña" data-toggle-password>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>

        <button class="btn btn-primary auth-submit" type="submit">Entrar al Club</button>
      </form>

      <% if (process.env.NODE_ENV !== 'production') { %>
        <p class="muted center" style="font-size:12px;margin-top:8px">Demo: miembro@gorillaz.co / gorillaz123</p>
      <% } %>
    </div>
  </div>

</section>

<script>
(function () {
  function b64uToBuffer(b) {
    const s = atob(b.replace(/-/g, '+').replace(/_/g, '/'));
    return Uint8Array.from(s, c => c.charCodeAt(0)).buffer;
  }
  function bufToB64u(buf) {
    const b = new Uint8Array(buf);
    let s = ''; for (const x of b) s += String.fromCharCode(x);
    return btoa(s).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
  }

  const btn = document.getElementById('passkeyLoginBtn');
  const errEl = document.getElementById('passkeyError');

  if (!btn) return;
  if (!window.PublicKeyCredential) {
    btn.style.display = 'none';
    document.getElementById('passkeyError') && (document.getElementById('passkeyError').style.display = 'none');
    return;
  }

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    btn.textContent = 'Esperando…';
    errEl.style.display = 'none';
    try {
      const optsRes = await fetch('/club/auth/passkey/login-options');
      if (!optsRes.ok) throw new Error('Error obteniendo opciones');
      const opts = await optsRes.json();
      opts.challenge = b64uToBuffer(opts.challenge);
      if (opts.allowCredentials) {
        opts.allowCredentials = opts.allowCredentials.map(c => ({ ...c, id: b64uToBuffer(c.id) }));
      }

      const cred = await navigator.credentials.get({ publicKey: opts });
      const body = {
        id: cred.id,
        rawId: bufToB64u(cred.rawId),
        type: cred.type,
        response: {
          authenticatorData: bufToB64u(cred.response.authenticatorData),
          clientDataJSON: bufToB64u(cred.response.clientDataJSON),
          signature: bufToB64u(cred.response.signature),
          userHandle: cred.response.userHandle ? bufToB64u(cred.response.userHandle) : null,
        },
        clientExtensionResults: cred.getClientExtensionResults(),
      };

      const csrf = document.querySelector('input[name="_csrf"]')?.value || '';
      const res = await fetch('/club/auth/passkey/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrf },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || 'Verificación fallida');
      window.location.href = data.redirect || '/club/panel';
    } catch (e) {
      const txt = e.name === 'NotAllowedError' ? 'Operación cancelada.' : (e.message || 'Error inesperado');
      errEl.textContent = txt;
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg> Iniciar con passkey';
    }
  });

  // Password toggle
  const toggleBtn = document.querySelector('[data-toggle-password]');
  const pwdInput  = document.getElementById('password');
  if (toggleBtn && pwdInput) {
    toggleBtn.addEventListener('click', () => {
      const isPwd = pwdInput.type === 'password';
      pwdInput.type = isPwd ? 'text' : 'password';
      toggleBtn.classList.toggle('is-on', isPwd);
      toggleBtn.innerHTML = isPwd
        ? '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C5 20 1 12 1 12a21.82 21.82 0 0 1 5.06-6.94m3.9-2.11A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a21.82 21.82 0 0 1-3.16 4.19M1 1l22 22"/></svg>'
        : '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
    });
  }
})();
</script>

<%- include('../partials/footer') %>
