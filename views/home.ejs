<%- include('partials/head', { title: 'Gorillaz Motorbikes' , user }) %>

    <h1 class="sr-only">Gorillaz Motorbikes — Taller de motos en Bogotá</h1>

    <!-- Hero con CTA -->
    <section class="hero" data-slideshow='<%- JSON.stringify(slides||[]) %>'>
      <div class="hero-slides" aria-hidden="true"></div>
      <div class="hero-content">
        <h2>Tu moto en manos de expertos en Bogotá</h2>
        <div class="btn-row">
          <a class="btn" href="/servicios/agendar">Agendar servicio</a>
          <a class="btn btn-outline" href="/servicios">Ver servicios</a>
        </div>
      </div>
      <button class="scroll-cue" aria-label="Desplázate para ver el contenido" title="Desplázate"
        onclick="(function(){var next=document.querySelector('.stats-strip'); if(next){next.scrollIntoView({behavior:'smooth'});} else {window.scrollTo({top: window.innerHeight, behavior:'smooth'});} })()">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="currentColor"
            d="M12 16.5c-.3 0-.6-.1-.8-.3l-6-6a1.1 1.1 0 0 1 1.6-1.6L12 13.8l5.2-5.2a1.1 1.1 0 0 1 1.6 1.6l-6 6c-.2.2-.5.3-.8.3Z" />
        </svg>
      </button>
    </section>

    <!-- Franja de estadísticas — rellena los números con tus datos reales -->
    <section class="stats-strip" aria-label="Números de confianza">
      <div class="stats-inner">
        <div class="stat-item">
          <span class="stat-num"><!-- CLIENTES -->+</span>
          <span class="stat-label">Clientes atendidos</span>
        </div>
        <div class="stat-item">
          <span class="stat-num"><!-- AÑOS --></span>
          <span class="stat-label">Años en Bogotá</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">8</span>
          <span class="stat-label">Servicios especializados</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">⭐ <!-- RATING --></span>
          <span class="stat-label">en Google</span>
        </div>
      </div>
    </section>

    <!-- Servicios disponibles -->
    <section class="container">
      <h2>Servicios destacados</h2>
      <ul class="grid halves services-grid">
        <li>
          <a href="/servicios/mecanica" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/mecanica.webp')"
              aria-label="Mecánica — diagnóstico y mantenimiento preventivo">
              <div class="service-content">
                <h3>Mecánica</h3>
                <p>Diagnóstico, mantenimiento preventivo y correctivo con control de calidad.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/pintura" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/pintura.webp')"
              aria-label="Pintura — acabados y protección">
              <div class="service-content">
                <h3>Pintura</h3>
                <p>Acabados profesionales, retoques y protección de superficies.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/alistamiento-tecnomecanica" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/alisamiento.webp')"
              aria-label="Alistamiento tecnomecánica — revisión para inspección">
              <div class="service-content">
                <h3>Alistamiento tecnomecánica</h3>
                <p>Revisión integral y ajustes previos a la inspección.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/electricidad" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/electricidad.webp')"
              aria-label="Electricidad — sistema de carga e iluminación">
              <div class="service-content">
                <h3>Electricidad</h3>
                <p>Diagnóstico eléctrico, sistema de carga, arranque e iluminación.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/torno" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/torno.webp')"
              aria-label="Torno — fabricación y ajuste de piezas">
              <div class="service-content">
                <h3>Torno</h3>
                <p>Fabricación y ajuste de componentes según especificación.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/prensa" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/prensa.webp')"
              aria-label="Prensa — montaje y desmontaje seguro">
              <div class="service-content">
                <h3>Prensa</h3>
                <p>Montaje y desmontaje seguro de rodamientos y piezas a presión.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/mecanica-rapida" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/mecanica-rapida.webp')"
              aria-label="Mecánica rápida — servicios ágiles">
              <div class="service-content">
                <h3>Mecánica rápida</h3>
                <p>Cambios de aceite, filtros y ajustes ágiles con cita.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/escaneo-de-motos" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/scaneo.webp')"
              aria-label="Escaneo de motos — diagnóstico computarizado">
              <div class="service-content">
                <h3>Escaneo de motos</h3>
                <p>Diagnóstico computarizado para detectar fallas electrónicas con precisión.</p>
              </div>
            </div>
          </a>
        </li>
      </ul>
    </section>

    <!-- Servicios próximamente -->
    <section class="container coming-soon-section">
      <h2 class="coming-soon-title">Lo que viene</h2>
      <p class="muted">Nuevos servicios en preparación para ti.</p>
      <ul class="grid coming-soon-grid">
        <li>
          <a href="/servicios/lavado-motos" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/lavado-motos.png')"
              aria-label="Lavado de motos — limpieza profunda">
              <div class="service-content">
                <h3>Lavado de motos <span
                    style="background:#eab54d; color:#000; padding:2px 6px; border-radius:4px; font-size:12px; margin-left:8px; vertical-align:middle; text-transform:uppercase; letter-spacing:0.5px;">Próximamente</span>
                </h3>
                <p>Limpieza profunda para tu motocicleta, cuidando cada detalle para que luzca impecable y protegida.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/lavado-cascos" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/lavado-cascos.webp')"
              aria-label="Lavado de cascos — desinfección total">
              <div class="service-content">
                <h3>Lavado de cascos <span
                    style="background:#eab54d; color:#000; padding:2px 6px; border-radius:4px; font-size:12px; margin-left:8px; vertical-align:middle; text-transform:uppercase; letter-spacing:0.5px;">Próximamente</span>
                </h3>
                <p>Desinfección y limpieza interior y exterior de tu casco, eliminando olores e impurezas acumuladas.</p>
              </div>
            </div>
          </a>
        </li>
        <li>
          <a href="/servicios/detailing-motos" style="text-decoration:none; color:inherit; display:block; height:100%;">
            <div class="service-card" style="--bg:url('/images/services/detailing-motos.webp')"
              aria-label="Detailing de motos — restauración premium">
              <div class="service-content">
                <h3>Detailing de motos <span
                    style="background:#eab54d; color:#000; padding:2px 6px; border-radius:4px; font-size:12px; margin-left:8px; vertical-align:middle; text-transform:uppercase; letter-spacing:0.5px;">Próximamente</span>
                </h3>
                <p>Restauración y protección estética paso a paso con productos premium para dejar tu moto como nueva.</p>
              </div>
            </div>
          </a>
        </li>
      </ul>
    </section>

    <!-- CTA consulta de orden -->
    <section class="container">
      <div class="order-qr-section">
        <div class="order-qr-text">
          <p class="section-label">¿Tu moto está en el taller?</p>
          <h2>Consulta el estado de tu moto</h2>
          <p>Ingresa tu placa y revisa en qué etapa está el trabajo, el valor total y los días de parqueadero, sin llamar al taller.</p>
          <a class="btn" href="/mi-orden">Ver estado de mi moto &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Club Gorillaz -->
    <section class="container club-section">
      <h2>Club Gorillaz</h2>
      <ul class="grid four" style="margin-top:8px">
        <li class="card">
          <h3 style="margin:0 0 6px">Descuento en mecánica rápida</h3>
          <p class="muted" style="margin:0">Ahorra en servicios ágiles y mantenimiento esencial.</p>
        </li>
        <li class="card">
          <h3 style="margin:0 0 6px">Recordatorios de SOAT y Tecnomecánica</h3>
          <p class="muted" style="margin:0">Evita vencimientos y mantén tus documentos al día.</p>
        </li>
        <li class="card">
          <h3 style="margin:0 0 6px">Descuentos en repuestos y consumibles</h3>
          <p class="muted" style="margin:0">Mejores precios en lo que tu moto necesita.</p>
        </li>
        <li class="card">
          <h3 style="margin:0 0 6px">Historial detallado de servicios</h3>
          <p class="muted" style="margin:0">Consulta trabajos, fechas y recomendaciones.</p>
        </li>
      </ul>
      <div class="btn-row" style="margin-top:12px">
        <a class="btn btn-sm" href="/club">Conoce el Club</a>
        <% if (!user) { %>
          <a class="btn btn-sm btn-outline" href="/club/login">Iniciar sesión</a>
        <% } else { %>
          <a class="btn btn-sm btn-outline" href="/club/panel">Mi panel</a>
        <% } %>
      </div>
      <p class="muted">Ser parte del Club Gorillaz te da prioridad en agenda y sorpresas durante el año.</p>
      <!-- Rellena el número de miembros cuando tengas el dato:
      <p class="club-member-count">Únete a los <strong>N miembros</strong> del Club</p>
      -->
    </section>

    <!-- Reseñas -->
    <section class="container reviews-cta-card" style="text-align:center">
      <p class="section-label">Tu opinión nos importa</p>
      <h2>¿Cómo te fue con nosotros?</h2>
      <p class="muted">Cuéntale a otros moteros tu experiencia — te toma menos de un minuto.</p>
      <div class="btn-row" style="margin-top:16px; justify-content:center">
        <a href="/resenas" class="btn btn-outline">Déjanos tu reseña en Google</a>
      </div>
    </section>

    <!-- REVIEWS: descomenta y adapta cuando conectes con Google Business API para mostrar reseñas reales
    <section class="container reviews-section">
      <p class="section-label">Lo que dicen nuestros clientes</p>
      <h2>Reseñas verificadas de Google</h2>
      <div class="reviews-grid">
        [loop de reviews: r.text, r.author, r.date]
      </div>
    </section>
    -->

    <!-- Tienda destacada -->
    <section class="container fp-section">
      <div class="fp-header">
        <div>
          <p class="fp-label">Nuestra tienda</p>
          <h2 class="fp-title">Equípate con lo mejor</h2>
        </div>
        <a href="/tienda" class="fp-all-link">Ver todos los productos &rarr;</a>
      </div>
      <div class="fp-grid">
        <% featuredProducts.forEach((p, i) => { %>
          <article class="fp-card">
            <a href="/tienda/<%= p.id %>" class="fp-card-media">
              <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
              <% if (p.discount > 0) { %>
                <span class="fp-badge">-<%= p.discount %>% OFF</span>
              <% } else if (i === 0) { %>
                <span class="fp-badge">Destacado</span>
              <% } %>
            </a>
            <div class="fp-card-body">
              <p class="fp-card-meta"><%= p.brand %> &middot; <%= p.category.charAt(0).toUpperCase() + p.category.slice(1) %></p>
              <h3 class="fp-card-name"><a href="/tienda/<%= p.id %>"><%= p.name %></a></h3>
              <div class="fp-card-footer">
                <% if (p.discount > 0) { %>
                  <span class="fp-price">$<%= Math.round(p.price * (1 - p.discount / 100)).toLocaleString('es-CO') %></span>
                <% } else { %>
                  <span class="fp-price">$<%= p.price.toLocaleString('es-CO') %></span>
                <% } %>
                <button type="button" class="fp-add-btn btn-add-cart" data-id="<%= p.id %>"
                  data-name="<%= p.name %>"
                  data-image="<%= (p.gallery && p.gallery[0]) || p.image || '/images/download.png' %>"
                  data-price="$<%= (p.discount > 0 ? Math.round(p.price * (1 - p.discount / 100)) : p.price).toLocaleString('es-CO') %>"
                  aria-label="Añadir al carrito">+</button>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <!-- Ubicación -->
    <section class="container">
      <h2>¿Dónde estamos?</h2>
      <div class="map-wrap">
        <iframe class="map-embed" title="Ubicación Gorillaz Motorbikes" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=GORILLAZ%20MOTORBIKES%20Bogot%C3%A1&hl=es&z=17&output=embed">
        </iframe>
      </div>
      <p class="muted">Bogotá, Colombia — <a
          href="https://www.google.com/maps/place/GORILLAZ+MOTORBIKES/data=!4m2!3m1!1s0x0:0xbb0428b400709cf?sa=X&ved=1t:2428&ictx=111"
          target="_blank" rel="noopener">Abrir en Google Maps</a></p>
    </section>

    <!-- Newsletter -->
    <section class="newsletter">
      <div class="newsletter-inner">
        <h2>Recibe tu checklist de mantenimiento gratis</h2>
        <p class="muted">Suscríbete y te enviamos la guía de mantenimiento preventivo para tu moto — más novedades y descuentos exclusivos.</p>
        <p class="muted">Lee nuestra <a href="/privacidad">política de privacidad</a> para conocer cómo tratamos tus datos.</p>

        <% if (newsletterStatus==='ok') { %>
          <p class="alert success" role="status">¡Gracias! Te hemos suscrito. Revisa tu correo para el checklist.</p>
        <% } else if (newsletterStatus==='error') { %>
          <p class="alert error" role="alert">Ingresa un correo válido.</p>
        <% } else if (newsletterStatus==='captcha') { %>
          <p class="alert error" role="alert">Por favor completa la verificación reCAPTCHA.</p>
        <% } %>

        <form class="newsletter-form" action="/newsletter" method="post" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="sr-only" for="nl-email">Correo electrónico</label>
          <input id="nl-email" type="email" name="email" placeholder="tu@correo.com" required />
          <button type="submit" class="btn btn-square">Quiero mi checklist</button>
        </form>
        <% if (recaptchaSiteKey) { %>
          <div class="recaptcha-wrap">
            <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
          </div>
          <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        <% } %>
        <p class="muted tiny">Este sitio está protegido por reCAPTCHA y aplican la <a
            href="/privacidad">Política de Privacidad</a> y los <a href="/terminos">Términos del Servicio</a>.</p>
      </div>
    </section>

  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "AutoRepair",
      "name": "Gorillaz Motorbikes",
      "url": "https://gorillazmotorbikes.com",
      "logo": "https://gorillazmotorbikes.com/images/nobg_logo/logo_transp.png",
      "image": "https://gorillazmotorbikes.com/images/og-default.jpg",
      "description": "Taller de motos en Bogotá: mecánica, pintura, electricidad, alistamiento tecnomecánica, escaneo computarizado, torno y tienda de accesorios.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Bogotá",
        "addressLocality": "Bogotá",
        "addressRegion": "Cundinamarca",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 4.6479,
        "longitude": -74.0817
      },
      "telephone": "+573213204299",
      "sameAs": [
        "https://www.facebook.com/gorillazmotorbikes",
        "https://www.instagram.com/gorillazmotorbikes"
      ],
      "priceRange": "$$",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "08:00",
          "closes": "14:00"
        }
      ],
      "hasMap": "https://maps.google.com/?q=Gorillaz+Motorbikes+Bogot%C3%A1",
      "areaServed": {
        "@type": "City",
        "name": "Bogotá"
      },
      "knowsAbout": [
        "Mecánica de motos",
        "Pintura de motos",
        "Electricidad de motos",
        "Alistamiento tecnomecánica",
        "Escaneo computarizado",
        "Accesorios para motos"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "RATING_AQUI",
        "reviewCount": "N_RESENAS_AQUI",
        "bestRating": "5",
        "worstRating": "1"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Gorillaz Motorbikes",
      "url": "https://gorillazmotorbikes.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://gorillazmotorbikes.com/tienda?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo agendo una cita para mi moto?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Puedes solicitar agendamiento desde la sección Servicios en gorillazmotorbikes.com/servicios. Completa el formulario con tus datos, servicio y fecha deseada. Te contactaremos para confirmar."
          }
        },
        {
          "@type": "Question",
          "name": "¿Tienen servicios rápidos sin cita?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ofrecemos mecánica rápida para cambios de aceite y ajustes menores. Puedes venir directamente o agendar para asegurar tu espacio."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué métodos de pago aceptan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Aceptamos Nequi, Daviplata y todas las tarjetas débito y crédito en la tienda y en el taller."
          }
        },
        {
          "@type": "Question",
          "name": "¿Pueden preparar mi moto para la tecnomecánica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Ofrecemos alistamiento tecnomecánico, diagnóstico y corrección de fallas para que tu moto pase la revisión sin problemas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo obtengo o renuevo mi membresía del club?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Regístrate o inicia sesión en gorillazmotorbikes.com/club. Desde tu panel puedes ver tu estado, renovar y acceder a beneficios exclusivos."
          }
        }
      ]
    }
  ]
  </script>

  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
  <script src="/static/js/hero-gsap.js"></script>

  <%- include('partials/footer') %>
