<%- include('../partials/head', { title: listing.title }) %>

<%
  // Construye el enlace de WhatsApp: solo dígitos, anteponiendo 57 (Colombia)
  // cuando el número local tiene 10 dígitos y no trae indicativo.
  const digits = (listing.contactPhone || '').replace(/\D/g, '');
  const waNumber = digits.length === 10 ? ('57' + digits) : digits;
  const waText = encodeURIComponent('Hola, vi tu anuncio "' + listing.title + '" en los clasificados del club de Gorillaz Motorbikes y me interesa.');
  const images = (listing.images && listing.images.length) ? listing.images : ['/images/download.png'];
%>

<main class="container clf-page">
  <nav class="breadcrumb">
    <a href="/">Inicio</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/clasificados">Clasificados</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/clasificados?cat=<%= listing.category %>"><%= catName(listing.category) %></a>
  </nav>

  <% if (listing.status !== 'active') { %>
    <div class="clf-status-banner clf-status-<%= listing.status %>">
      <% if (listing.status === 'pending') { %>Este anuncio está pendiente de aprobación. Solo tú y el equipo pueden verlo por ahora.
      <% } else if (listing.status === 'rejected') { %>Este anuncio fue rechazado<%= listing.rejectReason ? (': ' + listing.rejectReason) : '.' %>
      <% } else if (listing.status === 'sold') { %>Este artículo ya fue vendido.
      <% } %>
    </div>
  <% } %>

  <div class="clf-detail">
    <div class="clf-gallery">
      <div class="clf-gallery-main">
        <% images.forEach((img, i) => { %>
          <img src="<%= img %>" alt="<%= listing.title %> imagen <%= i + 1 %>" class="<%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>">
        <% }) %>
      </div>
      <% if (images.length > 1) { %>
        <div class="clf-gallery-thumbs">
          <% images.forEach((img, i) => { %>
            <button type="button" class="clf-thumb <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>">
              <img src="<%= img %>" alt="Miniatura <%= i + 1 %>" loading="lazy">
            </button>
          <% }) %>
        </div>
      <% } %>
    </div>

    <aside class="clf-info">
      <span class="clf-chip clf-chip-cat"><%= catName(listing.category) %></span>
      <h1 class="clf-detail-title"><%= listing.title %></h1>
      <div class="clf-detail-price">
        $<%= listing.price.toLocaleString('es-CO') %>
        <% if (listing.negotiable) { %><small class="muted">· Negociable</small><% } %>
      </div>

      <ul class="clf-specs">
        <li><span>Estado</span><strong><%= listing.condition === 'nuevo' ? 'Nuevo' : 'Usado' %></strong></li>
        <% if (listing.brand) { %><li><span>Marca</span><strong><%= listing.brand %></strong></li><% } %>
        <% if (listing.city || listing.department) { %><li><span>Ubicación</span><strong><%= [listing.city, listing.department].filter(Boolean).join(', ') %></strong></li><% } %>
        <% if (listing.sellerName) { %><li><span>Vendedor</span><strong><%= listing.sellerName %></strong></li><% } %>
      </ul>

      <% if (listing.status === 'active') { %>
        <div class="clf-contact">
          <% if (waNumber) { %>
            <a class="btn btn-primary clf-wa-btn" href="https://wa.me/<%= waNumber %>?text=<%= waText %>" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 00-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1112 20zm4.4-5.6c-.2-.1-1.4-.7-1.7-.8s-.4-.1-.5.1-.6.8-.8.9-.3.2-.5.1a6.5 6.5 0 01-1.9-1.2 7.2 7.2 0 01-1.3-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4v-.4c0-.1-.5-1.3-.7-1.7s-.4-.4-.5-.4h-.5a.9.9 0 00-.7.3 2.8 2.8 0 00-.9 2.1 4.9 4.9 0 001 2.6 11 11 0 004.3 3.8c.6.2 1 .4 1.4.5a3.3 3.3 0 001.5.1 2.5 2.5 0 001.6-1.1 2 2 0 00.1-1.1c0-.1-.2-.2-.4-.3z"/></svg>
              Escribir por WhatsApp
            </a>
          <% } %>
          <% if (listing.contactPhone) { %>
            <a class="btn btn-ghost" href="tel:<%= listing.contactPhone.replace(/\s/g, '') %>">📞 Llamar <%= listing.contactPhone %></a>
          <% } else if (!waNumber) { %>
            <p class="muted">El vendedor no dejó datos de contacto. Escríbenos por los canales del club.</p>
          <% } %>
        </div>
      <% } %>

      <% if (user && (listing.userId === user.id || user.role === 'admin')) { %>
        <div class="clf-owner-actions">
          <a class="btn btn-ghost btn-sm" href="/clasificados/<%= listing.id %>/editar">Editar</a>
        </div>
      <% } %>
    </aside>
  </div>

  <% if (listing.description) { %>
    <section class="clf-description">
      <h2 class="clf-section-h">Descripción</h2>
      <p><%= listing.description %></p>
    </section>
  <% } %>

  <% if (related && related.length) { %>
    <section class="clf-related">
      <h2 class="clf-section-h">Otros anuncios de <%= catName(listing.category) %></h2>
      <div class="clf-grid">
        <% related.forEach(l => { %>
          <article class="clf-card">
            <a class="clf-card-media" href="/clasificados/<%= l.id %>">
              <img src="<%= (l.images && l.images[0]) || '/images/download.png' %>" alt="<%= l.title %>" loading="lazy">
            </a>
            <div class="clf-card-body">
              <a class="clf-card-title" href="/clasificados/<%= l.id %>"><%= l.title %></a>
              <div class="clf-card-price">$<%= l.price.toLocaleString('es-CO') %></div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</main>

<script>
  (function () {
    const mains  = document.querySelectorAll('.clf-gallery-main img');
    const thumbs = document.querySelectorAll('.clf-thumb');
    if (mains.length <= 1) return;
    thumbs.forEach(t => t.addEventListener('click', () => {
      const idx = t.dataset.idx;
      mains.forEach(m => m.classList.toggle('active', m.dataset.idx === idx));
      thumbs.forEach(x => x.classList.toggle('active', x === t));
    }));
  })();
</script>

<%- include('../partials/footer') %>
