<%- include('../partials/head', { title: 'Clasificados del Club' }) %>

<main class="container clf-page">
  <nav class="breadcrumb">
    <a href="/">Inicio</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/club">Club</a>
    <span class="breadcrumb-sep">›</span>
    <span>Clasificados</span>
  </nav>

  <header class="clf-header">
    <div>
      <h1 class="section-title">Clasificados del Club</h1>
      <p class="muted">Compra y vende motos, partes y accesorios entre miembros del club. La publicación es un beneficio exclusivo para socios.</p>
    </div>
    <% if (user) { %>
      <a class="btn btn-primary" href="/clasificados/nuevo">＋ Publicar anuncio</a>
    <% } else { %>
      <a class="btn btn-primary" href="/club/login?return=/clasificados/nuevo">Inicia sesión para publicar</a>
    <% } %>
  </header>

  <form class="clf-filters" method="get" action="/clasificados">
    <div class="clf-search-wrap">
      <input name="q" placeholder="Buscar por título, marca o descripción" value="<%= q %>" />
      <button type="submit" class="clf-search-btn" aria-label="Buscar">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </div>
    <% if (cities && cities.length) { %>
      <select name="city" onchange="this.form.submit()" class="clf-city-select">
        <option value="">Toda Colombia</option>
        <% cities.forEach(c => { %>
          <option value="<%= c %>" <%= city === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    <% } %>
  </form>

  <div class="clf-cats" role="tablist" aria-label="Categorías">
    <a class="clf-cat-chip <%= !selectedCat ? 'is-active' : '' %>" href="/clasificados<%= q ? ('?q=' + encodeURIComponent(q)) : '' %>">Todo</a>
    <% categories.forEach(c => { %>
      <a class="clf-cat-chip <%= selectedCat === c.slug ? 'is-active' : '' %>" href="/clasificados?cat=<%= c.slug %><%= q ? ('&q=' + encodeURIComponent(q)) : '' %>">
        <span aria-hidden="true"><%= c.icon %></span> <%= c.name %>
      </a>
    <% }) %>
  </div>

  <% if (!listings.length) { %>
    <div class="clf-empty">
      <p>Todavía no hay anuncios publicados<%= selectedCat || q || city ? ' con estos filtros' : '' %>.</p>
      <% if (user) { %><a class="btn btn-ghost" href="/clasificados/nuevo">Publica el primero</a><% } %>
    </div>
  <% } else { %>
    <div class="clf-grid">
      <% listings.forEach(l => { %>
        <article class="clf-card">
          <a class="clf-card-media" href="/clasificados/<%= l.id %>">
            <img src="<%= (l.images && l.images[0]) || '/images/download.png' %>" alt="<%= l.title %>" loading="lazy">
            <span class="clf-chip clf-chip-cat"><%= catName(l.category) %></span>
            <% if (l.condition === 'nuevo') { %><span class="clf-chip clf-chip-new">Nuevo</span><% } %>
          </a>
          <div class="clf-card-body">
            <a class="clf-card-title" href="/clasificados/<%= l.id %>"><%= l.title %></a>
            <div class="clf-card-price">
              $<%= l.price.toLocaleString('es-CO') %>
              <% if (l.negotiable) { %><small class="muted">· Negociable</small><% } %>
            </div>
            <div class="clf-card-meta">
              <% if (l.brand) { %><span><%= l.brand %></span><% } %>
              <% if (l.city) { %><span>📍 <%= l.city %></span><% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
