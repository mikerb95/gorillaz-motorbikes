<%- include('partials/head', { title: 'Checkout' }) %>

<div class="co-page">

  <!-- Progress steps -->
  <div class="co-steps-wrap">
    <ol class="co-steps">
      <li class="co-step co-step--done">
        <span class="co-step__dot">✓</span>
        <span class="co-step__label">Carrito</span>
      </li>
      <div class="co-step__line co-step__line--done"></div>
      <li class="co-step co-step--active">
        <span class="co-step__dot">2</span>
        <span class="co-step__label">Datos &amp; Pago</span>
      </li>
      <div class="co-step__line"></div>
      <li class="co-step">
        <span class="co-step__dot">3</span>
        <span class="co-step__label">Confirmación</span>
      </li>
    </ol>
  </div>

  <div class="co-layout">

    <!-- LEFT: form -->
    <div class="co-main">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="post" action="/pagar">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <!-- Section 1: Shipping info -->
        <div class="co-card">
          <div class="co-card__header">
            <span class="co-section-num">1</span>
            <h2 class="co-card__title">Información de envío</h2>
          </div>

          <% if (!user) { %>
            <p class="co-login-hint">
              ¿Tienes cuenta? <a href="/club/login?return=/checkout">Inicia sesión</a> para autocompletar tus datos.
            </p>
          <% } %>

          <div class="co-field">
            <label for="customer_name">Nombre completo <span class="co-required">*</span></label>
            <input id="customer_name" name="customer_name" type="text" required
              value="<%= user ? user.name : '' %>" placeholder="Juan García" />
          </div>

          <div class="co-row">
            <div class="co-field">
              <label for="customer_email">Correo electrónico <span class="co-required">*</span></label>
              <input id="customer_email" name="customer_email" type="email" required
                value="<%= user ? user.email : '' %>" placeholder="tu@correo.com" />
            </div>
            <div class="co-field">
              <label for="customer_phone">Teléfono <span class="co-required">*</span></label>
              <input id="customer_phone" name="customer_phone" type="tel" required
                value="<%= user && user.phone ? user.phone : '' %>" placeholder="300 000 0000" />
            </div>
          </div>

          <div class="co-field">
            <label for="customer_address">Dirección de entrega <span class="co-required">*</span></label>
            <input id="customer_address" name="customer_address" type="text" required
              value="" placeholder="Calle 123 # 45-67, Apto 8" />
          </div>

          <div class="co-row">
            <div class="co-field">
              <label for="customer_dept">Departamento <span class="co-required">*</span></label>
              <select id="customer_dept" name="customer_dept" class="dept-select" data-location-group="checkout"
                data-current-dept="<%= user && user.department ? user.department : '' %>" required>
                <option value="">— Seleccione —</option>
              </select>
            </div>
            <div class="co-field">
              <label for="customer_city">Ciudad / Municipio <span class="co-required">*</span></label>
              <select id="customer_city" name="customer_city" class="city-select" data-location-group="checkout"
                data-current="<%= user && user.city ? user.city : '' %>" required>
                <option value="">— Seleccione un departamento —</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Section 2: Payment -->
        <div class="co-card">
          <div class="co-card__header">
            <span class="co-section-num">2</span>
            <h2 class="co-card__title">Método de pago</h2>
          </div>

          <div class="co-payment-option co-payment-option--selected">
            <span class="co-payment-radio"></span>
            <div class="co-payment-info">
              <strong>Bold</strong>
              <span class="co-payment-desc">Tarjeta, PSE, Nequi, Daviplata</span>
            </div>
            <div class="co-payment-badges">
              <span class="co-badge">PSE</span>
              <span class="co-badge">Visa</span>
              <span class="co-badge">MC</span>
              <span class="co-badge">Nequi</span>
            </div>
          </div>
        </div>

        <button class="co-pay-btn" type="submit">
          Confirmar y pagar
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        </button>
        <p class="co-secure-note">
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
          Pago cifrado y seguro. Al continuar aceptas nuestros <a href="/terminos" class="co-terms-link">Términos y Condiciones</a>.
        </p>

      </form>
    </div>

    <!-- RIGHT: order summary -->
    <aside class="co-summary">
      <h2 class="co-summary__title">Tu pedido</h2>

      <ul class="co-summary-items">
        <% items.forEach(item => { %>
        <li class="co-summary-item">
          <div class="co-summary-img-wrap">
            <img src="<%= item.image || '/images/download.png' %>" alt="<%= item.name %>"
              class="co-summary-thumb" width="56" height="56" loading="lazy">
            <span class="co-summary-qty"><%= item.qty %></span>
          </div>
          <span class="co-summary-name"><%= item.name %></span>
          <span class="co-summary-price">$<%= item.total.toLocaleString('es-CO') %></span>
        </li>
        <% }) %>
      </ul>

      <div class="co-summary-totals">
        <div class="co-totals-row">
          <span>Subtotal</span>
          <span>$<%= cart.subtotal.toLocaleString('es-CO') %></span>
        </div>
        <div class="co-totals-row">
          <span>Envío</span>
          <span class="co-shipping-note">Calculado al confirmar</span>
        </div>
        <div class="co-totals-divider"></div>
        <div class="co-totals-row co-totals-row--total">
          <span>Total</span>
          <strong>$<%= cart.subtotal.toLocaleString('es-CO') %> <small>COP</small></strong>
        </div>
      </div>

      <ul class="co-trust-list">
        <li>
          <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
          Pago 100% seguro con SSL
        </li>
        <li>
          <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
          Devolución garantizada
        </li>
        <li>
          <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>
          Procesado por <strong>Bold</strong> — pasarela certificada
        </li>
      </ul>
    </aside>

  </div>
</div>

<%- include('partials/footer') %>
